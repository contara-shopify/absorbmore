        "id": "data__product__variant_metafield",
        "label": "Variant metafield namespaces",
        "info": "Comma separated list of namespaces."
      },
      {
        "type": "checkbox",
        "id": "data__product__product__load_product_data",
        "label": "Load metafield product data",
        "default": false,
        "info": "Enable this setting to access dynamic product data of metafields attached to products. This can have a negative impact on initial load performance."
      },
      {
        "type": "checkbox",

  {
    "name": "t:settings_schema.search_engine_optimization.name",
    "settings": [
      {
        "type": "header",
        "content": "Image Override"
      },
      {
        "type": "text",
        "id": "seo__image_override",
        "label": "Reviews Average Rating",
        "default": "smart.seo_image",
        "info": "Metafield 'namespace.key'. The metafield needs to be of type 'file' and set to 'image' on the Product, Collection, Page, Article  or Blog object"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "header",
        "content": "Header Layout"
      },
      {
        "type": "checkbox",
        "id": "layout__header_hide_on_scroll",
        "label": "Layout header hide on scroll",
        "default": true
      },
      {
        "type": "paragraph",
        "content": "t:all.empty_char"
      },
      {
        "type": "header",
        "content": "Section Container spacing"
      },
      {
        "type": "range",
        "id": "layout__page_width_xs",
        "min": 400,
        "max": 1400,
        "step": 10,
        "default": 640,
        "unit": "px",
        "label": "Page width xs"
      },
      {
        "type": "range",
        "id": "layout__page_width_sm",
        "min": 640,
        "max": 1440,
        "step": 20,
        "default": 960,
        "unit": "px",
        "label": "Page width sm"
      },
      {
        "type": "range",
        "id": "layout__page_width_md",
        "min": 960,
        "max": 1920,
        "step": 20,
        "default": 1440,
        "unit": "px",
        "label": "Page width md"
      },
      {
        "type": "range",
        "id": "layout__page_width_lg",
        "min": 1200,
        "max": 2400,
        "step": 20,
        "default": 1600,
        "unit": "px",
        "label": "Page width lg"
      },
      {
        "type": "paragraph",
        "content": "t:all.empty_char"
      },
      {
        "type": "header",
        "content": "Container Margin Spacing"
      },
      {
        "type": "range",
        "id": "layout__page_gutter_desktop",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 36,
        "unit": "px",
        "label": "Desktop"
      },
      {
        "type": "range",
        "id": "layout__page_gutter_mobile",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 20,
        "unit": "px",
        "label": "Mobile"
      }
    ]
  },

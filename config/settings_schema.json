  {
    "name": "Data Models",
    "settings": [
      {
        "type": "header",
        "content": "Products"
      },
      {
        "type": "paragraph",
        "content": "t:all.empty_char"
      },
      {
        "type": "header",
        "content": "Reviews Configuration"
      },
      {
        "type": "text",
        "id": "data__product__reviews_rating",
        "label": "Reviews Average Rating",
        "default": "smart.rating",
        "info": "Metafield 'namespace.key'. The metafield needs to be of type 'text', 'decimal' or type 'rating'."
      },
      {
        "type": "text",
        "id": "data__product__reviews_count",
        "label": "Reviews count",
        "default": "smart.review_count",
        "info": "Metafield 'namespace.key'. The metafield needs to be of type 'text' or 'integer'"
      },
      {
        "type": "paragraph",
        "content": "t:all.empty_char"
      },
      {
        "type": "header",
        "content": "Custom Price Overrides"
      },
      {
        "type": "checkbox",
        "id": "data__product__enable_price_overrides",
        "label": "Enable price overrides",
        "info": "Set via metafields on Product/Variant level: 'smart.discount_percentage' and on Variant level 'smart.price_override'"
      },
      {
        "type": "paragraph",
        "content": "t:all.empty_char"
      },
      {
        "type": "header",
        "content": "Variant Preorder Configuration"
      },
      {
        "type": "text",
        "id": "data__product__variant__preorder",
        "label": "Preorder Metafield",
        "info": "Metafield 'namespace.key'. The metafield needs to be of type 'boolean' or return a truthy value. I.e. 'smart.preorder'"
      },
      {
        "type": "text",
        "id": "data__product__variant__preorder_date",
        "label": "Preorder Date",
        "info": "Metafield 'namespace.key'. The metafield needs to be of type 'date' or a value that can be turned into a valid Date using 'new Date()'. I.e 'smart.preorder_date'"
      },
      {
        "type": "text",
        "id": "data__product__variant__preorder_quantity",
        "label": "Preorder Quantity",
        "info": "Metafield 'namespace.key'. The metafield needs to be of type 'integer'. I.e 'smart.preorder_quantity'"
      },
      {
        "type": "number",
        "id": "data__product__variant__preorder_threshold",
        "label": "Preorder inventory threshold",
        "default": 1,
        "info": "Activate Preorders when inventory is below the threshold."
      },
      {
        "type": "paragraph",
        "content": "t:all.empty_char"
      },

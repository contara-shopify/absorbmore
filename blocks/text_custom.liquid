{%- liquid
  assign block_type = "text_custom"
  assign content = block.settings.content
  assign wrapper_tag = block.settings.wrapper_tag | default: 'div'
  assign inner_tag = block.settings.inner_tag | default: 'span'
  assign content_class = block.settings.content_class
  assign extra_class = block.settings.extra_class
  assign text_alignment = block.settings.text_alignment
  assign text_color = block.settings.text_color
  assign custom_css = block.settings.custom_css
  assign hide_if_empty = block.settings.hide_if_empty
-%}

{% liquid
  assign content_check = content | strip_html | strip

  if content_check == blank
    assign is_empty = true
  endif
  if is_empty and hide_if_empty != 'none'
    capture hide_conditionally
      if hide_if_empty == 'block'
        echo '<script type="block/hide"></script>'
        assign hide_attribute = 'data-hide-if-empty-block'
      endif
      if hide_if_empty == 'container'
        echo '<script type="container/break"></script>'
        assign hide_attribute = 'data-hide-if-empty-container'
      endif
      if hide_if_empty == 'section'
        echo '<script type="section/break"></script>'
        assign hide_attribute = 'data-hide-if-empty-section'
      endif
    endcapture

    if request.design_mode != true and hide_conditionally contains '<script'
      echo hide_conditionally
      break
    endif
    assign hide_attribute = hide_attribute | append: ' data-block-type="' | append: block_type | append: '"' | append: ' data-block-id="' | append: block.id | append: '"'
  endif
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank and text_color.alpha != 0 %}{% capture css %}& { color: {{ text_color }}; }{% endcapture %}{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

<{{ wrapper_tag }} data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }} {{ hide_attribute }}
  class="relative {{ text_alignment | prepend: 'text-' }} {{ extra_class | escape }}">
  {% render '_input.text', content: content, class: content_class, tag: inner_tag %}
</{{ wrapper_tag }}>

{% schema %}
{
  "name": "Text Custom",
  "settings": [
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "info": "HTML allowed. Shortcodes: [br], [span.class||text], [icon.name.size.color], [gap.16]"
    },
    {
      "type": "select",
      "id": "wrapper_tag",
      "label": "Wrapper tag",
      "default": "div",
      "options": [
        { "value": "div", "label": "div" },
        { "value": "p", "label": "p" },
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "h4", "label": "h4" },
        { "value": "h5", "label": "h5" },
        { "value": "h6", "label": "h6" },
        { "value": "span", "label": "span" }
      ]
    },
    {
      "type": "select",
      "id": "inner_tag",
      "label": "Inner tag",
      "default": "span",
      "info": "Tag wrapping the content (with the Content Class).",
      "options": [
        { "value": "span", "label": "span" },
        { "value": "div", "label": "div" },
        { "value": "p", "label": "p" }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Auto" },
        { "value": "left", "label": "←" },
        { "value": "center", "label": "↔" },
        { "value": "right", "label": "→" }
      ]
    },
    {
      "type": "text",
      "id": "content_class",
      "label": "Content Class",
      "info": "Classes added to the inner tag.",
      "default": "richtext-md"
    },
    {
      "type": "text",
      "id": "extra_class",
      "label": "Wrapper Class",
      "info": "Classes added to the wrapper tag. Use \"clinicians\" to make this open the Clinicians modal."
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    },
    {
      "type": "select",
      "id": "hide_if_empty",
      "label": "If empty, hide:",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "section", "label": "Section" },
        { "value": "container", "label": "Container" },
        { "value": "block", "label": "Block" }
      ],
      "info": "Always shows in the Theme Editor."
    }
  ],
  "presets": [
    {
      "name": "Text Custom",
      "category": "Basic"
    }
  ],
  "tag": null,
  "class": "shopify_block__text_custom"
}
{% endschema %}

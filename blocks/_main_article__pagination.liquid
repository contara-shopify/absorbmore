{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_article__pagination"
  assign section_type = "main_article"
  assign previous_button_content = block.settings.previous_button_content
  assign next_button_content = block.settings.next_button_content
  assign button_class = block.settings.button_class
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
     class="flex items-center justify-between">
  {% if previous_button_content != blank %}
    <button
        class="{{ button_class }}"
        {% if blog.previous_article %}
          aria-label="Previous Article"
          role="link"
          tabindex="0"
          x-init="utils.simulateAnchorTag($el)"
          data-href="{{ blog.previous_article.url }}"
        {% else %}
          disabled="disabled"
        {% endif %}
        rel="prev">
      {% render '_input.inline_richtext', content: previous_button_content %}
    </button>
  {% endif %}

  {% if next_button_content != blank %}
    <button
        class="{{ button_class }}"
        {% if blog.next_article %}
          aria-label="Next Article"
          role="link"
          tabindex="0"
          x-init="utils.simulateAnchorTag($el)"
          data-href="{{ blog.next_article.url }}"
        {% else %}
          disabled="disabled"
        {% endif %}
        rel="next">
      {% render '_input.inline_richtext', content: next_button_content %}
    </button>
  {% endif %}
</div>

{% schema %}
{
  "name": "Article Pagination",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "previous_button_content",
      "label": "Previous button content",
      "default": "[icon.arrow-left] Previous",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "inline_richtext",
      "id": "next_button_content",
      "label": "Next button content",
      "default": "Next [icon.arrow-right]",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button class",
      "default": "button-primary"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Article Pagination",
      "category": "** Article **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_article__pagination"
}
{% endschema %}

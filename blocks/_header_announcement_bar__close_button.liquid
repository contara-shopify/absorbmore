{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_header_announcement_bar__close_button"
  assign section_type = "header_announcement_bar"
  assign icon = block.settings.icon
  assign keep_closed_for = block.settings.keep_closed_for
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<button data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
        type="button"
        @click.prevent.stop="() => {
           document.body.style.setProperty('--announcement-bar-height', `0px`, 'important');
           utils.setCookie(`${Shopify.theme.id}--hide-announcement`, 'true', +`{{ keep_closed_for | times: 60 | round }}`)
        }"
        class="[&_*]:pointer-events-none">
  <span class="sr-only">Close Announcements</span>
  {% render '_components.icon', icon: icon, class: 'w-full h-full' %}
</button>

{% schema %}
{
  "name": "Close Button",
  "settings": [
    {
      "type": "text",
      "id": "icon",
      "label": "Icon",
      "default": "x-mark"
    },
    {
      "type": "range",
      "id": "keep_closed_for",
      "label": "Keep closed for",
      "default": 24,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "hrs"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Close Button",
      "category": "Interactive"
    }
  ],
  "tag": null,
  "class": "shopify_block___header_announcement_bar__close_button"
}
{% endschema %}

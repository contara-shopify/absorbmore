{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_product__image"
  assign section_type = "main_product"
  assign primary_image = block.settings.primary_image
  assign show_secondary_image = block.settings.show_secondary_image
  assign secondary_image = block.settings.secondary_image
  assign link_to_object = block.settings.link_to_object
  assign show_overlay = block.settings.show_overlay
  assign overlay_color = block.settings.overlay_color
  assign sizes = block.settings.sizes
  assign max_width = block.settings.max_width
  assign quick_view_visibility = block.settings.quick_view_visibility
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign product = section.settings.product | default: product
  if section.settings.default_variant_metafield != blank
    assign variant_namespace = section.settings.default_variant_metafield | strip | split: "." | first
    assign variant_key = section.settings.default_variant_metafield | strip | split: "." | last
    assign variant = product.metafields[variant_namespace][variant_key].value | default: variant
  endif

  assign variant = variant | default: product.selected_or_first_available_variant | default: product.variants.first
%}

{% assign max_width = max_width | default: 600 %}
{% assign primary_image_sources = primary_image | remove: " " | split: ',' %}
{% for source in primary_image_sources %}
  {% capture primary %}{% render '_input.dynamic_content', content: source, keys: 'product, selected_variant', product: product, selected_variant: variant, max_width: max_width %}{% endcapture %}
  {% assign primary = primary | remove: " " %}
  {% if primary contains '|%SPLIT%|' %}
    {% assign primary_image_url = primary | split: "|%SPLIT%|" | first %}
    {% assign primary_image_aspect_ratio = primary | split: "|%SPLIT%|" | last | times: 1.0 %}
    {% break %}
  {% endif %}
{% endfor %}

{% if show_secondary_image %}
  {% assign secondary_image_sources = secondary_image | remove: " " | split: ',' %}
  {% for source in secondary_image_sources %}
    {% capture secondary %}{% render '_input.dynamic_content', content: source, keys: 'product, selected_variant', product: product, selected_variant: variant, max_width: max_width %}{% endcapture %}
    {% assign secondary = secondary | remove: " " %}
    {% if secondary contains '|%SPLIT%|' %}
      {% assign secondary_image_url = secondary | split: "|%SPLIT%|" | first %}
      {% assign secondary_image_aspect_ratio = secondary | split: "|%SPLIT%|" | last | times: 1.0 %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}


{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

{% if show_overlay %}
  {% capture css %}
    &:after {
    content: '';
    position: absolute;
    inset: 0;
    background: {{ overlay_color }};
    pointer-events: none;
    }
  {% endcapture %}
{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

<div
    data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
    data-quick-view-visibility="{{ quick_view_visibility }}"
    x-ignore
    x-data="{ primary_image: getDynamicValueWithFallbacks(`{{ primary_image }}`), secondary_image: getDynamicValueWithFallbacks(`{{ secondary_image }}`)}"
    {% if link_to_object %}
      aria-label="{{ product.title }}"
      role="link"
      tabindex="0"
      x-init="utils.simulateAnchorTag($el); $watch('pdp.selected_variant', () => { primary_image = getDynamicValueWithFallbacks(`{{ primary_image }}`); secondary_image = getDynamicValueWithFallbacks(`{{ secondary_image }}`) })"
      :data-href="`${_stores.router?.pathname?.replace(/^.*?(\/collections\/[^/]*)?.*$/gi,'$1')?.replace(/^\/$/gi,'') ?? ''}/products/${pdp.product_handle}?variant=${pdp.selected_variant?.id}`"
      data-href="{{ product.url | within: collection }}"
    {% else %}
      x-init="$watch('pdp.selected_variant', () => { primary_image = getDynamicValueWithFallbacks(`{{ primary_image }}`); secondary_image = getDynamicValueWithFallbacks(`{{ secondary_image }}`) })"
    {% endif %}
    class="relative block shrink-0 overflow-hidden group">
  {% capture html_attributes %}
    :src="(primary_image?.src ? primary_image?.src : primary_image) || $el.src"
    :alt="primary_image?.alt ?? pdp.product?.title ?? $el.alt"
    :srcset="(primary_image?.src || primary_image ? utils.getImageSrcSet(primary_image?.src ?? primary_image ?? '', +`{{ max_width }}`) : primary_image) || $el.srcset"
    :loading="utils.isInViewport($el) ? 'eager' : 'lazy'"
    {% if show_secondary_image %}
      x-effect="$el.classList.toggle('group-hf:opacity-0', secondary_image?.src || secondary_image)"
    {% endif %}
  {% endcapture %}
  {% assign classes = 'pointer-events-none relative h-full w-full select-none overflow-hidden object-[inherit] transition-opacity duration-100 ease-in' %}
  {% if secondary_image_url %}
    {% assign classes = classes | append: ' group-hf:opacity-0' %}
  {% endif %}
  {% render '_object.image_from_url',
      image_url: primary_image_url,
      aspect_ratio: primary_image_aspect_ratio,
      alt: product.title,
      max_width: max_width,
      sizes: sizes,
      class: classes,
      preload: preload_images,
      html_attributes: html_attributes %}
  {% if show_secondary_image %}
    {% capture html_attributes %}
      :src="secondary_image?.src || secondary_image || $el.src"
      :alt="secondary_image?.alt ?? pdp.product?.title ?? $el.alt"
      :srcset="utils.getImageSrcSet(secondary_image?.src ?? secondary_image ?? '', +`{{ max_width }}`) || $el.srcset"
      :loading="utils.isInViewport($el) ? 'eager' : 'lazy'"
      x-show="!!secondary_image?.src"
      {% if secondary_image_url == blank %}
        x-cloak
      {% endif %}
    {% endcapture %}
    {% assign classes = 'absolute inset-0 h-full w-full select-none overflow-hidden object-[inherit] group-hf:opacity-100 bg-inherit opacity-0 transition-opacity duration-100 ease-in' %}
    {% render '_object.image_from_url',
        image_url: secondary_image_url,
        aspect_ratio: secondary_image_aspect_ratio,
        alt: product.title,
        max_width: max_width,
        sizes: sizes,
        class: classes,
        html_attributes: html_attributes %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Product Image",
  "settings": [
    {
      "type": "header",
      "content": "Image selection"
    },
    {
      "type": "text",
      "id": "primary_image",
      "label": "Primary image",
      "default": "[selected_variant.featured_media]",
      "info": "Use bracket notation for data access: i.e.[selected_variant.featured_media] or [product.metafields.smart.image]. Comma separated list for fallback options."
    },
    {
      "type": "header",
      "content": "Hover Effect"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image",
      "default": true
    },
    {
      "type": "text",
      "id": "secondary_image",
      "label": "Secondary image",
      "default": "[product.metafields.smart.secondary_image]",
      "info": "Use bracket notation for data access: i.e.[selected_variant.featured_media] or [product.metafields.smart.image]. Comma separated list for fallback options.",
      "visible_if": "{{ block.settings.show_secondary_image }}"
    },
    {
      "type": "paragraph",
      "content": "[Available keys](https://shopify.dev/docs/api/liquid/objects/product)"
    },
    {
      "type": "checkbox",
      "id": "link_to_object",
      "label": "Link to object",
      "default": true
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay"
    },
    {
      "type": "color_background",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "linear-gradient(to bottom, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.25) 100%)",
      "visible_if": "{{ block.settings.show_overlay == true }}"
    },
    {
      "type": "header",
      "content": "Image Performance Optimization"
    },
    {
      "type": "text",
      "id": "sizes",
      "label": "Sizes",
      "default": "(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Max Width",
      "default": 540
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Quick View Settings"
    },
    {
      "type": "select",
      "id": "quick_view_visibility",
      "label": "Quick View Visibility",
      "default": "default",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "hidden",
          "label": "hidden"
        },
        {
          "value": "mobile_header",
          "label": "Mobile Header"
        },
        {
          "value": "quick_view_only",
          "label": "Quick view only"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "You can additionally style elements using the Custom CSS, by targeting: '.quick-view & {}'"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Product Image",
      "category": "** Product **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_product__image"
}
{% endschema %}

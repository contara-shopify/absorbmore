{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_card_line_item_card__quantity_selector"
  assign section_type = "card_line_item_card"
  assign quantity_class = block.settings.quantity_class
  assign custom_css = block.settings.custom_css
  assign show_conditionally = block.settings.show_conditionally
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% if request.design_mode or metaobjects.line_item_cards[section.settings.line_item_card] == blank %}
  {% capture selector %}[data-style-id="{{ block.id | split: "__" | last }}"]{% endcapture %}

  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
    {% if request.design_mode %}
    {% assign query_selector = '[data-section-id="'|append: section.id | append: '"][data-preview-container] ' | append: selector %}
    {{-  css | append:custom_css | replace: '&', query_selector  | strip_newlines | replace: '@media screen and', '@container'| replace: '@media', '@container' -}}
    {% endif %}
  </style>
{% endif %}

{% capture html_attributes %}data-style-id="{{ block.id | split: "__" | last }}" {{ block.shopify_attributes }} x-show="!line_card?.line_item?.properties?._p_fixed_quantity && $data.showConditionally('{{ show_conditionally }}')"{% endcapture %}

{% render '_components.quantity_stepper',
    class: quantity_class,
    setState: "_cart.updateLineItemQuantity(value, line_card?.line_item?.index)",
    state: "line_card?.line_item?.quantity",
    max: "line_card?.quantity_limit",
    min: 'line_card?.line_item?.properties?._p_required ? 1 : 0',
    disabled: "$cart.loading",
    disabled_min: 'line_card?.line_item?.properties?._p_required && line_card?.line_item?.quantity <= 1 || $cart.loading',
    disabled_max: 'line_card?.line_item?.quantity >= line_card?.quantity_limit || $cart.loading',
    disabled_manual_input: true,
    html_attributes: html_attributes
%}


{% schema %}
{
  "name": "Quantity selector",
  "settings": [
    {
      "type": "text",
      "id": "quantity_class",
      "label": "Quantity class",
      "default": "quantity-stepper"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    },
    {
      "type": "select",
      "id": "show_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "with_subscriptions",
          "label": "Subscription"
        },
        {
          "value": "no_subscriptions",
          "label": "One-time"
        },
        {
          "value": "no_addon_products",
          "label": "Hide with Addon products"
        },
        {
          "value": "addon_products",
          "label": "Only with Addon Products"
        },
        {
          "value": "with_variants",
          "label": "With Variants"
        },
        {
          "value": "no_variants",
          "label": "No Variants"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quantity selector",
      "category": "** Card **"
    }
  ],
  "tag": null,
  "class": "shopify_block___card_line_item_card__quantity_selector"
}
{% endschema %}

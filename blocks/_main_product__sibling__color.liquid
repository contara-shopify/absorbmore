{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_product__sibling__color"
  assign section_type = "main_product"
  assign legend_label = block.settings.legend_label
  assign metafield = block.settings.metafield
  assign legend = block.settings.legend
  assign legend_class = block.settings.legend_class
  assign primary_source = block.settings.primary_source
  assign fallback_source = block.settings.fallback_source
  assign hover_border_color = block.settings.hover_border_color
  assign hover_outline_color = block.settings.hover_outline_color
  assign show_tooltip = block.settings.show_tooltip
  assign content_flow = block.settings.content_flow
  assign scrollbar_class = block.settings.scrollbar_class
  assign scroll_pagination_class = block.settings.scroll_pagination_class
  assign dangerously_check_markets = block.settings.dangerously_check_markets
  assign quick_view_visibility = block.settings.quick_view_visibility
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign product = section.settings.product | default: product

  assign namespace_key = metafield | remove: " " | strip_newlines | split: '.'
  assign metafield = product.metafields[namespace_key[0]][namespace_key[1]].value

  unless metafield.count > 0
    break
  endunless

  assign sibling_products = "" | split: "" | uniq
  assign sibling_handles = "" | split: "" | uniq
  assign sibling_titles = "" | split: "" | uniq
  assign sibling_colors = "" | split: "" | uniq
  assign sibling_images = "" | split: "" | uniq
  assign sibling_swatch_titles = "" | split: "" | uniq
  assign sibling_swatch_colors = "" | split: "" | uniq
  assign sibling_swatch_images = "" | split: "" | uniq

  for object in metafield
    if object.product.value.handle == blank
      continue
    endif

    if dangerously_check_markets
      assign item = all_products[object.product.value.handle]
      if item == blank
        continue
      endif
    endif

    assign _sibling_product = object.product.value | uniq
    assign _sibling_handle = object.product.value.handle | uniq
    assign _sibling_title = object.title.value | uniq
    assign _sibling_color = object.color.value | uniq
    assign _sibling_image = object.image.value | uniq
    assign _sibling_swatch_title = object.swatch.value.title.value | uniq
    assign _sibling_swatch_color = object.swatch.value.color.value | uniq
    assign _sibling_swatch_image = object.swatch.value.image.value | uniq

    assign sibling_products = sibling_products | concat: _sibling_product
    assign sibling_handles = sibling_handles | concat: _sibling_handle
    assign sibling_titles = sibling_titles | concat: _sibling_title
    assign sibling_colors = sibling_colors | concat: _sibling_color
    assign sibling_images = sibling_images | concat: _sibling_image
    assign sibling_swatch_titles = sibling_swatch_titles | concat: _sibling_swatch_title
    assign sibling_swatch_colors = sibling_swatch_colors | concat: _sibling_swatch_color
    assign sibling_swatch_images = sibling_swatch_images | concat: _sibling_swatch_image

    if object.product.value.handle == product.handle
      assign current_handle = product.handle
      assign current_title = object.title.value
    endif
  endfor

  assign sibling_colors = sibling_colors | json
  assign sibling_swatch_colors = sibling_swatch_colors | json

  unless metafield.count > 0
    assign is_empty = true
  endunless

  if current_handle == blank
    assign is_empty = true
  endif

  if is_empty and hide_if_empty != 'none'
    capture hide_conditionally
      if hide_if_empty == 'block'
        echo '<script type="block/hide"></script>'
        assign hide_attribute = 'data-hide-if-empty-block'
      endif
      if hide_if_empty == 'container'
        echo '<script type="container/break"></script>'
        assign hide_attribute = 'data-hide-if-empty-container'
      endif
      if hide_if_empty == 'section'
        echo '<script type="section/break"></script>'
        assign hide_attribute = 'data-hide-if-empty-section'
      endif
    endcapture

    if request.design_mode != true and hide_conditionally contains '<script'
      echo hide_conditionally
      break
    endif
    assign hide_attribute = hide_attribute | append: ' data-block-type="' | append: block_type | append: '"' | append: ' data-block-id="' | append: block.id | append: '"'
  endif

  if is_empty
    break
  endif

  assign content_legend = legend | replace: "[heading]", legend_label
  assign current_legend = content_legend | replace: "[value]", current_title | default: legend_label

  case content_flow
    when "show_all"
      assign container_classes = 'flex-wrap'
    when "truncate"
      assign container_classes = 'overflow-hidden'
    when "overflow"
      assign container_classes = 'overflow-x-auto'
  endcase
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>
  {{ custom_css | replace: '&', selector | strip_newlines }}
</style>

<div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }} {{ hide_attribute }}
     data-quick-view-visibility="{{ quick_view_visibility }}"
    {% if content_flow == 'overflow' %}
      x-data="{ current_sibling: `{{ current_handle }}`, hoverValue: `{{ current_handle }}`, sibling_handles: utils.JSONParse($el.getAttribute('data-values')), offset: +`{{ sibling_handles.size }}`, ...utils.initContentSlider($el, $refs.scrollContainer, undefined,`{{ infinite_scroll }}`, +`{{ auto_rotate }}`), show_all_items: true, desktop_display_limit: 9999, mobile_display_limit: 9999 }"
      x-init="sibling_handles?.forEach(handle =>{ barba.prefetch(utils.getSiblingUrl(handle)) }); $refs.scrollContainer.scrollLeft = ([...$refs.scrollContainer.children]?.find(child=> child?.classList?.contains('active'))?.offsetLeft ?? 0) - 5;"
    {% else %}
      x-data="{ current_sibling: `{{ current_handle }}`, hoverValue: `{{ current_handle }}`, sibling_handles: utils.JSONParse($el.getAttribute('data-values')), offset: +`{{ sibling_handles.size }}` }"
      x-init="sibling_handles?.forEach(handle =>{ barba.prefetch(utils.getSiblingUrl(handle)) })"
    {% endif %}
     data-values="{{ sibling_handles | json | escape }}"
     x-defer="intersect">
  <legend id="legend-{{ block.id }}"
          x-ignore
          class="flex w-full max-w-full truncate {{ legend_class }}"
          data-legend="{% render '_input.inline_richtext', content: content_legend, escape: true %}"
          data-current-title="{{ current_title | escape }}"
          x-effect="$el.innerHTML = $el.getAttribute('data-legend').replace('[value]', $el.getAttribute('data-current-title'))">
    {% render '_input.inline_richtext', content: current_legend %}
  </legend>
  <fieldset
      aria-labelledby="legend-{{ block.id }}"
      x-ignore
      class="relative w-full flex scrollbar-none {{ container_classes }}"
      {% if content_flow == 'overflow' %}
        x-ref="scrollContainer"
        @resize.window="content_slider.handleResize"
        x-init="$nextTick(() => content_slider.handleResize())"
        @scroll="content_slider.handleScroll"
        @scrollend="content_slider.handleInfiniteScroll"
      {% endif %}
  >
    {% for value in sibling_handles %}
      {% if value == blank %}{% continue %}{% endif %}
      {% liquid
        assign i = forloop.index0
        assign title = sibling_titles[i] | handleize
        assign tooltip = sibling_swatch_titles[i] | default: sibling_colors[i]

        if title == blank
          continue
        endif

        if sibling_products[i]
          assign _sibling_variant = null
          for sibling_variant in sibling_products[i].variants
            if sibling_variant.options[0] == product.options[0] and sibling_variant.options[1] == product.options[1] and sibling_variant.options[2] == product.options[2]
              assign _sibling_variant = sibling_variant
              break
            endif
          endfor
          if _sibling_variant == null
            for sibling_variant in sibling_products[i].variants
              if sibling_variant.options[0] == product.options[0] and sibling_variant.options[1] == product.options[1]
                assign _sibling_variant = sibling_variant
                break
              endif
            endfor
          endif
          if _sibling_variant == null
            for sibling_variant in sibling_products[i].variants
              if sibling_variant.options[0] == product.options[0]
                assign _sibling_variant = sibling_variant
                break
              endif
            endfor
          endif

          if _sibling_variant == null
            assign _sibling_variant = sibling_products[i].variants[0]
          endif

          assign current_image = _sibling_variant.image | default: product.image
        endif

        assign image = ''

        case primary_source
          when "title"
            assign primary_swatch = "--primary-swatch: var(--swatch-" | append: title | append: ")"
          when "image"
            assign image = current_image | image_url: width: 180, height: 180, crop: 'center' | escape
            assign primary_swatch = "--primary-swatch: url(" | append: image | append: ") center center/cover no-repeat"
          when "metafield"
            if sibling_colors[i] != blank
              assign primary_swatch = "--primary-swatch: " | append: sibling_colors[i]
            endif
            if sibling_swatch_colors[i] != blank
              assign primary_swatch = "--primary-swatch: " | append: sibling_swatch_colors[i]
            endif
            if sibling_images[i] != blank
              assign image = sibling_images[i] | image_url: width: 180, height: 180, crop: 'center' | escape
              assign primary_swatch = "--primary-swatch: url(" | append: image | append: ") center center/cover no-repeat"
            endif
            if sibling_swatch_images[i] != blank
              assign image = sibling_swatch_images[i] | image_url: width: 180, height: 180, crop: 'center' | escape
              assign primary_swatch = "--primary-swatch: url(" | append: image | append: ") center center/cover no-repeat"
            endif
        endcase

        case fallback_source
          when "title"
            assign fallback_swatch = "--fallback-swatch: var(--swatch-" | append: title | append: ")"
          when "image"
            assign image = current_image | image_url: width: 180, height: 180, crop: 'center' | escape
            assign fallback_swatch = "--fallback-swatch: url(" | append: image | append: ") center center/cover no-repeat"
          when "metafield"
            if sibling_colors[i] != blank
              assign fallback_swatch = "--fallback-swatch: " | append: sibling_colors[i]
            endif
            if sibling_swatch_colors[i] != blank
              assign fallback_swatch = "--fallback-swatch: " | append: sibling_swatch_colors[i]
            endif
            if sibling_images[i] != blank
              assign image = sibling_images[i] | image_url: width: 180, height: 180, crop: 'center' | escape
              assign fallback_swatch = "--fallback-swatch: url(" | append: image | append: ") center center/cover no-repeat"
            endif
            if sibling_swatch_images[i] != blank
              assign image = sibling_swatch_images[i] | image_url: width: 180, height: 180, crop: 'center' | escape
              assign fallback_swatch = "--fallback-swatch: url(" | append: image | append: ") center center/cover no-repeat"
            endif
        endcase
      %}

      <label class="shrink-0 flex border-gray-300 cursor-pointer relative {% if value == current_handle %}active{% endif %}"
             x-effect="$el.classList.toggle('active', current_sibling === '{{ value }}')"
             x-show="offset >= +`{{ forloop.index0 }}`"
          {% if show_tooltip %}
            @mouseenter="$tooltip.addTooltip($el, '{{ tooltip }}')"
            @mouseleave="$tooltip.removeTooltip($el)"
          {% endif %}
             @pointerenter="hoverValue = '{{ tooltip }}'"
             @pointerleave="hoverValue = ''"
             aria-label="{{ tooltip }}"
             style="{{ primary_swatch }};{{ fallback_swatch }};background: var(--primary-swatch, var(--fallback-swatch, {{ title }}))">
        <input type="radio"
               class="sr-only"
            {% if show_tooltip %}
              @focus="$tooltip.addTooltip($el.parentElement, $el.value)"
              @blur="$tooltip.removeTooltip($el.parentElement)"
            {% endif %}
               name="{{ block.id }}"
               @change="$data.setSiblingProduct($el.value, $el.closest('[data-quick-view-container]'))"
               :checked="current_sibling === $el.value"
               value="{{ value }}">
      </label>
    {% endfor %}
    {% if content_flow == 'truncate' %}
      <div class="flex shrink-0 items-center text-sm font-medium"
           :class="offset < +`{{ sibling_handles.size }}` ? '':'opacity-0 pointer-events-none'"
           x-init="$nextTick(async ()=> { if (window.design_mode) { await utils.delay(20) } offset = utils.truncateChildren($el, $el.parentElement)})"
           @resize.window.debounce.200ms="offset = +`{{ sibling_handles.size }}`; await utils.delay(20); offset = utils.truncateChildren($el, $el.parentElement)"
           x-html="`+ ${+`{{ sibling_handles.size }}` - (offset + 1)} {{ legend_label }}`">
        +10 {{ legend_label }}
      </div>
    {% endif %}
  </fieldset>
  {% if content_flow == 'overflow' %}
    {% if scrollbar_class != blank %}
      {% render '_components.scrollbar', class: scrollbar_class %}
    {% endif %}
    {% if scroll_pagination_class != blank %}
      {% render '_components.scroll_pagination', class: scroll_pagination_class %}
    {% endif %}
  {% endif %}
</div>

{% schema %}

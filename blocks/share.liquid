{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "share"
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}>
  {% content_for 'blocks' %}
</div>



{% schema %}
{
  "name": "Share",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "blocks": [
    {
      "type": "_share__target"
    }
  ],
  "presets": [
    {
      "name": "Share",
      "blocks": [
        {
          "type": "_share__target",
          "settings": {
            "type": "email",
            "icon": "email"
          }
        },
        {
          "type": "_share__target",
          "settings": {
            "type": "facebook",
            "icon": "facebook"
          }
        },
        {
          "type": "_share__target",
          "settings": {
            "type": "twitter",
            "icon": "twitter"
          }
        },
        {
          "type": "_share__target",
          "settings": {
            "type": "linkedin",
            "icon": "linkedin"
          }
        },
        {
          "type": "_share__target",
          "settings": {
            "type": "pinterest",
            "icon": "pinterest"
          }
        }
      ],
      "category": "Social"
    }
  ],
  "tag": null,
  "class": "shopify_block__share"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_card_product_card__button"
  assign section_type = "card_product_card"
  assign type = block.settings.type
  assign label = block.settings.label
  assign button_class = block.settings.button_class
  assign url = block.settings.url
  assign collapsible_handle = block.settings.collapsible_handle
  assign product_modal_handle = block.settings.product_modal_handle
  assign accessibility_label = block.settings.accessibility_label
  assign custom_css = block.settings.custom_css
  assign hide_if_empty = block.settings.hide_if_empty
  assign show_conditionally = block.settings.show_conditionally
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% if request.design_mode or metaobjects.product_cards[section.settings.product_card] == blank %}
  {% capture selector %}[data-style-id="{{ block.id | split: "__" | last }}"]{% endcapture %}

  <style>
    {{ custom_css | replace: '&', selector | strip_newlines }}
    {% if request.design_mode %}
    {% assign query_selector = '[data-section-id="'|append: section.id | append: '"][data-preview-container] ' | append: selector %}
    {{- custom_css | replace: '&', query_selector  | strip_newlines | replace: '@media screen and', '@container'| replace: '@media', '@container' -}}
    {% endif %}
  </style>
{% endif %}

{% if type == 'modal_close' %}
  <button
      data-style-id="{{ block.id | split: "__" | last }}" {{ block.shopify_attributes }}
      x-ignore
      type="button"
      data-content="{% render '_input.inline_richtext', content: label, escape: true, skip_pluralization: true %}"
      x-data="{ content: getDynamicText($el.getAttribute('data-content')), url: getDynamicText(`{{ url }}`), accessibility_label: getDynamicText(`{{ accessibility_label }}`) }"
      x-effect="() => { if (p_card?.selected_variant || p_card?.hydrated) { content = getDynamicText($el.getAttribute('data-content')); content_check = getDynamicText($el.getAttribute('data-content-check')); url = getDynamicText(`{{ url }}`); utils.hideIfEmpty($el, `{{ hide_if_empty }}`, !content.trim()) } }"
      x-cloak
      x-html="content"
      class="{{ button_class }}"
      {% if accessibility_label != blank %}
        :aria-label="accessibility_label"
      {% endif %}
      x-show="!!content && ($editor.select_block_id === `{{ block.id }}` || $data.showConditionally('{{ show_conditionally }}', $data?.bundle))"
      @click.prevent.stop="$modal.setId(''); $data.submenu = '';">
  </button>
{% elsif type == 'product_modal' %}
  <button
      data-style-id="{{ block.id | split: "__" | last }}" {{ block.shopify_attributes }}
      x-ignore
      type="button"
      data-content="{% render '_input.inline_richtext', content: label, escape: true, skip_pluralization: true %}"
      x-data="{ content: getDynamicText($el.getAttribute('data-content')), url: getDynamicText(`{{ url }}`), accessibility_label: getDynamicText(`{{ accessibility_label }}`) }"
      x-effect="() => { if (p_card?.selected_variant || p_card?.hydrated) { content = getDynamicText($el.getAttribute('data-content')); content_check = getDynamicText($el.getAttribute('data-content-check')); url = getDynamicText(`{{ url }}`); utils.hideIfEmpty($el, `{{ hide_if_empty }}`, !content.trim()) } }"
      x-cloak
      x-html="content"
      class="{{ button_class }}"
      {% if accessibility_label != blank %}
        :aria-label="accessibility_label"
      {% endif %}
      x-show="!!content && ($editor.select_block_id === `{{ block.id }}` || $data.showConditionally('{{ show_conditionally }}', $data?.bundle))"
      @click.prevent.stop="$modal.setId(`modal--product-{{ product_modal_handle }}`, false, p_card?.product_handle, p_card?.product?.id, p_card?.selected_variant?.id, updateProductState)">
  </button>
{% elsif type == 'toggle_collapsible' %}
  <button
      data-style-id="{{ block.id | split: "__" | last }}" {{ block.shopify_attributes }}
      x-ignore
      type="button"
      data-content="{% render '_input.inline_richtext', content: label, escape: true, skip_pluralization: true %}"
      x-data="{ ...utils.initCollapsible($el, document.querySelector(`[data-collapsible-handle='{{ collapsible_handle }}']`), document.querySelector(`[data-collapsible-handle='{{ collapsible_handle }}']`)?.hasAttribute('data-default-open')), content: getDynamicText($el.getAttribute('data-content')), url: getDynamicText(`{{ url }}`), accessibility_label: getDynamicText(`{{ accessibility_label }}`) }"
      x-effect="() => { if (p_card?.selected_variant || p_card?.hydrated) { content = getDynamicText($el.getAttribute('data-content')); content_check = getDynamicText($el.getAttribute('data-content-check')); url = getDynamicText(`{{ url }}`); utils.hideIfEmpty($el, `{{ hide_if_empty }}`, !content.trim()) } }"
      x-cloak
      x-html="content"
      class="{{ button_class }}"
      {% if accessibility_label != blank %}
        :aria-label="accessibility_label"
      {% endif %}
      x-show="!!content && ($editor.select_block_id === `{{ block.id }}` || $data.showConditionally('{{ show_conditionally }}', $data?.bundle))"
      @click.prevent.stop="toggleOpen()"
      :class="collapsible?.open_accordion ? 'active' : ''"
      id="{{ block.id }}">
  </button>
{% elsif type == 'button' %}
  <button
      data-style-id="{{ block.id | split: "__" | last }}" {{ block.shopify_attributes }}
      x-ignore
      type="submit"
      :formaction="url"
      formmethod="get"
      data-content="{% render '_input.inline_richtext', content: label, escape: true, skip_pluralization: true %}"
      x-data="{ content: getDynamicText($el.getAttribute('data-content')), url: getDynamicText(`{{ url }}`), accessibility_label: getDynamicText(`{{ accessibility_label }}`) }"
      x-effect="() => { if (p_card?.selected_variant || p_card?.hydrated) { content = getDynamicText($el.getAttribute('data-content')); content_check = getDynamicText($el.getAttribute('data-content-check')); url = getDynamicText(`{{ url }}`); utils.hideIfEmpty($el, `{{ hide_if_empty }}`, !content.trim()) } }"
      x-cloak
      role="link"
      tabindex="0"
      x-init="utils.simulateAnchorTag($el);"
      :data-href="url"
      x-html="content"
      class="{{ button_class }}"
      {% if accessibility_label != blank %}
        :aria-label="accessibility_label"
      {% endif %}
      x-show="!!content && ($editor.select_block_id === `{{ block.id }}` || $data.showConditionally('{{ show_conditionally }}', $data?.bundle))">
  </button>
{% endif %}

{% schema %}
{
  "name": "Button",
  "settings": [
    {
      "type": "select",
      "id": "type",
      "label": "Type",
      "default": "button",
      "options": [
        {
          "value": "button",
          "label": "Button"
        },
        {
          "value": "modal_close",
          "label": "Close Modal"
        },
        {
          "value": "product_modal",
          "label": "Open product modal"
        },
        {
          "value": "toggle_collapsible",
          "label": "Toggle Collapsible"
        }
      ]
    },
    {
      "type": "inline_richtext",
      "id": "label",
      "label": "Label",
      "default": "Read More",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use bracket notation for data access: i.e.[product.title] or [product.metafields.smart.short_description]."
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button class",
      "default": "button-primary"
    },
    {
      "type": "text",
      "id": "url",
      "label": "Dynamic URL",
      "info": "Use bracket notation for data access.",
      "default": "[product.url]",
      "visible_if": "{{ block.settings.type == 'button' }}"
    },
    {
      "type": "text",
      "id": "collapsible_handle",
      "label": "Collapsible handle",
      "visible_if": "{{ block.settings.type == 'toggle_collapsible' }}"
    },
    {
      "type": "text",
      "id": "product_modal_handle",
      "label": "Product modal handle",
      "default": "product",
      "visible_if": "{{ block.settings.type == 'product_modal' }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Accessibility label",
      "info": "Please provide an accessibility label if the button has generic content. I.e. 'Read More' or only uses an icon."
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "[Available keys](https://shopify.dev/docs/api/liquid/objects/product)"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    },
    {
      "type": "select",
      "id": "hide_if_empty",
      "label": "If empty, hide:",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "section",
          "label": "Section"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "block",
          "label": "Block"
        }
      ],
      "info": "Always shows in the Theme Editor."
    },
    {
      "type": "select",
      "id": "show_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "with_subscriptions",
          "label": "Subscription"
        },
        {
          "value": "no_subscriptions",
          "label": "One-time"
        },
        {
          "value": "no_bundle",
          "label": "Hide in Bundle"
        },
        {
          "value": "bundle",
          "label": "Only in Bundle"
        },
        {
          "value": "with_variants",
          "label": "With Variants"
        },
        {
          "value": "no_variants",
          "label": "No Variants"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Button",
      "category": "** Card **"
    }
  ],
  "tag": null,
  "class": "shopify_block___card_product_card__button"
}
{% endschema %}

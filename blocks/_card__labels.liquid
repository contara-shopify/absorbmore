{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_card__labels"
  assign section_type = "card"
  assign content_source = block.settings.content_source
  assign label_class__content = block.settings.label_class__content
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% if request.design_mode or metaobjects.product_cards[section.settings.product_card] == blank %}
  {% capture selector %}[data-style-id="{{ block.id | split: "__" | last }}"]{% endcapture %}

  <style>
    {{ custom_css | replace: '&', selector | strip_newlines }}
    {% if request.design_mode %}
    {% assign query_selector = '[data-section-id="'|append: section.id | append: '"][data-preview-container] ' | append: selector %}
    {{- custom_css | replace: '&', query_selector  | strip_newlines | replace: '@media screen and', '@container'| replace: '@media', '@container' -}}
    {% endif %}
  </style>
{% endif %}

<div data-style-id="{{ block.id | split: "__" | last }}" {{ block.shopify_attributes }}
     x-ignore
     data-labels-key="{{ content_source }}"
     x-show="$editor.select_block_id === `{{ block.id }}` || getContentLabels($el.getAttribute('data-labels-key'))?.length">
  <template x-for="value in getContentLabels($el.parentElement.getAttribute('data-labels-key'))">
    <div data-loop-item class="{{ label_class__content }}" x-html="value"></div>
  </template>
</div>

{% schema %}
{
  "name": "Label",
  "settings": [
    {
      "type": "header",
      "content": "Theme Editor Settings"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "content_source",
      "label": "Content source",
      "default": "metafields.smart.labels",
      "info": "Accepts `single_line_text_field` or `list.single_line_text_field` matching data. (i.e. product.tags, product.metafields.smart.labels) [Learn more](https://shopify.dev/docs/apps/custom-data/metafields/types)"
    },
    {
      "type": "text",
      "id": "label_class__content",
      "label": "Label class",
      "default": "label-primary"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 4px;  \n}"
    }
  ],
  "presets": [
    {
      "name": "Label",
      "category": "** Card **"
    }
  ],
  "tag": null,
  "class": "shopify_block___card__labels"
}
{% endschema %}

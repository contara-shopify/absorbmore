{% style %}
  /* Preview bar */
  #preview-bar-iframe,
  #PBarNextFrameWrapper,
  #PBarNextFrame {
    display: block !important;
  }

  /* Pre-Order */
  div[data-style-id*="main_product_choose_supply"] {
    margin-top: 27px;
  }

  .batch-card {
    font-family: 'DM Sans', -apple-system, sans-serif;
    border-radius: 6px;
    padding: 18px 16px;
    margin-top: 14px;
    margin-bottom: 14px;
    background: linear-gradient(135deg, #eef0ff 0%, #f4f0ff 50%, #eef0ff 100%);
    border: 1.5px solid #d6daff;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }
  .batch-card * { box-sizing: border-box; margin: 0; padding: 0; }

  .batch-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .batch-header div:first-child {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    align-items: center;
  }
  .batch-label {
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    display: block;
  }
  .batch-countdown {
    display: flex;
    gap: 4px;
    font-weight: 600;
    color: #4659FF;
    align-items: center;
    text-transform: uppercase;
  }
  .batch-countdown-unit {
    text-align: center;
    min-width: 38px;
  }
  .batch-countdown-val {
    font-family: 'DM Sans', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1;
    display: block;
  }
  .batch-countdown-lbl {
    font-size: 10px;
    color: #999;
    font-weight: 400;
    letter-spacing: 0.3px;
  }
  .batch-countdown-sep {
    font-size: 16px;
    color: #ccc;
    font-weight: 300;
    margin-top: -8px;
  }

  .batch-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 100px;
    background: #fff;
    border: 1px solid #d6daff;
  }
  .batch-pill-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #4659FF;
    animation: batchDotPulse 2s ease infinite;
  }
  .batch-pill-text {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: #4659FF;
  }

  .batch-desc {
    font-size: 13px;
    color: #777;
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .batch-rows {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .batch-row {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-radius: 100px;
    overflow: hidden;
    background: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.5);
    animation: batchFadeIn 0.35s ease both;
  }
  .batch-row--active {
    background: #fff;
    border: 1.5px solid #4659FF;
  }
  .batch-row--sold-out {
    opacity: 0.45;
  }

  .batch-row-fill {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    background: rgba(70,89,255,0.07);
    transition: width 1.5s ease;
  }

  .batch-row-left {
    display: flex;
    align-items: center;
    gap: 8px;
    position: relative;
    z-index: 1;
  }
  .batch-row-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4659FF;
    animation: batchDotPulse 2s ease infinite;
  }
  .batch-row-date {
    font-size: 13px;
    font-weight: 400;
    color: #1a1a1a;
    letter-spacing: 0.2px;
  }
  .batch-row--active .batch-row-date { font-weight: 600; }
  .batch-row--sold-out .batch-row-date {
    color: #aaa;
    text-decoration: line-through;
  }

  .batch-row-status {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: #999;
    position: relative;
    z-index: 1;
  }
  .batch-row--active .batch-row-status { color: #4659FF; }
  .batch-row--sold-out .batch-row-status { color: #ccc; }

  @keyframes batchDotPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  @keyframes batchFadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Notify Me button */
  #klaviyo-bis-button-container {
    display: none !important;
  }

  /* Add to Cart button */
  div[data-style-id*="main_product_container"] .button-primary[data-pre-order-button] {
    display: block !important;
    margin-top: 0;
    width: 100%;
  }

  @media (max-width: 768px) {
    .batch-header > div:first-child {
      font-size: 70%;
    }
  }
{% endstyle %}

<div class="shopify_block__pre_order">
  {% comment %}{% render 'pre-order-choose-supply', product: product, input_name: 'bplp-choose-supply-p1' %}{% endcomment %}
  
  <div class="batch-card">
    <div class="batch-header">
      <div>
        <span class="batch-label">{{ block.settings.pre_order_label | default: 'Next Batch Ships In' }}</span>
        <div class="batch-countdown" id="batchCountdown"></div>
      </div>
      <div class="batch-pill">
        <div class="batch-pill-dot"></div>
        <span class="batch-pill-text">{{ block.settings.pre_order_pill_text | default: 'Preorders Open' }}</span>
      </div>
    </div>

    <p class="batch-desc">{{ block.settings.pre_order_description | default: "Reserve yours today. You'll be charged now and your order ships when the next batch arrives." }}</p>

    <div class="batch-rows">
      <!-- Sold out -->
      <div class="batch-row batch-row--sold-out" style="animation-delay: 0s">
        <div class="batch-row-left">
          <span class="batch-row-date">February 28th</span>
        </div>
        <span class="batch-row-status">SOLD OUT</span>
      </div>
      <!-- Active -->
      <div class="batch-row batch-row--active" style="animation-delay: 0.08s">
        <div class="batch-row-fill" style="width: 92%"></div>
        <div class="batch-row-left">
          <div class="batch-row-dot"></div>
          <span class="batch-row-date">March 25th</span>
        </div>
        <span class="batch-row-status">92% RESERVED</span>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
  (function() {
    const preOrderShipDate = '{{ product.metafields.custom.pre_order_ship_date }}';

    if (!preOrderShipDate) return;

    const target = new Date(`${preOrderShipDate}T00:00:00`).getTime();
    const el = document.getElementById('batchCountdown');
    
    function pad(n) { return String(n).padStart(2, '0'); }
    
    function tick() {
      const diff = Math.max(0, target - Date.now());
      const d = Math.floor(diff / 86400000);
      const h = Math.floor((diff % 86400000) / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      
      const units = [
        { val: d, label: 'days' },
        { val: h, label: 'hrs' },
        { val: m, label: 'min' },
        { val: s, label: 'sec' }
      ];

      const daysUntilShipment = d;
      
      /*el.innerHTML = units.map((u, i) => 
        '<div class="batch-countdown-unit">' +
          '<span class="batch-countdown-val">' + pad(u.val) + '</span>' +
          '<span class="batch-countdown-lbl">' + u.label + '</span>' +
        '</div>' +
        (i < 3 ? '<span class="batch-countdown-sep">:</span>' : '')
      ).join('');*/

      el.innerHTML = `<div class="batch-days-until-shipment">
          <span class="batch-days-until-shipment-value">${pad(daysUntilShipment)} days</span>
        </div>`;
    }
    
    tick();
    //setInterval(tick, 1000);
  })();
</script>

{% schema %}
{
  "name": "Pre-Order",
  "settings": [
    {
      "type": "text",
      "id": "pre_order_label",
      "label": "Pre-Order Label",
      "default": "Next Batch Ships In"
    },
    {
      "type": "text",
      "id": "pre_order_pill_text",
      "label": "Pre-Order Pill Text",
      "default": "Preorders Open"
    },
    {
      "type": "text",
      "id": "pre_order_description",
      "label": "Pre-Order Description",
      "default": "Reserve yours today. You'll be charged now and your order ships when the next batch arrives."
    }
  ],
  "presets": [
    {
      "name": "Pre-Order",
      "category": "Custom"
    }
  ],
  "tag": null,
  "class": "shopify_block__pre_order"
}
{% endschema %}
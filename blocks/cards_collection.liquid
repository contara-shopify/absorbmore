{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "cards_collection"
  assign _collections = block.settings.collections
  assign order_offset = block.settings.order_offset
  assign display_limit = block.settings.display_limit
  assign collection_card_class = block.settings.collection_card_class
  assign hydrate_immediately = block.settings.hydrate_immediately
  assign preload_images = block.settings.preload_images
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
  assign hide_if_empty = block.settings.hide_if_empty
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid

  assign order_offset = order_offset | default: 1
  if request.visual_preview_mode and _collections == blank or _collections.size <= 0
    assign _collections = collections
  endif

  assign display_limit = display_limit | strip_newlines | replace: ' ', "" | split: '|'
  assign display_limit = display_limit[0] | split: '/'

  assign desktop_display_limit = display_limit.first | abs
  assign mobile_display_limit = display_limit.last | abs

  assign max_display_limit = desktop_display_limit | at_least: mobile_display_limit | default: 12
%}
{% liquid
  if _collections.size <= 0
    assign is_empty = true
  endif
  if is_empty and hide_if_empty != 'none'
    capture hide_conditionally
      if hide_if_empty == 'block'
        echo '<script type="block/hide"></script>'
        assign hide_attribute = 'data-hide-if-empty-block'
      endif
      if hide_if_empty == 'container'
        echo '<script type="container/break"></script>'
        assign hide_attribute = 'data-hide-if-empty-container'
      endif
      if hide_if_empty == 'section'
        echo '<script type="section/break"></script>'
        assign hide_attribute = 'data-hide-if-empty-section'
      endif
    endcapture

    if request.design_mode != true and hide_conditionally contains '<script'
      echo hide_conditionally
      break
    endif
    assign hide_attribute = hide_attribute | append: ' data-block-type="' | append: block_type | append: '"' | append: ' data-block-id="' | append: block.id | append: '"'
  endif
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
  {% capture css %}
    & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    }
  {% endcapture %}
{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

{% assign collection_section = collection_card_class.schema.value %}

{% for collection in _collections limit: max_display_limit %}
  {% assign order_index = forloop.index0 | plus: order_offset %}
  {% assign collection_visibility = "" %}
  {% if forloop.index > desktop_display_limit %}
    {% assign collection_visibility = "mobile-only" %}
  {% endif %}
  {% if forloop.index > mobile_display_limit %}
    {% assign collection_visibility = "desktop-tablet-only" %}
  {% endif %}
  <div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
       class="shrink-0 max-w-full w-full order-[--order] {{ collection_visibility }}"
       data-collection-handle="{{ collection.handle }}"
       style="--order: {{ order_index | times: 10 }}">
    {% if collection_section != blank %}
      {% assign preload_images_boolean = true %}
      {% if forloop.index0 >= preload_images %}
        {% assign preload_images_boolean = false %}
      {% endif %}
      {% render "card_collection_card._static", collection: collection, section: collection_section, preload_images: preload_images_boolean %}
    {% else %}
      <section class="card-loading collection-card--{{ collection_card_class }}"
               data-collection-handle="{{ collection.handle }}"
               data-collection-id="{{ collection.id }}"
               {% if request.visual_preview_mode or hydrate_immediately %}data-intersected{% endif %}
               data-card-handle="{{ collection_card_class }}"
               x-init="$nextTick(() => _sections.hydrateCollectionCard($el))"></section>
    {% if load_async != true %}
      <script type="application/json"
              data-collection-data="{{ collection.handle }}">{%- render '_json.collection', collection: collection, meta_collection: true -%}</script>
    {% endif %}
    {% endif %}
  </div>
{% endfor %}

{% schema %}
{
  "name": "Collection Cards",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Collection"
    },
    {
      "type": "number",
      "id": "order_offset",
      "label": "Order index offset",
      "default": 1,
      "info": "Use this when mixing multiple sources and order items. Defaults to 1."
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Display Settings"
    },
    {
      "type": "text",
      "id": "display_limit",
      "label": "Display limit",
      "default": "12 / 4"
    },
    {
      "type": "metaobject",
      "id": "collection_card_class",
      "label": "Collection card",
      "metaobject_type": "collection_cards"
    },
    {
      "type": "header",
      "content": "Performance"
    },
    {
      "type": "checkbox",
      "id": "hydrate_immediately",
      "label": "Hydrate immediately"
    },
    {
      "type": "range",
      "id": "preload_images",
      "label": "Preload first images",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    },
    {
      "type": "select",
      "id": "hide_if_empty",
      "label": "If empty, hide:",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "section",
          "label": "Section"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "block",
          "label": "Block"
        }
      ],
      "info": "Always shows in the Theme Editor."
    }
  ],
  "presets": [
    {
      "name": "Collection Cards",
      "category": "Cards"
    }
  ],
  "tag": null,
  "class": "shopify_block__cards_collection"
}
{% endschema %}

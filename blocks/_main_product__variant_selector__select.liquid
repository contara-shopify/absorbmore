{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_product__variant_selector__select"
  assign section_type = "main_product"
  assign legend_label = block.settings.legend_label
  assign legend = block.settings.legend
  assign legend_class = block.settings.legend_class
  assign select_class = block.settings.select_class
  assign sold_out_variants = block.settings.sold_out_variants
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign product = section.settings.product | default: product

  assign filtered_variants = product.variants
  if sold_out_variants == 'hide'
    assign filtered_variants = product.variants | where: 'available'
  endif

  if product.variants.first.title == "Default Title" and product.variants.size == 1 or filtered_variants.size <= 0
    break
  endif

  if section.settings.default_variant_metafield != blank
    assign variant_namespace = section.settings.default_variant_metafield | strip | split: "." | first
    assign variant_key = section.settings.default_variant_metafield | strip | split: "." | last
    assign variant = product.metafields[variant_namespace][variant_key].value | default: variant
  endif

  assign variant = variant | default: product.selected_or_first_available_variant | default: product.variants.first

  assign current_value = variant.id
  assign current_title = variant.title
  assign content_legend = legend | replace: "[heading]", legend_label
  assign current_legend = content_legend | replace: "[value]", current_title | default: legend_label

  assign variant_ids = filtered_variants | map: "id"
  assign variant_titles = filtered_variants | map: "title"
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>
  {{ custom_css | replace: '&', selector | strip_newlines }}
</style>

<fieldset data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
          x-defer="intersect">
  <legend class="flex w-full max-w-full truncate {{ legend_class }}"
          x-ignore
          data-legend="{% render '_input.inline_richtext', content: content_legend, escape: true %}"
          x-effect="$el.innerHTML = $el.getAttribute('data-legend').replace('[value]', pdp.selected_variant?.title)">
    {% render '_input.inline_richtext', content: current_legend %}
  </legend>
  {% render '_components.select',
      values: variant_ids,
      titles: variant_titles,
      select_class: select_class,
      label: legend_label,
      setState: "$data.setSelectedVariant(value);",
      state: "pdp.selected_variant.id",
      current_value: current_value,
      current_title: current_title,
      html_attributes: "x-ignore",
      disabled_clickable: true
  %}
</fieldset>

{% schema %}
{
  "name": "Variant: Select",
  "settings": [
    {
      "type": "text",
      "id": "legend_label",
      "label": "Heading",
      "default": "Variants"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "legend",
      "label": "Heading",
      "default": "[heading]: [value]",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use [heading] as a placeholder for the title, and [value] as a placeholder for the current / hover value."
    },
    {
      "type": "text",
      "id": "legend_class",
      "label": "Heading class",
      "default": "richtext-md h5"
    },
    {
      "type": "text",
      "id": "select_class",
      "label": "Select class",
      "default": "input-select"
    },
    {
      "type": "select",
      "id": "sold_out_variants",
      "label": "Sold Out Variants",
      "default": "",
      "options": [
        {
          "value": "",
          "label": "Show"
        },
        {
          "value": "hide",
          "label": "Hide"
        },
        {
          "value": "disable",
          "label": "Disable"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n\n}\n& legend {\n  margin-bottom: 6px;\n}\n@media (max-width: 1024px) {\n  & {\n    \n  }\n}"
    }
  ],
  "presets": [
    {
      "name": "Variant: Select",
      "category": "** Product Variant Select **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_product__variant_selector__select"
}
{% endschema %}

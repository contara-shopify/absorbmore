{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_form__input_textarea"
  assign section_type = "form"
  assign title = block.settings.title
  assign placeholder = block.settings.placeholder
  assign textarea_class = block.settings.textarea_class
  assign name = block.settings.name
  assign default_value = block.settings.default_value
  assign limit_characters = block.settings.limit_characters
  assign required = block.settings.required
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture html_attributes %}data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}{% endcapture %}
{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

{% render '_components.textarea',
    class: textarea_class,
    label: title,
    placeholder: placeholder,
    name: name,
    default_value: default_value,
    html_attributes: html_attributes,
    maxlength: limit_characters,
    required: required
%}

{% schema %}
{
  "name": "Input: Textarea",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Label",
      "default": "First name"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder",
      "default": "First name"
    },
    {
      "type": "text",
      "id": "textarea_class",
      "label": "Textarea class",
      "default": "input-textarea"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "contact[body]"
    },
    {
      "type": "text",
      "id": "default_value",
      "label": "Default value"
    },
    {
      "type": "number",
      "id": "limit_characters",
      "label": "Limit characters"
    },
    {
      "type": "checkbox",
      "id": "required",
      "label": "Required",
      "default": true
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Input: Textarea",
      "category": "** Form **"
    }
  ],
  "tag": null,
  "class": "shopify_block___form__input_textarea"
}
{% endschema %}

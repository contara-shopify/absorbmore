{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_article__comment_cards"
  assign section_type = "main_article"
  assign pagination_size = block.settings.pagination_size
  assign comment_card_class = block.settings.comment_card_class
  assign hydrate_immediately = block.settings.hydrate_immediately
  assign preload_images = block.settings.preload_images
  assign pagination_style = block.settings.pagination_style
  assign pagination_class = block.settings.pagination_class
  assign results_count = block.settings.results_count
  assign results_count_class = block.settings.results_count_class
  assign load_more_button_text = block.settings.load_more_button_text
  assign load_more_button_class = block.settings.load_more_button_class
  assign enable_mouse_dragging = block.settings.enable_mouse_dragging
  assign slider_scroll_snap = block.settings.slider_scroll_snap
  assign slider_overflow_container = block.settings.slider_overflow_container
  assign infinite_scroll = block.settings.infinite_scroll
  assign scrollbar_class = block.settings.scrollbar_class
  assign scroll_pagination_class = block.settings.scroll_pagination_class
  assign custom_css = block.settings.custom_css
  assign hide_if_empty = block.settings.hide_if_empty
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid

  if blog.comments_enabled? != true or article.comments_count <= 0
    assign is_empty = true
  endif

  if is_empty and hide_if_empty != 'none'
    capture hide_conditionally
      if hide_if_empty == 'block'
        echo '<script type="block/hide"></script>'
        assign hide_attribute = 'data-hide-if-empty-block'
      endif
      if hide_if_empty == 'container'
        echo '<script type="container/break"></script>'
        assign hide_attribute = 'data-hide-if-empty-container'
      endif
      if hide_if_empty == 'section'
        echo '<script type="section/break"></script>'
        assign hide_attribute = 'data-hide-if-empty-section'
      endif
    endcapture

    if request.design_mode != true and hide_conditionally contains '<script'
      echo hide_conditionally
      break
    endif
    assign hide_attribute = hide_attribute | append: ' data-block-type="' | append: block_type | append: '"' | append: ' data-block-id="' | append: block.id | append: '"'
  endif

  assign container_spacing = section.settings.container_spacing
  assign order_offset = order_offset | default: 1
  case slider_overflow_container
    when 'all'
      assign slider_overflow = container_spacing | replace: 'px', '-mx' | append: " scroll-" | append: container_spacing | append: " " | append: container_spacing
    when 'mobile'
      assign slider_overflow = container_spacing | replace: 'px', 'max-md:-mx' | append: " max-md:scroll-" | append: container_spacing | append: " max-md:" | append: container_spacing
    when 'desktop'
      assign slider_overflow = container_spacing | replace: 'px', 'md:-mx' | append: " md:scroll-" | append: container_spacing | append: " md:" | append: container_spacing
  endcase
%}

{% assign comment_section = comment_card_class.schema.value %}

{% paginate article.comments by pagination_size %}
  {% assign results_count = results_count | replace: '[total]', paginate.items %}
  {% assign current_count = paginate.page_size | at_most: paginate.items %}
  {% assign results_count_transformed = results_count | replace: '[count]', current_count %}

  {% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

  <style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

  <section data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }} {{ hide_attribute }}
           class="relative flex flex-col"
           x-data="{ ...utils.initContentSlider($el, $refs.scrollContainer, undefined,`{{ infinite_scroll }}`, undefined, `{{ enable_mouse_dragging }}` === 'true') }"
           x-defer="intersect">
    <div class="grid-container relative grid overflow-x-auto scrollbar-none overflow-y-hidden {{ slider_scroll_snap }} {{ slider_overflow }}"
         x-ref="scrollContainer"
         @resize.window="content_slider.handleResize"
         x-init="$nextTick(() => content_slider.handleResize())"
         @scroll="content_slider.handleScroll"
         @scrollend="content_slider.handleInfiniteScroll"
         data-next-url="{{ paginate.next.url }}">
      {% content_for 'blocks' %}
      {% for comment in article.comments %}
        {% assign order_index = forloop.index0 | plus: order_offset %}
        {% if pagination_style == 'manual' or pagination_style == 'auto' %}
          {% assign order_index = paginate.current_offset | plus: forloop.index0 | plus: order_offset %}
        {% endif %}
        <div class="shrink-0 max-w-full w-full h-full order-[--order]"
             data-render-index="{{ block.id }}--{{ forloop.index0 }}"
             data-comment-handle="{{ comment.handle }}"
             style="--order: {{ order_index | times: 10 }}">
          {% if comment_section != blank %}
            {% assign preload_images_boolean = true %}
            {% if forloop.index0 >= preload_images %}
              {% assign preload_images_boolean = false %}
            {% endif %}
            {% render "card_comment_card._static", comment: comment, section: comment_section, preload_images: preload_images_boolean %}
          {% else %}
            <section class="card-loading comment-card--{{ comment_card_class }}"
                     data-comment-handle="{{ comment.handle }}"
                     data-comment-id="{{ comment.id }}"
                     {% if request.visual_preview_mode or hydrate_immediately %}data-intersected{% endif %}
                     data-card-handle="{{ comment_card_class }}"
                     x-init="$nextTick(() => _sections.hydrateCommentCard($el))"></section>
            <script type="application/json"
                    data-comment-data="{{ comment.id }}">{%- render '_json.comment', comment: comment -%}</script>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    {% case pagination_style %}
      {% when 'classic' %}
        {% if pagination_class != blank %}
          {% render '_components.pagination', class: pagination_class, paginate: paginate, pagination_container_ref: '$refs.scrollContainer' %}
        {% endif %}
      {% when 'manual' %}
        <footer x-show="!!main_article.state.next_url"
                class="flex justify-center items-center flex-col text-center mt-14 gap-4">
          <div class="{{ results_count_class }}"
               x-html="$el.getAttribute('data-results-content').replaceAll('[count]',`${main_article?.state?.count}`)"
               data-results-content="{% render '_input.inline_richtext', content: results_count, escape: true %}">
            {% render '_input.inline_richtext', cont1ent: results_count_transformed %}
          </div>
          <button type="button"
                  :disabled="main_article.state.loading"
                  :class="main_article.state.loading ? 'button-loading' : ''"
                  @click="main_article.loadNextPage()"
                  class="{{ load_more_button_class }} max-md:w-full"
                  x-show="main_article?.state?.count < +`{{ paginate.items }}`">
            {% render '_input.inline_richtext', content: load_more_button_text %}
          </button>
        </footer>
      {% when 'auto' %}
        <div x-show="!!main_article.state.next_url"
             class="p-4"
             x-intersect.margin.1200px="main_article.loadNextPage"
             x-effect="!main_article.state.loading && ($el.getBoundingClientRect().top - window.innerHeight) < 1200 ? main_article.loadNextPage() : null"
        >
          <div class="relative h-12 button-loading">
          </div>
        </div>
    {% endcase %}

    {% if scrollbar_class != blank %}
      {% render '_components.scrollbar', class: scrollbar_class %}
    {% endif %}

    {% if scroll_pagination_class != blank %}
      {% render '_components.scroll_pagination', class: scroll_pagination_class %}
    {% endif %}
  </section>
{% endpaginate %}


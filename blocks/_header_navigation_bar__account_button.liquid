{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_header_navigation_bar__account_button"
  assign section_type = "header_navigation_bar"
  assign icon = block.settings.icon
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<a data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
   class="shrink-0"
   aria-label="Accounts"
   href="/account">
  {% render '_components.icon', icon: icon, class: "w-5 h-5" %}
</a>

{% schema %}
{
  "name": "Account Button",
  "settings": [
    {
      "type": "text",
      "id": "icon",
      "label": "Icon",
      "default": "user"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Account Button",
      "category": "** Navigation Bar **"
    }
  ],
  "tag": null,
  "class": "shopify_block___header_navigation_bar__account_button"
}
{% endschema %}

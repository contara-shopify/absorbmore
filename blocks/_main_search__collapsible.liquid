
{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_search__collapsible"
  assign section_type = "main_search"
  assign show_search_conditionally = block.settings.show_search_conditionally
  assign label = block.settings.label
  assign accordion_class = block.settings.accordion_class
  assign show = block.settings.show
  assign custom_css = block.settings.custom_css
  assign hide_if_empty = block.settings.hide_if_empty
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture container_content %}
  {% capture html_attributes %}data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }} {% endcapture %}
  {% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
  <style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

  {% capture accordion_content %}
    {% content_for 'blocks' %}
  {% endcapture %}
  {% render '_components.collapsible', label: label, content: accordion_content, default_open: show, class: accordion_class, html_attributes: html_attributes %}
{% endcapture %}

{% if container_content contains '<script type="container/break"></script>' %}
  {% break %}
{% endif %}
{{ container_content }}


{% schema %}
{
  "name": "Collapsible",
  "settings": [
    {
      "type": "select",
      "id": "show_search_conditionally",
      "label": "Show conditionally",
      "default": "always",

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_modal_quick_view__close_button"
  assign section_type = "modal_quick_view"
  assign close_icon = block.settings.close_icon
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<button data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
        type="button"
        class="absolute right-4 top-3 z-10 text-theme-text/60 lg:top-4 hf:text-theme-text/90"
        @click="$quickView.show = false">
  <span class="sr-only">Close Drawer</span>
  {% render '_components.icon', icon: close_icon, class: "h-6 shrink-0" %}
</button>

{% schema %}
{
  "name": "Close Button",
  "settings": [
    {
      "type": "text",
      "id": "close_icon",
      "label": "Close icon",
      "default": "x-mark"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Close Button",
      "category": "** Quick View **"
    }
  ],
  "tag": null,
  "class": "shopify_block___modal_quick_view__close_button"
}
{% endschema %}

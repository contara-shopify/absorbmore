{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_product__option__radio"
  assign section_type = "main_product"
  assign legend = block.settings.legend
  assign legend_class = block.settings.legend_class
  assign radio_button_content = block.settings.radio_button_content
  assign radio_button_class = block.settings.radio_button_class
  assign select_on_hover = block.settings.select_on_hover
  assign content_flow = block.settings.content_flow
  assign scrollbar_class = block.settings.scrollbar_class
  assign scroll_pagination_class = block.settings.scroll_pagination_class
  assign sold_out_variants = block.settings.sold_out_variants
  assign quick_view_visibility = block.settings.quick_view_visibility
  assign option_type = block.settings.option_type
  assign match_option_titles = block.settings.match_option_titles
  assign match_option_index = block.settings.match_option_index
  assign match_exact_word = block.settings.match_exact_word
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign product = section.settings.product | default: product
  if section.settings.default_variant_metafield != blank
    assign variant_namespace = section.settings.default_variant_metafield | strip | split: "." | first
    assign variant_key = section.settings.default_variant_metafield | strip | split: "." | last
    assign variant = product.metafields[variant_namespace][variant_key].value | default: variant
  endif

  assign variant = variant | default: product.selected_or_first_available_variant | default: product.variants.first

  if product.variants.first.title == "Default Title" and product.variants.size == 1
    break
  endif

  assign match_options = match_option_titles | split: ","

  if option_type == 'by_name'
    for option in product.options
      assign optionIndex = forloop.index0
      for match_option in match_options
        if match_exact_word
          assign _match_option = match_option | strip
          assign _option = option
        else
          assign _match_option = match_option | strip | downcase
          assign _option = option | downcase
        endif

        if _option == _match_option
          assign _optionIndex = optionIndex
          break
        endif
      endfor
      if _optionIndex != blank
        break
      endif
    endfor

    assign option = product.options_with_values[_optionIndex]

    if option == blank
      break
    endif
  endif

  if option_type == 'by_index'
    assign _optionIndex = match_option_index | minus: 1
    assign option = product.options_with_values[_optionIndex]

    if option == blank
      break
    endif
  endif

  case content_flow
    when "show_all"
      assign container_classes = 'flex-wrap'
    when "truncate"
      assign container_classes = 'overflow-hidden'
    when "overflow"
      assign container_classes = 'overflow-x-auto'
  endcase
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

{% for i in (0..2) %}
  {% liquid
    if option_type == 'fallback_options'
      assign _optionIndex = i
      assign option = product.options_with_values[_optionIndex]
    endif

    if option == blank
      break
    endif

    assign current_value = variant.options[_optionIndex]
    assign content_legend = legend | replace: "[heading]", option.name
    assign current_legend = content_legend | replace: "[value]", current_value | default: option.name
  %}

  {% if forloop.first %}
    <style>
      {{ custom_css | replace: '&', selector | strip_newlines }}
    </style>
  {% endif %}

  <product-option {{ _optionIndex }} {{ option_type }}>
    <div
        data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
        data-quick-view-visibility="{{ quick_view_visibility }}"
        {% if content_flow == 'overflow' %}
          x-data="{ index: +`{{ _optionIndex }}`, hoverValue: '', offset: +`{{ option.values.size }}`, ...utils.initContentSlider($el, $refs.scrollContainer, undefined,`{{ infinite_scroll }}`, +`{{ auto_rotate }}`), show_all_items: true, desktop_display_limit: 9999, mobile_display_limit: 9999 }"
          x-init="$refs.scrollContainer.scrollLeft = ([...$refs.scrollContainer.children]?.find(child=> child?.classList?.contains('active'))?.offsetLeft ?? 0) - 5;"
        {% else %}
          x-data="{ index: +`{{ _optionIndex }}`, hoverValue: '', offset: +`{{ option.values.size }}` }"
        {% endif %}
        x-defer="intersect">
      <legend id="legend-{{ block.id }}--{{ forloop.index0 }}"
              x-ignore
              class="flex w-full max-w-full truncate gap-1 {{ legend_class }}"
              data-legend="{% render '_input.inline_richtext', content: content_legend, escape: true %}"
              x-effect="$el.innerHTML = $el.getAttribute('data-legend').replace('[value]', hoverValue || pdp.selected_options?.[index])">
        {% render '_input.inline_richtext', content: current_legend %}
      </legend>
      <fieldset
          aria-labelledby="legend-{{ block.id }}--{{ forloop.index0 }}"
          x-ignore
          class="relative w-full flex scrollbar-none {{ container_classes }}"
          {% if content_flow == 'overflow' %}
            x-ref="scrollContainer"
            @resize.window="content_slider.handleResize"
            x-init="$nextTick(() => content_slider.handleResize())"
            @scroll="content_slider.handleScroll"
            @scrollend="content_slider.handleInfiniteScroll"
          {% endif %} >
        {% for value in option.values %}
          {% liquid
            if sold_out_variants == 'hide' and value.available != true
              continue
            endif

            assign continue = true

            for v in product.variants
              if v.options[_optionIndex] == value
                unless v.metafields.custom.hide_on_frontend.value
                  assign continue = false
                  break
                endunless
              endif
            endfor

            if continue
              continue
            endif
          %}
          <label
              class="shink-0 !outline-none {{ radio_button_class }} {% if value == current_value %}active{% endif %} {% if value.available != true %}sold-out{% endif %}"
              x-effect="$el.classList.toggle('active', pdp.selected_options[index] === $el.getAttribute('aria-label'))"
              x-show="offset >= +`{{ forloop.index0 }}`"
              {% if select_on_hover %}
                @mouseenter="$data.setProductOption({ index, value: `{{ value }}` })"
              {% endif %}
              aria-label="{{ value }}">
            <input
                type="radio"
                class="sr-only"
                {% if sold_out_variants == 'disable' and value.available != true %}
                  disabled="disabled"
                {% endif %}
                name="{{ block.id }}--{{ forloop.index0 }}"
                @change="$data.setProductOption({ index, value: $el.value })"
                :checked="pdp.selected_options?.[index] === $el.value"
                value="{{ value }}">
            <span>
              {% assign value_content = radio_button_content | replace: "[value]", value %}
              {% render '_input.inline_richtext', content: value_content %}
            </span>
          </label>
        {% endfor %}
        {% if content_flow == 'truncate' %}
          <div class="flex shrink-0 items-center text-sm font-medium"
               x-cloak
               x-show="true"
               :class="(offset + 1) < +`{{ option.values.size }}` ? '':'opacity-0 pointer-events-none'"
               x-init="$nextTick(async ()=> { if (window.design_mode) { await utils.delay(20) } offset = utils.truncateChildren($el, $el.parentElement)})"
               @resize.window.debounce.200ms="offset = +`{{ option.values.size }}`; await utils.delay(20); offset = utils.truncateChildren($el, $el.parentElement)"
               x-html="`+ ${+`{{ option.values.size }}` - (offset + 1)} {{ option.name }}`">
            +10 {{ option.name }}
          </div>
        {% endif %}
      </fieldset>
      {% if content_flow == 'overflow' %}
        {% if scrollbar_class != blank %}
          {% render '_components.scrollbar', class: scrollbar_class %}
        {% endif %}
        {% if scroll_pagination_class != blank %}
          {% render '_components.scroll_pagination', class: scroll_pagination_class %}
        {% endif %}
      {% endif %}
    </div>
  </product-option>

  {% if option_type != 'fallback_options' %}
    {% break %}
  {% endif %}
{% endfor %}

{% schema %}
{

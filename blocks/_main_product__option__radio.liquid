      "default": "button-primary-sm"
    },
    {
      "type": "checkbox",
      "id": "select_on_hover",
      "label": "Select on hover"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",

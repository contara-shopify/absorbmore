{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "countdown"
  assign type = block.settings.type
  assign timezone = block.settings.timezone
  assign end_date = block.settings.end_date
  assign end_time = block.settings.end_time
  assign duration_offset_hours = block.settings.duration_offset_hours
  assign auto_refresh_hours = block.settings.auto_refresh_hours
  assign content = block.settings.content
  assign timer_expired_message = block.settings.timer_expired_message
  assign content_class = block.settings.content_class
  assign hide_if_expired = block.settings.hide_if_expired
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

{% capture block_settings %}
  {
  "type": {{ type | json }},
  "timezone": {{ timezone | json }},
  "end_date": {{ end_date | json }},
  "end_time": {{ end_time | json }},
  "duration_offset_hours": {{ duration_offset_hours | json }},
  "auto_refresh_hours": {{ auto_refresh_hours | json }},
  "content": "{% render '_input.inline_richtext', content: content, escape_quotes: true %}",
  "timer_expired_message": "{% render '_input.inline_richtext', content: timer_expired_message, escape_quotes: true %}",
  "hide_if_expired": {{ hide_if_expired | json }},
  "block_id": {{ block.id | json }}
  }
{% endcapture %}

<span data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
      x-data="{ ...window._sections.initCountDownTimer($el, utils.JSONParse($el.getAttribute('data-settings'))) }"
      data-settings='{{ block_settings | strip_newlines | escape }}'
      x-html="countdown.content"
      class="inline-block {{ block.settings.content_class }}">
</span>

{% schema %}
{
  "name": "Countdown",
  "settings": [
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "select",
      "id": "type",
      "label": "Type",
      "default": "date",
      "options": [
        {
          "value": "date",
          "label": "Date"
        },
        {
          "value": "duration_offset",
          "label": "Duration offset"
        }
      ]
    },
    {
      "type": "select",
      "id": "timezone",
      "label": "Timezone (UTC Offset)",
      "options": [
        {
          "value": "user",
          "label": "User Based Timezone"
        },
        {
          "value": "-12",
          "label": "(GMT-12:00) Baker Island"
        },
        {
          "value": "-11",
          "label": "(GMT-11:00) American Samoa"
        },
        {
          "value": "-10",
          "label": "(GMT-10:00) Hawaii"
        },
        {
          "value": "-9",
          "label": "(GMT-09:00) Alaska"
        },
        {
          "value": "-8",
          "label": "(GMT-08:00) Pacific Time (US & Canada)"
        },
        {
          "value": "-7",
          "label": "(GMT-07:00) Mountain Time (US & Canada)"
        },
        {
          "value": "-6",
          "label": "(GMT-06:00) Central Time (US & Canada)"
        },
        {
          "value": "-5",
          "label": "(GMT-05:00) Eastern Time (US & Canada)"
        },
        {
          "value": "-4",
          "label": "(GMT-04:00) Atlantic Time (Canada)"
        },
        {
          "value": "-3",
          "label": "(GMT-03:00) Buenos Aires"
        },
        {
          "value": "-2",
          "label": "(GMT-02:00) South Georgia"
        },
        {
          "value": "-1",
          "label": "(GMT-01:00) Azores"
        },
        {
          "value": "0",
          "label": "(GMT+00:00) UTC / London"
        },
        {
          "value": "1",
          "label": "(GMT+01:00) Central European Time"
        },
        {
          "value": "2",
          "label": "(GMT+02:00) Eastern European Time"
        },
        {
          "value": "3",
          "label": "(GMT+03:00) Moscow"
        },
        {
          "value": "4",
          "label": "(GMT+04:00) Dubai"
        },
        {
          "value": "5",
          "label": "(GMT+05:00) Pakistan"
        },
        {
          "value": "5.5",
          "label": "(GMT+05:30) India Standard Time"
        },
        {
          "value": "6",
          "label": "(GMT+06:00) Bangladesh"
        },
        {
          "value": "7",
          "label": "(GMT+07:00) Indochina Time"
        },
        {
          "value": "8",
          "label": "(GMT+08:00) China Standard Time"
        },
        {
          "value": "9",
          "label": "(GMT+09:00) Japan/Korea Standard Time"
        },
        {
          "value": "10",
          "label": "(GMT+10:00) Australian Eastern Time"
        },
        {
          "value": "11",

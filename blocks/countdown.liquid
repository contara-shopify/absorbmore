          "label": "(GMT+12:00) New Zealand Standard Time"
        }
      ],
      "default": "-5",
      "visible_if": "{{ block.settings.type == 'date' }}"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End Date",
      "default": "2025-12-31",
      "info": "Use format: YYYY-MM-DD",
      "visible_if": "{{ block.settings.type == 'date' }}"
    },
    {
      "type": "text",
      "id": "end_time",
      "label": "End Time",
      "default": "23:59:59",
      "info": "Use format: HH:MM:SS",
      "visible_if": "{{ block.settings.type == 'date' }}"
    },
    {
      "type": "range",
      "id": "duration_offset_hours",
      "label": "Duration (hours)",
      "default": 48,
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "h",
      "info": "Length of the countdown after a visitor first sees it.",
      "visible_if": "{{ block.settings.type == 'duration_offset' }}"
    },
    {
      "type": "range",
      "id": "auto_refresh_hours",
      "label": "Restart delay (hours)",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "h",
      "info": "Wait time before the countdown restarts. Set to 0 to disable auto-restart."
    },

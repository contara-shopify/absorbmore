{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_modal_search__search_input"
  assign section_type = "modal_search"
  assign label = block.settings.label
  assign placeholder = block.settings.placeholder
  assign input_class = block.settings.input_class
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<form data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
      action="{{ routes.search_url }}">
  {% render '_components.input',
      name: 'q',
      type: 'search',
      label: label,
      placeholder: placeholder,
      autocomplete: 'off',
      inline_button: true,
      button_content: '',
      class: input_class,
      setState: '$search.query = value',
      suffix: '[icon.search]',
      default_value: default_value,
      value: '$search.query',
      onFocus: "",
      onBlur: "if (!$search.query) { setTimeout(() => { hasFocus = false }, 300) }; "
  %}
</form>

{% schema %}
{
  "name": "Search Input",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder"
    },
    {
      "type": "text",
      "id": "input_class",
      "label": "Input class"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Search Input",
      "category": "Interactive"
    }
  ],
  "tag": null,
  "class": "shopify_block___modal_search__search_input"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_modal_search__static_search_suggestion"
  assign section_type = "modal_search"
  assign show_search_conditionally = block.settings.show_search_conditionally
  assign label = block.settings.label
  assign button_class = block.settings.button_class
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<a data-style-id="{{ section.id }}--{{ block.id }}"{{ block.shopify_attributes }}
   class="flex {{ button_class }}"
   data-search-suggestion
   tabindex="-1"
   data-barba-prevent="self"
   :class="search_modal.state.active_query === `{{ label }}` ? 'active' : ''"
   @pointerenter="search_modal.state.active_query = `{{ label }}`"
   @focus.stop.prevent="search_modal.state.active_query = `{{ label }}`"
   href="{{ routes.search_url }}?q={{ label }}">{{ label }}</a>

{% schema %}
{
  "name": "Static Search Suggestion",
  "settings": [
    {
      "type": "select",
      "id": "show_search_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "no_search_query",
          "label": "No Search Query"
        },
        {
          "value": "with_search_query",
          "label": "With Search Query"
        },
        {
          "value": "search_empty",
          "label": "Empty"
        },
        {
          "value": "items_found",
          "label": "With Items"
        }
      ]
    },
    {
      "type": "inline_richtext",
      "id": "label",
      "label": "Label",
      "default": "snowdrop",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button class",
      "default": "button-primary"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Static Search Suggestion",
      "category": "** Search Modal **"
    }
  ],
  "tag": null,
  "class": "shopify_block___modal_search__static_search_suggestion"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_search__dynamic_text"
  assign section_type = "main_search"
  assign show_search_conditionally = block.settings.show_search_conditionally
  assign content = block.settings.content
  assign text_alignment = block.settings.text_alignment
  assign content_class = block.settings.content_class
  assign text_color = block.settings.text_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign content = content | replace: '[search.terms]', search.terms | replace: '[search.results_count]', search.results_count
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank and text_color.alpha != 0 %}{% capture css %}& { color: {{ text_color }}; }{% endcapture %}{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

<div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
     class="relative {{ text_alignment | prepend: 'text-' }}"
  {% if show_search_conditionally == 'search_empty' and search.results_count > 0 %}x-cloak{% endif %}
  {% if show_search_conditionally == 'items_found' and search.results_count <= 0 %}x-cloak{% endif %}
     x-show="main_search.showConditionally(`{{ show_search_conditionally }}`) || $editor.select_block_id === `{{ block.id }}`">
  {% render '_input.richtext', content: content, class: content_class %}
</div>


{% schema %}
{
  "name": "Dynamic Text",
  "settings": [
    {
      "type": "select",
      "id": "show_search_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "no_search_query",
          "label": "No Search Query"
        },
        {
          "value": "with_search_query",
          "label": "With Search Query"
        },
        {
          "value": "search_empty",
          "label": "Empty"
        },
        {
          "value": "items_found",
          "label": "With Items"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<h1>Search results for \"[search.terms]\"</h1>",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use [search.terms] as a placeholder for the search term and [search.results_count] as a placeholder for the results count."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Auto"
        },
        {
          "value": "left",
          "label": "←"
        },
        {
          "value": "center",
          "label": "↔"
        },
        {
          "value": "right",
          "label": "→"
        }
      ]
    },
    {
      "type": "text",
      "id": "content_class",
      "label": "Content class",
      "default": "richtext-md"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Dynamic Text",
      "category": "** Search **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_search__dynamic_text"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_bundle__bundle_selector"
  assign section_type = "bundle"
  assign type = block.settings.type
  assign select_class = block.settings.select_class
  assign discount_label = block.settings.discount_label
  assign price_content = block.settings.price_content
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% capture css %}
  & {
  color: {{ text_color }};
  background-color: {{ background_color }};
  }
{% endcapture %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>


<div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
     data-select-settings="{{ block.settings | json | escape }}">
  {% content_for 'blocks' %}

  {% if block.blocks.size > 1 and block.settings.type == 'manual' %}
    {% render '_components.select',
        dynamic: true,
        values: 'bundle_targets?.map(item => item?.id)',
        titles: 'bundle.bundle_target_titles',
        disabled_items: '[...bundle_targets].sort((a,b) => a?.settings?.target - b?.settings?.target)?.map((item, i, arr) => item?.settings?.target < bundle?.items_added?.length && i !== arr.length -1)',
        select_class: select_class,
        label: 'Bundle Targets',
        setState: 'updateBundleById(value);',
        state: 'bundle.bundle_target_id',
        current_value: 'bundle.bundle_target_id',
        current_title: 'bundle.bundle_target_titles?.[bundle_targets?.findIndex(item => item.id === bundle?.bundle_target_id)]'
    %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Bundle Selector",
  "settings": [
    {
      "type": "select",
      "id": "type",
      "label": "Type",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "Automatic"
        },
        {
          "value": "manual",
          "label": "Manual Select"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "This Block will only show if at least 2 `bundle targets` are configured.",
      "visible_if": "{{ block.settings.type == 'manual' }}"
    },
    {
      "type": "text",
      "id": "select_class",
      "label": "Select class",
      "default": "input-select",
      "visible_if": "{{ block.settings.type == 'manual' }}"
    },
    {
      "type": "text",
      "id": "discount_label",
      "label": "Discount label",
      "default": "label-primary-sm",
      "info": "Keep the label empty to hide the discount preview.",
      "visible_if": "{{ block.settings.type == 'manual' }}"
    },
    {
      "type": "inline_richtext",
      "id": "price_content",
      "label": "Price content",
      "default": "From [compare_at_price] <strong>[price]</strong>",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use [compare_at_price] and [price] as placeholders for the lowest possible prices based on items added.",
      "visible_if": "{{ block.settings.type == 'manual' }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n        }"
    }
  ],
  "blocks": [
    {
      "type": "_bundle__bundle_target"
    }
  ],
  "presets": [
    {
      "name": "Bundle Selector",
      "category": "Interactive"
    }
  ],
  "tag": null,
  "class": "shopify_block___bundle__bundle_selector"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_account__addresses"
  assign section_type = "main_account"
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
  {% capture css %}
    & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    }
  {% endcapture %}
{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

{% paginate customer.addresses by 1000 %}
  <div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}>
    <div class="grid gap-4 lg:grid-cols-3 md:grid-cols-2">
      {% assign address = customer.default_address %}

      {%- for address in customer.addresses -%}
        {%- if address.id != customer.default_address.id -%}
          {%- continue -%}
        {%- endif -%}
        <section class="flex h-full flex-col px-6 py-4 text-sm">
          <header class="mb-2 font-semibold uppercase tracking-wide">Default Address</header>
          <div>
            {{- address | format_address -}}
          </div>
          <footer class="mt-2 flex flex-1 items-end gap-3 text-13 uppercase text-primary-outline">
            <button type="button"
                    @click="$modal.setId('address--{{ address.id }}')">
              Edit
            </button>
            <form method="post"
                  action="/account/addresses/{{ address.id }}"
            >
              <input type="hidden"
                     name="_method"
                     value="delete"
                     data-address-delete="{{ address.id }}">
              <button type="submit">Delete</button>
            </form>
          </footer>
        </section>
        {% render 'main_account.address_modal', address: address %}
      {% endfor %}

      {%- assign address_count = paginate.current_offset | plus: 2 -%}

      {%- for address in customer.addresses -%}
        {%- if address.id == customer.default_address.id -%}
          {%- continue -%}
        {%- endif -%}

        <section class="flex h-full flex-col px-6 py-4 text-sm">
          <header class="mb-2 font-semibold uppercase tracking-wide">Address {{ address_count }}</header>
          <div>
            {{- address | format_address -}}
          </div>
          <footer class="mt-2 flex flex-1 items-end gap-3 text-13 uppercase text-primary-outline">
            <button type="button"
                    @click="$modal.setId('address--{{ address.id }}')">
              Edit
            </button>
            <form method="post"
                  action="/account/addresses/{{ address.id }}">
              <input type="hidden" name="_method" value="delete" data-address-delete="{{ address.id }}">
              <button type="submit">Delete</button>
            </form>
          </footer>
        </section>

        {%- assign address_count = address_count | plus: 1 -%}
        {% render 'main_account.address_modal', address: address %}
      {%- endfor -%}
    </div>
  </div>
{% endpaginate %}

{% schema %}
{
  "name": "Addresses",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Addresses",
      "category": "** Account **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_account__addresses"
}
{% endschema %}

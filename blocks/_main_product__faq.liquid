{% style %}
  [data-component-faq] {
    margin-top: 15px;
    grid-column: span 2;
  }

  .faq-accordion {
    width: 100%;
    font-family: "Inter", -apple-system, sans-serif;
  }

  .faq-item {
    border-bottom: 1px solid #d0ccc3;
  }

  .faq-item:first-child {
    border-top: 1px solid #d0ccc3;
  }

  .faq-trigger {
    width: 100%;
    min-height: 49px;
    padding: 14px 0 15px;
    border: 0;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    text-align: left;
    color: #1a1a1a;
    cursor: pointer;
  }

  .faq-label {
    font-family: var(--typography-family-tertiary, "Suisse Intl");
    font-size: var(--typography-richtext-md-p1, 16px);
    font-style: normal;
    font-weight: 500;
    line-height: 140%;
  }

  .faq-icon {
    position: relative;
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  .faq-icon::before,
  .faq-icon::after {
    content: "";
    position: absolute;
    background: #1a1a1a;
    border-radius: 1px;
  }

  .faq-icon::before {
    top: 7px;
    left: -1.5px;
    width: 18px;
    height: 1.5px;
  }

  .faq-icon::after {
    top: -1.5px;
    left: 7px;
    width: 1.5px;
    height: 18px;
    opacity: 1;
  }

  .faq-item.is-open .faq-icon::after {
    opacity: 0;
  }

  .faq-icon span {
    display: none;
  }

  .faq-panel {
    display: none;
    padding: 0 0 14px;
    font-family: "Suisse Intl", Sans-Serif;
    font-size: var(--typography-richtext-md-p1, 16px);
    font-style: normal;
    font-weight: 400;
    line-height: 140%;
    letter-spacing: -0.16px;
    color: #6a6a6a;
  }

  .faq-item.is-open .faq-panel {
    display: block;
  }

  .faq-panel p {
    margin: 0;
  }

  .faq-panel p + p {
    margin-top: 0;
  }

  .faq-panel strong {
    color: #1a1a1a;
    font-weight: 600;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .faq-label {
      font-size: 13px;
    }

    .faq-panel {
      font-size: 11px;
    }
  }
{% endstyle %}

<div data-component-faq data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="component component--faq">
    <div class="faq-accordion" data-faq-accordion>
      {% for i in (1..8) %}
        {% liquid
          assign question_key = 'question_' | append: i
          assign answer_key = 'answer_' | append: i
          assign question_value = block.settings[question_key]
          assign answer_value = block.settings[answer_key]
        %}
        {% if question_value != blank %}
          {% assign panel_id = 'faq-panel-' | append: section.id | append: '-' | append: block.id | append: '-' | append: i %}
          <div class="faq-item{% if i == 1 %} is-open{% endif %}" data-faq-item>
            <button
              class="faq-trigger"
              type="button"
              aria-controls="{{ panel_id }}"
              aria-expanded="{% if i == 1 %}true{% else %}false{% endif %}"
              data-faq-trigger
            >
              <span class="faq-label">{{ question_value | escape }}</span>
              <i data-animated-icon="" class="faq-icon relative flex shrink-0 items-center justify-center h-2.5 w-2.5" aria-hidden="true">
                <span class="absolute rounded-full bg-current transition-all duration-200 h-0.5 w-2.5 rotate-0" :class="collapsible.open_accordion &amp;&amp; !collapsible.closing ? 'rotate-0' : '-rotate-180'"></span>
                <span class="absolute origin-center rounded-full bg-current transition-all h-0.5 w-2.5 rotate-0" :class="collapsible.open_accordion &amp;&amp; !collapsible.closing ? 'rotate-0' : '-rotate-90'"></span>
              </i>
            </button>
            {% if answer_value != blank %}
              <div
                id="{{ panel_id }}"
                class="faq-panel"
                role="region"
                aria-label="{{ question_value | escape }}"
                {% if i != 1 %}hidden{% endif %}
                data-faq-panel
              >
                {{ answer_value }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (() => {
    const root = document.querySelector('[data-component-faq][data-style-id="{{ section.id }}--{{ block.id }}"]');
    if (!root) return;

    const triggers = root.querySelectorAll('[data-faq-trigger]');
    if (!triggers.length) return;

    const closeItem = (item) => {
      if (!item) return;

      item.classList.remove('is-open');

      const trigger = item.querySelector('[data-faq-trigger]');
      if (trigger) trigger.setAttribute('aria-expanded', 'false');

      const panel = item.querySelector('[data-faq-panel]');
      if (!panel) return;
      panel.hidden = true;
    };

    const openItem = (item) => {
      if (!item) return;

      item.classList.add('is-open');

      const trigger = item.querySelector('[data-faq-trigger]');
      if (trigger) trigger.setAttribute('aria-expanded', 'true');

      const panel = item.querySelector('[data-faq-panel]');
      if (!panel) return;
      panel.hidden = false;
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('[data-faq-item]');
        if (!item) return;

        if (item.classList.contains('is-open')) {
          closeItem(item);
          return;
        }

        root.querySelectorAll('[data-faq-item].is-open').forEach(closeItem);
        openItem(item);
      });
    });
  })();
</script>


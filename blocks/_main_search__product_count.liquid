{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_search__product_count"
  assign section_type = "main_search"
  assign show_search_conditionally = block.settings.show_search_conditionally
  assign content = block.settings.content
  assign singular_name = block.settings.singular_name
  assign plural_name = block.settings.plural_name
  assign content_class = block.settings.content_class
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

{% if search.results_count == 1 %}
  {% assign content = content | replace: '[count]', search.results_count | replace: '[name]', singular_name %}
{% else %}
  {% assign content = content | replace: '[count]', search.results_count | replace: '[name]', plural_name %}
{% endif %}

<div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }} class="{{ content_class }}">
  {% render '_input.inline_richtext', content: content %}
</div>

{% schema %}
{
  "name": "Filtered Product Count",
  "settings": [
    {
      "type": "select",
      "id": "show_search_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "no_search_query",
          "label": "No Search Query"
        },
        {
          "value": "with_search_query",
          "label": "With Search Query"
        },
        {
          "value": "search_empty",
          "label": "Empty"
        },
        {
          "value": "items_found",
          "label": "With Items"
        }
      ]
    },
    {
      "type": "inline_richtext",
      "id": "content",
      "label": "Content",
      "default": "[count] [name]",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use [count] and [name] as placeholders for the count and name based on the quantity."
    },
    {
      "type": "text",
      "id": "singular_name",
      "label": "Singular name",
      "default": "product"
    },
    {
      "type": "text",
      "id": "plural_name",
      "label": "Plural name",
      "default": "products"
    },
    {
      "type": "text",
      "id": "content_class",
      "label": "Content class",
      "default": "richtext-md p"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Filtered Product Count",
      "category": "** Search **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_search__product_count"
}
{% endschema %}

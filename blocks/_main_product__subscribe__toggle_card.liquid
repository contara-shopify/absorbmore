  "settings": [
    {
      "type": "inline_richtext",
      "id": "label",
      "label": "Label",
      "info": "Accepts [value] as placeholders to show potential savings based on a set percentage or a fixed amount as set your Subscription App settings."
    },
    {
      "type": "text",
      "id": "label_class",
      "label": "Label class",
      "default": "richtext-md"
    },
    {
      "type": "inline_richtext",
      "id": "savings_label",
      "label": "Savings label",
      "info": "Accepts [value] as placeholders to show potential savings based on a set percentage or a fixed amount as set your Subscription App settings."
    },
    {
      "type": "text",
      "id": "savings_label_class",
      "label": "Savingss label class",
      "default": "label-secondary"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Price"
    },
    {
      "type": "text",
      "id": "price_class",
      "label": "Price class",
      "default": "richtext-md font-bold"
    },
    {
      "type": "text",
      "id": "compare_at_price_class",
      "label": "Compare Price class",
      "default": "richtext-md h6"
    },
    {
      "type": "select",
      "id": "price_calculation",

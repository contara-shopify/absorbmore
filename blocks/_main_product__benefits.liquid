{% style %}
  :root {
    --component_benefits_white:    #FFFFFF;
    --component_benefits_black:    #111111;
    --component_benefits_dark:     #1A1A1A;
    --component_benefits_light:    #888888;
    --component_benefits_lighter:  #AAAAAA;
    --component_benefits_border:   #D5D1C8;
  }

  [data-component-benefits] {
    grid-column: span 2;
    display: flex;
    justify-content: flex-end;
  }

  /* Benefits section */
  .benefits-section {
    overflow: hidden;
    background: var(--component_benefits_white);
    border: 1px solid var(--component_benefits_border);
    border-radius: 8px;
  }

  .benefits-header {
    padding: 14px 20px 12px;
    background-color: {{ block.settings.header_background_color | default: '#5E91D5' }};
    border-bottom: 1px solid var(--component_benefits_border);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ block.settings.header_title_color | default: '#ffffff' }};
  }

  .benefits-list {
    padding: 6px 0;
  }

  .benefit-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 13px 20px;
    border-bottom: 1px solid var(--component_benefits_border);
  }

  .benefit-row:last-child { border-bottom: none; }

  .check-circle {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--component_benefits_black);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .check-circle svg {
    width: 10px;
    height: 10px;
  }

  .benefit-text {
    flex: 1;
  }

  .benefit-title {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--component_benefits_dark);
    margin-bottom: 2px;
    line-height: 1.3;
  }

  .benefit-sub {
    font-size: 12px;
    color: var(--component_benefits_light);
    line-height: 1.45;
    font-weight: 400;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .benefits-header {
      font-size: 10px;
    }

    .benefit-title {
      font-size: 13px;
    }

    .benefit-sub {
      font-size: 11px;
    }
  }
{% endstyle %}

<div data-component-benefits data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="component component--benefits">
    <div class="benefits-section">
      <div class="benefits-header">{{ block.settings.heading | escape }}</div>
      <div class="benefits-list">
        {% if block.settings.benefit_1_title != blank %}
          <div class="benefit-row">
            <div class="check-circle">
              <svg viewBox="0 0 10 8" fill="none">
                <polyline points="1,4 3.5,6.5 9,1" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="benefit-text">
              <div class="benefit-title">{{ block.settings.benefit_1_title | escape }}</div>
              <div class="benefit-sub">{{ block.settings.benefit_1_sub | escape }}</div>
            </div>
          </div>
        {% endif %}
        {% if block.settings.benefit_2_title != blank %}
          <div class="benefit-row">
            <div class="check-circle">
              <svg viewBox="0 0 10 8" fill="none">
                <polyline points="1,4 3.5,6.5 9,1" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="benefit-text">
              <div class="benefit-title">{{ block.settings.benefit_2_title | escape }}</div>
              <div class="benefit-sub">{{ block.settings.benefit_2_sub | escape }}</div>
            </div>
          </div>
        {% endif %}
        {% if block.settings.benefit_3_title != blank %}
          <div class="benefit-row">
            <div class="check-circle">
              <svg viewBox="0 0 10 8" fill="none">
                <polyline points="1,4 3.5,6.5 9,1" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="benefit-text">
              <div class="benefit-title">{{ block.settings.benefit_3_title | escape }}</div>
              <div class="benefit-sub">{{ block.settings.benefit_3_sub | escape }}</div>
            </div>
          </div>
        {% endif %}
        {% if block.settings.benefit_4_title != blank %}
          <div class="benefit-row">
            <div class="check-circle">
              <svg viewBox="0 0 10 8" fill="none">
                <polyline points="1,4 3.5,6.5 9,1" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="benefit-text">
              <div class="benefit-title">{{ block.settings.benefit_4_title | escape }}</div>
              <div class="benefit-sub">{{ block.settings.benefit_4_sub | escape }}</div>
            </div>
          </div>
        {% endif %}
        {% if block.settings.benefit_5_title != blank %}
          <div class="benefit-row">
            <div class="check-circle">
              <svg viewBox="0 0 10 8" fill="none">
                <polyline points="1,4 3.5,6.5 9,1" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="benefit-text">
              <div class="benefit-title">{{ block.settings.benefit_5_title | escape }}</div>
              <div class="benefit-sub">{{ block.settings.benefit_5_sub | escape }}</div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>


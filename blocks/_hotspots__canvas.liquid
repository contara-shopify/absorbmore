{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_hotspots__canvas"
  assign section_type = "hotspots"
  assign image = block.settings.image
  assign mobile_image = block.settings.mobile_image
  assign show_overlay = block.settings.show_overlay
  assign overlay_color = block.settings.overlay_color
  assign preload = block.settings.preload
  assign sizes = block.settings.sizes
  assign max_width = block.settings.max_width
  assign mobile_max_width = block.settings.mobile_max_width
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  if image.presentation.focal_point
    assign focalPointStyle = 'object-position: ' | append: image.presentation.focal_point | append: ';'
  endif
%}
{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

{% if show_overlay %}
  {% capture css %}
    &:after {
    content: '';
    position: absolute;
    inset: 0;
    background: {{ overlay_color }};
    pointer-events: none;
    }
  {% endcapture %}
{% endif %}

<style>{{ css | append: custom_css | replace: '&', selector | strip_newlines }}</style>

<figure data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
        data-hotspot-canvas
        class="image-wrapper block relative shrink-0">
  {% render '_object.image', image: image, mobile_image: mobile_image, class: "w-full h-full relative transition-all object-[inherit] rounded-[inherit]", preload: preload, sizes: sizes, max_width: max_width, mobile_max_width: mobile_max_width %}
  <figcaption class="absolute z-10 pointer-events-none top-0 left-0 aspect-[--img-ar] translate-x-[--offset-x] translate-y-[--offset-y] will-change-transform w-full h-auto [.fit-height>&]:w-auto [.fit-height>&]:h-full opacity-0 transition-opacity duration-200"
              x-init="$el.classList.remove('opacity-0', 'transition-opacity','duration-200')"
              style="aspect-ratio: {{ image.aspect_ratio }};">
    {% content_for 'blocks' %}
  </figcaption>
</figure>


{% schema %}
{
  "name": "Canvas",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image (optional)"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay"
    },
    {
      "type": "color_background",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "linear-gradient(to bottom, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.25) 100%)",
      "visible_if": "{{ block.settings.show_overlay == true }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Image Performance Optimization"
    },
    {
      "type": "checkbox",
      "id": "preload",
      "label": "Preload",
      "info": "Activate this for any image that should show immediately on page view (Above the fold content)."
    },
    {
      "type": "text",
      "id": "sizes",
      "label": "Sizes",
      "default": "(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 48vw"
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Max Width",
      "default": 1200
    },
    {
      "type": "number",
      "id": "mobile_max_width",
      "label": "Mobile Max Width",
      "default": 1200,
      "visible_if": "{{ block.settings.mobile_image != blank }}"
    },
    {
      "type": "paragraph",
      "content": "Ready more about the [sizes](https://web.dev/learn/performance/image-performance#sizes) attribute and [Image optimization](https://www.shopify.com/za/blog/image-sizes)."
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "blocks": [
    {
      "type": "_hotspots__hotspot"
    }
  ],
  "presets": [
    {
      "name": "Canvas",
      "category": "** Hotspots **"
    }
  ],
  "tag": null,
  "class": "shopify_block___hotspots__canvas"
}
{% endschema %}

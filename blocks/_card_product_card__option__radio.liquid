{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_card_product_card__option__radio"
  assign section_type = "card_product_card"
  assign legend = block.settings.legend
  assign legend_class = block.settings.legend_class
  assign radio_button_content = block.settings.radio_button_content
  assign radio_button_class = block.settings.radio_button_class
  assign select_on_hover = block.settings.select_on_hover
  assign content_flow = block.settings.content_flow
  assign truncate_text = block.settings.truncate_text
  assign sold_out_variants = block.settings.sold_out_variants
  assign option_type = block.settings.option_type
  assign match_option_titles = block.settings.match_option_titles
  assign match_option_index = block.settings.match_option_index
  assign match_exact_word = block.settings.match_exact_word
  assign custom_css = block.settings.custom_css
  assign show_conditionally = block.settings.show_conditionally
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign content_legend = legend | replace: "[heading]", legend_label
  case content_flow
    when "show_all"
      assign container_classes = 'flex-wrap'
    when "truncate"
      assign container_classes = 'overflow-hidden'
    when "overflow"
      assign container_classes = 'overflow-x-auto'
  endcase
%}

{% if request.design_mode or metaobjects.product_cards[section.settings.product_card] == blank %}
  {% capture selector %}[data-style-id="{{ block.id | split: "__" | last }}"]{% endcapture %}

  <style>
    {{ custom_css | replace: '&', selector | strip_newlines }}
    {% if request.design_mode %}
    {% assign query_selector = '[data-section-id="'|append: section.id | append: '"][data-preview-container] ' | append: selector %}
    {{- custom_css | replace: '&', query_selector  | strip_newlines | replace: '@media screen and', '@container'| replace: '@media', '@container' -}}
    {% endif %}
  </style>
{% endif %}

{% capture option_settings %}
  {
  "block_id": "{{ block.id }}__0",
  "option_type": {{ option_type | json }},
  "match_option_index": {{ match_option_index | minus: 1 | json }},
  "match_option_titles": {{ match_option_titles | json }},
  "match_exact_word": {{ match_exact_word | json }}
  }
{% endcapture %}

{% for i in (0..2) %}
  {% if option_type == 'fallback_options' %}
    {% capture option_settings %}
      {
      "block_id": "{{ block.id }}__{{ i }}",
      "option_type": {{ option_type | json }},
      "match_option_index": {{ i | json }},
      "match_option_titles": {{ match_option_titles | json }},
      "match_exact_word": {{ match_exact_word | json }}
      }
    {% endcapture %}
  {% endif %}
  <div
      data-style-id="{{ block.id | split: "__" | last }}" {{ block.shopify_attributes }}
      @click.stop="()=>{}"
      data-options-block="{{ option_settings | escape }}"
      x-data="{ hoverValue: '', index: getOptionIndex(`{{ block.id }}__{{ i }}`)}"
      x-effect="() => { if (p_card?.product?.id) { index = getOptionIndex(`{{ block.id }}__{{ i }}`) } }"
      x-cloak
      {% if sold_out_variants == 'hide' %}
        x-show="p_card?.hydrated && index !== -1 && p_card?.product?.options_with_values?.[index]?.values?.some(value => hasAvailableVariant(index, value)) && p_card?.product?.variants?.length && p_card?.product?.variants?.[0]?.title !== 'Default Title' && p_card?.selected_variant?.id && ($editor.select_block_id === `{{ block.id }}` || $data.showConditionally('{{ show_conditionally }}', $data?.bundle))"
      {% else %}
        x-show="p_card?.hydrated && index !== -1 && p_card?.product?.variants?.length && p_card?.product?.variants?.[0]?.title !== 'Default Title' && p_card?.selected_variant?.id && ($editor.select_block_id === `{{ block.id }}` || $data.showConditionally('{{ show_conditionally }}', $data?.bundle))"
      {% endif %}
      x-ignore>
    <legend class="flex w-full max-w-full truncate {{ legend_class }}"
            data-legend="{% render '_input.inline_richtext', content: legend, escape: true %}"
            x-effect="$el.innerHTML = $el.getAttribute('data-legend').replace('[heading]',p_card?.product?.options?.[index]).replace('[value]', hoverValue || p_card?.selected_options?.[index])">
    </legend>
    <fieldset class="relative w-full flex scrollbar-none {{ container_classes }}"
              x-data="{ offset: p_card?.product?.options_with_values?.[index]?.values?.length }">
      <template x-for="value in p_card?.product?.options_with_values?.[index]?.values.slice(0, offset)">
        <label data-loop-item class="shrink-0 !outline-none {{ radio_button_class }}"
               x-effect="$el.classList.toggle('active', p_card?.selected_options[index] === value)"
            {% if sold_out_variants == 'hide' %}
              x-show="hasAvailableVariant(index, value)"
            {% endif %}
               :class="hasAvailableVariant(index, value) ? '' : 'sold-out'"
            {% if select_on_hover %}
              @mouseenter="$data.setProductOption({ index, value })"
            {% endif %}
               @pointerenter="hoverValue = `${value}`"
               @pointerleave="hoverValue = ''"
               :aria-label="value">
          <input type="radio"
                 class="sr-only"
              {% if sold_out_variants == 'disable' %}
                :disabled="!hasAvailableVariant(index, value)"
              {% endif %}
                 :name="`${p_card?.random_id}-${p_card?.product?.id}-${p_card?.product?.options[index]}-option__radio`"
                 @change="$data.setProductOption({ index, value })"
                 :checked="p_card?.selected_options[index] === value"
                 :value="value">
          <span x-text="$el.getAttribute('data-content')?.replaceAll('[value]', value)"
                data-content="{% render '_input.inline_richtext', content: radio_button_content %}"></span>
        </label>
      </template>
      {% if content_flow == 'truncate' %}
        <div class="flex shrink-0 items-center text-sm font-medium"
             :class="(offset + 1) < p_card?.product?.options_with_values?.[index]?.values?.length ? '':'opacity-0 pointer-events-none'"
             x-init="$nextTick(async ()=> { if (window.design_mode) { await utils.delay(20) } offset = utils.truncateChildren($el, $el.parentElement)})"
             @resize.window.debounce.200ms="offset = p_card?.product?.options_with_values?.[index]?.values?.length; await utils.delay(1); offset = utils.truncateChildren($el, $el.parentElement)"
             x-html="utils.applyInlinePluralization(`{{ truncate_text }}`.replace('[count]', `${p_card?.product?.options_with_values?.[index]?.values?.length - offset}`).replace('[option]', `${p_card?.product?.options?.[index]}`)) || ''">
          +10 placeholder
        </div>
      {% endif %}
    </fieldset>
  </div>
  {% if option_type != 'fallback_options' %}
    {% break %}
  {% endif %}
{% endfor %}

{% schema %}
{
  "name": "Option: Radio Buttons",
  "settings": [
    {
      "type": "header",
      "content": "Option title"
    },
    {
      "type": "inline_richtext",
      "id": "legend",
      "label": "Heading",
      "default": "[heading]",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use [heading] as a placeholder for the option title, and [value] as a placeholder for the current / hover value."
    },
    {
      "type": "text",
      "id": "legend_class",
      "label": "Heading class",
      "default": "richtext-md h5"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Value"
    },
    {
      "type": "inline_richtext",
      "id": "radio_button_content",
      "label": "Radio button content",
      "default": "[value]",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use [value] as a placeholder for the value."
    },
    {
      "type": "text",
      "id": "radio_button_class",
      "label": "Radio button class",
      "default": "button-primary-sm"
    },
    {
      "type": "checkbox",
      "id": "select_on_hover",
      "label": "Select on hover"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Inline Layout"
    },
    {
      "type": "select",
      "id": "content_flow",
      "label": "Content flow",
      "default": "show_all",
      "options": [
        {
          "value": "show_all",
          "label": "Show all"
        },
        {
          "value": "truncate",
          "label": "Truncate"
        },
        {
          "value": "overflow",
          "label": "Slider"
        }
      ]
    },
    {
      "type": "text",
      "id": "truncate_text",
      "label": "Truncate text",
      "default": "+[count] [option]",
      "info": "Use [count] and [option] as placeholders for values.",
      "visible_if": "{{ block.settings.content_flow == 'truncate' }}"
    },
    {
      "type": "select",
      "id": "sold_out_variants",
      "label": "Sold Out Variants",
      "default": "",
      "options": [
        {
          "value": "",
          "label": "Show"
        },
        {
          "value": "hide",
          "label": "Hide"
        },
        {
          "value": "disable",
          "label": "Disable"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Match Option"
    },
    {
      "type": "select",
      "id": "option_type",
      "label": "Match Option type",
      "default": "by_name",
      "options": [
        {
          "value": "by_name",
          "label": "By Name"
        },
        {
          "value": "by_index",
          "label": "By Index"
        },
        {
          "value": "fallback_options",
          "label": "Fallback Options"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "Priority By name, By Index, then Fallback Options."
    },
    {
      "type": "text",
      "id": "match_option_titles",
      "label": "Match option titles",
      "info": "Comma separated list of possible option titles.",
      "visible_if": "{{ block.settings.option_type == 'by_name' }}"
    },
    {
      "type": "range",
      "id": "match_option_index",
      "label": "Match option index",
      "default": 1,
      "min": 1,
      "max": 3,
      "step": 1,
      "visible_if": "{{ block.settings.option_type == 'by_index' }}"
    },
    {
      "type": "checkbox",
      "id": "match_exact_word",
      "label": "Match exact word",
      "default": false,
      "info": "Enable this if you want to match the exact titles and make the 'Match option titles' case sensitive.",
      "visible_if": "{{ block.settings.option_type == 'by_name' }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n\n}\n& legend {\n  margin-bottom: 6px;\n}\n& fieldset {\n  gap: 6px;\n}\n"
    },
    {
      "type": "select",
      "id": "show_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "with_subscriptions",
          "label": "Subscription"
        },
        {
          "value": "no_subscriptions",
          "label": "One-time"
        },
        {
          "value": "no_bundle",
          "label": "Hide in Bundle"
        },
        {
          "value": "bundle",
          "label": "Only in Bundle"
        },
        {
          "value": "with_variants",
          "label": "With Variants"
        },
        {
          "value": "no_variants",
          "label": "No Variants"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Option: Radio Buttons",
      "category": "** Card **"
    }
  ],
  "tag": null,
  "class": "shopify_block___card_product_card__option__radio"

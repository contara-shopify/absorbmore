{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_collection__applied_count"
  assign section_type = "main_collection"
  assign content = block.settings.content
  assign content_class = block.settings.content_class
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign filters = collection.filters | map: 'active_values'
  assign active_filters = 0
  for filter in filters
    assign active_filters = active_filters | plus: filter.size
  endfor
  assign content = content | replace: '[count]', active_filters
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }} class="{{ content_class }}">
  {% render '_input.inline_richtext', content: content %}
</div>

{% schema %}
{
  "name": "Applied Filter Count",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "content",
      "label": "Content",
      "default": "[count]",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use [count] as placeholders for the count based on the applied filters."
    },
    {
      "type": "text",
      "id": "content_class",
      "label": "Content class",
      "default": "richtext-md p"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Applied Filter Count",
      "category": "** Collection **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_collection__applied_count"
}
{% endschema %}

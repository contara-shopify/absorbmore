    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char",
      "visible_if": "{{ block.settings.dynamic_content_type == 'metafield' }}"
    },
    {
      "type": "text",
      "id": "metafield_image_key",
      "label": "Image Key",
      "default": "image",
      "info": "Metaobject key for the image value. I.e. `image`",
      "visible_if": "{{ block.settings.dynamic_content_type == 'metafield' }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char",
      "visible_if": "{{ block.settings.dynamic_content_type == 'metafield' }}"
    },
    {
      "type": "text",
      "id": "metafield_caption_key",
      "label": "Caption Key",
      "default": "caption",
      "info": "Metaobject key for the caption value. I.e. `content`",
      "visible_if": "{{ block.settings.dynamic_content_type == 'metafield' }}"
    },
    {
      "type": "text",
      "id": "caption_class",
      "label": "Caption class",
      "default": "richtext-md",
      "visible_if": "{{ block.settings.dynamic_content_type != 'target_element' }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char",
      "visible_if": "{{ block.settings.dynamic_content_type != 'target_element' }}"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)",
      "visible_if": "{{ block.settings.dynamic_content_type == 'default' }}"
    },
    {
      "type": "text",
      "id": "metafield_description_key",
      "label": "Description Key",
      "default": "description",
      "info": "Metaobject key for the description value. I.e. `content`",
      "visible_if": "{{ block.settings.dynamic_content_type == 'metafield' }}"
    },
    {
      "type": "text",
      "id": "description_class",
      "label": "Description class",
      "default": "richtext-md",
      "visible_if": "{{ block.settings.dynamic_content_type != 'target_element' }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char",
      "visible_if": "{{ block.settings.dynamic_content_type == 'metafield' }}"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Auto"
        },
        {
          "value": "left",
          "label": "←"
        },
        {
          "value": "center",
          "label": "↔"
        },
        {
          "value": "right",
          "label": "→"
        }
      ],
      "visible_if": "{{ block.settings.dynamic_content_type != 'target_element' }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char",
      "visible_if": "{{ block.settings.dynamic_content_type != 'target_element' }}"
    },
    {
      "type": "text",
      "id": "metafield_url_key",
      "label": "Url Key",
      "default": "url",
      "info": "Metaobject key for the url value. I.e. `url`",
      "visible_if": "{{ block.settings.dynamic_content_type == 'metafield' }}"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Url",
      "visible_if": "{{ block.settings.dynamic_content_type == 'default' }}"
    },
    {

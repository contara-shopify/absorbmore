{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_cart__gift_with_purchase"
  assign section_type = "main_cart"
  assign show_conditionally = block.settings.show_conditionally
  assign target_type = block.settings.target_type
  assign target = block.settings.target
  assign products = block.settings.products
  assign receives_quantity = block.settings.receives_quantity
  assign allow_duplicates = block.settings.allow_duplicates
  assign auto_add_to_cart = block.settings.auto_add_to_cart
  assign auto_remove_from_cart = block.settings.auto_remove_from_cart
  assign hide_in_cart = block.settings.hide_in_cart
  assign legend = block.settings.legend
  assign accordion_class = block.settings.accordion_class
  assign product_card_class = block.settings.product_card_class
  assign hide_out_of_stock = block.settings.hide_out_of_stock
  assign enable_mouse_dragging = block.settings.enable_mouse_dragging
  assign slider_scroll_snap = block.settings.slider_scroll_snap
  assign slider_overflow_container = block.settings.slider_overflow_container
  assign infinite_scroll = block.settings.infinite_scroll
  assign scrollbar_class = block.settings.scrollbar_class
  assign scroll_pagination_class = block.settings.scroll_pagination_class
  assign custom_css = block.settings.custom_css
  assign hide_if_empty = block.settings.hide_if_empty
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign container_spacing = section.settings.container_spacing
  case slider_overflow_container
    when 'all'
      assign slider_overflow = container_spacing | replace: 'px', '-mx' | append: " scroll-" | append: container_spacing | append: " " | append: container_spacing
    when 'mobile'
      assign slider_overflow = container_spacing | replace: 'px', 'max-md:-mx' | append: " max-md:scroll-" | append: container_spacing | append: " max-md:" | append: container_spacing
    when 'desktop'
      assign slider_overflow = container_spacing | replace: 'px', 'md:-mx' | append: " md:scroll-" | append: container_spacing | append: " md:" | append: container_spacing
  endcase
%}

{% capture product_data %}
  [{% for _product in products %}
  {%- render '_json.product', product: _product, card: true -%}{% unless forloop.last %},{% endunless %}
{% endfor %}]
{% endcapture %}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

{% capture accordion_content %}
  <div class="relative flex flex-col"
       x-data="{ ...utils.initContentSlider($el, $refs.scrollContainer, undefined, `{{ infinite_scroll }}`, undefined, `{{ enable_mouse_dragging }}` === 'true') }">
    <div class="grid-container relative grid overflow-x-auto scrollbar-none overflow-y-hidden {{ slider_scroll_snap }} {{ slider_overflow }}"
         x-ref="scrollContainer"
         @resize.window="content_slider.handleResize"
         x-init="$nextTick(content_slider.handleResize)"
         @scroll="content_slider.handleScroll"
         @scrollend="content_slider.handleInfiniteScroll"
         data-gift-products="{{ product_data | escape }}"
         x-effect="() => {
          if ($cart.state.item_count && (!$el.closest(`[data-modal-id='modal--cart-drawer']`) || $data.show)) {
            _cart.renderGiftProducts($el, {
              target_type: `{{ target_type }}`,
              target: +`{{ target }}`,
              receives_quantity:  +`{{ receives_quantity }}`,
              allow_duplicates: `{{ allow_duplicates }}` === 'true',
              product_card_class: `{{ product_card_class }}`,
              hide_if_empty: `{{ hide_if_empty }}`,
              handleResize: () => { $data?.content_slider?.handleResize() },
              block_id: `{{ block.id }}`,
              auto_add_to_cart: `{{ auto_add_to_cart }}` === 'true',
              auto_remove_from_cart: `{{ auto_remove_from_cart }}` === 'true',
              hide_in_cart: `{{ hide_in_cart }}` === 'true'
            })
          }
        }"
    >
    </div>
    {% if scrollbar_class != blank %}
      {% render '_components.scrollbar', class: scrollbar_class %}
    {% endif %}
    {% if scroll_pagination_class != blank %}
      {% render '_components.scroll_pagination', class: scroll_pagination_class %}
    {% endif %}
  </div>

{% endcapture %}

<section
    data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
    class="@container"
    x-show="_cart.showConditionally(`{{ show_conditionally }}`) && $cart.state.item_count && $cart.gift_products[`{{ block.id }}`]?.length"
    {% if request.design_mode %}
      x-effect="() => {
        if ($editor?.select_block_id === `{{ block.id }}` && $cart.state.items?.length === 0 && Object.values(_products)?.find(p => p.available)) {
          _cart.add({ items: [{ id: Object.values(_products)?.find(p => p.available)?.variants?.find(v => v?.available)?.id, quantity: 1 }] })
        }
      }"
    {% endif %}
    x-cloak>
  {% render '_components.collapsible', label: legend, content: accordion_content, default_open: true, class: accordion_class, no_richtext_content: true %}
</section>


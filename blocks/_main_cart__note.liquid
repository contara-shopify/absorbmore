{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_cart__note"
  assign section_type = "main_cart"
  assign show_conditionally = block.settings.show_conditionally
  assign checkbox_enabled = block.settings.checkbox_enabled
  assign checkbox_label = block.settings.checkbox_label
  assign checkbox_class = block.settings.checkbox_class
  assign checkbox_name = block.settings.checkbox_name
  assign checkbox_default_state = block.settings.checkbox_default_state
  assign textarea_placeholder = block.settings.textarea_placeholder
  assign textarea_label = block.settings.textarea_label
  assign textarea_class = block.settings.textarea_class
  assign dynamic_display = block.settings.dynamic_display
  assign limit_characters = block.settings.limit_characters
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  if checkbox_default_state == 'checked'
    assign default_checked = true
  endif
  assign checkbox_name = "attributes[" | append: checkbox_name | append: "]"
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
     class="flex flex-col gap-4"
     x-data="{ checkbox_checked: $el.querySelector(`input[type='checkbox']`)?.checked ?? false }"
     x-show="_cart.showConditionally(`{{ show_conditionally }}`) || $editor?.select_block_id === `{{ block.id }}`"
  {% if show_conditionally == 'cart_empty' and cart.item_count > 0 %}x-cloak{% endif %}
  {% if show_conditionally == 'items_added' and cart.item_count <= 0 %}x-cloak{% endif %}>
  {% if checkbox_enabled %}
    {% render '_components.checkbox',
        class: checkbox_class,
        label: checkbox_label,
        name: checkbox_name,
        default_checked: default_checked,
        html_attributes: "",
        setState: 'checkbox_checked = value'
    %}
  {% endif %}
  {% if dynamic_display == 'show_checkbox_checked' and checkbox_enabled %}
    {% render '_components.textarea',
        class: textarea_class,
        label: textarea_label,
        placeholder: textarea_placeholder,
        name: 'note',
        default_value: "",
        html_attributes: "",
        maxlength: limit_characters,
        html_attributes: ' x-show="checkbox_checked" '
    %}
  {% else %}
    {% render '_components.textarea',
        class: textarea_class,
        label: textarea_label,
        placeholder: textarea_placeholder,
        name: 'note',
        default_value: "",
        html_attributes: "",
        maxlength: limit_characters
    %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Note",
  "settings": [
    {
      "type": "select",
      "id": "show_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "cart_empty",
          "label": "Cart Empty"
        },
        {
          "value": "items_added",
          "label": "Items Added"
        }
      ]
    },
    {
      "type": "header",
      "content": "Checkbox"
    },
    {
      "type": "checkbox",
      "id": "checkbox_enabled",
      "label": "Enabled",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "checkbox_label",
      "label": "Label",
      "default": "This is a gift",
      "visible_if": "{{ block.settings.checkbox_enabled }}",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "text",
      "id": "checkbox_class",
      "label": "Checkbox class",
      "visible_if": "{{ block.settings.checkbox_enabled }}"
    },
    {
      "type": "text",
      "id": "checkbox_name",
      "label": "Checkbox property name",
      "default": "Cart-note",
      "info": "This shows in the checkout and in the final order.",
      "visible_if": "{{ block.settings.checkbox_enabled }}"
    },
    {
      "type": "select",
      "id": "checkbox_default_state",
      "label": "Checkbox default state",
      "default": "unchecked",
      "options": [
        {
          "value": "unchecked",
          "label": "Not checked"
        },
        {
          "value": "checked",
          "label": "checked"
        }
      ],
      "visible_if": "{{ block.settings.checkbox_enabled }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Textarea"
    },
    {
      "type": "text",
      "id": "textarea_placeholder",
      "label": "Placeholder",
      "default": "Write you gift note here"
    },
    {
      "type": "text",
      "id": "textarea_label",
      "label": "Label",
      "default": "Cart note"
    },
    {
      "type": "text",
      "id": "textarea_class",
      "label": "Textarea class",
      "default": "input-textarea"
    },
    {
      "type": "select",
      "id": "dynamic_display",
      "label": "Show dynamically:",
      "default": "show_checkbox_checked",
      "options": [
        {
          "value": "show_always",
          "label": "Always"
        },
        {
          "value": "show_checkbox_checked",
          "label": "If checkbox checked"
        }
      ],
      "visible_if": "{{ block.settings.checkbox_enabled }}"
    },
    {
      "type": "number",
      "id": "limit_characters",
      "label": "Limit characters"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Note",
      "category": "** Cart **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_cart__note"
}
{% endschema %}

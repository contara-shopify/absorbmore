{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_form__input_select"
  assign section_type = "form"
  assign title = block.settings.title
  assign select_class = block.settings.select_class
  assign name = block.settings.name
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  capture options
    content_for 'blocks'
  endcapture
  assign options = options | strip_newlines | strip | split: "|%|END|%|"
  assign select_titles = title
  assign select_values = title
  assign current_value = title
  assign current_title = title
  assign disabled_items = 'true' | uniq
  for option in options

    assign disabled = option | split: "|%|DISABLED|%|" | last
    assign select_title = option | split: "|%|DISABLED|%|" | first | split: "|%|SPLIT|%|" | first
    assign select_value = option | split: "|%|DISABLED|%|" | first | split: "|%|SPLIT|%|" | last
    assign select_titles = select_titles | append: "|%|SPLIT|%|" | append: select_title
    assign select_values = select_values | append: "|%|SPLIT|%|" | append: select_value
    if disabled == 'true'
      assign disabled = 'true' | uniq
      assign disabled_items = disabled_items | concat: disabled
    else
      assign disabled = '' | uniq
      assign disabled_items = disabled_items | concat: disabled
    endif
    if current_value == blank
      assign current_value = select_value
    endif
    if current_title == blank
      assign current_title = select_title
    endif
  endfor

  assign select_values = select_values | split: "|%|SPLIT|%|" | json
  assign select_titles = select_titles | split: "|%|SPLIT|%|" | json
  assign disabled_items = disabled_items | json
%}

{% capture html_attributes %}data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}{% endcapture %}
{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

{% render '_components.select',
    values: select_values,
    titles: select_titles,
    disabled_items: disabled_items,
    current_value: current_value,
    current_title: current_title,
    select_class: select_class,
    label: title
%}

{% schema %}
{
  "name": "Input: Select",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Label",
      "default": "What is this regarding?"
    },
    {
      "type": "text",
      "id": "select_class",
      "label": "Select class",
      "default": "input-select"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "contact[request_type]"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "blocks": [
    {
      "type": "_form__option"
    }
  ],
  "presets": [
    {
      "name": "Input: Select",
      "category": "** Form **"
    }
  ],
  "tag": null,
  "class": "shopify_block___form__input_select"
}
{% endschema %}

      "label": "Rating icon",
      "default": "star"
    },
    {
      "type": "range",
      "id": "rating",
      "label": "Rating",
      "default": 5,
      "min": 1,
      "max": 5,
      "step": 1
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "label",

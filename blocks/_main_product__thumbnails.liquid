{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_product__thumbnails"
  assign section_type = "main_product"
  assign thumbnail_filter_images = block.settings.thumbnail_filter_images
  assign hide_image_alt = block.settings.hide_image_alt
  assign select_variant_on_click = block.settings.select_variant_on_click
  assign enable_mouse_dragging = block.settings.enable_mouse_dragging
  assign slider_scroll_snap = block.settings.slider_scroll_snap
  assign slider_overflow_container = block.settings.slider_overflow_container
  assign scrollbar_class = block.settings.scrollbar_class
  assign scroll_pagination_class = block.settings.scroll_pagination_class
  assign infinite_scroll = block.settings.infinite_scroll
  assign preload_images = block.settings.preload_images
  assign sizes = block.settings.sizes
  assign max_width = block.settings.max_width
  assign quick_view_visibility = block.settings.quick_view_visibility
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign product = section.settings.product | default: product
  if section.settings.default_variant_metafield != blank
    assign variant_namespace = section.settings.default_variant_metafield | strip | split: "." | first
    assign variant_key = section.settings.default_variant_metafield | strip | split: "." | last
    assign variant = product.metafields[variant_namespace][variant_key].value | default: variant
  endif

  assign variant = variant | default: product.selected_or_first_available_variant | default: product.variants.first

  assign container_spacing = section.settings.container_spacing
  case slider_overflow_container
    when 'all'
      assign slider_overflow = container_spacing | replace: 'px', '-mx' | append: " scroll-" | append: container_spacing | append: " " | append: container_spacing
    when 'mobile'
      assign slider_overflow = container_spacing | replace: 'px', 'max-md:-mx' | append: " max-md:scroll-" | append: container_spacing | append: " max-md:" | append: container_spacing
    when 'desktop'
      assign slider_overflow = container_spacing | replace: 'px', 'md:-mx' | append: " md:scroll-" | append: container_spacing | append: " md:" | append: container_spacing
  endcase
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>
  {{ custom_css | replace: '&', selector | strip_newlines }}
</style>

<div
    data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
    data-quick-view-visibility="{{ quick_view_visibility }}"
    {% if show_conditionally != blank and show_conditionally != 'always' %}
      x-cloak
      x-show="$editor.select_block_id === `{{ block_id }}` || $data.showConditionally('{{ show_conditionally }}', $data?.bundle)"
    {% endif %}
    class="relative"
    x-ref="thumbnails"
    x-data="{ ...utils.initContentSlider($el, $el.firstElementChild, undefined, `{{ infinite_scroll }}`, undefined, `{{ enable_mouse_dragging }}` === 'true') }"
    x-defer="intersect"
    :class="content_slider.state.slide_count > 1 ? (content_slider.state.horizontal ? 'horizontal-scroll' : 'vertical-scroll') : ''"
    data-settings="{{ block.settings | json | escape }}">
  <div class="grid-container relative flex snap-mandatory overflow-x-auto scrollbar-none max-lg:order-first {{ slider_scroll_snap }} {{ slider_overflow }}"
       x-ignore
       @resize.window="content_slider.handleResize"
       x-data="{ initVariants: () => { pdp.thumbnail_media = $data?.handleImageSelection(`{{ thumbnail_filter_images }}`, pdp.selected_variant); $nextTick(() =>{ $data.content_slider.handleResize() }); } }"
       x-init="initVariants(); $watch('pdp.selected_variant', $data.initVariants); utils.hydrateImages(true, $el)"
       @scroll="(e) => { content_slider.handleScroll(e); const mediaId = [...$el.querySelectorAll(':scope > div:not(.hidden):not(.\\!hidden)')].find(pic => pic?.classList?.contains('centered'))?.getAttribute('data-media-id'); if (mediaId && mediaId !== pdp.selected_media_id) { pdp.selected_media_id = mediaId }}"
       @scrollend="content_slider.handleInfiniteScroll"
       x-effect="() => {
         if (pdp.selected_variant?.id && pdp.selected_variant?.id !== pdp.initial_variant_id && !pdp.thumbnail_images_cleaned) {
           $el.querySelectorAll(':scope > button:not([\\:data-media-id])').forEach(el => el.remove())
           pdp.thumbnail_images_cleaned = true
         }

         const prev_target = $el.querySelector(`[data-media-id='${pdp.previous_selected_media_id}']`);
         const target = $el.querySelector(`[data-media-id='${pdp.selected_media_id}']`);
         const paddingTop = parseFloat(getComputedStyle($el)?.paddingTop?.replace('auto', '0'));
         const paddingLeft = parseFloat(getComputedStyle($el)?.paddingLeft?.replace('auto', '0'));
         if (target && content_slider.state.slide_count > 1 && !pdp.scrolling_to_image && !utils.isElementFullyVisible(target)) {
          if (prev_target && parseInt(getComputedStyle(prev_target)?.order) > parseInt(getComputedStyle(target)?.order)) {
            let pastOrEqualTarget = false
            const newTarget =[...$el.querySelectorAll(':scope > button:not(.hidden):not(.\\!hidden)')].reverse().find((child) => {
              pastOrEqualTarget ||= child.getAttribute('data-media-id') === `${pdp.selected_media_id}`;
              if (pastOrEqualTarget) {
                 if (getComputedStyle(child)?.scrollSnapAlign !== 'none') return true
              }
              return false
            })
            $el.scrollTo({ top: newTarget?.offsetTop - paddingTop, left: newTarget?.offsetLeft - paddingLeft, behavior: 'instant' })
            return;
          }
          $el.scrollTo({ top: target?.offsetTop - paddingTop, left: target?.offsetLeft - paddingLeft, behavior: 'instant' })
         }
       }"
       x-ref="scrollContainer">
    <template x-for="(value, i) in (pdp.thumbnail_images_cleaned ? (pdp.thumbnail_media?.slice(0, +{{ max_images | default: 'pdp.thumbnail_media?.length ?? 9999' }}) || []) : [])">
      <button type="button"
              :data-media-id="pdp.thumbnail_media[i].id"
              @click.prevent.stop.capture="() => $data.scrollToMediaById(+$el.getAttribute('data-media-id'))"
              tabindex="-1"
              :style="`--order: ${i * 10};`"
              x-effect="$el.classList.toggle('active', +pdp.selected_media_id === +pdp.thumbnail_media[i].id || (i === 0 && ![...$el.parentElement.querySelectorAll(':scope > button[data-media-id]')].some(el => +el.getAttribute('data-media-id') === +pdp.selected_media_id)))"
              class="image-wrapper snap-start relative flex shrink-0 overflow-hidden order-[--order]">
        <template x-if="pdp.thumbnail_media[i]?.media_type === 'image'">
          <img class="h-full w-full object-[inherit] transition-opacity duration-300 ease-in"
               :class="i !== 0 ? '!opacity-0' : ''"
               src=""
               alt=""
               onload="this.classList.remove('!opacity-0')"
               :srcset="utils.getImageSrcSet(pdp.thumbnail_media[i]?.src ?? '', +`{{ max_width }}`)"
               :src="pdp?.thumbnail_media[i]?.src"
               :alt="pdp?.thumbnail_media[i]?.alt"
               sizes="{{ sizes }}" />
        </template>
        <template x-if="pdp?.thumbnail_media[i]?.media_type === 'video'">
          <video playsinline
                 controls
                 x-effect="() => { if (!$el.paused && ($mediaGallery.scrollIndex !== i || !$modal.id === 'media-gallery--vertical-gallery')) { $el.pause() } }"
                 loop
                 preload="none"
                 class="h-full w-full object-[inherit]"
                 :aria-label="pdp?.thumbnail_media[i]?.alt"
                 :poster="pdp?.thumbnail_media[i]?.preview_image?.src">
            <template x-for="(source, index) in [...(pdp?.thumbnail_media[i]?.sources || [])].sort((a, b) => a.width - b.width)">
              <source data-loop-item
                      src=""
                      :src="source?.url"
                      :type="source?.mime_type"
                      :media="index === 0 ? 'all' : `(min-width: ${[...(pdp?.thumbnail_media[i]?.sources || [])].sort((a, b) => a.width - b.width)[index - 1].width + 1}px)`"
                      type="video/mp4" />
            </template>
            <img x-show="pdp?.thumbnail_media[i]?.preview_image?.src"
                 :src="pdp?.thumbnail_media[i]?.preview_image.src"
                 :alt="pdp?.thumbnail_media[i]?.alt" />
          </video>
        </template>
        <template x-if="pdp?.thumbnail_media[i]?.media_type === 'external_video'">
          <iframe allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  class="relative h-full w-full object-contain js-youtube"
                  loading="lazy"
                  :src="pdp?.thumbnail_media[i].host === 'youtube'
                           ? `https://www.youtube.com/embed/${pdp?.thumbnail_media[i].external_id}?autoplay=${$mediaGallery.scrollIndex === i ? '1' : '0'}&controls=1&muted=${$mediaGallery.scrollIndex === i ? '0' : '1'}&enablejsapi=1&loop=${1}&modestbranding=1&playsinline=1&rel=0`
                           : `https://player.vimeo.com/video/${pdp?.thumbnail_media[i].external_id}`"
                  :title="pdp?.thumbnail_media[i].alt"></iframe>
        </template>
        <template x-if="pdp?.thumbnail_media[i]?.media_type === 'model'">
          <div class="relative aspect-1 h-full w-full">
            <div x-html="`
                    <model-viewer
                      class='inset-0 h-full w-full object-contain md:absolute'
                      style='--poster-color: transparent; position: absolute;'
                      src='${pdp?.thumbnail_media[i]?.sources?.find((source) => source.format === 'glb')?.url}'
                      camera-controls='true'
                      data-shopify-feature='1.12'
                      alt='${pdp?.thumbnail_media[i]?.alt}'
                      poster='${pdp?.thumbnail_media[i]?.preview_image.src}'
                      data-js-focus-visible='
                      ar-status='not-presenting'
                      ></model-viewer>
                  `"></div>
          </div>
        </template>
      </button>
    </template>
    {% liquid
      assign variant_media_id = variant.featured_media.id | default: product.media.first.id
      assign variant_media_ids = product.variants | map: "featured_media" | map: "id" | uniq
      assign max_images = max_images | default: 9999 | at_least: 1
      assign images_rendered = 0
      assign start_index = 0
      case thumbnail_filter_images
        when "show_all"
          assign media_array = product.media
        when "selected_variant"
          assign media_array = variant.featured_media | uniq
        when "show_all_variants"
          assign media_array = product.variants | map: "featured_media" | uniq
        when "variant_images_by_order"
          assign media_array = product.media
          assign start_index = product.media | find_index: 'id', variant.featured_media.id
        when "variant_images_by_metafield"
          assign media_array = variant.featured_media | uniq
          assign additional_media_array = variant.metafields.smart.images.value | uniq
          assign media_array = media_array | concat: additional_media_array
        when "variant_images_and_unassigned"
          assign media_array = product.media
        when "only_unassigned"
          assign media_array = product.media
        when "first_or_selected_image"
          assign media_array = product.media | first | uniq
      endcase

      if media_array.size <= 0 and product.featured_media
        assign media_array = product.featured_media | uniq
      endif
    %}

    {% for i in (start_index..media_array.size) %}
      {% assign media = media_array[i] %}
      {% if media == blank %}{% continue %}{% endif %}
      {% if thumbnail_filter_images == 'only_unassigned' and variant_media_ids contains media.id %}{% continue %}{% endif %}
      {% if thumbnail_filter_images == 'variant_images_and_unassigned' and media.id != variant_media_id and variant_media_ids contains media.id %}{% continue %}{% endif %}
      {% if thumbnail_filter_images == 'variant_images_by_order' and media.id != variant_media_id and variant_media_ids contains media.id %}{% break %}{% endif %}

      {% if preload_images %}
        {% assign preload = true %}
      {% endif %}
      {% if images_rendered > preload_images %}
        {% assign preload = false %}
      {% endif %}

      <button type="button"
              data-media-id="{{ media.id }}"
              @click.prevent.stop.capture="() => $data.scrollToMediaById(+$el.getAttribute('data-media-id'))"
              tabindex="-1"
              style="--order: {{ images_rendered | times: 10 }};"
              x-effect="document.contains($el) && $el.classList.toggle('active', +pdp?.selected_media_id === +'{{ media.id }}')"
              class="image-wrapper snap-start relative flex shrink-0 overflow-hidden order-[--order] {% if images_rendered == 0 %}active{% endif %}">
        {% render '_object.media',
            media: media,
            data_src: data_src,
            class: "w-full h-full object-cover transition-opacity duration-300 ease-in",
            sizes: sizes,
            max_width: max_width,
            preload: preload
        %}
      </button>
      {% assign images_rendered = images_rendered | plus: 1 %}
      {% if images_rendered >= max_images %}{% break %}{% endif %}
    {% endfor %}
  </div>
  {% if scrollbar_class != blank %}
    {% render '_components.scrollbar', class: scrollbar_class %}
  {% endif %}
  {% if scroll_pagination_class != blank %}
    {% render '_components.scroll_pagination', class: scroll_pagination_class %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Thumbnails",
  "settings": [
    {
      "type": "radio",
      "id": "thumbnail_filter_images",
      "label": "Filter Thumbnails",
      "default": "show_all",
      "options": [
        {
          "value": "show_all",
          "label": "Show all images"
        },
        {
          "value": "show_all_variants",
          "label": "Show each variant image"
        },
        {
          "value": "selected_variant",
          "label": "Selected Variant image only."
        },
        {
          "value": "variant_images_by_order",
          "label": "t:all.selected_variant_image_and_images_following_until_the_next_image_is_assigned_to_a_variant_or_there_are_no_more_images"
        },
        {
          "value": "variant_images_by_metafield",
          "label": "t:all.selected_variant_image_and_images_assigned_to_the_metafield_smart_images_on_the_variant_level_set_to_type_list_file_reference"
        },
        {
          "value": "variant_images_and_unassigned",
          "label": "t:all.selected_variant_image_and_images_that_are_not_assigned_to_any_other_variant"
        },
        {
          "value": "only_unassigned",
          "label": "Only images that are not assigned to any variant."
        }
      ]
    },
    {
      "type": "text",
      "id": "hide_image_alt",
      "label": "Hide images with ALT text:",
      "default": "hide-image"
    },
    {
      "type": "checkbox",
      "id": "select_variant_on_click",
      "label": "Select variant on click"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Scrollbar Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_mouse_dragging",
      "label": "Enable mouse dragging"
    },
    {
      "type": "select",
      "id": "slider_scroll_snap",
      "label": "Scroll snap to",
      "default": "snap-mandatory [&>*]:snap-start",
      "options": [
        {
          "value": "",
          "label": "None"
        },
        {
          "value": "snap-mandatory snap-to-slide",
          "label": "Slide"
        },
        {
          "value": "snap-mandatory [&>*]:snap-start",
          "label": "Item"
        },
        {
          "value": "snap-m md:[&>*]:snap-start [&>*]:snap-center",
          "label": "Item (mobile centered)"

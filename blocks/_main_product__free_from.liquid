{% style %}
  :root {
    --component_free_from_surface:   #ffffff;
    --component_free_from_stroke:    #d5d1c8;
    --component_free_from_bullet:      #111111;
    --component_free_from_text:      #555555;
    --component_free_from_muted:     #aaaaaa;
  }

  [data-component-free-from] {
    grid-column: span 2;
    display: flex;
    justify-content: flex-end;
  }

  /* Free from — matches Figma SECTION 4: FREE FROM / CERTS (node 417:514) */
  [data-component-free-from] .certs-section {
    overflow: hidden;
    background: var(--component_free_from_surface);
    border: 1px solid var(--component_free_from_stroke);
    border-radius: 8px;
  }

  [data-component-free-from] .certs-header {
    padding: 14px 20px 13px;
    background-color: #5E91D5;
    border-bottom: 1px solid var(--component_free_from_stroke);
    font-family: inherit;
    font-size: 12px;
    font-weight: 700;
    line-height: normal;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #FFFFFF;
  }

  [data-component-free-from] .certs-grid {
    display: flex;
    flex-wrap: wrap;
    width: 100%;
  }

  [data-component-free-from] .cert-tag {
    box-sizing: border-box;
    display: flex;
    align-items: center;
    gap: 6px;
    flex: 0 0 50%;
    max-width: 50%;
    padding: 10px 15px 11px 14px;
    border-right: 1px solid var(--component_free_from_stroke);
    border-top: none;
    font-family: inherit;
    font-size: 11.5px;
    font-weight: 500;
    line-height: normal;
    color: var(--component_free_from_text);
    min-width: 0;
  }

  /* Row dividers via top border so the last row never stacks with .footnote’s border-top */
  [data-component-free-from] .cert-tag:nth-child(n + 3) {
    border-top: 1px solid var(--component_free_from_stroke);
  }

  [data-component-free-from] .cert-tag:nth-child(2n) {
    border-right-width: 0;
  }

  [data-component-free-from] .cert-dot {
    width: 6px;
    height: 6px;
    border-radius: 3px;
    background: var(--component_free_from_bullet);
    flex-shrink: 0;
  }

  [data-component-free-from] .footnote {
    padding: 14px 20px;
    border-top: 1px solid var(--component_free_from_stroke);
    font-family: inherit;
    font-size: 10.5px;
    font-weight: 400;
    line-height: 15.75px;
    color: var(--component_free_from_muted);
  }

  @media (min-width: 750px) {
    [data-component-free-from] .cert-tag {
      flex: 0 0 25%;
      max-width: 25%;
    }

    [data-component-free-from] .cert-tag:nth-child(2n) {
      border-right-width: 1px;
    }

    [data-component-free-from] .cert-tag:nth-child(4n) {
      border-right-width: 0;
    }

    [data-component-free-from] .cert-tag:nth-child(n + 3) {
      border-top: none;
    }

    /* Figma: row 1 ×4, row 2 ×3, row 3 ×1 */
    [data-component-free-from] .cert-tag:nth-child(n + 5) {
      border-top: 1px solid var(--component_free_from_stroke);
    }
  }
{% endstyle %}

<div data-component-free-from data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="component component--free-from">
    <div class="certs-section">
      <div class="certs-header">{{ block.settings.heading | escape }}</div>
      <div class="certs-grid">
        {% if block.settings.cert_1_text != blank %}
          <div class="cert-tag"><span class="cert-dot"></span>{{ block.settings.cert_1_text | escape }}</div>
        {% endif %}
        {% if block.settings.cert_2_text != blank %}
          <div class="cert-tag"><span class="cert-dot"></span>{{ block.settings.cert_2_text | escape }}</div>
        {% endif %}
        {% if block.settings.cert_3_text != blank %}
          <div class="cert-tag"><span class="cert-dot"></span>{{ block.settings.cert_3_text | escape }}</div>
        {% endif %}
        {% if block.settings.cert_4_text != blank %}
          <div class="cert-tag"><span class="cert-dot"></span>{{ block.settings.cert_4_text | escape }}</div>
        {% endif %}
        {% if block.settings.cert_5_text != blank %}
          <div class="cert-tag"><span class="cert-dot"></span>{{ block.settings.cert_5_text | escape }}</div>
        {% endif %}
        {% if block.settings.cert_6_text != blank %}
          <div class="cert-tag"><span class="cert-dot"></span>{{ block.settings.cert_6_text | escape }}</div>
        {% endif %}
        {% if block.settings.cert_7_text != blank %}
          <div class="cert-tag"><span class="cert-dot"></span>{{ block.settings.cert_7_text | escape }}</div>
        {% endif %}
        {% if block.settings.cert_8_text != blank %}
          <div class="cert-tag"><span class="cert-dot"></span>{{ block.settings.cert_8_text | escape }}</div>
        {% endif %}
      </div>
      <div class="footnote">
        {{ block.settings.footnote_line_1 | escape }}<br>
        {{ block.settings.footnote_line_2 | escape }}
      </div>
    </div>
  </div>
</div>


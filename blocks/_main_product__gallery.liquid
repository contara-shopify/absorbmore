  "settings": [
    {
      "type": "header",
      "content": "Dynamic Filters"
    },
    {
      "type": "radio",
      "id": "filter_images",
      "label": "Filter images",
      "default": "show_all",
      "options": [
        {
          "value": "show_all",
          "label": "Show all images"
        },
        {
          "value": "selected_variant",
          "label": "Selected Variant image only."
        },
        {
          "value": "variant_images_by_order",
          "label": "t:all.selected_variant_image_and_images_following_until_the_next_image_is_assigned_to_a_variant_or_there_are_no_more_images"
        },
        {
          "value": "variant_images_by_metafield",
          "label": "t:all.selected_variant_image_and_images_assigned_to_the_metafield_smart_images_on_the_variant_level_set_to_type_list_file_reference"
        },
        {
          "value": "variant_images_and_unassigned",
          "label": "t:all.selected_variant_image_and_images_that_are_not_assigned_to_any_other_variant"
        },
        {

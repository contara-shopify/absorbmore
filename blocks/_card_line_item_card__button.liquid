{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_card_line_item_card__button"
  assign section_type = "card_line_item_card"
  assign label = block.settings.label
  assign url = block.settings.url
  assign button_class = block.settings.button_class
  assign custom_css = block.settings.custom_css
  assign hide_if_empty = block.settings.hide_if_empty
  assign show_conditionally = block.settings.show_conditionally
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% if request.design_mode or metaobjects.line_item_cards[section.settings.line_item_card] == blank %}
  {% capture selector %}[data-style-id="{{ block.id | split: "__" | last }}"]{% endcapture %}

  <style>
    {{ custom_css | replace: '&', selector | strip_newlines }}
    {% if request.design_mode %}
    {% assign query_selector = '[data-section-id="'|append: section.id | append: '"][data-preview-container] ' | append: selector %}
    {{- custom_css | replace: '&', query_selector  | strip_newlines | replace: '@media screen and', '@container'| replace: '@media', '@container' -}}
    {% endif %}
  </style>
{% endif %}

<button
    data-style-id="{{ block.id | split: "__" | last }}" {{ block.shopify_attributes }}

    type="submit"
    :formaction="url"
    formmethod="get"
    data-content="{% render '_input.inline_richtext', content: label, escape: true, skip_pluralization: true %}"
    x-data="{ content: getDynamicText($el.getAttribute('data-content')), url: getDynamicText(`{{ url }}`) }"
    x-effect="() => { if (line_card?.variant || line_card?.hydrated) { content = getDynamicText($el.getAttribute('data-content')); content_check = getDynamicText($el.getAttribute('data-content-check')); url = getDynamicText(`{{ url }}`); utils.hideIfEmpty($el, `{{ hide_if_empty }}`, !content.trim()) } }"
    :href="url"
    x-html="content"
    class="{{ button_class }}"
    x-show="!!content && $data.showConditionally('{{ show_conditionally }}')">
</button>

{% schema %}
{
  "name": "Button",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "label",
      "label": "Label",
      "default": "Read More",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use bracket notation for data access: i.e.[product.title] or [product.metafields.smart.short_description]."
    },
    {
      "type": "text",
      "id": "url",
      "label": "Dynamic URL",
      "info": "Use bracket notation for data access.",
      "default": "[line_item.url]"
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button class",
      "default": "button-primary"
    },
    {
      "type": "paragraph",
      "content": "[Available keys](https://shopify.dev/docs/api/liquid/objects/line-item)"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    },
    {
      "type": "select",
      "id": "hide_if_empty",
      "label": "If empty, hide:",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "section",
          "label": "Section"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "block",
          "label": "Block"
        }
      ],
      "info": "Always shows in the Theme Editor."
    },
    {
      "type": "select",
      "id": "show_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "with_subscriptions",
          "label": "Subscription"
        },
        {
          "value": "no_subscriptions",
          "label": "One-time"
        },
        {
          "value": "no_addon_products",
          "label": "Hide with Addon products"
        },
        {
          "value": "addon_products",
          "label": "Only with Addon Products"
        },
        {
          "value": "with_variants",
          "label": "With Variants"
        },
        {
          "value": "no_variants",
          "label": "No Variants"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Button",
      "category": "** Card **"
    }
  ],
  "tag": null,
  "class": "shopify_block___card_line_item_card__button"
}
{% endschema %}

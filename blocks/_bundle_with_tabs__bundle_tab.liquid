{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_bundle_with_tabs__bundle_tab"
  assign section_type = "bundle_with_tabs"
  assign tab_name = block.settings.tab_name
  assign content = block.settings.content
  assign content_class = block.settings.content_class
  assign primary_product = block.settings.primary_product
  assign image = block.settings.image
  assign quantity_class = block.settings.quantity_class
  assign category_1_heading = block.settings.category_1_heading
  assign category_1_class = block.settings.category_1_class
  assign category_1_products = block.settings.category_1_products
  assign category_2_heading = block.settings.category_2_heading
  assign category_2_class = block.settings.category_2_class
  assign category_2_products = block.settings.category_2_products
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture container_content %}
  <tab-content-label>{{ tab_name }}</tab-content-label>

  {% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

  <style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

  <section data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
           class="block relative bg-white md:px-5 md:py-12 px-6 py-5 border-x border-x-[#D3D3D3] border-b border-b-[#D3D3D3] max-xl:border-x-0" {% if hash_target != blank %}id="{{ hash_target | replace: "#", '' }}"{% endif %}
           data-tab-id="{{ tab_name }}"
           data-tab-content-x-cloak-placeholder
           x-show="current_tab === '{{ tab_name }}'">
    <header class="flex gap-5">
      <div class="image-wrapper aspect-1 relative w-[26%] shrink-0 max-md:hidden">
        {% render '_object.image', image: image, preload: true, sizes: '(max-width: 768px) 25vw, (max-width: 1024px) 20vw, 15vw', class: "w-full h-full object-contain" %}
      </div>
      <div>
        {% render '_input.richtext', content: content, class: content_class %}
        <a class="underline hf:opacity-70 max-md:hidden mt-4 inline-block richtext-md p"
           href="{{ primary_product.url }}">View Product Details</a>
      </div>
    </header>
    {% if category_1_heading != blank and category_1_products.count > 0 %}
      <div class="mt-5 flex flex-col gap-7 md:gap-5">
        {% render '_input.richtext', content: category_1_heading, class: category_1_class %}
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2.5 lg:gap-4">
          {% for product in category_1_products %}
            {% if product.available != true %}{% continue %}{% endif %}
            {% assign metafield = product.metafields.smart.swatch.value | first %}
            {% if metafield == blank or metafield.title == blank %}{% continue %}{% endif %}
            <div class="flex flex-col p-4 md:py-5 border border-[#D3D3D3] rounded-sm"
                 x-intersect.once="utils.preloadImage(image)"
                 :class="added ? 'outline-2 outline-current outline' : ''"
                 x-effect="added = bundle_items?.some(item => item.variant_id === variant_id)"
                 x-data="{ variant_id: +`{{ product.first_available_variant.id }}`, image: `{{ product.featured_image | image_url: width: 180, height: 180 }}`, title: `{{ product.title }}`, added: false }">
              <h5 class="text-center richtext-md h5 text-18">{{ metafield.title }}</h5>
              <p class="text-center text-sm text-balance mt-2.5">{{ metafield.short_description }}</p>
              <div class="mt-2.5 flex flex-col justify-end flex-1">
                <div class="flex justify-center items-center">
                  <button type="button"
                          x-show="!added"
                          @click="bundle_items?.push({ variant_id, image, title })"
                          :disabled="bundle_items?.length >= 3"
                          class="border-2 border-current size-10 flex items-center justify-center rounded-[5px] hfa:bg-current group transition-all duration-75 disabled:opacity-50 disabled:pointer-events-none">
                    <span class="sr-only">Add item to bundle</span>
                    {% render '_components.icon', icon: 'plus', class: 'h-4 group-hf:text-white' %}
                  </button>
                  {% capture html_attributes %}x-cloak x-show="added"{% endcapture %}
                  {% render '_components.quantity_stepper',
                      html_attributes: html_attributes,
                      class: quantity_class,
                      setState: "value > bundle_items?.reduce((acc, item) => { if (item.variant_id === variant_id) { acc += 1}; return acc;}, 0) ? bundle_items?.push({ variant_id, image, title }) : bundle_items.splice(bundle_items.findLastIndex(item=> item.variant_id === variant_id), 1)",
                      state: "bundle_items?.reduce((acc, item) => { if (item.variant_id === variant_id) { acc += 1}; return acc;}, 0)",
                      disabled_max: 'bundle_items?.length >= 3',
                      disabled_manual_input: 'true'
                  %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
    {% if category_2_heading != blank and category_2_products.count > 0 %}
      <div class="mt-5 flex flex-col gap-7 md:gap-5">
        {% render '_input.richtext', content: category_2_heading, class: category_2_class %}
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2.5 lg:gap-4">
          {% for product in category_2_products %}
            {% if product.available != true %}{% continue %}{% endif %}
            {% assign metafield = product.metafields.smart.swatch.value | first %}
            {% if metafield == blank or metafield.title == blank %}{% continue %}{% endif %}
            <div class="flex flex-col p-4 md:py-5 border border-[#D3D3D3] rounded-sm"
                 x-intersect.once="utils.preloadImage(image)"
                 :class="added ? 'outline-2 outline-current outline' : ''"
                 x-effect="added = bundle_items?.some(item => item.variant_id === variant_id)"
                 x-data="{ variant_id: +`{{ product.first_available_variant.id }}`, image: `{{ product.featured_image | image_url: width: 180, height: 180 }}`, title: `{{ product.title }}`, added: false }">
              <h5 class="text-center richtext-md h5 text-18">{{ metafield.title }}</h5>
              <p class="text-center text-sm text-balance mt-2.5">{{ metafield.short_description }}</p>
              <div class="mt-2.5 flex flex-col justify-end flex-1">
                <div class="flex justify-center items-center">
                  <button type="button"
                          x-show="!added"
                          @click="bundle_items?.push({ variant_id, image, title })"
                          :disabled="bundle_items?.length >= 3"
                          class="border-2 border-current size-10 flex items-center justify-center rounded-[5px] hfa:bg-current group transition-all duration-75 disabled:opacity-50 disabled:pointer-events-none">
                    <span class="sr-only">Add item to bundle</span>
                    {% render '_components.icon', icon: 'plus', class: 'h-4 group-hf:text-white' %}
                  </button>
                  {% capture html_attributes %}x-cloak x-show="added"{% endcapture %}
                  {% render '_components.quantity_stepper',
                      html_attributes: html_attributes,
                      class: quantity_class,
                      setState: "value > bundle_items?.reduce((acc, item) => { if (item.variant_id === variant_id) { acc += 1}; return acc;}, 0) ? bundle_items?.push({ variant_id, image, title }) : bundle_items.splice(bundle_items.findLastIndex(item=> item.variant_id === variant_id), 1)",
                      state: "bundle_items?.reduce((acc, item) => { if (item.variant_id === variant_id) { acc += 1}; return acc;}, 0)",
                      disabled_max: 'bundle_items?.length >= 3',
                      disabled_manual_input: 'true'
                  %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </section>

{% endcapture %}

{% if container_content contains '<script type="container/break"></script>' %}
  {% break %}
{% endif %}
{{ container_content }}


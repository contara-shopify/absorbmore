{% style %}
  :root {
    --component_clinical_results_white:    #FFFFFF;
    --component_clinical_results_black:    #111111;
    --component_clinical_results_mid:      #555555;
    --component_clinical_results_light:    #888888;
    --component_clinical_results_lighter:  #AAAAAA;
    --component_clinical_results_border:   #D5D1C8;
  }

  [data-style-id="template--26301830136097__main_product_PJRr9q--ANjRqU0hNRXlLbkNmY__custom_liquid_fWTgn7"] {
    /*width: 536px;*/
    background-color: var(--component_clinical_results_white);
    border-color: var(--component_clinical_results_border);
  }

  [data-component-clinical-results] {
    grid-column: span 2;
    display: flex;
    justify-content: flex-end;
  }

  /* Component container */
  .component {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;/*536px*/
  }

  /* Stat section */
  .stat-section {
    overflow: hidden;
    background: var(--component_clinical_results_white);
    border: 1px solid var(--component_clinical_results_border);
    border-radius: 8px;
  }

  .stat-section-header {
    padding: 14px 20px 12px;
    background-color: {{ block.settings.header_background_color | default: '#5E91D5' }};
    border-bottom: 1px solid var(--component_clinical_results_border);
    font-size: 12px;
    color: {{ block.settings.header_title_color | default: '#ffffff' }};
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
  }

  .stat-cell {
    padding: 20px 16px 18px;
    border-right: 1px solid var(--component_clinical_results_border);
    text-align: center;
  }

  .stat-cell:last-child { border-right: none; }

  .stat-number {
    font-size: 30px;
    font-weight: 700;
    color: var(--component_clinical_results_black);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .stat-number sup {
    font-size: 14px;
    font-weight: 600;
    vertical-align: super;
    letter-spacing: 0;
  }

  .stat-desc {
    font-size: 12px;
    color: var(--component_clinical_results_mid);
    line-height: 1.45;
    font-weight: 400;
  }

  .stat-dagger {
    font-size: 10px;
    color: var(--component_clinical_results_lighter);
    margin-top: 6px;
    display: block;
    line-height: 1.3;
  }
{% endstyle %}

<div data-component-clinical-results data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="component component--clinical-results">
    <div class="stat-section">
      <div class="stat-section-header">{{ block.settings.heading | escape }}</div>
      <div class="stat-grid">
        {% if block.settings.stat_1_number != blank %}
          <div class="stat-cell">
            <div class="stat-number">{{ block.settings.stat_1_number | escape }}{% if block.settings.stat_1_sup != blank %}{{ block.settings.stat_1_sup | escape }}{% endif %}</div>
            <div class="stat-desc">{{ block.settings.stat_1_description | escape }}</div>
            <span class="stat-dagger">{{ block.settings.stat_1_footnote | escape }}</span>
          </div>
        {% endif %}
        {% if block.settings.stat_2_number != blank %}
          <div class="stat-cell">
            <div class="stat-number">{{ block.settings.stat_2_number | escape }}{% if block.settings.stat_2_unit != blank %}<span style="font-size:18px;font-weight:600;">{{ block.settings.stat_2_unit | escape }}</span>{% endif %}</div>
            <div class="stat-desc">{{ block.settings.stat_2_description | escape }}</div>
            <span class="stat-dagger">{{ block.settings.stat_2_footnote | escape }}</span>
          </div>
        {% endif %}
        {% if block.settings.stat_3_number != blank %}
          <div class="stat-cell">
            <div class="stat-number">{{ block.settings.stat_3_number | escape }}{% if block.settings.stat_3_sup != blank %}{{ block.settings.stat_3_sup | escape }}{% endif %}</div>
            <div class="stat-desc">{{ block.settings.stat_3_description | escape }}</div>
            <span class="stat-dagger">{{ block.settings.stat_3_footnote | escape }}</span>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>


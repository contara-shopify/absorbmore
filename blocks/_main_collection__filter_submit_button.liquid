{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_collection__filter_submit_button"
  assign section_type = "main_collection"
  assign button_text = block.settings.button_text
  assign button_class = block.settings.button_class
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

{% assign button_text = button_text | replace_first: '[count]', collection.products_count %}

<button data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
        class="w-full mt-3 {{ button_class }}"
        type="submit"
        @click="$modal.setId('');"
        :class="main_collection.state.loading ? 'button-loading': ''">
  {% render '_input.inline_richtext', content: button_text %}
</button>

{% schema %}
{
  "name": "Filter Submit button",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "Button text",
      "default": "Apply Filters",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use [count] as a placeholder for the number of products in the current filter."
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button class",
      "default": "button-primary"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Filter Submit button",
      "category": "** Collection **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_collection__filter_submit_button"
}
{% endschema %}

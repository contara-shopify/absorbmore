{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_cart__dynamic_checkout_button"
  assign section_type = "main_cart"
  assign show_conditionally = block.settings.show_conditionally
  assign button_class = block.settings.button_class
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
     x-show="_cart.showConditionally(`{{ show_conditionally }}`) || $editor?.select_block_id === `{{ block.id }}`"
    {% if request.design_mode %}
      x-effect="() => {
        if ($editor?.select_block_id === `{{ block.id }}` && $cart.state.items?.length === 0 && Object.values(_products)?.find(p => p.available)) {
          _cart.add({ items: [{ id: Object.values(_products)?.find(p => p.available)?.variants?.find(v => v?.available)?.id, quantity: 1 }] })
        }
      }"
    {% endif %}
  {% if show_conditionally == 'cart_empty' and cart.item_count > 0 %}x-cloak{% endif %}
  {% if show_conditionally == 'items_added' and cart.item_count <= 0 %}x-cloak{% endif %}>
  {% if additional_checkout_buttons %}
    <script>
      const originalAttachShadow = Element.prototype.attachShadow;

      Element.prototype.attachShadow = function (init) {
        const shadowRoot = originalAttachShadow.call(this, init);

        if (init.mode === 'closed' && shadowRoot?.host?.nodeName?.includes('SHOPIFY-ACCELERATED-CHECKOUT-CART')) {
          setTimeout(() => {
            const style = document.createElement('style');
            style.textContent = `
              .wallet-cart-grid {
                 flex-direction: column !important;
                 gap: 12px !important;
              }
              .wallet-cart-button-container, .wallet-cart-button {
                width: 100% !important;
                margin: 0 !important;
              }
              .wallet-cart-grid {
                margin: 0 !important;
              }
          `;
            shadowRoot.prepend(style);
          });
        }

        return shadowRoot;
      };
    </script>
    <style>
      shopify-accelerated-checkout-cart {
        --shopify-accelerated-checkout-button-block-size: 48px;
        --shopify-accelerated-checkout-button-inline-size: 48px;
        --shopify-accelerated-checkout-button-border-radius: 999px;
        --shopify-accelerated-checkout-button-box-shadow: none;
        --shopify-accelerated-checkout-inline-alignment: stretch;
        --shopify-accelerated-checkout-row-gap: 12px;
        --shopify-accelerated-checkout-skeleton-background-color: #dedede;
        --shopify-accelerated-checkout-skeleton-animation-opacity-start: 1;
        --shopify-accelerated-checkout-skeleton-animation-opacity-end: 0.5;
        --shopify-accelerated-checkout-skeleton-animation-duration: 4s;
        --shopify-accelerated-checkout-skeleton-animation-timing-function: ease;
      }
    </style>
    <div class="additional-checkout-buttons grid">
      {{ content_for_additional_checkout_buttons }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Dynamic Checkout Button",
  "settings": [
    {
      "type": "select",
      "id": "show_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "cart_empty",
          "label": "Cart Empty"
        },
        {
          "value": "items_added",
          "label": "Items Added"
        }
      ]
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button class",
      "default": "button-primary"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Dynamic Checkout Button",
      "category": "** Cart **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_cart__dynamic_checkout_button"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_search__search_type_filter"
  assign section_type = "main_search"
  assign show_search_conditionally = block.settings.show_search_conditionally
  assign label = block.settings.label
  assign accordion_class = block.settings.accordion_class
  assign default_state = block.settings.default_state
  assign style = block.settings.style
  assign checkbox_class = block.settings.checkbox_class
  assign radio_button_class = block.settings.radio_button_class
  assign show_product = block.settings.show_product
  assign show_article = block.settings.show_article
  assign show_page = block.settings.show_page
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  if search.types contains 'product'
    assign product_active = true
  endif
  if search.types contains 'article'
    assign article_active = true
  endif
  if search.types contains 'page'
    assign page_active = true
  endif

  case default_state
    when 'show'
      assign open_accordion = true
    when 'hide'
      assign open_accordion = false
  endcase
%}

{% capture filter_content %}
  {% if style == 'checkbox' %}
    <fieldset class="filter-checkboxes flex flex-col gap-3">
      {% if show_product %}
        {% render '_components.checkbox',
            class: checkbox_class,
            label: 'Products',
            value: 'product',
            default_checked: product_active,
            setState: "$el.checked ? main_search.state.types.add('product') :  main_search.state.types.delete('product')",
            disabled: 'main_search.state.loading'
        %}
      {% endif %}
      {% if show_article %}
        {% render '_components.checkbox',
            class: checkbox_class,
            label: 'Articles',
            value: 'article',
            default_checked: article_active,
            setState: "$el.checked ? main_search.state.types.add('article') :  main_search.state.types.delete('article')",
            disabled: 'main_search.state.loading'
        %}
      {% endif %}
      {% if show_page %}
        {% render '_components.checkbox',
            class: checkbox_class,
            label: 'Pages',
            value: 'page',
            default_checked: page_active,
            setState: "$el.checked ? main_search.state.types.add('page') :  main_search.state.types.delete('page')",
            disabled: 'main_search.state.loading'
        %}
      {% endif %}
    </fieldset>
  {% endif %}

  {% if style == 'radio_button' %}
    <fieldset data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
              class="filter-radio-buttons flex gap-1.5 flex-wrap">
      {% if show_product %}
        <label x-data="{ checked: $el.firstElementChild.checked }"
               class="shrink-0 !outline-none cursor-pointer {{ radio_button_class }}"
               :class="utils.clsx(checked ? 'active' : '', main_search.state.loading && 'pointer-events-none')"
               aria-label="Products">
          <input type="checkbox"
                 class="sr-only"
                 @change="checked = $el.checked; $el.checked ? main_search.state.types.add('product') : main_search.state.types.delete('product')"
                 :disbaled="main_search.state.loading"
              {% if product_active %}
                checked="checked"
              {% endif %}
                 value="product">
          <span>Products</span>
        </label>
      {% endif %}
      {% if show_article %}
        <label x-data="{ checked: $el.firstElementChild.checked }"
               class="shrink-0 !outline-none cursor-pointer {{ radio_button_class }}"
               :class="utils.clsx(checked ? 'active' : '', main_search.state.loading && 'pointer-events-none')"
               aria-label="Articles">
          <input type="checkbox"
                 class="sr-only"
                 @change="checked = $el.checked; $el.checked ? main_search.state.types.add('article') :  main_search.state.types.delete('article')"
                 :disbaled="main_search.state.loading"
              {% if article_active %}
                checked="checked"
              {% endif %}
                 value="article">
          <span>Articles</span>
        </label>
      {% endif %}
      {% if show_page %}
        <label x-data="{ checked: $el.firstElementChild.checked }"
               class="shrink-0 !outline-none cursor-pointer {{ radio_button_class }}"
               :class="utils.clsx(checked ? 'active' : '', main_search.state.loading && 'pointer-events-none')"
               aria-label="Pages">
          <input type="checkbox"
                 class="sr-only"
                 @change="checked = $el.checked; $el.checked ? main_search.state.types.add('page') :  main_search.state.types.delete('page')"
                 :disbaled="main_search.state.loading"
              {% if page_active %}
                checked="checked"
              {% endif %}
                 value="page">
          <span>Pages</span>
        </label>
      {% endif %}
    </fieldset>
  {% endif %}
{% endcapture %}

{% capture html_attributes %}
  data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
  {% if show_search_conditionally == 'search_empty' and search.results_count > 0 %}x-cloak{% endif %}
  {% if show_search_conditionally == 'items_found' and search.results_count <= 0 %}x-cloak{% endif %}
  x-show="main_search.showConditionally(`{{ show_search_conditionally }}`) || $editor.select_block_id === `{{ block.id }}` || $el.querySelector(`[data-style-id='${$editor.select_section_id}--${$editor.select_block_id}']`)"
{% endcapture %}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

{% render '_components.collapsible', label: label, content: filter_content, default_open: open_accordion, class: accordion_class, html_attributes: html_attributes %}

{% schema %}

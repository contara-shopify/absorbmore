      "default": "accordion"
    },
    {
      "type": "select",
      "id": "default_state",
      "label": "Default state",
      "default": "hide",
      "options": [
        {
          "value": "show",
          "label": "Open"
        },
        {
          "value": "hide",
          "label": "Closed"
        }
      ]
    },
    {
      "type": "header",
      "content": "Filter Options"
    },
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "default": "checkbox",
      "options": [
        {
          "value": "checkbox",
          "label": "Checkbox"
        },
        {
          "value": "radio_button",
          "label": "Button"
        }
      ]
    },
    {
      "type": "text",
      "id": "checkbox_class",
      "label": "Checkbox class",
      "default": "input-checkbox"
    },
    {
      "type": "text",
      "id": "radio_button_class",
      "label": "Radio button class",
      "default": "button-primary-sm"
    },
    {
      "type": "header",
      "content": "Types"
    },
    {
      "type": "checkbox",
      "id": "show_product",
      "label": "Product",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_article",
      "label": "Article",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_page",
      "label": "Page",
      "default": true
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Search Type Filter",
      "category": "** Search **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_search__search_type_filter"
}
{% endschema %}

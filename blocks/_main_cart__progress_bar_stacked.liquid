{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_cart__progress_bar_stacked"
  assign section_type = "main_cart"
  assign show_conditionally = block.settings.show_conditionally
  assign incentive_type = block.settings.incentive_type
  assign success_bg_color = block.settings.success_bg_color
  assign success_border_color = block.settings.success_border_color
  assign base_bg_color = block.settings.base_bg_color
  assign base_border_color = block.settings.base_border_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<section data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
         x-show="_cart.showConditionally(`{{ show_conditionally }}`) || $editor?.select_block_id === `{{ block.id }}`"
  {% if show_conditionally == 'cart_empty' and cart.item_count > 0 %}x-cloak{% endif %}
  {% if show_conditionally == 'items_added' and cart.item_count <= 0 %}x-cloak{% endif %}
         x-data="{
             settings: utils.JSONParse($el.getAttribute('data-settings')),
             current: 0,
             targets: [...$el.querySelectorAll('[data-progress-bar-target]')]?.map(node => +node.getAttribute('data-progress-bar-target'))?.sort((a, b) => a - b),
             gifts: [],
             percentages: [],
             icons: [],
             success_icons: [],
             currentIndex: 0,
           }"
         x-effect="() => {
             current = $cart.state?.[settings.incentive_type] ?? 0;
             percentages = targets.map((target, i, arr)=> [Math.max(0, Math.min(1, (current - (arr[i - 1] ?? 0)) / (target - (arr[i - 1] ?? 0)))) * 100, i, target]);
             icons = targets.map(target => $el.querySelector(`[data-progress-bar-target='${target}']`)?.getAttribute('data-progress-bar-icon'));
             success_icons = targets.map(target => $el.querySelector(`[data-progress-bar-target='${target}']`)?.getAttribute('data-progress-bar-success-icon'));
             currentIndex = percentages.find(([percent])=> percent > 0 && percent < 100)?.[1] ?? percentages.find(([percent,i,target]) => percent === 0)?.[1] ?? percentages.findLast(([percent,i,target]) => percent === 100)?.[1];

             percentages.forEach(([percentage, index, target]) => {
               if (percentage >= 100 && gifts[index]?.variants?.[0]?.available && !$cart.state?.items?.some(item=> item.properties?._gift_item_id === `Gift Item - ${index}`) && !$cart.loading && !$cart.isChanging && !Object.keys($cart.debounce_updates ?? {})?.length) {
                 $nextTick(() => {
                    if ($cart.loading || $cart.isChanging || Object.keys($cart.debounce_updates ?? {})?.length) return;
                    $cart.loading = true;
                    _cart.add({ items: [{ id: gifts[index]?.variants?.[0]?.id, quantity: 1, properties: { _gift_item_id: `Gift Item - ${index}` }}] }).finally(() => { $cart.loading = false })
                  })
               }
               if (percentage < 100 && gifts[index]?.variants?.[0]?.id && $cart.state?.items?.some(item=> item.properties?._gift_item_id === `Gift Item - ${index}`) && !$cart.loading && !$cart.isChanging && !Object.keys($cart.debounce_updates ?? {})?.length) {
                 $nextTick(() => {
                   if ($cart.loading || $cart.isChanging || Object.keys($cart.debounce_updates ?? {})?.length) return;
                   _cart.updateLineItemQuantity(0, $cart.state?.items?.findIndex(item=> item.properties?._gift_item_id === `Gift Item - ${index}` ));
                 })
               }
             })
           }"
         data-settings="{{ block.settings | json | escape }}"
         class="relative flex flex-col"
         style="--success-bg-color: {{ success_bg_color }};--success-border-color: {{ success_border_color }}; --base-bg-color: {{ base_bg_color }};--base-border-color: {{ base_border_color }};">
  <header class="flex flex-col [&_a]:underline">
    {% content_for "blocks" %}
  </header>
  <footer class="grid mt-5" style="grid-template-columns: 50% repeat({{ block.blocks | size | minus: 1 }}, 1fr)">
    {% for _ in block.blocks %}
      <div x-data="{ percent: percentages.find(([percent, i, target])=> i === +`{{ forloop.index0 }}`)[0], order: percentages.findIndex(([percent, i, target])=> i === +`{{ forloop.index0 }}`), index: +`{{ forloop.index0 }}` }"
           x-effect="()=> {
               order = percentages.findIndex(([percent, i, target])=> i === index)
               percent = percentages[order][0];
             }"
           class="relative flex w-full bg-[--base-bg-color] p-px transition-all duration-150 ease-linear first-of-type:rounded-l-full last-of-type:rounded-r-full"
           :style="`order: ${order};`">
        <div class="relative h-[14px] flex-1 overflow-hidden rounded-l-full bg-[--base-bg-color]">
          <div class="relative h-full rounded-full bg-[--success-bg-color] transition-all duration-150 ease-linear"
               :style="`width: ${percent}%`"></div>
        </div>
        <div class="absolute top-1/2 flex h-9 -translate-y-1/2 flex-col justify-between transition-all duration-150 ease-linear -translate-x-1/2 left-0"
             :class="index === currentIndex && percent !== 100 ? '' : '!hidden'"
             :style="`left: ${percent}%`">
          <div style="border-top: 9px solid currentColor; border-left: 9px solid transparent; border-right: 9px solid transparent;"></div>
          <div style="border-bottom: 9px solid currentColor; border-left: 9px solid transparent; border-right: 9px solid transparent;"></div>
        </div>
        <img :src="icons[index]" x-show="percent !== 100" class="absolute top-1/2 -right-2 z-10 block size-8 -translate-y-1/2 rounded-full">
        <img :src="success_icons[index]"
             x-show="percent === 100"
             class="absolute top-1/2 -right-2 z-10 block size-8 -translate-y-1/2 rounded-full">
      </div>
    {% endfor %}
  </footer>
</section>

{% schema %}
{
  "name": "Progress Bar: Stacked",
  "settings": [
    {
      "type": "select",
      "id": "show_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "cart_empty",
          "label": "Cart Empty"
        },
        {
          "value": "items_added",
          "label": "Items Added"
        }
      ]
    },
    {
      "type": "header",
      "content": "Incentive Targets"
    },
    {
      "type": "paragraph",
      "content": "Important. This section does not create actual discounts. All discounts need to be created in the Shopify Admin Dashboard to match the settings here."
    },
    {
      "type": "select",
      "id": "incentive_type",
      "label": "Incentive Targets",
      "default": "total_price",
      "options": [
        {
          "value": "total_price",
          "label": "Amount based"
        },
        {
          "value": "item_count",
          "label": "Quantity based"
        }
      ]
    },
    {
      "type": "header",
      "content": "Styling Settings"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "success_bg_color",
      "label": "Success color",
      "default": "#4fd351"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "success_border_color",
      "label": "Success Border color",
      "default": "#4fd351"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "base_bg_color",
      "label": "Base color",
      "default": "#cacacc"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "base_border_color",
      "label": "Base Border color",
      "default": "#d3d3d3"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "blocks": [
    {
      "type": "_main_cart__progress_bar_stacked_target"
    }
  ],
  "presets": [
    {
      "name": "Progress Bar: Stacked",
      "category": "** Cart **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_cart__progress_bar_stacked"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_product__quantity_selector"
  assign section_type = "main_product"
  assign label = block.settings.label
  assign label_class = block.settings.label_class
  assign quantity_class = block.settings.quantity_class
  assign quick_view_visibility = block.settings.quick_view_visibility
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>
  {{ custom_css | replace: '&', selector | strip_newlines }}
</style>

<fieldset data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
          data-quick-view-visibility="{{ quick_view_visibility }}">
  {% if label != blank %}
    <legend class="{{ label_class }}">{% render '_input.inline_richtext', content: label %}</legend>
  {% endif %}
  {% render '_components.quantity_stepper',
      class: quantity_class,
      name: "value",
      setState: "pdp.quantity = +value;",
      state: "pdp.quantity ?? 1",
      max: "pdp.quantity_limit",
      disabled: "pdp.quantity_limit <= 0"
  %}
</fieldset>


{% schema %}
{
  "name": "Quantity selector",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "label",
      "label": "Label",
      "default": "Quantity",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "text",
      "id": "label_class",
      "label": "Label class",
      "default": "richtext-md h5"
    },
    {
      "type": "text",
      "id": "quantity_class",
      "label": "Quantity class",
      "default": "quantity-stepper"
    },
    {
      "type": "header",
      "content": "Quick View Settings"
    },
    {
      "type": "select",
      "id": "quick_view_visibility",
      "label": "Quick View Visibility",
      "default": "default",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "hidden",
          "label": "hidden"
        },
        {
          "value": "mobile_header",
          "label": "Mobile Header"
        },
        {
          "value": "quick_view_only",
          "label": "Quick view only"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "You can additionally style elements using the Custom CSS, by targeting: '.quick-view & {}'"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Quantity selector",
      "category": "** Product **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_product__quantity_selector"
}
{% endschema %}

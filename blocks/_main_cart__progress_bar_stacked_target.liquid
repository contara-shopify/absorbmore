{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_cart__progress_bar_stacked_target"
  assign section_type = "main_cart"
  assign target = block.settings.target
  assign icon = block.settings.icon
  assign success_icon = block.settings.success_icon
  assign incentive_message = block.settings.incentive_message
  assign success_message = block.settings.success_message
  assign content_class = block.settings.content_class
  assign gift_product = block.settings.gift_product
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

<div x-data="{ index: percentages.findIndex(discount => discount[2] === +`{{ target }}`) }"
     data-progress-bar-target="{{ target }}"
     data-progress-bar-icon="{{ icon | image_url }}"
     data-progress-bar-success-icon="{{ success_icon | image_url }}"
     class="flex">
  {% if gift_product != blank %}
    <script type="application/json"
            x-init="gifts[index] = utils.JSONParse($el.innerHTML); $el.remove();">{% render '_json.product', product: gift_product, card: true, meta_product: true %}</script>
  {% endif %}
  <div x-cloak
       x-show="percentages[index][0] === 100">{% render '_input.richtext', content: success_message, class: content_class %}
  </div>
  <div x-cloak
       x-show="percentages[index][0] !== 100"
       x-html="$el.getAttribute('data-content')?.replace('[difference]', settings.incentive_type === 'total_price' ? utils.formatMoney(targets[index] - current) : `${targets[index] - current}`)"
       data-content="{% render '_input.richtext', content: incentive_message, class: content_class, escape: true, skip_pluralization: true %}"></div>
</div>

{% schema %}
{
  "name": "Incentive Target",
  "settings": [
    {
      "type": "number",
      "id": "target",
      "label": "Target",
      "default": 10000,
      "info": "Use cents for target calculation based on amount (i.e. For a target of $39,40 set this to 3940)"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon"
    },
    {
      "type": "image_picker",
      "id": "success_icon",
      "label": "Success icon"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "paragraph",
      "content": "Use [difference] as a placeholder for the calculated difference amount based on the current cart total and the target."
    },
    {
      "type": "richtext",
      "id": "incentive_message",
      "label": "Incentive message",
      "default": "<h6>You are [difference] from <strong>Free Shipping</strong></h6>",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "richtext",
      "id": "success_message",
      "label": "Success message",
      "default": "<h6><strong>You've unlocked Free Shipping</strong></h6>",
      "info": "This will only show for the last / highest target. [Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "text",
      "id": "content_class",
      "label": "Content class",
      "default": "richtext-md"
    },
    {
      "type": "header",
      "content": "Gift Item"
    },
    {
      "type": "paragraph",
      "content": "Important: Adding gift items here does not create any related discounts. All discounts for gift items should be set up as Automatic Discounts or via Shopify Functions."
    },
    {
      "type": "product",
      "id": "gift_product",
      "label": "Gift Product"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    }
  ],
  "presets": [
    {
      "name": "Incentive Target",
      "category": "** Cart **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_cart__progress_bar_stacked_target"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_product__dynamic_text"
  assign section_type = "main_product"
  assign title = block.settings.title
  assign text_alignment = block.settings.text_alignment
  assign type_richtext_metafield = block.settings.type_richtext_metafield
  assign css_class = block.settings.css_class
  assign link_to_product = block.settings.link_to_product
  assign quick_view_visibility = block.settings.quick_view_visibility
  assign text_color = block.settings.text_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  if type_richtext_metafield != blank
    assign title = type_richtext_metafield
  endif

  assign product = section.settings.product | default: product
  if section.settings.default_variant_metafield != blank
    assign variant_namespace = section.settings.default_variant_metafield | strip | split: "." | first
    assign variant_key = section.settings.default_variant_metafield | strip | split: "." | last
    assign variant = product.metafields[variant_namespace][variant_key].value | default: variant
  endif

  assign variant = variant | default: product.selected_or_first_available_variant | default: product.variants.first

%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank and text_color.alpha != 0 %}{% capture css %}& { color: {{ text_color }}; }{% endcapture %}{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

{% capture dynamic_parsed_content %}{% render '_input.dynamic_content', content: title, keys: 'product, selected_variant', product: product, selected_variant: variant %}{% endcapture %}

{% if title contains '[selected_' %}
  {% assign is_dynamic = true %}
{% endif %}
{% if dynamic_parsed_content == blank and is_dynamic != true %}
  {% break %}
{% endif %}

<div
    data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }} {{ block.shopify_attributes }}
    data-quick-view-visibility="{{ quick_view_visibility }}"
    x-ignore
    class="{{ text_alignment | prepend: 'text-' }}"
    {% if is_dynamic %}
      x-data="{ content: getDynamicText($el.getAttribute('data-content')), content_check: getDynamicText($el.getAttribute('data-content-check')) }"
      data-content="{% render '_input.richtext', content: title, class: css_class, escape: true, skip_pluralization: true %}"
      data-content-check="{{ title | strip_html | escape }}"
      x-effect="() => { if (pdp.selected_variant) { content = getDynamicText($el.getAttribute('data-content')); content_check = getDynamicText($el.getAttribute('data-content-check')); utils.hideIfEmpty($el, `{{ hide_if_empty }}`, !content_check.trim()) } }"
      x-html="content"
      {% if show_conditionally != 'always' %}
        x-cloak
        x-show="!!content_check.trim() && $editor.select_block_id === `{{ block_id }}`"
      {% endif %}
    {% endif %}
    {% if link_to_product %}
      aria-label="{{ product.title }}"
      role="link"
      tabindex="0"
      x-init="utils.simulateAnchorTag($el)"
      {% if open_in_new_tab %}
        data-target="_blank"
      {% endif %}
      :data-href="`${_stores.router?.pathname?.replace(/^.*?(\/collections\/[^/]*)?.*$/gi,'$1')?.replace(/^\/$/gi,'') ?? ''}/products/${pdp.product_handle}?variant=${pdp.selected_variant?.id}`"
      data-href="{{ product.url | within: collection }}"
    {% endif %}
>
  {% render '_input.richtext', content: dynamic_parsed_content, class: css_class %}
</div>

{% schema %}
{
  "name": "Dynamic Text",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Content",
      "default": "<h3>[product.title]</h3>",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use bracket notation for data access: i.e.[product.title] or [selected_variant.metafields.smart.short_description]."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Auto"
        },
        {
          "value": "left",
          "label": "←"
        },
        {
          "value": "center",
          "label": "↔"
        },
        {
          "value": "right",
          "label": "→"
        }
      ]
    },
    {
      "type": "text",
      "id": "type_richtext_metafield",
      "label": "Type richtext metafield",
      "info": "Use bracket notation as above. This overrides the `Content` field."
    },
    {
      "type": "text",
      "id": "css_class",
      "label": "Type CSS class",
      "default": "richtext-md"
    },
    {
      "type": "paragraph",
      "content": "[Available keys](https://shopify.dev/docs/api/liquid/objects/product)"
    },
    {
      "type": "checkbox",
      "id": "link_to_product",
      "label": "Link to product",
      "default": false
    },
    {
      "type": "header",
      "content": "Quick View Settings"
    },
    {
      "type": "select",
      "id": "quick_view_visibility",
      "label": "Quick View Visibility",
      "default": "default",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "hidden",
          "label": "hidden"
        },
        {
          "value": "mobile_header",
          "label": "Mobile Header"
        },
        {
          "value": "quick_view_only",
          "label": "Quick view only"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "You can additionally style elements using the Custom CSS, by targeting: '.quick-view & {}'"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Dynamic Text",
      "category": "** Product **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_product__dynamic_text"
}
{% endschema %}

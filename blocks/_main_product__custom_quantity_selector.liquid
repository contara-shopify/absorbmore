{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_product__custom_quantity_selector"
  assign section_type = "main_product"
  assign legend = block.settings.legend
  assign legend_class = block.settings.legend_class
  assign quick_view_visibility = block.settings.quick_view_visibility
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>
  {{ custom_css | replace: '&', selector | strip_newlines }}
</style>

<div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }} {{ hide_attribute }}
     data-quick-view-visibility="{{ quick_view_visibility }}">
  <legend id="legend-{{ block.id }}"
          class="flex w-full max-w-full truncate {{ legend_class }}">
    {% render '_input.inline_richtext', content: legend %}
  </legend>
  <fieldset aria-labelledby="legend-{{ block.id }}"
            class="relative w-full flex scrollbar-none">
    {% content_for 'blocks' %}
  </fieldset>
</div>

{% schema %}
{
  "name": "Custom Quantity Selector",
  "settings": [
    {
      "type": "header",
      "content": "Option title"
    },
    {
      "type": "inline_richtext",
      "id": "legend",
      "label": "Heading",
      "default": "Quantity",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "text",
      "id": "legend_class",
      "label": "Heading class",
      "default": "richtext-md h5"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Value"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Inline Layout"
    },
    {
      "type": "header",
      "content": "Quick View Settings"
    },
    {
      "type": "select",
      "id": "quick_view_visibility",
      "label": "Quick View Visibility",
      "default": "default",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "hidden",
          "label": "hidden"
        },
        {
          "value": "mobile_header",
          "label": "Mobile Header"
        },
        {
          "value": "quick_view_only",
          "label": "Quick view only"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "You can additionally style elements using the Custom CSS, by targeting: '.quick-view & {}'"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n\n}\n& legend {\n  margin-bottom: 6px;\n}\n& fieldset {\n  gap: 6px;\n}\n@media (max-width: 1024px) {\n  & {\n    \n  }\n}"
    }
  ],
  "blocks": [
    {
      "type": "_main_product__custom_quantity"
    }
  ],
  "presets": [
    {
      "name": "Custom Quantity Selector",
      "category": "** Product **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_product__custom_quantity_selector"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_search__container"
  assign section_type = "main_search"
  assign show_search_conditionally = block.settings.show_search_conditionally
  assign element_id = block.settings.element_id
  assign custom_effect = block.settings.custom_effect
  assign url = block.settings.url
  assign accessibility_label = block.settings.accessibility_label
  assign open_in_new_tab = block.settings.open_in_new_tab
  assign scroll_reveal = block.settings.scroll_reveal
  assign collapsible_handle = block.settings.collapsible_handle
  assign show = block.settings.show
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture html_attributes %}
  {% if show_search_conditionally == 'search_empty' and search.results_count > 0 %}x-cloak{% endif %}
  {% if show_search_conditionally == 'items_found' and search.results_count <= 0 %}x-cloak{% endif %}
  x-show="main_search.showConditionally(`{{ show_search_conditionally }}`) || $editor.select_block_id === `{{ block.id }}` || $el.querySelector(`[data-style-id='${$editor.select_section_id}--${$editor.select_block_id}']`)"
{% endcapture %}

{% liquid
  capture blocks_content
    content_for 'blocks'
  endcapture

  capture container_content
    render '_block.container', block: block, blocks_content: blocks_content, html_attributes: html_attributes
  endcapture

  if container_content contains '<script type="container/break"></script>'
    break
  endif
  echo container_content
%}

{% schema %}
{
  "name": "Container",
  "settings": [
    {
      "type": "select",
      "id": "show_search_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "no_search_query",
          "label": "No Search Query"
        },
        {
          "value": "with_search_query",
          "label": "With Search Query"
        },
        {
          "value": "search_empty",
          "label": "Empty"
        },
        {
          "value": "items_found",
          "label": "With Items"
        }
      ]
    },
    {
      "type": "text",
      "id": "element_id",
      "label": "Element ID"
    },
    {
      "type": "select",
      "id": "custom_effect",
      "label": "Custom effect",
      "default": "off",
      "options": [
        {
          "value": "off",
          "label": "Off"
        },
        {
          "value": "scroll_reveal",
          "label": "Scroll Reveal"
        },
        {
          "value": "collapsible",
          "label": "Collapsible"
        },
        {
          "value": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Link Settings",
      "visible_if": "{{ block.settings.custom_effect == 'link' }}"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Url",
      "visible_if": "{{ block.settings.custom_effect == 'link' }}"
    },
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Accessibility label",
      "info": "Please provide an accessibility label if the link has generic content. I.e. 'Read More' or only uses an image or icon.",
      "visible_if": "{{ block.settings.custom_effect == 'link' }}"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open in new tab",
      "default": false,
      "visible_if": "{{ block.settings.custom_effect == 'link' }}"
    },
    {
      "type": "header",
      "content": "Scroll Reveal Settings",
      "visible_if": "{{ block.settings.custom_effect == 'scroll_reveal' }}"
    },
    {
      "type": "select",
      "id": "scroll_reveal",
      "label": "Scroll Reveal",
      "default": "children",
      "options": [
        {
          "value": "container",
          "label": "Box"
        },
        {
          "value": "children",
          "label": "Spread"
        }
      ],
      "visible_if": "{{ block.settings.custom_effect == 'scroll_reveal' }}"
    },
    {
      "type": "header",
      "content": "Collapsible Content",
      "visible_if": "{{ block.settings.custom_effect == 'collapsible' }}"
    },
    {
      "type": "paragraph",
      "content": "In order for collapsible containers to operate, you will need to add a button targeting the trigger handle. Trigger handles have to be unique per page.",
      "visible_if": "{{ block.settings.custom_effect == 'collapsible' }}"
    },
    {
      "type": "text",
      "id": "collapsible_handle",
      "label": "Collapsible Trigger Handle",
      "visible_if": "{{ block.settings.custom_effect == 'collapsible' }}"
    },
    {
      "type": "checkbox",
      "id": "show",
      "label": "Default Open",
      "visible_if": "{{ block.settings.custom_effect == 'collapsible' }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "header",
      "content": "Development Integration",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "select",
      "id": "generate_block_presets",
      "label": "Presets Codegen",
      "default": "never",
      "options": [
        {
          "value": "never",
          "label": "Off"
        },
        {
          "value": "always",
          "label": "On"
        },
        {
          "value": "manual_override",
          "label": "Override"
        }
      ],
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "text",
      "id": "category_name",
      "label": "Category",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "text",
      "id": "hidden_name_backup",
      "label": " Hidden Name Backup",
      "visible_if": "{{ settings.development__dev_mode == 'show_never' }}"
    },
    {
      "type": "paragraph",
      "content": "Setting the preset to 'Override' and running the dev tools will override the existing manual preset if the names match. NB: This should be switched off right after updated a Preset!",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "@theme"
    },
    {
      "type": "richtext"
    },
    {
      "type": "slider"
    },
    {
      "type": "_filter_tags"
    },
    {
      "type": "_main_search__product_count"
    },
    {
      "type": "_main_search__dynamic_text"
    },
    {
      "type": "_main_search__container"
    },
    {
      "type": "_main_search__collapsible"
    },
    {
      "type": "_main_search__filter_sidebar"
    },
    {
      "type": "_main_search__applied_filters"
    },
    {
      "type": "_main_search__filters"
    },
    {
      "type": "_main_search__sort"
    },
    {
      "type": "_main_search__filter_submit_button"
    },
    {
      "type": "_main_search__filter_clear_button"
    },
    {
      "type": "_main_search__filter_button"
    },
    {
      "type": "_main_search__mixed_cards"
    },
    {
      "type": "_main_search__empty_state"
    },
    {
      "type": "_main_search__search_input"
    }
  ],
  "presets": [
    {
      "name": "Container",
      "category": "** Search **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_search__container"
}
{% endschema %}

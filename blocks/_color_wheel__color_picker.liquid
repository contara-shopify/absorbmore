{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_color_wheel__color_picker"
  assign section_type = "color_wheel"
  assign image = block.settings.image
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<button data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
        type="button"
        class="relative rounded-full overflow-hidden active:cursor-grabbing"
        @click="$data.color_wheel.selectColor"
        @mousedown="$data.color_wheel.startDragging"
        @mouseup.prevent="$data.color_wheel.stopDragging">
  <div
      x-show="color_wheel.state.clickXPercent !== null && color_wheel.state.clickYPercent !== null"
      :style="`left: ${color_wheel.state.clickXPercent * 100}%; top: ${color_wheel.state.clickYPercent * 100}%`"
      class="absolute size-10 border-2 border-white rounded-full transform -translate-x-1/2 -translate-y-1/2 pointer-events-none"
  ></div>
  {% render '_object.image', image: image, class: "w-full h-full transition-all object-[inherit] select-none pointer-events-none" %}
</button>

{% schema %}
{
  "name": "Color Picker",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Color Picker",
      "category": "** Color Wheel **"
    }
  ],
  "tag": null,
  "class": "shopify_block___color_wheel__color_picker"
}
{% endschema %}

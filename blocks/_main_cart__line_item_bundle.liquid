{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_cart__line_item_bundle"
  assign section_type = "main_cart"
  assign show_conditionally = block.settings.show_conditionally
  assign content = block.settings.content
  assign text_alignment = block.settings.text_alignment
  assign content_class = block.settings.content_class
  assign product_card_class = block.settings.product_card_class
  assign button_label = block.settings.button_label
  assign button_class = block.settings.button_class
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

{% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
  {% capture css %}
    & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    }
  {% endcapture %}
{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

<div
  data-style-id="{{ section.id }}--{{ block.id }}"
  {{ block.shopify_attributes }}
  x-show="$cart?.state?.item_count === 1 && $cart.bundle?.parent && !$cart.bundle?.added && (_cart.showConditionally(`{{ show_conditionally }}`) || $editor?.select_block_id === `{{ block.id }}`)"
  {% if show_conditionally == 'cart_empty' and cart.item_count > 0 %}
    x-cloak
  {% endif %}
  {% if show_conditionally == 'items_added' and cart.item_count <= 0 %}
    x-cloak
  {% endif %}
>
  <div
    class="{{ text_alignment | prepend: 'text-' }}"
    x-show="_cart.getBundleParentDynamicTextWithFormattedPrice($el.getAttribute('data-content'), $cart.bundle?.child)"
    data-content="{% render '_input.richtext', content: content, class: content_class, escape: true %}"
    x-html="_cart.getBundleParentDynamicTextWithFormattedPrice($el.getAttribute('data-content'), $cart.bundle?.child)"
  ></div>

  <div
    class="shrink-0 max-w-full w-full order-[--order]"
    :data-product-handle="$cart.bundle.parent?.handle"
  >
    <section
      class="card-loading product-card--{{ product_card_class }}"
      data-card-handle="{{ product_card_class }}"
      :data-product-handle="$cart.bundle.parent?.handle"
      :data-product-id="$cart.bundle.parent?.id"
      {% if request.visual_preview_mode %}
        data-intersected
      {% endif %}
      x-init="$nextTick(() => _sections.hydrateProductCard($el))"
    ></section>
  </div>

  {% if button_label != blank %}
    <button
      class="w-full {{ button_class }}"
      @click="_cart.upgradeLineItemToBundle"
      :class="$cart.loading || $cart.isChanging ? 'button-loading' : ''"
    >
      {% render '_input.inline_richtext', content: button_label %}
    </button>
  {% endif %}
</div>

{% schema %}
{
  "name": "Line Item Bundle",
  "settings": [
    {
      "type": "select",
      "id": "show_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "cart_empty",
          "label": "Cart Empty"
        },
        {
          "value": "items_added",
          "label": "Items Added"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "paragraph",
      "content": "Content accepts 'product' object access via the bracket notation. i.e.'[product.title]' "
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Auto"
        },
        {
          "value": "left",
          "label": "←"
        },
        {
          "value": "center",
          "label": "↔"
        },
        {
          "value": "right",
          "label": "→"
        }
      ]
    },
    {
      "type": "text",
      "id": "content_class",
      "label": "Content Class",
      "default": "richtext-md"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Display Settings"
    },
    {
      "type": "text",
      "id": "product_card_class",
      "label": "Product card class",
      "default": "product-card"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "inline_richtext",
      "id": "button_label",
      "label": "Button Label",
      "default": "Upgrade to bundle"
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button Class",
      "default": "button-secondary"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Line Item Bundle",
      "category": "** Cart **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_cart__line_item_bundle"
}
{% endschema %}

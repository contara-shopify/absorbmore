{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_card__text"
  assign section_type = "card"
  assign content = block.settings.content
  assign text_alignment = block.settings.text_alignment
  assign css_class = block.settings.css_class
  assign link_to_object = block.settings.link_to_object
  assign text_color = block.settings.text_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% if request.design_mode or metaobjects.product_cards[section.settings.product_card] == blank %}
  {% capture selector %}[data-style-id="{{ block.id | split: "__" | last }}"]{% endcapture %}
  {% if text_color != blank and text_color.alpha != 0 %}{% capture css %}& { color: {{ text_color }}; }{% endcapture %}{% endif %}

  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
    {% if request.design_mode %}
    {% assign query_selector = '[data-section-id="'|append: section.id | append: '"][data-preview-container] ' | append: selector %}
    {{-  css | append:custom_css | replace: '&', query_selector  | strip_newlines | replace: '@media screen and', '@container'| replace: '@media', '@container' -}}
    {% endif %}
  </style>
{% endif %}

<div data-style-id="{{ block.id | split: "__" | last }}" {{ block.shopify_attributes }}
     x-ignore
     x-data="{ content: getDynamicText($el.getAttribute('data-content')), content_check: getDynamicText($el.getAttribute('data-content-check')) }"
     class="{{ text_alignment | prepend: 'text-' }}"
     data-content="{% render '_input.richtext', content: content, class: css_class, escape: true, skip_pluralization: true %}"
     data-content-check="{{ content | strip_html | escape }}"
     x-effect="() => { if (card?.hydrated) { content = getDynamicText($el.getAttribute('data-content')) } }"
     x-show="!!content_check.trim()"
     x-cloak
    {% if link_to_object %}
      :aria-label="card?.title"
      role="link"
      tabindex="0"
      x-init="utils.simulateAnchorTag($el)"
      :data-href="card?.url"
    {% endif %}
     x-cloak>
  <div x-html="content"></div>
</div>

{% schema %}
{
  "name": "Richtext",
  "settings": [
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<h3>[title]</h3>",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk). Use bracket notation for data access: i.e.[title] or [metafields.smart.short_description]."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "inherit",
      "options": [
        {
          "value": "inherit",
          "label": "Auto"
        },
        {
          "value": "left",
          "label": "←"
        },
        {
          "value": "center",
          "label": "↔"
        },
        {
          "value": "right",
          "label": "→"
        }
      ]
    },
    {
      "type": "text",
      "id": "css_class",
      "label": "Type CSS class",
      "default": "richtext-md"
    },
    {
      "type": "paragraph",
      "content": "[Available keys](https://shopify.dev/docs/api/liquid/objects/product)"
    },
    {
      "type": "checkbox",
      "id": "link_to_object",
      "label": "Link to object",
      "default": false
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Richtext",
      "category": "** Card **"
    }
  ],
  "tag": null,
  "class": "shopify_block___card__text"
}
{% endschema %}

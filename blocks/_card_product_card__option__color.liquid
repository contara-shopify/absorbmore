{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_card_product_card__option__color"
  assign section_type = "card_product_card"
  assign legend = block.settings.legend
  assign legend_class = block.settings.legend_class
  assign primary_source = block.settings.primary_source
  assign fallback_source = block.settings.fallback_source
  assign show_tooltip = block.settings.show_tooltip
  assign select_on_hover = block.settings.select_on_hover
  assign content_flow = block.settings.content_flow
  assign truncate_text = block.settings.truncate_text
  assign sold_out_variants = block.settings.sold_out_variants
  assign option_type = block.settings.option_type
  assign match_option_titles = block.settings.match_option_titles
  assign match_option_index = block.settings.match_option_index
  assign match_exact_word = block.settings.match_exact_word
  assign custom_css = block.settings.custom_css
  assign show_conditionally = block.settings.show_conditionally
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  case content_flow
    when "show_all"
      assign container_classes = 'flex-wrap'
    when "truncate"
      assign container_classes = 'overflow-hidden'
    when "overflow"
      assign container_classes = 'overflow-x-auto'
  endcase
%}

{% if request.design_mode or metaobjects.product_cards[section.settings.product_card] == blank %}
  {% capture selector %}[data-style-id="{{ block.id | split: "__" | last }}"]{% endcapture %}

  <style>
    {{ custom_css | replace: '&', selector | strip_newlines }}
    {% if request.design_mode %}
    {% assign query_selector = '[data-section-id="'|append: section.id | append: '"][data-preview-container] ' | append: selector %}
    {{- custom_css | replace: '&', query_selector  | strip_newlines | replace: '@media screen and', '@container'| replace: '@media', '@container' -}}
    {% endif %}
  </style>
{% endif %}

{% capture option_settings %}
  {
  "block_id": "{{ block.id }}__0",
  "option_type": {{ option_type | json }},
  "match_option_index": {{ match_option_index | minus: 1 | json }},
  "match_option_titles": {{ match_option_titles | json }},
  "match_exact_word": {{ match_exact_word | json }}
  }
{% endcapture %}

{% for i in (0..2) %}
  {% if option_type == 'fallback_options' %}
    {% capture option_settings %}
      {
      "block_id": "{{ block.id }}__{{ i }}",
      "option_type": {{ option_type | json }},
      "match_option_index": {{ i | json }},
      "match_option_titles": {{ match_option_titles | json }},
      "match_exact_word": {{ match_exact_word | json }}
      }
    {% endcapture %}
  {% endif %}
  <div
      data-style-id="{{ block.id | split: "__" | last }}" {{ block.shopify_attributes }}
      @click.stop="()=>{}"
      data-options-block="{{ option_settings | escape }}"
      x-data="{ hoverValue: '', index: getOptionIndex(`{{ block.id }}__{{ i }}`), primary_source: `{{ primary_source }}`, fallback_source: `{{ fallback_source }}` }"
      x-effect="() => { if (p_card?.product?.id) { index = getOptionIndex(`{{ block.id }}__{{ i }}`) } }"
      x-cloak
      {% if sold_out_variants == 'hide' %}
        x-show="p_card?.hydrated && index !== -1 && p_card?.product?.options_with_values?.[index]?.values?.some(value => hasAvailableVariant(index, value)) && p_card?.product?.variants?.length && p_card?.product?.variants?.[0]?.title !== 'Default Title' && p_card?.selected_variant?.id && ($editor.select_block_id === `{{ block.id }}` || $data.showConditionally('{{ show_conditionally }}', $data?.bundle))"
      {% else %}
        x-show="p_card?.hydrated && index !== -1 && p_card?.product?.variants?.length && p_card?.product?.variants?.[0]?.title !== 'Default Title' && p_card?.selected_variant?.id && ($editor.select_block_id === `{{ block.id }}` || $data.showConditionally('{{ show_conditionally }}', $data?.bundle))"
      {% endif %} >
    <legend class="flex w-full max-w-full truncate {{ legend_class }}"
            data-legend="{% render '_input.inline_richtext', content: legend, escape: true %}"
            x-effect="$el.innerHTML = $el.getAttribute('data-legend').replace('[heading]',p_card?.product?.options?.[index]).replace('[value]', hoverValue || p_card?.selected_options?.[index])">
    </legend>
    <fieldset class="relative w-full flex scrollbar-none gap-1 {{ container_classes }}"
              x-data="{ offset: p_card?.product?.options_with_values?.[index]?.values?.length }">
      <template x-for="value in p_card?.product?.options_with_values?.[index]?.values?.slice(0, offset) ?? []">
        <label
            data-loop-item
            class="flex shrink-0 cursor-pointer border-gray-300 relative !outline-none border-none ac:border-solid"
            x-effect="$el.classList.toggle('active', p_card?.selected_options[index] === value)"
            {% if sold_out_variants == 'hide' %}
              x-show="hasAvailableVariant(index, value)"
            {% endif %}
            :class="hasAvailableVariant(index, value) ? '' : 'sold-out'"
            {% if select_on_hover and show_tooltip %}
              @mouseenter="$tooltip.addTooltip($el, value); $data.setProductOption({ index, value })"
              @mouseleave="$tooltip.removeTooltip($el)"
            {% elsif select_on_hover %}
              @mouseenter="$data.setProductOption({ index, value })"
            {% elsif show_tooltip %}
              @mouseenter="$tooltip.addTooltip($el, value)"
              @mouseleave="$tooltip.removeTooltip($el)"
            {% endif %}
            @pointerenter="hoverValue = value"
            @pointerleave="hoverValue = ''"
            :aria-label="value"
            :style="getOptionSwatches(primary_source, fallback_source, value, index)">
          <input
              type="radio"
              class="sr-only"
              {% if sold_out_variants == 'disable' %}
                :disabled="!hasAvailableVariant(index, value)"
              {% endif %}
              :name="`${p_card?.random_id}-${p_card?.product?.id}-${p_card?.product?.options[index]}-option__color`"
              {% if show_tooltip %}
                @focus="$tooltip.addTooltip($el.parentElement, value)"
                @blur="$tooltip.removeTooltip($el.parentElement)"
              {% endif %}
              @change="$data.setProductOption({ index, value })"
              :checked="p_card?.selected_options[index] === value"
              :value="value">
        </label>
      </template>
      {% if content_flow == 'truncate' %}
        <div class="flex shrink-0 items-center text-sm font-medium"
             :class="(offset + 1) < p_card?.product?.options_with_values?.[index]?.values?.length ? '':'opacity-0 pointer-events-none'"
             x-init="$nextTick(async ()=> { if (window.design_mode) { await utils.delay(20) } offset = utils.truncateChildren($el, $el.parentElement)})"
             @resize.window.debounce.200ms="offset = p_card?.product?.options_with_values?.[index]?.values?.length; await utils.delay(1); offset = utils.truncateChildren($el, $el.parentElement)"
             x-html="utils.applyInlinePluralization(`{{ truncate_text }}`.replace('[count]', `${p_card?.product?.options_with_values?.[index]?.values?.length - offset}`).replace('[option]', `${p_card?.product?.options?.[index]}`)) || ''">
          +10 placeholder
        </div>
      {% endif %}
    </fieldset>
  </div>
  {% if option_type != 'fallback_options' %}
    {% break %}
  {% endif %}
{% endfor %}

{% schema %}
{
  "name": "t:blocks.option_color_image_swatch.name",
  "settings": [
    {
      "type": "header",
      "content": "Option title"

    },
    {
      "type": "checkbox",
      "id": "select_on_hover",
      "label": "Select on hover"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Inline Layout"
    },
    {
      "type": "select",
      "id": "content_flow",
      "label": "Content flow",
      "default": "show_all",
      "options": [
        {
          "value": "show_all",
          "label": "Show all"
        },
        {
          "value": "truncate",
          "label": "Truncate"
        },
        {
          "value": "overflow",
          "label": "Slider"
        }
      ]
    },
    {
      "type": "text",
      "id": "truncate_text",
      "label": "Truncate text",
      "default": "+[count] [option]",
      "info": "Use [count] and [option] as placeholders for values.",
      "visible_if": "{{ block.settings.content_flow == 'truncate' }}"
    },
    {
      "type": "select",
      "id": "sold_out_variants",
      "label": "Sold Out Variants",
      "default": "",
      "options": [
        {
          "value": "",
          "label": "Show"
        },
        {
          "value": "hide",
          "label": "Hide"
        },
        {
          "value": "disable",
          "label": "Disable"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Match Option"
    },
    {
      "type": "select",
      "id": "option_type",
      "label": "Match Option type",
      "default": "by_name",
      "options": [
        {
          "value": "by_name",
          "label": "By Name"

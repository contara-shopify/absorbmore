{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_product__custom_quantity"
  assign section_type = "main_product"
  assign quantity = block.settings.quantity
  assign discount = block.settings.discount
  assign image = block.settings.image
  assign icon = block.settings.icon
  assign title = block.settings.title
  assign radio_button_class = block.settings.radio_button_class
  assign label_content = block.settings.label_content
  assign label_class = block.settings.label_class
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<label data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
       x-ignore
       class="relative shrink-0 flex flex-col border-gray-300 cursor-pointer  {% if quantity == 1 %}active{% endif %} {{ radio_button_class }}"
       x-init="if (pdp.quantity === +`{{ quantity }}`) { setDynamicPrice({discount: +`{{ discount }}` });  }"
       x-effect="$el.classList.toggle('active', pdp.quantity === +`{{ quantity }}`)">
  <input type="radio"
         class="sr-only"
         name="{{ block.id }}"
         @change="pdp.quantity = +$el.value; setDynamicPrice({ discount: +`{{ discount }}` });"
         :checked="pdp.quantity === +$el.value"
         value="{{ quantity }}">
  {% if label_content != blank %}
    <span class="!absolute bottom-full translate-y-1/2 left-1/2 -translate-x-1/2 {{ label_class }} {% if quantity == 1 %}active{% endif %}"
          x-effect="$el.classList.toggle('active', pdp.quantity === +`{{ quantity }}`)">
      {% render '_input.inline_richtext', content: label_content %}
    </span>
  {% endif %}
  {% if image != blank %}
    {% render '_object.image', image: image, class: 'h-5 mt-1.5' %}
  {% endif %}
  {% if icon != blank %}
    {% render '_components.icon', icon: icon, class: 'h-5 mt-1.5' %}
  {% endif %}
  <div>{% render '_input.inline_richtext', content: title %}</div>
</label>

{% schema %}
{
  "name": "Quantity",
  "settings": [
    {
      "type": "header",
      "content": "Quantity Multiplier"
    },
    {
      "type": "number",
      "id": "quantity",
      "label": "Quantity",
      "default": 1
    },
    {
      "type": "range",
      "id": "discount",
      "label": "Discount",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "radio_button_class",
      "label": "Radio button class",
      "default": "button-primary-sm"
    },
    {
      "type": "header",
      "content": "Top Label"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "text",
      "id": "label_content",
      "label": "Label content"
    },
    {
      "type": "text",
      "id": "label_class",
      "label": "Label class"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Quantity",
      "category": "** Product **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_product__custom_quantity"
}
{% endschema %}

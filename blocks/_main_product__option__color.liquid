    },
    {
      "type": "text",
      "id": "legend_class",
      "label": "Heading class",
      "default": "richtext-md h5"
    },
    {
      "type": "header",
      "content": "Swatches"
    },
    {
      "type": "select",
      "id": "primary_source",
      "label": "Primary source:",
      "default": "title",
      "options": [
        {
          "value": "title",
          "label": "Title"
        },
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "metafield",
          "label": "Metafield"
        }
      ]
    },
    {
      "type": "select",
      "id": "fallback_source",
      "label": "Fallback source:",

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_header_navigation_bar__burger_menu_button"
  assign section_type = "header_navigation_bar"
  assign url = block.settings.url
  assign submenu_handle = block.settings.submenu_handle
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<a data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
    {% if submenu_handle != blank %}
      @click="$modal.setSubId(`{{ submenu_handle }}`)"
    {% endif %}
   href="{{ url }}"
   :class="$modal.id === $el.href?.split('#').at(-1) ? 'active' :''"
   class="relative flex flex-col items-center justify-center group gap-[4px] shrink-0">
  <span class="sr-only">Main Menu</span>
  <span class="block h-[2px] w-5 rounded-full bg-current transition-all duration-[400ms] group-ac:-rotate-45 group-ac:translate-y-[calc(2px+4px)]"></span>
  <span class="block h-[2px] w-5 rounded-full bg-current transition-all duration-[400ms] group-ac:opacity-0"></span>
  <span class="block h-[2px] w-5 rounded-full bg-current transition-all duration-[400ms] group-ac:rotate-45 group-ac:translate-y-[calc(-2px-4px)]"></span>
</a>

{% schema %}
{
  "name": "Burger Menu",
  "settings": [
    {
      "type": "url",
      "id": "url",
      "label": "Url",
      "info": "#megamenu--sidebar-menu-shop"
    },
    {
      "type": "text",
      "id": "submenu_handle",
      "label": "Submenu handle",
      "default": "shop"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Burger Menu",
      "category": "** Navigation Bar **"
    }
  ],
  "tag": null,
  "class": "shopify_block___header_navigation_bar__burger_menu_button"
}
{% endschema %}

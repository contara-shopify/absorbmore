{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_product__rating"
  assign section_type = "main_product"
  assign reviews_heading = block.settings.reviews_heading
  assign css_class = block.settings.css_class
  assign url = block.settings.url
  assign icon = block.settings.icon
  assign icon_active_color = block.settings.icon_active_color
  assign icon_base_color = block.settings.icon_base_color
  assign hide_zero_reviews = block.settings.hide_zero_reviews
  assign quick_view_visibility = block.settings.quick_view_visibility
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  if icon_active_color.alpha > 0
    assign styles = styles | append: "--color-review-stars--hex:" | append: icon_active_color | append: ";"
  endif

  if icon_base_color.alpha > 0
    assign styles = styles | append: "--color-review-stars-base--hex:" | append: icon_base_color | append: ";"
  endif
%}
{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

{% capture meterStyling %}
  & {
  --star-size: 20px;
  --star-gap: 3px;
  }
  & meter {
  --star-size-with-gap: calc(var(--star-size) + var(--star-gap));

  display: block;
  position: relative;
  width: calc(var(--star-size-with-gap) * 5 - var(--star-gap));
  height: var(--star-size);
  background: var(--color-review-stars-base--hex);
  mask: var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }});
  mask-position: calc(var(--star-size-with-gap) * 0) 0, calc(var(--star-size-with-gap) * 1) 0, calc(var(--star-size-with-gap) * 2) 0, calc(var(--star-size-with-gap) * 3) 0, calc(var(--star-size-with-gap) * 4) 0;
  }

  & meter:-moz-meter-optimum::-moz-meter-bar {
  height: var(--star-size);
  background: var(--color-review-stars--hex);
  mask: var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }});
  mask-position: calc(var(--star-size-with-gap) * 0) 0, calc(var(--star-size-with-gap) * 1) 0, calc(var(--star-size-with-gap) * 2) 0, calc(var(--star-size-with-gap) * 3) 0, calc(var(--star-size-with-gap) * 4) 0;
  }

  /* The gray background in Webkit browsers */

  & meter::-webkit-meter-bar {
  background: transparent;
  border-radius: 0;
  border: 0;
  height: var(--star-size);
  }

  /* The bar in Webkit browsers */

  & meter::-webkit-meter-optimum-value {
  height: var(--star-size);
  background: var(--color-review-stars--hex);
  mask: var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }}), var(--icon-{{ icon | handleize }});
  mask-position: calc(var(--star-size-with-gap) * 0) 0, calc(var(--star-size-with-gap) * 1) 0, calc(var(--star-size-with-gap) * 2) 0, calc(var(--star-size-with-gap) * 3) 0, calc(var(--star-size-with-gap) * 4) 0;
  }

{% endcapture %}

<style>
  {{- meterStyling | replace: '&', selector  | strip_newlines  -}}
  {{ custom_css | replace: '&', selector | strip_newlines }}
</style>

{% liquid
  assign product = section.settings.product | default: product

  assign reviews_rating = settings.data__product__reviews_rating | replace: " ", '' | split: "."
  assign reviews_rating = product.metafields[reviews_rating.first][reviews_rating.last].value
  assign reviews_rating = reviews_rating.rating | default: reviews_rating | default: 0 | times: 1.0

  assign reviews_count = settings.data__product__reviews_count | replace: " ", '' | split: "."
  assign reviews_count = product.metafields[reviews_count.first][reviews_count.last].value | default: 0 | times: 1

  assign reviews_count_content = reviews_count
  assign reviews_rating_content = reviews_rating

  if reviews_rating <= 0
    assign reviews_count_content = 'No Rating'
    assign reviews_rating_content = ''
  endif
  assign reviews_content = reviews_heading | replace: "[count]", reviews_count_content | replace: "[rating]", reviews_rating_content
%}

{% if hide_zero_reviews != blank and reviews_count <= hide_zero_reviews %}
  {% break %}
{% endif %}

<label
    data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
    data-quick-view-visibility="{{ quick_view_visibility }}"
    x-ignore
    {% if url != blank %}
      role="link"
      tabindex="0"
      x-init="utils.simulateAnchorTag($el)"
      data-href="{{ url }}"
      class="cursor-pointer"
    {% endif %}
    aria-label="Product Rating"
    style="{{ styles }}">
  <meter class="relative block appearance-none shrink-0"
         value="{{ reviews_rating }}"
         min="0"
         max="5">
    <span>
      <span>{{ reviews_rating }}</span>/
      <span>5</span>
    </span>
  </meter>
  <label class="{{ css_class }} {% if url != blank %}cursor-pointer{% endif %}"
         x-cloak
         x-show="!!pdp.product?.reviews"
         data-content="{% render '_input.inline_richtext', content: reviews_heading, escape: true %}"
         x-html="$el.getAttribute('data-content').replace('[count]', pdp.product?.reviews?.review_count).replace('[rating]',pdp.product?.reviews?.rating || 'No rating')">
    {% render '_input.inline_richtext', content: reviews_content %}
  </label>
</label>

{% schema %}
{
  "name": "Rating",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "reviews_heading",
      "label": "Reviews heading",
      "default": "[rating] - based on [count] reviews",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk) Use [count] as a placeholder for the number of reviews, and [rating] for the product rating."
    },
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS Class",
      "default": "richtext-md h5"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Url"
    },
    {
      "type": "header",
      "content": "Rating Icons"
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Icon",
      "default": "star"
    },
    {
      "type": "header",
      "content": "Fallback Colors"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "icon_active_color",
      "label": "Icon active color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "icon_base_color",
      "label": "Icon base color"
    },
    {
      "type": "paragraph",
      "content": "Leave the colors empty to use the Global Theme Setting colors."
    },
    {
      "type": "header",
      "content": "Hide Reviews"
    },
    {
      "type": "number",
      "id": "hide_zero_reviews",
      "label": "Hide reviews if less than:"
    },
    {
      "type": "header",
      "content": "Quick View Settings"
    },
    {
      "type": "select",
      "id": "quick_view_visibility",
      "label": "Quick View Visibility",
      "default": "default",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "hidden",
          "label": "hidden"
        },
        {
          "value": "mobile_header",
          "label": "Mobile Header"
        },
        {
          "value": "quick_view_only",
          "label": "Quick view only"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "You can additionally style elements using the Custom CSS, by targeting: '.quick-view & {}'"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n  --star-size: 20px;\n  --star-gap: 0px;\n  display: block;\n  width: 100%;\n  height: auto;\n  aspect-ratio: unset;\n  border: unset;\n  background: unset;\n  padding: 0;\n}"
    }
  ],
  "presets": [
    {
      "name": "Rating",
      "category": "** Product **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_product__rating"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_search__color_override"
  assign section_type = "main_search"
  assign _handle = block.settings.handle
  assign open_by_default = block.settings.open_by_default
  assign show_tooltip = block.settings.show_tooltip
  assign show_empty_entries = block.settings.show_empty_entries
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign _handle = _handle | downcase | strip
  for filter in search.filters
    assign _label = filter.label | downcase | strip
    if _label == _handle and filter.type == 'list' or filter.type == 'boolean'
      assign _filter = filter
      break
    endif
  endfor

  if _filter == blank
    break
  endif

  if show_empty_entries == false
    assign filter_count_arr = _filter.values | where: 'count', 0

    if filter_count_arr.size == _filter.values.size
      break
    endif
  endif
%}

<filter-override>
  <filter-handle>{{ _handle }}</filter-handle>
  {%- if open_by_default -%}
    <filter-open-by-default></filter-open-by-default>{%- endif -%}
  {% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

  <style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

  <fieldset data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
            class="filter-color-buttons flex flex-wrap gap-1.5">
    {% for value in _filter.values %}
      {% assign label = value.label %}
      {% if filters_show_count %}
        {% assign label = value.label | append: ' (' | append: value.count | append: ')' %}
      {% endif %}
      {% if show_empty_entries == false and value.count <= 0 %}
        {% continue %}
      {% endif %}
      {% assign image_src = '' %}
      {% if value.swatch.image.src != blank %}
        {% assign image_src = value.swatch.image.src | image_url: width: 48, height: 48 %}
      {% endif %}
      <label x-data="{ checked: $el.firstElementChild.checked, src: `{{ image_src }}`?.split('?')?.[0] ?? '', version: `{{ image_src }}`?.split('?')?.[1] ?? '', color: `{{ value.swatch.color }}`, label: `{{ value.label }}` }"
             class="flex shrink-0 cursor-pointer border-gray-300 relative {{ outline_classes }}"
             :class="utils.clsx(checked ? 'active' : '', main_search.state.loading && 'pointer-events-none')"
          {% if show_tooltip %}
            @mouseenter="$tooltip.addTooltip($el, `{{ label }}`)"
            @mouseleave="$tooltip.removeTooltip($el)"
          {% endif %}
             aria-label="{{ label }}"
             :style="`
           --primary-swatch: ${src ? ` url(${src}?width=180&height=180&${version}) center center/cover no-repeat` : 'var(--secondary-swatch)'};
           --secondary-swatch: ${color ? ` ${color}` : 'var(--fallback-swatch)'};
           --fallback-swatch: var(--swatch-${utils.handlelize(label)}, ${utils.handlelize(label)});
           background: var(--primary-swatch, ${utils.handlelize(label)})`">
        <input type="checkbox"
               class="sr-only"
               name="{{ value.param_name }}"
               @change="checked = $el.checked"
               :disbaled="main_search.state.loading"
            {% if value.active %}
              checked="checked"
            {% endif %}
            {% if show_tooltip %}
              @focus="$tooltip.addTooltip($el.parentElement,  `{{ label }}`)"
              @blur="$tooltip.removeTooltip($el.parentElement)"
            {% endif %} value="{{ value.value }}">
      </label>
    {%- endfor -%}
  </fieldset>
</filter-override>

{% schema %}
{
  "name": "Color override",
  "settings": [
    {
      "type": "text",
      "id": "handle",
      "label": "Handle",
      "default": "color",
      "info": "Lowercase handle of the filter category to match."
    },
    {
      "type": "checkbox",
      "id": "open_by_default",
      "label": "Open by default"
    },
    {
      "type": "checkbox",
      "id": "show_tooltip",
      "label": "Show tooltip on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_empty_entries",
      "label": "Show empty entries"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Color override",
      "category": "** Search **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_search__color_override"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_account__orders_table"
  assign section_type = "main_account"
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
  {% capture css %}
    & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    }
  {% endcapture %}
{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

{% paginate customer.orders by 1000 %}
  <div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}>
    <table class="min-w-full divide-y divide-current/30">
      <thead class="bg-inherit">
        <tr>
          <th scope="col"
              class="pl-4 pr-3 text-left text-sm font-semibold opacity-90 py-3.5 sm:pl-6">Order ID
          </th>
          <th scope="col"
              class="px-2 text-left text-sm font-semibold opacity-90 py-3.5">Date
          </th>
          <th scope="col"
              class="px-2 text-left text-sm font-semibold opacity-90 py-3.5">Payment status
          </th>
          <th scope="col"
              class="px-2 text-left text-sm font-semibold opacity-90 py-3.5">Fulfillment status
          </th>
          <th scope="col"
              class="relative pl-3 pr-4 text-right py-3.5 sm:pr-6"> Total
          </th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-current/20">
        {% for order in customer.orders %}
          <tr class="cursor-pointer group hf:bg-current/5"
              data-order-link="{{ order.customer_url }}">
            <td class="py-2 pl-4 pr-3 text-sm sm:pl-6">
              <a href="{{ order.customer_url }}"
                 class="group-hf:underline">
                {{ order.name }}
              </a>
            </td>
            <td class="whitespace-nowrap px-2 py-2 text-sm opacity-50">
              <span class="hidden md:block">{{ order.created_at | time_tag: format: 'date' }}</span>
              <span class="md:hidden">{{ order.created_at | time_tag: format: 'abbreviated_date' }}</span>
            </td>
            <td class="whitespace-nowrap px-2 py-2 text-sm opacity-50">
              {{ order.financial_status_label }}
            </td>
            <td class="whitespace-nowrap px-2 py-2 text-sm opacity-50">
              <a href="{{ order.order_status_url }}"
                 onclick="(e)=>{e.stopPropagation()}"
                 class="text-gray-600 hf:underline">
                {{ order.fulfillment_status_label }}
              </a>
            </td>
            <td class="whitespace-nowrap px-2 py-2 text-right text-sm opacity-50">
              {{ order.total_price | money_with_currency }}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endpaginate %}

{% schema %}
{
  "name": "Orders Table",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Orders Table",
      "category": "** Account **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_account__orders_table"
}
{% endschema %}

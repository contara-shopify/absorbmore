{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_blog__applied_filters"
  assign section_type = "main_blog"
  assign content = block.settings.content
  assign content_class = block.settings.content_class
  assign no_filter_content = block.settings.no_filter_content
  assign no_filter_content_class = block.settings.no_filter_content_class
  assign button_class = block.settings.button_class
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign current_sort = blog.sort_by | default: blog.default_sort_by
  assign current_sort = blog.sort_options | where: 'value', current_sort | first
%}

{% capture active_filters %}
  {% assign firstColorValue = null %}
  {% assign has_tag_filters = false %}
  {% for tag in current_tags %}
    {% assign has_tag_filters = true %}
    <button
        class="{{ button_class }}"
        type="button"
        x-data="{ clicked: false }"
        :class="clicked ? 'button-loading': ''"
        {% if current_tags.size <= 1 %}
          @click="async () => {
              const url = new URL(`${window.location.href.split('/tagged/')[0]}`);
              url.searchParams.set('barba_prefetch', 'true')
              clicked = true
              await main_blog.updateSortAndFilters(url)
              clicked = false
            }"
        {% else %}
          @click="async () => {
              const url = new URL(`${window.location.href.replace(/(\/tagged\/[^?\\/]*){{ tag | handleize }}\+?/gi,'$1')}`);
              url.searchParams.set('barba_prefetch', 'true')
              clicked = true
              await main_blog.updateSortAndFilters(url)
              clicked = false
            }"
        {% endif %}
        :disabled="main_blog.state.loading">
      {{ tag }}
      {% render '_components.icon', icon: 'x-mark', class: 'size-[0.9em]' %}
    </button>
  {% endfor %}

  {% if has_tag_filters %}
    <button type="button"
            x-data="{ clicked: false }"
            :class="clicked ? 'button-loading': ''"
            @click="async () => {
              const url = new URL(`${window.location.href.split('/tagged/')[0]}`);
              url.searchParams.set('barba_prefetch', 'true')
              clicked = true
              await main_blog.updateSortAndFilters(url)
              clicked = false
            }"
            :disabled="main_blog.state.loading"
            class="{{ button_class }}">
      Clear All {% render '_components.icon', icon: 'x-mark', class: 'size-[0.9em]' %}
    </button>
  {% endif %}
{% endcapture %}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }} class="pb-4">
  <div class="py-4 {{ content_class }}">{{ content }}</div>
  {% if has_tag_filters or true %}
    <div class="flex flex-wrap gap-2">
      {{ active_filters }}
    </div>
  {% else %}
    <div class="{{ no_filter_content_class }}">{{ no_filter_content }}</div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Applied Tag Filters",
  "settings": [
    {
      "type": "text",
      "id": "content",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "content_class",
      "label": "Title class",
      "default": "richtext-md h6"
    },
    {
      "type": "text",
      "id": "no_filter_content",
      "label": "No filter content",
      "default": "No filter applied"
    },
    {
      "type": "text",
      "id": "no_filter_content_class",
      "label": "No filter content class",
      "default": "richtext-md p"
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button class",
      "default": "button-primary-sm"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Applied Tag Filters",
      "category": "** Blog **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_blog__applied_filters"
}
{% endschema %}

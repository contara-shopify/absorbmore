{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_collection__empty_state"
  assign section_type = "main_collection"
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture container_content %}
  {% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

  <style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

  <div data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
       x-show="main_collection.state.count <= 0 || $editor.select_block_id === `{{ block.id }}` || $el.querySelector(`[data-style-id='${$editor.select_section_id}--${$editor.select_block_id}']`)"
       x-cloak="!$el.closest('.shopify-section').querySelector('[data-next-url]')?.children?.length">
    {% content_for 'blocks' %}
  </div>
{% endcapture %}

{% if container_content contains '<script type="container/break"></script>' %}
  {% break %}
{% endif %}
{{ container_content }}

{% schema %}
{
  "name": "Empty State",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "blocks": [
    {
      "type": "image"
    },
    {
      "type": "richtext"
    }
  ],
  "presets": [
    {
      "name": "Empty State",
      "category": "** Collection **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_collection__empty_state"
}
{% endschema %}

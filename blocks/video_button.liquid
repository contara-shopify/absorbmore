{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "video_button"
  assign label = block.settings.label
  assign button_class = block.settings.button_class
  assign video = block.settings.video
  assign video_url = block.settings.video_url
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  if video == blank and video_url == blank or label == blank
    assign is_empty = true
  endif
  if is_empty and hide_if_empty != 'none'
    capture hide_conditionally
      if hide_if_empty == 'block'
        echo '<script type="block/hide"></script>'
        assign hide_attribute = 'data-hide-if-empty-block'
      endif
      if hide_if_empty == 'container'
        echo '<script type="container/break"></script>'
        assign hide_attribute = 'data-hide-if-empty-container'
      endif
      if hide_if_empty == 'section'
        echo '<script type="section/break"></script>'
        assign hide_attribute = 'data-hide-if-empty-section'
      endif
    endcapture

    if request.design_mode != true and hide_conditionally contains '<script'
      echo hide_conditionally
      break
    endif
    assign hide_attribute = hide_attribute | append: ' data-block-type="' | append: block_type | append: '"' | append: ' data-block-id="' | append: block.id | append: '"'
  endif
%}

{% liquid
  assign media_object = video | json
%}
{% if video == blank and video_url != blank %}
  {%- capture media_object -%}
    {
    "media_type": "external_video",
    "external_id": {{ video_url.id | json }},
    "host": {{ video_url.type | json }},
    "alt": {{ video_url.alt | json }},
    "src": {{ video_url | json }}
    }
  {%- endcapture -%}
{% endif %}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<button data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }} {{ hide_attribute }}
        type="button"
        aria-label="Open Media Player"
        data-media="{{ media_object | escape }}"
        @click.prevent.stop="$mediaGallery.showGallery({ media: [utils.JSONParse($el.getAttribute('data-media'))], index: 0 })"
        class="w-full {{ button_class }}">
  {% render '_input.inline_richtext', content: label %}
</button>

{% schema %}
{
  "name": "Video Button",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "label",
      "label": "Label",
      "default": "Button",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button class",
      "default": "button-primary"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video Url",
      "accept": [
        "youtube",
        "vimeo"
      ]
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Video Button",
      "category": "Custom"
    }
  ],
  "tag": null,
  "class": "shopify_block__video_button"
}
{% endschema %}

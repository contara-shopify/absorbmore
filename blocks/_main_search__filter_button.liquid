{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_search__filter_button"
  assign section_type = "main_search"
  assign button_text = block.settings.button_text
  assign button_class = block.settings.button_class
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% assign filters = search.filters | map: 'active_values' %}
{% assign active_filters = 0 %}
{% for filter in filters %}
  {% assign active_filters = active_filters | plus: filter.size %}
{% endfor %}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<button data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
        type="button"
        class="{{ button_class }} flex gap-2"
        @click="$data.show_sidebar = !$data.show_sidebar">
  {% render '_input.inline_richtext', content: button_text %}
</button>

{% schema %}
{
  "name": "Filters Trigger Button",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "Button text",
      "default": "Filters [icon.filters]",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button class",
      "default": "button-primary"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Filters Trigger Button",
      "category": "** Search **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_search__filter_button"
}
{% endschema %}

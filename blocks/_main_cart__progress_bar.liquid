{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_cart__progress_bar"
  assign section_type = "main_cart"
  assign show_conditionally = block.settings.show_conditionally
  assign incentive_type = block.settings.incentive_type
  assign success_bg_color = block.settings.success_bg_color
  assign base_bg_color = block.settings.base_bg_color
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
  {% capture css %}
    & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    }
  {% endcapture %}
{% endif %}

{% liquid

  capture blocks_content
    content_for "blocks"
  endcapture

  assign blocks_split_size = blocks_content | split: 'data-progress-bar-target' | size | minus: 2
%}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

<section data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
         x-show="_cart.showConditionally(`{{ show_conditionally }}`) || $editor?.select_block_id === `{{ block.id }}`"
  {% if show_conditionally == 'cart_empty' and cart.item_count > 0 %}x-cloak{% endif %}
  {% if show_conditionally == 'items_added' and cart.item_count <= 0 %}x-cloak{% endif %}
         x-data="{
             settings: utils.JSONParse($el.getAttribute('data-settings')),
             current: 0,
             targets: [...$el.querySelectorAll('[data-progress-bar-target]')]?.map(node => +node.getAttribute('data-progress-bar-target')),
             pre_target_messages: [...$el.querySelectorAll('[data-progress-bar-target]')]?.map(node => node.getAttribute('data-progress-bar-pre-target-message')),
             percentages: [],
             currentIndex: 0
           }"
         x-effect="() => {
             current = $data?.bundle?.[settings.incentive_type] ?? $cart.state?.[settings.incentive_type] ?? 0;
             percentages = targets.map((target, i, arr)=> [Math.max(0, Math.min(1, (current - (arr[i - 1] ?? 0)) / (target - (arr[i - 1] ?? 0)))) * 100, i, target])?.sort((a,b)=> a[2] - b[2]);
             currentIndex = percentages.find(([percent])=> percent > 0 && percent < 100)?.[1] ?? percentages.find(([percent,i,target]) => percent === 0)?.[1] ?? percentages.findLast(([percent,i,target]) => percent === 100)?.[1];
           }"
         data-settings="{{ block.settings | json | escape }}"
         class="relative flex flex-col justify-center"
         style="--success-bg-color: {{ success_bg_color }};--success-border-color: {{ success_border_color }}; --base-bg-color: {{ base_bg_color }};--base-border-color: {{ base_border_color }};">
  <header>
    {{ blocks_content }}
  </header>
  <div class="flex w-full items-center mt-1.5 gap-1.5">
    {% for index in (0..blocks_split_size) %}
      <div x-data="{ percent: percentages.find(([percent, i, target])=> i === +`{{ index }}`)[0], order: percentages.findIndex(([percent, i, target])=> i === +`{{ index }}`) }"
           x-effect="()=> {
               order = percentages.findIndex(([percent, i, target])=> i === +`{{ index }}`)
               if (order !== -1 && percentages[order]) {
                    percent = percentages[order][0];
               }
             }"
           class="relative flex w-full rounded-full bg-[--base-bg-color]"
           :style="`background: linear-gradient(90deg, var(--success-border-color), var(--success-border-color) ${percent}%, var(--base-border-color) ${percent}%, var(--base-border-color)); order: ${order};`">
        <div data-progress-bar class="flex-1 rounded-full bg-[--base-bg-color] h-[3px]">
          <div class="h-full bg-[--success-bg-color] rounded-full transition-all duration-150 ease-linear"
               :style="`width: ${percent}%`"></div>
        </div>
      </div>
    {% endfor %}
  </div>
  <footer
      class="mt-1.5 richtext-md h6"
      x-html="pre_target_messages[currentIndex]?.replace('[difference]', settings.incentive_type === 'total_price' ? utils.formatMoney(targets[currentIndex] - current) : `${targets[currentIndex] - current}`)"
      x-show="percentages?.[0]?.[0] === 100 && !percentages?.every(p => p?.[0] >= 100)">
  </footer>
</section>

{% schema %}
{
  "name": "Progress Bar",
  "settings": [
    {
      "type": "select",
      "id": "show_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "cart_empty",
          "label": "Cart Empty"
        },
        {
          "value": "items_added",
          "label": "Items Added"
        }
      ]
    },
    {
      "type": "header",
      "content": "Incentive Targets"
    },
    {
      "type": "paragraph",
      "content": "Important. This section does not create actual discounts. All discounts need to be created in the Shopify Admin Dashboard to match the settings here."
    },
    {
      "type": "select",
      "id": "incentive_type",
      "label": "Incentive Targets",
      "default": "total_price",
      "options": [
        {
          "value": "total_price",
          "label": "Amount based"
        },
        {
          "value": "item_count",
          "label": "Quantity based"
        }
      ]
    },
    {
      "type": "header",
      "content": "Styling Settings"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "success_bg_color",
      "label": "Success color",
      "default": "#4fd351"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "base_bg_color",
      "label": "Base color",
      "default": "#cacacc"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "blocks": [
    {
      "type": "_main_cart__progress_bar_target"
    }
  ],
  "presets": [
    {
      "name": "Progress Bar",
      "category": "** Cart **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_cart__progress_bar"
}
{% endschema %}

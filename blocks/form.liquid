               x-init="_stores.toast.addToast({type: 'success', target: 'generic', title: 'Successfully Signed Up', content: 'Thank you for signing up', timestamp: Date.now()}); utils?.replaceSearchParams({remove: ['customer_posted'] });">
          </div>
        {%- endif -%}
      {% endcapture %}
    {% endform %}

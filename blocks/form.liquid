{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "form"
  assign type = block.settings.type
  assign _article = block.settings.article
  assign target_id = block.settings.target_id
  assign target_visibility = block.settings.target_visibility
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
  assign hide_if_empty = block.settings.hide_if_empty
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% if target_id == blank %}
  {% capture target_id %}form__{{ type }}__{{ section.id }}--{{ block.id }}{% endcapture %}
{% endif %}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
  {% capture css %}
    & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    }
  {% endcapture %}
{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

{% capture blocks_content %}{% content_for 'blocks' %}{% endcapture %}

{% if type == 'contact' %}
  {% capture no_render %}
    {% form 'contact' %}
      {% capture notifications %}
        {%- if form.errors -%}
          <div class="!hidden"
               data-error-content="{{ form.errors.translated_fields['email'] | capitalize | append: " " | append: form.errors.messages['email'] | escape }}"
               x-init="_stores.toast.addToast({type: 'error', target: 'generic', title: 'We\'ve encountered a problem.',content: $el.getAttribute('data-error-content'), timestamp: Date.now()})">
          </div>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <div class="!hidden"
               x-init="_stores.toast.addToast({type: 'success', target: 'generic', title: 'Successfully Submitted', content: 'Thank you for contacting us', timestamp: Date.now()}); utils?.replaceSearchParams({remove: ['contact_posted'] });">
          </div>
        {%- endif -%}
      {% endcapture %}
    {% endform %}
  {% endcapture %}

  <form
      data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
      {% if target_id != blank %}
        id="{{ target_id }}"
      {% endif %}
      {% if target_visibility == 'targeted' %}
        x-show="$router.hash === '#{{ target_id }}' || $editor.select_block_id === `{{ block.id }}` || $el.querySelector(`[data-style-id='${$editor.select_section_id}--${$editor.select_block_id}']`)"
        x-cloak
      {% endif %}
      {% if target_visibility == 'no_target' %}
        x-show="!$router.hash || $router.hash === '#' || $editor.select_block_id === `{{ block.id }}` || $el.querySelector(`[data-style-id='${$editor.select_section_id}--${$editor.select_block_id}']`)"
        x-cloak
      {% endif %}
      x-data="{ submitting: false }"
      @submit.prevent="if (utils.validateFormAndToast($el)) { submitting = true; $el.submit(); }"
      method="post" action="/contact#{{ target_id }}" accept-charset="UTF-8">
    <input type="hidden" name="form_type" value="contact">
    <input type="hidden" name="utf8" value="✓">
    {{ blocks_content }}
    {{ notifications }}
  </form>
{% endif %}

{% if type == 'newsletter_signup' %}

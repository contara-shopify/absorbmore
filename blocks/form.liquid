{% if type == 'new_comment' %}
  {% assign article = _article | default: article %}
  {% capture no_render %}
    {% form 'new_comment', article: article %}
      {% capture notifications %}
        {%- if form.errors -%}
          <div class="!hidden"
               data-error-content="{{ form.errors.translated_fields['email'] | capitalize | append: " " | append: form.errors.messages['email'] | escape }}"
               x-init="_stores.toast.addToast({type: 'error', target: 'generic', title: 'We\'ve encountered a problem.',content: $el.getAttribute('data-error-content'), timestamp: Date.now()})">
          </div>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <div class="!hidden"
               x-init="_stores.toast.addToast({type: 'success', target: 'generic', title: 'Comment posted successfully', content: 'Thank you leaving a comment.', timestamp: Date.now()}); utils?.replaceSearchParams({remove: ['new_comment_posted'] });">
          </div>
        {%- endif -%}
      {% endcapture %}
    {% endform %}
  {% endcapture %}


  {% liquid
    if article.blog.comments_enabled? != true
      assign is_empty = true
    endif

    if is_empty and hide_if_empty != 'none'
      capture hide_conditionally
        if hide_if_empty == 'block'
          echo '<script type="block/hide"></script>'
          assign hide_attribute = 'data-hide-if-empty-block'
        endif
        if hide_if_empty == 'container'
          echo '<script type="container/break"></script>'
          assign hide_attribute = 'data-hide-if-empty-container'
        endif
        if hide_if_empty == 'section'
          echo '<script type="section/break"></script>'
          assign hide_attribute = 'data-hide-if-empty-section'
        endif
      endcapture

      if request.design_mode != true and hide_conditionally contains '<script'
        echo hide_conditionally
        break
      endif
      assign hide_attribute = hide_attribute | append: ' data-block-type="' | append: block_type | append: '"' | append: ' data-block-id="' | append: block.id | append: '"'
    endif
  %}

  <form
      data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }} {{ hide_attribute }}
      {% if target_id != blank %}
        id="{{ target_id }}"
      {% endif %}
      {% if target_visibility == 'targeted' %}
        x-show="$router.hash === '#{{ target_id }}' || $editor.select_block_id === `{{ block.id }}` || $el.querySelector(`[data-style-id='${$editor.select_section_id}--${$editor.select_block_id}']`)"
        x-cloak
      {% endif %}
      {% if target_visibility == 'no_target' %}
        x-show="!$router.hash || $router.hash === '#' || $editor.select_block_id === `{{ block.id }}` || $el.querySelector(`[data-style-id='${$editor.select_section_id}--${$editor.select_block_id}']`)"
        x-cloak
      {% endif %}
      x-data="{ submitting: false }"
      @submit.prevent="if (utils.validateFormAndToast($el)) { submitting = true; $el.submit(); }"
      method="post" action="{{ article.url }}/comments#{{ target_id }}" accept-charset="UTF-8">
    <input type="hidden" name="form_type" value="new_comment">
    <input type="hidden" name="utf8" value="✓">
    {{ blocks_content }}
    {{ notifications }}
  </form>

{% endif %}


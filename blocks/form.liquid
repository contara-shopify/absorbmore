{% schema %}
{
  "name": "Form",
  "settings": [
    {
      "type": "select",
      "id": "type",
      "label": "Type",
      "default": "contact",
      "options": [
        {
          "group": "Generic",
          "value": "contact",
          "label": "Contact"
        },
        {
          "group": "Generic",
          "value": "newsletter_signup",
          "label": "Newsletter"
        },
        {
          "group": "Generic",
          "value": "new_comment",
          "label": "New Comment"
        },
        {
          "group": "Accounts",
          "value": "sign_up",
          "label": "Sign Up"
        },
        {
          "group": "Accounts",
          "value": "sign_in",
          "label": "Sign In"
        },
        {
          "group": "Accounts",
          "value": "password_activate",
          "label": "Password activate"
        },
        {
          "group": "Accounts",
          "value": "password_recover",
          "label": "Password recover"
        },
        {
          "group": "Accounts",
          "value": "password_reset",
          "label": "Password reset"
        },
        {
          "group": "Storefront",
          "value": "storefront_password",
          "label": "Storefront password"
        }
      ]
    },
    {
      "type": "article",
      "id": "article",
      "label": "Article"
    },
    {
      "type": "text",
      "id": "target_id",
      "label": "Target id"
    },
    {
      "type": "select",
      "id": "target_visibility",
      "label": "Target visibility",
      "default": "",
      "options": [
        {
          "value": "",
          "label": "Always"
        },
        {
          "value": "targeted",
          "label": "Targeted"
        },
        {
          "value": "no_target",
          "label": "No target"
        }
      ],
      "visible_if": "{{ block.settings.target_id != blank }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    },
    {
      "type": "select",
      "id": "hide_if_empty",
      "label": "If empty, hide:",
      "default": "block",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "section",
          "label": "Section"
        },
        {
          "value": "container",
          "label": "Container"
        },
        {
          "value": "block",
          "label": "Block"
        }
      ],
      "info": "Always shows in the Theme Editor.",
      "visible_if": "{{ block.settings.type == 'new_comment' }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "header",
      "content": "Development Integration",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "select",
      "id": "generate_block_presets",
      "label": "Presets Codegen",
      "default": "never",
      "options": [
        {
          "value": "never",
          "label": "Off"
        },
        {
          "value": "always",
          "label": "On"
        },

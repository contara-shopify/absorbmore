{% liquid
  assign custom_section_id = block.settings.custom_section_id | strip
%}

{% style %}
  :root {
    --component_stat_strip_white: #ffffff;
    --component_stat_strip_black: #111111;
    --component_stat_strip_desc: #888888;
    --component_stat_strip_border: #d5d1c8;
  }

  [data-component-stat-strip] {
    margin-top: 15px;
    grid-column: span 2;
  }

  .component--stat-strip {
    width: 100%;
  }

  .stat-strip {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: stretch;
    justify-content: flex-start;
    width: 100%;
    overflow: hidden;
    background: var(--component_stat_strip_white);
    border: 1px solid var(--component_stat_strip_border);
    border-radius: 8px;
  }

  .stat-strip__cell {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 13px 8px;
    border-right: 1px solid var(--component_stat_strip_border);
    text-align: center;
  }

  .stat-strip__cell:last-child {
    border-right: none;
  }

  .stat-strip__value {
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 17px;
    font-weight: 700;
    line-height: 18.7px;
    color: var(--component_stat_strip_black);
  }

  .stat-strip__lines {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-strip__line {
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 9.5px;
    font-weight: 400;
    line-height: 12.35px;
    letter-spacing: 0.38px;
    text-transform: uppercase;
    color: var(--component_stat_strip_desc);
  }

  @media (max-width: 768px) {
    #desktop-stat-strip {
      display: none;
    }

    #mobile-stat-strip {
      grid-column: span 1;
    }

    .stat-strip {
      flex-wrap: wrap;
    }

    .stat-strip__cell {
      flex: 1;
      flex-basis: 50%;
      width: 50%;
      max-width: 50%;
    }

    .stat-strip__cell:first-child,
    .stat-strip__cell:nth-child(2) {
      border-bottom: 1px solid var(--component_stat_strip_border);
    }
  }
{% endstyle %}

<div
  data-component-stat-strip
  data-style-id="{{ section.id }}--{{ block.id }}"
  {% if custom_section_id != blank %}
    id="{{ custom_section_id | handleize }}"
  {% endif %}
  {{ block.shopify_attributes }}
>
  <div class="component component--stat-strip">
    <div class="stat-strip">
      {% if block.settings.stat_1_value != blank %}
        <div class="stat-strip__cell">
          <div class="stat-strip__value">{{ block.settings.stat_1_value | escape }}</div>
          <div class="stat-strip__lines">
            {% if block.settings.stat_1_line_1 != blank %}
              <span class="stat-strip__line">{{ block.settings.stat_1_line_1 | escape }}</span>
            {% endif %}
            {% if block.settings.stat_1_line_2 != blank %}
              <span class="stat-strip__line">{{ block.settings.stat_1_line_2 | escape }}</span>
            {% endif %}
          </div>
        </div>
      {% endif %}
      {% if block.settings.stat_2_value != blank %}
        <div class="stat-strip__cell">
          <div class="stat-strip__value">{{ block.settings.stat_2_value | escape }}</div>
          <div class="stat-strip__lines">
            {% if block.settings.stat_2_line_1 != blank %}
              <span class="stat-strip__line">{{ block.settings.stat_2_line_1 | escape }}</span>
            {% endif %}
            {% if block.settings.stat_2_line_2 != blank %}
              <span class="stat-strip__line">{{ block.settings.stat_2_line_2 | escape }}</span>
            {% endif %}
          </div>
        </div>
      {% endif %}
      {% if block.settings.stat_3_value != blank %}
        <div class="stat-strip__cell">
          <div class="stat-strip__value">{{ block.settings.stat_3_value | escape }}</div>
          <div class="stat-strip__lines">
            {% if block.settings.stat_3_line_1 != blank %}
              <span class="stat-strip__line">{{ block.settings.stat_3_line_1 | escape }}</span>
            {% endif %}
            {% if block.settings.stat_3_line_2 != blank %}
              <span class="stat-strip__line">{{ block.settings.stat_3_line_2 | escape }}</span>
            {% endif %}
          </div>
        </div>
      {% endif %}
      {% if block.settings.stat_4_value != blank %}
        <div class="stat-strip__cell">
          <div class="stat-strip__value">{{ block.settings.stat_4_value | escape }}</div>
          <div class="stat-strip__lines">
            {% if block.settings.stat_4_line_1 != blank %}
              <span class="stat-strip__line">{{ block.settings.stat_4_line_1 | escape }}</span>
            {% endif %}
            {% if block.settings.stat_4_line_2 != blank %}
              <span class="stat-strip__line">{{ block.settings.stat_4_line_2 | escape }}</span>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>


    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Preorder state"
    },
    {
      "type": "inline_richtext",
      "id": "preorder_content",
      "label": "Button content",
      "default": "[icon.timer] Preorder• [price]",

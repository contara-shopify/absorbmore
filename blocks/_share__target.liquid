{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_share__target"
  assign section_type = "share"
  assign type = block.settings.type
  assign icon = block.settings.icon
  assign url = block.settings.url
  assign description = block.settings.description
  assign image = block.settings.image
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign object = page | default: product | default: article | default: collection | default: blog
  assign share_url = url | default: object.url | replace: shop.url, '' | prepend: shop.url | url_param_escape
  assign description = description | default: object.excerpt_or_content | default: object.content | strip_html | truncatewords: 15 | url_param_escape
  assign image = image | default: object.image | default: object.featured_image | default: object.featured_media | img_url: 'large' | prepend: 'https:' | url_param_escape
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

{% if type == 'facebook' %}
  <a data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
     class="hf:opacity-70"
     title="Share on Facebook"
     href="https://www.facebook.com/sharer.php?u={{ share_url }}"
     target="_blank"
     rel="noopener">
    {%- render '_components.icon', icon: icon -%}
  </a>
{% endif %}

{% if type == 'twitter' %}
  <a data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
     class="hf:opacity-70"
     title="Share on Twitter"
     href="https://twitter.com/share?{% if title != blank %}text={{ title }}&{% endif %}url={{ share_url }}"
     target="_blank"
     rel="noopener">
    {%- render '_components.icon', icon: icon -%}
  </a>

{% endif %}

{% if type == 'pinterest' %}
  <a data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
     class="hf:opacity-70"
     title="Share on Pinterest"
     href="https://pinterest.com/pin/create/button/?url={{ share_url }}{% if image != blank %}&media={{ image }}{% endif %}&description={{ description }}"
     target="_blank"
     rel="noopener">
    {%- render '_components.icon', icon: icon -%}
  </a>
{% endif %}

{% if type == 'linkedin' %}
  <a data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
     class="hf:opacity-70"
     title="Share on LinkedIn"
     href="https://www.linkedin.com/sharing/share-offsite/?url={{ share_url }}"
     target="_blank"
     rel="noopener">
    {%- render '_components.icon', icon: icon -%}
  </a>

{% endif %}

{% if type == 'email' %}
  <a data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
     class="hf:opacity-70"
     title="Share via Email"
     href="mailto:?&subject={{ title | escape }}&body={{ share_url }}">
    {% render '_components.icon', icon: icon %}
  </a>
{% endif %}

{% schema %}
{
  "name": "Target",
  "settings": [
    {
      "type": "select",
      "id": "type",
      "label": "Type",
      "default": "facebook",
      "options": [
        {
          "value": "facebook",
          "label": "Facebook"
        },
        {
          "value": "twitter",
          "label": "Twitter"
        },
        {
          "value": "pinterest",
          "label": "Pinterest"
        },
        {
          "value": "linkedin",
          "label": "LinkedIn"
        },
        {
          "value": "email",
          "label": "Email"
        }
      ]
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Icon",
      "default": "facebook"
    },
    {
      "type": "header",
      "content": "Overrides"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Url"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Target",
      "category": "Links"
    }
  ],
  "tag": null,
  "class": "shopify_block___share__target"
}
{% endschema %}

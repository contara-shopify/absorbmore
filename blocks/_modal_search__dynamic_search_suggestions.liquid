{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_modal_search__dynamic_search_suggestions"
  assign section_type = "modal_search"
  assign show_search_conditionally = block.settings.show_search_conditionally
  assign button_class = block.settings.button_class
  assign content = block.settings.content
  assign content_class = block.settings.content_class
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
  {% capture css %}
    & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    }
  {% endcapture %}
{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

<nav data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}>
  {% if content != blank %}
    <div class="shrink-0 {{ content_class }}">
      {% render '_input.inline_richtext', content: content %}
    </div>
  {% endif %}
  <script data-predictive-search-type="query"></script>
  <template x-for="search_query in search_modal.state.queries">
    <a data-loop-item
       data-search-suggestion
       tabindex="-1"
       class="flex {{ button_class }}"
       data-barba-prevent="self"
       :class="search_modal.state.active_query === search_query.text ? 'active' : ''"
       @pointerenter="search_modal.state.active_query = search_query.text"
       @focus.stop.prevent="search_modal.state.active_query = search_query.text"
       :href="`{{ routes.search_url }}?q=${search_query.text}`"
       x-html="search_query.styled_text"></a>
  </template>
</nav>

{% schema %}
{
  "name": "t:blocks.dynamic_search_suggestions.name",
  "settings": [
    {
      "type": "select",
      "id": "show_search_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "no_search_query",
          "label": "No Search Query"
        },
        {
          "value": "with_search_query",
          "label": "With Search Query"
        },
        {
          "value": "search_empty",
          "label": "Empty"
        },
        {
          "value": "items_found",
          "label": "With Items"
        }
      ]
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button class",
      "default": "button-primary"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Optional Header"
    },
    {
      "type": "inline_richtext",
      "id": "content",
      "label": "Content",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "text",
      "id": "content_class",
      "label": "Content class"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Dynamic Search Suggestions",
      "category": "** Search Modal **"
    }
  ],
  "tag": null,
  "class": "shopify_block___modal_search__dynamic_search_suggestions"
}
{% endschema %}

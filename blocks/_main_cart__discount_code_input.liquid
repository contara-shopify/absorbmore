{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_cart__discount_code_input"
  assign section_type = "main_cart"
  assign show_conditionally = block.settings.show_conditionally
  assign input_class = block.settings.input_class
  assign input_label = block.settings.input_label
  assign input_placeholder = block.settings.input_placeholder
  assign button_label = block.settings.button_label
  assign button_class = block.settings.button_class
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}

<style>{{ custom_css | replace: '&', selector | strip_newlines }}</style>

<form data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}
      class="flex gap-2"
      x-data="{ discount_loading: false, inputEl: $el.querySelector('input') }"
      @submit.prevent.stop="
        if ($cart.state.discount_codes?.some((d) => d.code === inputEl.value)) {
          $toast.addToast({ type: 'error', target: 'cart', title: 'Discount code already applied', content: 'The discount code you entered is already applied to your cart.' });
          return;
        }
        discount_loading = true; _cart.update( { discount:  [...($cart.state.discount_codes?.map(d=>d.code) ?? []), inputEl.value].join(',') }).finally(() => { discount_loading = false; $el.reset(); inputEl.dispatchEvent(new   Event('input', { bubbles: true })); inputEl.focus(); })"
      x-show="_cart.showConditionally(`{{ show_conditionally }}`) || $editor?.select_block_id === `{{ block.id }}`"
  {% if show_conditionally == 'cart_empty' and cart.item_count > 0 %}x-cloak{% endif %}
  {% if show_conditionally == 'items_added' and cart.item_count <= 0 %}x-cloak{% endif %}>
  {% render '_components.input', type: 'text', name: 'discount', label: input_label, class: input_class, placeholder: input_placeholder, autocomplete: 'off' %}
  <button type="submit"
          class="relative {{ button_class }}"
          :disabled="discount_loading"
          :class="discount_loading ? 'button-loading' : ''">
    {% render '_input.inline_richtext', content: button_label %}
  </button>
</form>

{% schema %}
{
  "name": "Discount Code Input",
  "settings": [
    {
      "type": "select",
      "id": "show_conditionally",
      "label": "Show conditionally",
      "default": "always",
      "options": [
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "cart_empty",
          "label": "Cart Empty"
        },
        {
          "value": "items_added",
          "label": "Items Added"
        }
      ]
    },
    {
      "type": "header",
      "content": "Input Element"
    },
    {
      "type": "text",
      "id": "input_class",
      "label": "Input class",
      "default": "input-text"
    },
    {
      "type": "text",
      "id": "input_label",
      "label": "Label",
      "default": "Discount Code"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Placeholder",
      "default": "Enter your coupon code"
    },
    {
      "type": "header",
      "content": "Submit Button"
    },
    {
      "type": "inline_richtext",
      "id": "button_label",
      "label": "Label",
      "default": "Apply",
      "info": "[Shortcodes](https://getplatter.atlassian.net/wiki/external/YTBhYmQxMzFhOWQ1NGQ4MzhlNzY1MjZiNDU1YmQ5ODk)"
    },
    {
      "type": "text",
      "id": "button_class",
      "label": "Button class",
      "default": "button-primary"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Discount Code Input",
      "category": "** Cart **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_cart__discount_code_input"
}
{% endschema %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_main_collection__sort"
  assign section_type = "main_collection"
  assign select_class = block.settings.select_class
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  assign current_sort = collection.sort_by | default: collection.default_sort_by
  assign titles = collection.sort_options | map: 'name'
  assign values = collection.sort_options | map: 'value'
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
  {% capture css %}
    & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    }
  {% endcapture %}
{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

{% capture html_attributes %}data-style-id="{{ section.id }}--{{ block.id }}" {{ block.shopify_attributes }}{% endcapture %}

{% render '_components.select',
    values: values,
    titles: titles,
    select_class: select_class,
    button_prefix: "SORT BY",
    label: 'SORT BY',
    name: "sort_by",
    setState: "main_collection.state.sort_by = value",
    state: "main_collection.state.sort_by",
    html_attributes: html_attributes,
    disabled: "main_collection.state.loading"
%}


{% schema %}
{
  "name": "Sort",
  "settings": [
    {
      "type": "header",
      "content": "Desktop Settings"
    },
    {
      "type": "text",
      "id": "select_class",
      "label": "Select class",
      "default": "input-select-plain"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Block Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n}\n"
    }
  ],
  "presets": [
    {
      "name": "Sort",
      "category": "** Collection **"
    }
  ],
  "tag": null,
  "class": "shopify_block___main_collection__sort"
}
{% endschema %}

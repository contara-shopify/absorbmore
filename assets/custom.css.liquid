[data-style-id="card_product_card_labels_yPd4hQ"] label.label-secondary,
[data-product-id="10223743729953"] [data-style-id="card_product_card_labels_zWd2hQ"] label.label-secondary {
    background: #E1225C;
    font-size: 11px;
}

[data-product-id="10235228717345"] [data-style-id="card_product_card_container_rKLkUG"] label.label-card,
[data-style-id="card_product_card_labels_zWd2hQ"] label.label-secondary,
label.longevity-immunity {
    background: #ffffff;
}

label.low-stock {
    background: #E1225C !important;
    font-size: 11px;
}
label.limited-time-offer {
    background: #3EA193 !important;
    font-size: 11px;
}
label.back-in-stock {
    background: #4759ff !important;
    font-size: 11px;
}

label.sold-out {
    background: #FF7815 !important;
    font-size: 11px;
}

label.reserve-yours {
    background: #FF7815 !important;
    font-size: 11px;
}

[data-product-available="false"] label.label-secondary {
    background: #FF7815 !important;
}

/* Hide author name on article cards */
[data-style-id="card_text_A7MrKw"],
[data-style-id="card_text_RnixUB"] {
    display: none !important;
}

/* Blue waterdrops */
.tac-magnesium-bullets {
	display: flex;
	flex-direction: column;
	gap: 10px;
	margin: 16px 0 4px 0;
	padding: 0;
}

.tac-magnesium-bullet {
	display: flex;
	align-items: center;
	gap: 10px;
}

.tac-magnesium-bullet svg {
	flex-shrink: 0;
}

.tac-magnesium-bullet span {
	font-family: inherit;
	font-size: 14px;
	line-height: 1.4;
	color: #6a6a6a;
	font-weight: 400;
	letter-spacing: 0.01em;
}
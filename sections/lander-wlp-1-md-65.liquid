<script>
(function(){
  var root = document.querySelector('.wlp65');
  if(!root) return;
  var endIso = root.getAttribute('data-end');
  var end = new Date(endIso).getTime();
  if(isNaN(end)){ return; }

  function pad(n){ return n<10 ? '0'+n : ''+n; }

  function tick(){
    var diff = end - Date.now();
    if(diff < 0) diff = 0;
    var d = Math.floor(diff/86400000);
    var h = Math.floor((diff%86400000)/3600000);
    var m = Math.floor((diff%3600000)/60000);
    var s = Math.floor((diff%60000)/1000);

    root.querySelectorAll('[data-cd-d]').forEach(function(el){ el.textContent = pad(d); });
    root.querySelectorAll('[data-cd-h]').forEach(function(el){ el.textContent = pad(h); });
    root.querySelectorAll('[data-cd-m]').forEach(function(el){ el.textContent = pad(m); });
    root.querySelectorAll('[data-cd-s]').forEach(function(el){ el.textContent = pad(s); });

    var bd = root.querySelector('[data-cd-bar-d]'); if(bd) bd.textContent = pad(d);
    var bh = root.querySelector('[data-cd-bar-h]'); if(bh) bh.textContent = pad(h);
    var bm = root.querySelector('[data-cd-bar-m]'); if(bm) bm.textContent = pad(m);
    var bs = root.querySelector('[data-cd-bar-s]'); if(bs) bs.textContent = pad(s);
  }
  tick();
  setInterval(tick, 1000);

  // Buy box option selector
  var opts = root.querySelectorAll('[data-opt]');
  var buyCta = root.querySelector('[data-buy-cta]');
  var stickCta = root.querySelector('[data-stick-cta]');
  var stickPrice = root.querySelector('[data-stick-price]');

  opts.forEach(function(opt){
    opt.addEventListener('click', function(){
      opts.forEach(function(o){ o.classList.remove('is-on'); });
      opt.classList.add('is-on');
      var radio = opt.querySelector('input');
      if(radio) radio.checked = true;
      var cart = opt.getAttribute('data-cart');
      var price = opt.getAttribute('data-price');
      var period = opt.getAttribute('data-period');
      if(buyCta && cart) buyCta.setAttribute('href', cart);
      if(stickCta && cart) stickCta.setAttribute('href', cart);
      if(stickPrice && price){
        stickPrice.innerHTML = price + ' <small>' + (period || '') + '</small>';
      }
    });
  });

  // Sticky mobile CTA reveal after hero
  var stick = root.querySelector('[data-stick]');
  var hero = root.querySelector('.wlp65-hero');
  if(stick && hero){
    var heroBottom = function(){ return hero.getBoundingClientRect().bottom; };
    var onScroll = function(){
      if(heroBottom() < 60){ stick.classList.add('is-on'); }
      else { stick.classList.remove('is-on'); }
    };
    window.addEventListener('scroll', onScroll, {passive:true});
    onScroll();
  }
})();
</script>


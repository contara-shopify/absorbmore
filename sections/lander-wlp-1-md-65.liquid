{%- comment -%} WLP-1 Memorial Day $65 lander. Drives 1-month sub at $65 first delivery (or upsell to 3mo/6mo). Ends 2026-05-25 23:59 PT. v2 — full blue hero, text countdown bar, $35-off badge, expanded benefits, buybox options selector, featured testimonial moved above buybox. {%- endcomment -%}

{%- liquid
  assign end_iso     = section.settings.end_iso       | default: '2026-05-25T23:59:59-07:00'
  assign discount    = section.settings.discount_pct  | default: 35
  assign hero_img    = section.settings.hero_img      | default: 'https://www.absorbmore.com/cdn/shop/files/TAC_PDP-Image_WLP1.png?crop=center&height=1200&v=1774483977&width=1200'
  assign cart_1mo    = section.settings.cart_1mo      | default: '/cart/52472821121313:1?selling_plan=691162546465'
  assign cart_3mo    = section.settings.cart_3mo      | default: '/cart/52472821154081:1?selling_plan=691162579233'
  assign cart_6mo    = section.settings.cart_6mo      | default: '/cart/52472821186849:1?selling_plan=691166544161'
  assign price_1mo   = section.settings.price_1mo     | default: '$65'
  assign price_1mo_was = section.settings.price_1mo_was | default: '$99'
  assign price_3mo   = section.settings.price_3mo     | default: '$193'
  assign price_3mo_per = section.settings.price_3mo_per | default: '$64/mo'
  assign price_6mo   = section.settings.price_6mo     | default: '$379'
  assign price_6mo_per = section.settings.price_6mo_per | default: '$63/mo'
  assign rating      = section.settings.rating        | default: '4.5'
  assign review_count = section.settings.review_count | default: '1,200+'
-%}

<style>
  .wlp65 { --navy:#0D273E; --red:#DB3519; --cream:#efe9dd; --blue:#B8DCE8; --blue-deep:#5BA8C8; --blue-ink:#1F6F8B; --blue-dark:#7BBED5; --gold:#d4a23a; --ink:#0D273E; --paper:#fff;
    color:var(--ink); font-family:'Helvetica Neue',Arial,sans-serif; -webkit-font-smoothing:antialiased; line-height:1.45; }
  .wlp65 *{box-sizing:border-box}
  .wlp65 img{max-width:100%;display:block}
  .wlp65 a{color:inherit;text-decoration:none}
  .wlp65 .wrap{max-width:1180px;margin:0 auto;padding:0 18px}

  /* ---------- STICKY TEXT COUNTDOWN BAR ---------- */
  .wlp65-bar{position:sticky;top:0;z-index:60;background:var(--red);color:#fff;border-bottom:3px solid var(--navy)}
  .wlp65-bar__row{display:flex;align-items:center;justify-content:center;gap:10px;padding:10px 14px;font-size:13px;flex-wrap:wrap;text-align:center;line-height:1.3}
  .wlp65-bar__lead{font-weight:800;letter-spacing:.04em;text-transform:uppercase;color:#fff}
  .wlp65-bar__lead em{font-style:normal;color:#fff;font-weight:800}
  .wlp65-bar__sep{opacity:.6;color:#fff}
  .wlp65-bar__cd{font-weight:700;letter-spacing:.04em;font-variant-numeric:tabular-nums;color:#fff;text-transform:uppercase}
  .wlp65-bar__cd b{color:#fff;font-weight:800}
  @media(max-width:480px){.wlp65-bar__row{font-size:12px;gap:6px}.wlp65-bar__sep{display:none}}

  /* ---------- HERO: full navy ---------- */
  .wlp65-hero{background:var(--navy);position:relative;overflow:hidden;padding:26px 0 34px;color:#fff}
  .wlp65-hero::before{content:"";position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent 0 16px,rgba(255,255,255,.04) 16px 17px);pointer-events:none}
  .wlp65-hero__grid{display:grid;grid-template-columns:1fr;gap:22px;align-items:center;position:relative}
  @media(min-width:880px){.wlp65-hero__grid{grid-template-columns:1.05fr .95fr;gap:40px;padding:18px 0}}

  .wlp65-hero__eyebrow{display:inline-flex;align-items:center;gap:8px;background:var(--red);color:#fff;font-weight:800;font-size:12px;letter-spacing:.08em;text-transform:uppercase;padding:6px 11px;border-radius:999px;margin-bottom:14px}
  .wlp65-hero__eyebrow svg{width:14px;height:14px}

  .wlp65-hero h1{font-size:clamp(28px,5.4vw,46px);line-height:1.06;letter-spacing:-.01em;font-weight:800;margin:0 0 12px;color:#fff}
  .wlp65-hero h1 em{font-style:normal;color:var(--blue)}
  .wlp65-hero h1 .nowrap{white-space:nowrap}
  .wlp65-hero__sub{font-size:clamp(15px,2vw,18px);max-width:520px;margin:0 0 18px;color:#cdd9e4}
  .wlp65-hero__sub b{color:#fff}

  /* Hero benefit bullets */
  .wlp65-hero__bullets{list-style:none;padding:0;margin:0 0 18px;display:grid;gap:8px;max-width:520px}
  .wlp65-hero__bullets li{display:flex;align-items:flex-start;gap:10px;font-size:15px;font-weight:500;color:#fff;line-height:1.4}
  .wlp65-hero__bullets li strong{font-weight:800}
  .wlp65-hero__bullets li svg{width:20px;height:20px;flex:0 0 auto;color:var(--blue);margin-top:2px}

  .wlp65-hero__pricing{display:flex;align-items:baseline;gap:14px;margin:14px 0 6px}
  .wlp65-hero__price-now{font-weight:900;font-size:clamp(26px,4vw,36px);color:#fff;letter-spacing:-.02em;line-height:1}
  .wlp65-hero__price-was{font-size:clamp(15px,2vw,18px);color:#94a8bd;text-decoration:line-through;font-weight:600}
  .wlp65-hero__price-tag{font-weight:800;color:#fff;background:var(--red);font-size:11px;text-transform:uppercase;letter-spacing:.06em;padding:4px 8px;border-radius:6px}

  .wlp65-hero__cta{display:inline-flex;align-items:center;justify-content:center;width:100%;max-width:440px;padding:18px 22px;background:var(--red);color:#fff !important;font-weight:800;font-size:17px;text-transform:uppercase;letter-spacing:.04em;border-radius:10px;border:none;cursor:pointer;box-shadow:0 6px 0 #9b2210,0 12px 24px rgba(219,53,25,.25);transition:transform .12s ease, box-shadow .12s ease;text-decoration:none}
  .wlp65-hero__cta *{color:#fff !important}
  .wlp65-hero__cta:hover{transform:translateY(2px);box-shadow:0 4px 0 #9b2210,0 8px 16px rgba(219,53,25,.22)}
  .wlp65-hero__cta:after{content:" →";margin-left:6px;color:#fff}

  .wlp65-hero__guarantee{display:flex;align-items:center;gap:8px;margin-top:14px;font-size:13px;color:#cdd9e4}
  .wlp65-hero__guarantee svg{width:18px;height:18px;color:var(--blue);flex:0 0 auto}

  .wlp65-hero__cd-lead{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--blue);margin:18px 0 8px;display:block}
  .wlp65-cd{display:flex;gap:8px;justify-content:flex-start;font-variant-numeric:tabular-nums;margin:0 0 8px}
  .wlp65-cd__box{background:#fff;color:var(--navy);border-radius:8px;padding:8px 10px;min-width:54px;text-align:center;border-top:3px solid var(--red)}
  .wlp65-cd__num{font-size:22px;font-weight:800;line-height:1;color:var(--navy)}
  .wlp65-cd__lbl{font-size:10px;text-transform:uppercase;opacity:.65;letter-spacing:.06em;margin-top:2px;color:var(--navy)}

  /* Hero image in square card */
  .wlp65-hero__media{position:relative;text-align:center}
  .wlp65-hero__card{background:#fff;border-radius:18px;padding:0;overflow:hidden;position:relative;width:100%;max-width:460px;margin:0 auto;aspect-ratio:1/1;box-shadow:0 18px 40px rgba(13,39,62,.22),inset 0 0 0 1px rgba(13,39,62,.08)}
  .wlp65-hero__card img{width:100%;height:100%;object-fit:cover;display:block}
  .wlp65-hero__badge{position:absolute;top:-12px;right:-12px;background:var(--red);color:#fff;border-radius:999px;width:96px;height:96px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-weight:800;line-height:1;transform:rotate(-8deg);border:3px solid #fff;box-shadow:0 6px 14px rgba(0,0,0,.22);z-index:2}
  .wlp65-hero__badge big{font-size:24px;color:#fff;letter-spacing:-.01em}
  .wlp65-hero__badge span{font-size:10px;text-transform:uppercase;letter-spacing:.06em;margin-top:2px;color:#fff}

  /* ---------- URGENCY BAND ---------- */
  .wlp65-urg{background:var(--navy);color:#fff;padding:38px 0;position:relative;overflow:hidden;border-top:3px solid var(--red)}
  .wlp65-urg::before{content:"";position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent 0 18px,rgba(255,255,255,.03) 18px 19px);pointer-events:none}
  .wlp65-urg__inner{text-align:center;position:relative}
  .wlp65-urg__chip{display:inline-block;background:var(--red);color:#fff;font-weight:800;font-size:11px;letter-spacing:.08em;text-transform:uppercase;padding:5px 11px;border-radius:999px;margin-bottom:14px}
  .wlp65-urg__head{font-size:clamp(26px,4.6vw,42px);line-height:1.1;letter-spacing:-.01em;font-weight:900;margin:0 0 10px;color:#fff;max-width:920px;margin-left:auto;margin-right:auto}
  .wlp65-urg__head em{font-style:normal;color:var(--blue)}
  .wlp65-urg__sub{font-size:clamp(14px,1.8vw,17px);color:#cdd9e4;margin:0 0 20px;max-width:640px;margin-left:auto;margin-right:auto}
  .wlp65-urg__cta{display:inline-flex;align-items:center;justify-content:center;padding:16px 26px;background:var(--red);color:#fff !important;font-weight:800;font-size:15px;text-transform:uppercase;letter-spacing:.04em;border-radius:10px;box-shadow:0 6px 0 #9b2210,0 12px 22px rgba(219,53,25,.25);text-decoration:none}
  .wlp65-urg__cta:after{content:" →";margin-left:6px;color:#fff}

  /* ---------- TRUST STRIP ---------- */
  .wlp65-trust{background:#fff;border-top:1px solid #e5ebef;border-bottom:1px solid #e5ebef;padding:14px 0}
  .wlp65-trust__row{display:grid;grid-template-columns:1fr;gap:10px 16px;text-align:left;font-size:13px;font-weight:600;color:var(--navy)}
  @media(min-width:520px){.wlp65-trust__row{grid-template-columns:1fr 1fr;text-align:center}}
  @media(min-width:720px){.wlp65-trust__row{grid-template-columns:repeat(5,1fr);font-size:13px}}
  .wlp65-trust__cell{display:flex;align-items:center;justify-content:flex-start;gap:8px}
  @media(min-width:520px){.wlp65-trust__cell{justify-content:center}}
  .wlp65-trust__cell svg{width:18px;height:18px;color:var(--blue-deep);flex:0 0 auto}
  .wlp65-trust__stars{color:var(--gold);letter-spacing:1px;font-size:14px}

  /* ---------- SECTION BASE ---------- */
  .wlp65-sec{padding:40px 0}
  .wlp65-sec--blue{background:var(--blue)}
  .wlp65-sec--cream{background:var(--cream)}
  .wlp65-sec--navy{background:var(--navy);color:#fff}
  .wlp65-sec--navy h2,.wlp65-sec--navy h3{color:#fff}
  .wlp65-sec__eyebrow{font-size:12px;text-transform:uppercase;letter-spacing:.12em;font-weight:800;color:var(--red);margin:0 0 8px}
  .wlp65-sec__title{font-size:clamp(26px,4.5vw,38px);font-weight:800;letter-spacing:-.01em;color:var(--navy);margin:0 0 8px;line-height:1.1}
  .wlp65-sec__sub{font-size:16px;color:#4d6478;max-width:680px;margin:0 0 24px}
  .wlp65-sec--navy .wlp65-sec__title{color:#fff}
  .wlp65-sec--navy .wlp65-sec__sub{color:#cdd9e4}

  /* ---------- BENEFITS NUMBERS ---------- */
  .wlp65-benefits{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
  @media(min-width:720px){.wlp65-benefits{grid-template-columns:repeat(4,1fr);gap:14px}}
  .wlp65-benefit{background:#fff;border:1px solid #dbe5ec;border-radius:14px;padding:18px 14px;text-align:center;position:relative;overflow:hidden}
  .wlp65-benefit__num{font-size:clamp(28px,4.5vw,40px);font-weight:900;color:var(--navy);letter-spacing:-.02em;line-height:1}
  .wlp65-benefit__num em{font-style:normal;color:var(--red)}
  .wlp65-benefit__lbl{font-size:13px;font-weight:600;color:#4d6478;margin-top:6px;line-height:1.3}
  .wlp65-benefit__ref{display:block;font-size:10px;color:#90a0b2;margin-top:6px}

  /* Benefits list (icon rows) */
  .wlp65-benefit-list{display:grid;grid-template-columns:repeat(1,1fr);gap:10px;margin-top:24px;max-width:720px;margin-left:auto;margin-right:auto}
  @media(min-width:600px){.wlp65-benefit-list{grid-template-columns:repeat(2,1fr)}}
  .wlp65-bl-item{background:#fff;border:1px solid #dbe5ec;border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:12px}
  .wlp65-bl-item__ico{width:38px;height:38px;border-radius:10px;background:var(--blue);color:var(--navy);display:flex;align-items:center;justify-content:center;flex:0 0 auto}
  .wlp65-bl-item__ico svg{width:22px;height:22px}
  .wlp65-bl-item__txt{font-size:14px;font-weight:600;color:var(--navy);line-height:1.3}
  .wlp65-bl-item__txt small{display:block;font-weight:500;color:#4d6478;font-size:12px;margin-top:2px}

  /* ---------- FEATURED TESTIMONIAL ---------- */
  .wlp65-feat{background:linear-gradient(180deg,#fff 0%,#f4f8fa 100%);border:1px solid #dbe5ec;border-radius:18px;padding:28px 24px;max-width:820px;margin:0 auto;box-shadow:0 10px 30px rgba(13,39,62,.06);position:relative}
  .wlp65-feat__stars{color:var(--gold);font-size:18px;letter-spacing:2px;margin-bottom:10px;text-align:center}
  .wlp65-feat__quote{font-size:clamp(20px,2.6vw,26px);line-height:1.35;font-weight:600;color:var(--navy);text-align:center;margin:0 0 18px;letter-spacing:-.01em}
  .wlp65-feat__quote span{color:var(--red)}
  .wlp65-feat__attrib{text-align:center;font-size:13px;color:#4d6478}
  .wlp65-feat__attrib b{color:var(--navy);font-weight:800}
  .wlp65-feat__verif{display:inline-flex;align-items:center;gap:4px;font-size:11px;color:#3a9b4a;font-weight:700;margin-left:6px}
  .wlp65-feat__verif svg{width:12px;height:12px}

  .wlp65-quotes{display:grid;grid-template-columns:1fr;gap:14px;margin-top:22px}
  @media(min-width:720px){.wlp65-quotes{grid-template-columns:repeat(3,1fr)}}
  .wlp65-quote{background:#fff;border-radius:14px;padding:18px;border:1px solid #dbe5ec}
  .wlp65-quote__stars{color:var(--gold);font-size:14px;letter-spacing:1px;margin-bottom:8px}
  .wlp65-quote__txt{font-size:14px;color:#1f3850;line-height:1.5;margin:0 0 12px}
  .wlp65-quote__name{font-size:13px;font-weight:700;color:var(--navy)}
  .wlp65-quote__verif{font-size:11px;color:#3a9b4a;display:flex;align-items:center;gap:4px;margin-top:2px;font-weight:700}
  .wlp65-quote__verif svg{width:11px;height:11px}

  /* ---------- BUY BOX (option selector) ---------- */
  .wlp65-buy{background:#fff;border:2px solid var(--navy);border-radius:18px;padding:22px;max-width:600px;margin:0 auto;box-shadow:0 14px 30px rgba(13,39,62,.10)}
  .wlp65-buy__flag{display:inline-block;background:var(--red);color:#fff;font-weight:800;font-size:11px;letter-spacing:.08em;text-transform:uppercase;padding:5px 9px;border-radius:6px;margin-bottom:12px}
  .wlp65-buy__lowstock{display:inline-flex;align-items:center;gap:6px;background:#b91d1d;color:#fff;font-weight:800;font-size:11px;letter-spacing:.08em;text-transform:uppercase;padding:5px 9px;border-radius:6px;margin:0 0 12px 8px;box-shadow:0 4px 12px rgba(185,29,29,0.32);vertical-align:top}
  .wlp65-buy__lowstock::before{content:"";width:6px;height:6px;border-radius:999px;background:#fff;box-shadow:0 0 0 3px rgba(255,255,255,0.32)}
  .wlp65-hero__lowstock{display:inline-flex;align-items:center;gap:6px;background:#b91d1d;color:#fff;font-weight:800;font-size:11px;letter-spacing:.08em;text-transform:uppercase;padding:6px 11px;border-radius:999px;margin-left:8px;box-shadow:0 4px 12px rgba(185,29,29,0.42);vertical-align:middle}
  .wlp65-hero__lowstock::before{content:"";width:6px;height:6px;border-radius:999px;background:#fff;box-shadow:0 0 0 3px rgba(255,255,255,0.32)}
  .wlp65-buy__hero{background:#f4f8fa;border:1px solid #e0e7ed;border-radius:12px;padding:14px;margin:0 0 16px;display:flex;align-items:center;justify-content:center;aspect-ratio:16/9;overflow:hidden}
  .wlp65-buy__hero img{max-width:80%;max-height:100%;width:auto;height:auto;filter:drop-shadow(0 8px 14px rgba(13,39,62,.14))}
  .wlp65-buy h3{font-size:22px;font-weight:800;color:var(--navy);margin:0 0 4px}
  .wlp65-buy__stars{display:flex;align-items:center;gap:6px;font-size:13px;color:#4d6478;margin:0 0 16px}
  .wlp65-buy__stars b{color:var(--gold);letter-spacing:1px}

  .wlp65-buy__sub{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--navy);margin:0 0 8px;opacity:.7}
  .wlp65-buy__banner{display:flex;align-items:center;gap:10px;background:var(--red);color:#fff;border-radius:10px;padding:10px 14px;margin:0 0 12px;font-size:13px;font-weight:700;line-height:1.3}
  .wlp65-buy__banner b{font-weight:900;letter-spacing:.02em}
  .wlp65-buy__banner svg{width:18px;height:18px;flex:0 0 auto}

  .wlp65-opts{display:grid;grid-template-columns:1fr;gap:10px;margin:0 0 16px}
  .wlp65-opt{display:flex;align-items:center;gap:12px;background:#f8fafc;border:2px solid #dbe5ec;border-radius:12px;padding:12px 14px;cursor:pointer;transition:border-color .12s, background .12s;position:relative}
  .wlp65-opt input{position:absolute;opacity:0;pointer-events:none}
  .wlp65-opt__bullet{width:20px;height:20px;border-radius:50%;border:2px solid #cbd6df;flex:0 0 auto;display:flex;align-items:center;justify-content:center;background:#fff;transition:border-color .12s}
  .wlp65-opt__bullet::after{content:"";width:10px;height:10px;border-radius:50%;background:var(--red);transform:scale(0);transition:transform .12s}
  .wlp65-opt__main{flex:1;min-width:0}
  .wlp65-opt__title{font-size:14px;font-weight:800;color:var(--navy);display:flex;align-items:center;gap:8px}
  .wlp65-opt__title small{display:inline-block;background:var(--blue);color:var(--navy);font-weight:800;font-size:10px;text-transform:uppercase;letter-spacing:.06em;padding:2px 6px;border-radius:5px}
  .wlp65-opt__meta{font-size:12px;color:#4d6478;margin-top:2px}
  .wlp65-opt__price{text-align:right;flex:0 0 auto;line-height:1}
  .wlp65-opt__price b{display:block;font-size:18px;font-weight:900;color:var(--navy)}
  .wlp65-opt__price s{display:block;font-size:11px;color:#7a8a99;font-weight:600;margin-top:3px}
  .wlp65-opt.is-on{border-color:var(--red);background:#fff7f5}
  .wlp65-opt.is-on .wlp65-opt__bullet{border-color:var(--red)}
  .wlp65-opt.is-on .wlp65-opt__bullet::after{transform:scale(1)}
  .wlp65-opt__flag{position:absolute;top:-8px;right:10px;background:var(--red);color:#fff;font-weight:800;font-size:9px;letter-spacing:.08em;text-transform:uppercase;padding:2px 7px;border-radius:4px}

  .wlp65-buy__list{list-style:none;padding:0;margin:0 0 18px}
  .wlp65-buy__list li{display:flex;gap:10px;align-items:flex-start;padding:7px 0;font-size:13px;color:#324a63;border-top:1px dashed #e0e7ed}
  .wlp65-buy__list li:first-child{border-top:none}
  .wlp65-buy__list svg{width:18px;height:18px;color:var(--blue-deep);flex:0 0 auto;margin-top:2px}

  .wlp65-buy__cta{display:flex;align-items:center;justify-content:center;width:100%;padding:18px 20px;background:var(--red);color:#fff !important;font-weight:800;font-size:17px;text-transform:uppercase;letter-spacing:.04em;border-radius:10px;border:none;cursor:pointer;box-shadow:0 6px 0 #9b2210,0 12px 22px rgba(219,53,25,.22);transition:transform .12s;text-decoration:none}
  .wlp65-buy__cta:hover{transform:translateY(2px);box-shadow:0 4px 0 #9b2210}
  .wlp65-buy__cta:after{content:" →";margin-left:6px;color:#fff !important}
  .wlp65-buy__sub-info{font-size:12px;color:#7a8a99;text-align:center;margin:12px 0 0;line-height:1.4}

  /* ---------- ACTIVES ---------- */
  .wlp65-actives{display:grid;grid-template-columns:1fr;gap:16px}
  @media(min-width:720px){.wlp65-actives{grid-template-columns:repeat(3,1fr);gap:18px}}
  .wlp65-active{background:#fff;border-radius:14px;padding:20px;border:1px solid #dbe5ec}
  .wlp65-active__name{font-size:17px;font-weight:800;color:var(--navy);margin:0 0 4px}
  .wlp65-active__stat{font-size:clamp(26px,4vw,32px);font-weight:900;color:var(--red);letter-spacing:-.01em;line-height:1;margin:8px 0}
  .wlp65-active__stat-lbl{font-size:12px;color:#7a8a99;text-transform:uppercase;letter-spacing:.06em;font-weight:700}
  .wlp65-active__body{font-size:14px;color:#4d6478;margin:10px 0 0;line-height:1.5}

  /* ---------- COMPARISON ---------- */
  .wlp65-comp{background:#fff;border-radius:14px;overflow:hidden;border:1px solid #dbe5ec;font-size:13px;position:relative}
  .wlp65-comp table{width:100%;border-collapse:collapse}
  .wlp65-comp th,.wlp65-comp td{padding:12px 10px;text-align:center;border-bottom:1px solid #eef2f5;vertical-align:middle}
  .wlp65-comp thead th{background:var(--navy);color:#fff;font-weight:800;font-size:12px;text-transform:uppercase;letter-spacing:.04em}

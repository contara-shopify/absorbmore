  <!-- ============ EMAIL CAPTURE (Klaviyo native client subscriptions) ============ -->
  <section class="pfd1-email" id="email">
    <div class="wrap">
      <div class="pfd1-email__inner">
        <p class="pfd1-email__kicker">Stay close</p>
        <h2>{{ email_head }}</h2>
        <p>{{ email_sub }}</p>
        <form class="pfd1-email__form" id="pfd1-email-form" novalidate>
          <label for="pfd1-email-input" style="position:absolute;left:-9999px">Email address</label>
          <input class="pfd1-email__input" id="pfd1-email-input" type="email" name="email" required autocomplete="email" placeholder="you@email.com">
          <button class="pfd1-email__btn" type="submit">{{ email_cta }}</button>
        </form>
        <p class="pfd1-email__msg" id="pfd1-email-ok" role="status" style="display:none">Thanks. The ingredient brief is on its way.</p>
        <p class="pfd1-email__msg pfd1-email__msg--err" id="pfd1-email-err" role="alert" style="display:none">Could not subscribe. Please check your email and try again.</p>
        <p class="pfd1-email__legal">We email roughly once a week. Unsubscribe anytime. Your address is never sold.</p>
      </div>
    </div>
  </section>

  <script>
    (function(){
      var form = document.getElementById('pfd1-email-form');
      if (!form) return;
      var ok = document.getElementById('pfd1-email-ok');
      var err = document.getElementById('pfd1-email-err');
      var btn = form.querySelector('button[type="submit"]');
      form.addEventListener('submit', function(e){
        e.preventDefault();
        ok.style.display = 'none';
        err.style.display = 'none';
        var email = form.querySelector('input[name="email"]').value.trim();
        if (!email || email.indexOf('@') === -1) {
          err.textContent = 'Please enter a valid email address.';
          err.style.display = 'block';
          return;
        }
        btn.disabled = true;
        btn.textContent = 'Sending…';
        fetch('https://a.klaviyo.com/client/subscriptions/?company_id={{ klaviyo_company_id }}', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'revision': '2024-10-15'
          },
          body: JSON.stringify({
            data: {
              type: 'subscription',
              attributes: {
                profile: { data: { type: 'profile', attributes: { email: email } } },
                custom_source: 'PFD1 Sorrys Advertorial'
              },
              relationships: { list: { data: { type: 'list', id: '{{ klaviyo_list_id }}' } } }
            }
          })
        }).then(function(r){
          btn.disabled = false;
          btn.textContent = '{{ email_cta }}';
          if (r.ok || r.status === 202) {
            form.style.display = 'none';
            ok.style.display = 'block';
          } else {
            err.style.display = 'block';
          }
        }).catch(function(){
          btn.disabled = false;
          btn.textContent = '{{ email_cta }}';
          err.style.display = 'block';
        });
      });
    })();
  </script>
  {%- endif -%}


  assign founder_quote     = section.settings.founder_quote
  assign founder_img       = section.settings.founder_img

  comment
    Klaviyo native client subscription endpoint. Requires public company_id + list_id.
  endcomment
  assign klaviyo_company_id = section.settings.klaviyo_company_id
  assign klaviyo_list_id    = section.settings.klaviyo_list_id
  assign email_head         = section.settings.email_head    | default: 'Not ready yet?'

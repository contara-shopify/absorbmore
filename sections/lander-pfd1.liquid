  assign email_cta          = section.settings.email_cta     | default: 'Send it to me'
-%}

<style>
  .pfd1 { --ink:#0B1220; --paper:#FBFAF6; --cream:#F4EFE4; --line:#E4DFD2; --blue:#4659FF; --blue-deep:#2C3FD9; --red:#E1225C; --gold:#C99A33; --mute:#5E6470;
    color:var(--ink); background:var(--paper);  -webkit-font-smoothing:antialiased; line-height:1.55; font-size:17px; }
  .pfd1 *{box-sizing:border-box}
  .pfd1 img{max-width:100%;display:block;height:auto}
  .pfd1 a{color:inherit;text-decoration:none}
  .pfd1 .wrap{max-width:720px;margin:0 auto;padding:0 22px}
  .pfd1 .wrap-wide{max-width:1080px;margin:0 auto;padding:0 22px}

  /* ---------- DISCLOSURE BAR ---------- */
  .pfd1-disc{background:#0B1220;color:#fff;font-size:12px;text-align:center;padding:8px 16px;letter-spacing:.08em;text-transform:uppercase;font-weight:700}
  .pfd1-disc span{opacity:.7;margin-right:8px}

  /* ---------- MASTHEAD ---------- */
  .pfd1-mast{background:#fff;border-bottom:1px solid var(--line);padding:14px 0}
  .pfd1-mast__row{display:flex;align-items:center;justify-content:space-between;gap:14px}
  .pfd1-mast__logo{font-weight:700;font-size:18px;letter-spacing:.01em;color:var(--ink)}
  .pfd1-mast__tag{font-size:11px;text-transform:uppercase;letter-spacing:.14em;color:var(--mute);font-weight:600}

  /* ---------- ARTICLE HEAD ---------- */
  .pfd1-art{padding:36px 0 24px}
  .pfd1-art__kicker{font-size:12px;text-transform:uppercase;letter-spacing:.16em;color:var(--red);font-weight:800;margin:0 0 14px}
  .pfd1-art h1{font-weight:700;font-size:clamp(30px,5.6vw,46px);line-height:1.08;letter-spacing:-.01em;margin:0 0 16px;color:var(--ink)}
  .pfd1-art h1 em{font-style:italic;color:var(--blue)}
  .pfd1-art__dek{font-size:clamp(17px,2.2vw,20px);line-height:1.45;color:#2D3340;margin:0 0 22px;font-weight:400}
  .pfd1-art__dek b{color:var(--ink);font-weight:600}
  .pfd1-art__meta{display:flex;flex-wrap:wrap;gap:10px 18px;align-items:center;font-size:13px;color:var(--mute);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:12px 0;margin:0 0 24px}
  .pfd1-art__meta b{color:var(--ink);font-weight:600}
  .pfd1-art__meta span{display:flex;align-items:center;gap:6px}

  /* ---------- HERO IMAGE ---------- */
  .pfd1-heroimg{margin:0 0 28px;border-radius:6px;overflow:hidden;background:var(--cream)}
  .pfd1-heroimg img{width:100%;aspect-ratio:16/10;object-fit:cover}
  .pfd1-heroimg figcaption{font-size:13px;color:var(--mute);padding:10px 4px 0;line-height:1.4}
  .pfd1-heroimg figcaption b{color:var(--ink);font-weight:600}

  /* ---------- BODY ---------- */
  .pfd1-body{padding:0 0 16px}
  .pfd1-body p{margin:0 0 18px;font-size:17px;line-height:1.65;color:#1E2330}
  .pfd1-body p.lede{font-size:19px;line-height:1.55;color:var(--ink);font-weight:500}
  .pfd1-body p.lede::first-letter{font-size:54px;font-weight:700;float:left;line-height:.9;padding:6px 10px 0 0;color:var(--blue)}
  .pfd1-body strong{font-weight:700;color:var(--ink)}

  /* ---------- SECTION IMAGE ---------- */
  .pfd1-secimg{margin:8px 0 22px;border-radius:6px;overflow:hidden;background:var(--cream)}
  .pfd1-secimg img{width:100%;aspect-ratio:4/3;object-fit:cover}
  .pfd1-secimg figcaption{font-size:12px;color:var(--mute);padding:8px 4px 0;line-height:1.4;font-style:italic}

  /* ---------- NUMBERED SORRY BLOCKS ---------- */
  .pfd1-sorry{padding:28px 0 28px;border-top:1px solid var(--line)}
  .pfd1-sorry__num{font-size:64px;font-weight:700;line-height:1;color:var(--blue);margin:0 0 6px;letter-spacing:-.03em}
  .pfd1-sorry__kicker{font-size:11px;text-transform:uppercase;letter-spacing:.18em;color:var(--mute);font-weight:700;margin:0 0 6px}
  .pfd1-sorry h2{font-weight:700;font-size:clamp(24px,4vw,32px);line-height:1.15;letter-spacing:-.01em;margin:0 0 18px;color:var(--ink)}
  .pfd1-sorry h2 em{font-style:italic;color:var(--blue)}
  .pfd1-sorry p{margin:0 0 16px;font-size:17px;line-height:1.65;color:#1E2330}
  .pfd1-sorry__pull{border-left:4px solid var(--blue);background:var(--cream);padding:16px 18px;margin:18px 0;font-size:16px;line-height:1.5;color:var(--ink);border-radius:0 4px 4px 0}
  .pfd1-sorry__pull b{font-weight:700;color:var(--blue-deep)}
  .pfd1-sorry__pull .stat{display:block;font-size:28px;font-weight:700;color:var(--blue-deep);line-height:1;margin:0 0 4px}

  /* ---------- INLINE CTA (after sorry #3) ---------- */
  .pfd1-inline-cta{background:var(--ink);color:#fff;border-radius:8px;padding:24px 22px;margin:24px 0;text-align:center}
  .pfd1-inline-cta p{margin:0 0 14px;font-size:16px;line-height:1.45;color:#E8ECF4}
  .pfd1-inline-cta p b{color:#fff;font-weight:700}
  .pfd1-inline-cta a{display:inline-block;background:var(--blue);color:#fff;padding:13px 24px;border-radius:6px;font-weight:700;font-size:14px;text-transform:uppercase;letter-spacing:.06em}

  /* ---------- PRODUCT REVEAL ---------- */
  .pfd1-reveal{background:var(--cream);padding:48px 0;border-top:1px solid var(--line);margin-top:32px}
  .pfd1-reveal__kicker{font-size:11px;text-transform:uppercase;letter-spacing:.16em;color:var(--red);font-weight:800;margin:0 0 12px;text-align:center}
  .pfd1-reveal h2{font-weight:700;font-size:clamp(28px,5vw,40px);line-height:1.1;letter-spacing:-.01em;margin:0 0 16px;color:var(--ink);text-align:center}
  .pfd1-reveal h2 em{font-style:italic;color:var(--blue)}
  .pfd1-reveal__sub{text-align:center;font-size:17px;line-height:1.55;color:#2D3340;max-width:560px;margin:0 auto 28px}
  .pfd1-reveal__three{display:grid;grid-template-columns:1fr;gap:14px;max-width:640px;margin:0 auto 0}
  @media(min-width:680px){.pfd1-reveal__three{grid-template-columns:repeat(3,1fr)}}
  .pfd1-reveal__card{background:#fff;border:1px solid var(--line);border-radius:6px;padding:18px 16px;text-align:center}
  .pfd1-reveal__card b{display:block;font-size:26px;font-weight:700;color:var(--blue);line-height:1;margin:0 0 6px}
  .pfd1-reveal__card span{display:block;font-size:13px;color:var(--mute);line-height:1.4;font-weight:500}

  /* ---------- BUYBOX (live PDP pattern) ---------- */
  .pfd1-buy{padding:48px 0;background:#fff}
  .pfd1-buy__head{text-align:center;margin:0 0 22px}
  .pfd1-buy__kicker{font-size:11px;text-transform:uppercase;letter-spacing:.16em;color:var(--red);font-weight:800;margin:0 0 10px}
  .pfd1-buy h2{font-weight:700;font-size:clamp(26px,4.6vw,36px);line-height:1.1;margin:0 0 8px;color:var(--ink)}
  .pfd1-buy__sub{font-size:15px;color:var(--mute);margin:0 auto;max-width:520px}
  .pfd1-buy__label{font-size:12px;text-transform:uppercase;letter-spacing:.14em;color:var(--mute);font-weight:700;max-width:720px;margin:0 auto 10px;padding:0 4px}

  .pfd1-buy__list{display:flex;flex-direction:column;gap:0;max-width:720px;margin:0 auto;border:1px solid var(--line);border-radius:12px;overflow:hidden;background:#fff}
  .pfd1-row{position:relative;display:block;padding:18px 18px 16px;border-bottom:1px solid var(--line);background:#fff;color:var(--ink);transition:background .15s ease}
  .pfd1-row:last-child{border-bottom:0}
  .pfd1-row:hover{background:#FBFAF6}
  .pfd1-row--best{background:#F4EFE4}
  .pfd1-row--best:hover{background:#EDE6D4}

  .pfd1-row__top{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;margin:0 0 6px}
  .pfd1-row__left{flex:1;min-width:0;display:flex;flex-direction:column;gap:6px}
  .pfd1-row__namerow{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .pfd1-row__radio{width:18px;height:18px;border:2px solid #B7BBC4;border-radius:999px;flex:0 0 auto;display:inline-flex;align-items:center;justify-content:center;background:#fff;margin-right:2px}
  .pfd1-row--best .pfd1-row__radio{border-color:var(--ink)}
  .pfd1-row--best .pfd1-row__radio:after{content:"";width:9px;height:9px;background:var(--ink);border-radius:999px;display:block}
  .pfd1-row__name{font-size:19px;font-weight:700;color:var(--ink);line-height:1.1}
  .pfd1-row__pill{display:inline-flex;align-items:center;font-size:10px;font-weight:800;letter-spacing:.10em;text-transform:uppercase;padding:4px 9px;border-radius:4px;line-height:1}
  .pfd1-row__pill--save{background:var(--red);color:#fff}
  .pfd1-row__pill--pop{background:#4E78D1;color:#fff}
  .pfd1-row__pill--best{background:#4E78D1;color:#fff}
  .pfd1-row__desc{font-size:14px;line-height:1.4;color:#3D4452;max-width:380px;margin:0}
  .pfd1-row__assure{font-size:13px;line-height:1.4;color:var(--mute);margin:0}

  .pfd1-row__right{text-align:right;flex:0 0 auto;display:flex;flex-direction:column;align-items:flex-end;gap:2px;min-width:120px}
  .pfd1-row__per{font-size:22px;font-weight:700;color:var(--ink);line-height:1.1;white-space:nowrap}
  .pfd1-row__totline{font-size:13px;color:#3D4452;white-space:nowrap}
  .pfd1-row__was{text-decoration:line-through;color:var(--mute);margin-right:4px}
  .pfd1-row__save{font-size:13px;color:var(--blue-deep);font-weight:600;white-space:nowrap}

  .pfd1-row__cta{display:inline-flex;align-items:center;justify-content:center;background:var(--ink);color:#fff;padding:11px 18px;border-radius:6px;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-top:10px}
  .pfd1-row--best .pfd1-row__cta{background:var(--blue)}
  .pfd1-row__cta:after{content:" →";margin-left:6px}

  @media(max-width:480px){
    .pfd1-row__top{flex-direction:column;align-items:stretch}
    .pfd1-row__right{align-items:flex-start;text-align:left;flex-direction:row;flex-wrap:wrap;gap:6px 12px}
    .pfd1-row__per{font-size:20px}
  }

  .pfd1-buy__assure{display:flex;flex-wrap:wrap;gap:10px 20px;justify-content:center;align-items:center;font-size:13px;color:var(--mute);margin:16px auto 0;max-width:720px}
  .pfd1-buy__assure span{display:inline-flex;align-items:center;gap:6px}
  .pfd1-buy__assure svg{width:16px;height:16px;color:var(--blue)}

  /* ---------- REVIEWS BAND ---------- */
  .pfd1-rev{padding:44px 0;background:var(--cream);border-top:1px solid var(--line)}
  .pfd1-rev__head{text-align:center;margin:0 0 24px}
  .pfd1-rev__kicker{font-size:11px;text-transform:uppercase;letter-spacing:.16em;color:var(--mute);font-weight:700;margin:0 0 6px}
  .pfd1-rev h2{font-size:clamp(22px,3.6vw,28px);font-weight:700;margin:0 0 6px;color:var(--ink)}
  .pfd1-rev__stars-row{display:flex;justify-content:center;align-items:center;gap:8px;font-size:14px;color:var(--mute)}
  .pfd1-stars{display:inline-block;color:var(--gold);letter-spacing:1px;font-size:16px}
  .pfd1-stars:before{content:"★★★★★"}
  .pfd1-rev__grid{display:grid;grid-template-columns:1fr;gap:14px;max-width:1000px;margin:0 auto}
  @media(min-width:720px){.pfd1-rev__grid{grid-template-columns:repeat(3,1fr)}}
  .pfd1-quote{background:#fff;border:1px solid var(--line);border-radius:6px;padding:18px 18px}
  .pfd1-quote__stars{margin:0 0 8px}
  .pfd1-quote p{font-size:16px;line-height:1.55;color:#1E2330;margin:0 0 12px}
  .pfd1-quote__name{font-size:13px;font-weight:700;color:var(--ink)}
  .pfd1-quote__verif{font-size:12px;color:var(--mute);display:flex;align-items:center;gap:4px;margin-top:2px}
  .pfd1-quote__verif svg{width:13px;height:13px;color:var(--blue)}

  /* ---------- FAQ ---------- */
  .pfd1-faq{padding:48px 0;background:#fff;border-top:1px solid var(--line)}
  .pfd1-faq__head{text-align:center;margin:0 0 24px}
  .pfd1-faq h2{font-size:clamp(24px,4vw,32px);font-weight:700;margin:0;color:var(--ink)}
  .pfd1-faq__list{max-width:720px;margin:0 auto}
  .pfd1-faq__item{border-bottom:1px solid var(--line)}
  .pfd1-faq__item summary{list-style:none;cursor:pointer;padding:18px 36px 18px 0;font-size:16px;font-weight:600;color:var(--ink);position:relative}
  .pfd1-faq__item summary::-webkit-details-marker{display:none}
  .pfd1-faq__item summary:after{content:"+";position:absolute;right:6px;top:50%;transform:translateY(-50%);font-size:22px;color:var(--blue);font-weight:700;line-height:1}
  .pfd1-faq__item[open] summary:after{content:"–"}
  .pfd1-faq__item p{margin:0 0 18px;font-size:16px;line-height:1.6;color:#2D3340}

  /* ---------- CLOSE / FINAL CTA ---------- */
  .pfd1-close{padding:56px 0;background:var(--ink);color:#fff;text-align:center}
  .pfd1-close__kicker{font-size:12px;text-transform:uppercase;letter-spacing:.16em;color:#A4B0CF;font-weight:700;margin:0 0 10px}
  .pfd1-close h2{font-size:clamp(28px,5vw,40px);font-weight:700;margin:0 0 12px;color:#fff;line-height:1.1}
  .pfd1-close h2 em{font-style:italic;color:#9EA9FF}
  .pfd1-close p{font-size:16px;color:#C9D1E2;max-width:520px;margin:0 auto 22px;line-height:1.5}
  .pfd1-close a{display:inline-flex;align-items:center;background:var(--blue);color:#fff;padding:15px 28px;border-radius:8px;font-weight:700;font-size:15px;text-transform:uppercase;letter-spacing:.05em}
  .pfd1-close a:after{content:" →";margin-left:6px}

  /* ---------- DISCLAIMER ---------- */
  .pfd1-disclaim{padding:24px 0 80px;background:#fff;border-top:1px solid var(--line)}
  .pfd1-disclaim p{font-size:12px;line-height:1.55;color:var(--mute);max-width:720px;margin:0 auto 10px}
  .pfd1-disclaim a{color:var(--blue-deep);text-decoration:underline}

  /* ---------- HERO ABOVE-FOLD RATING + CTA ROW ---------- */
  .pfd1-hero-row{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:10px 16px;margin:0 0 18px}
  .pfd1-hero-row__rating{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--mute)}
  .pfd1-hero-row__rating b{color:var(--ink);font-weight:700}
  .pfd1 a.pfd1-hero-row__cta{display:inline-flex;align-items:center;background:var(--blue);color:#fff;padding:11px 18px;border-radius:6px;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:.05em;min-height:44px}
  .pfd1 a.pfd1-hero-row__cta:after{content:" ↓";margin-left:6px}
  .pfd1 a.pfd1-hero-row__cta:hover{background:var(--blue-deep);color:#fff}

  /* ---------- UGC VIDEO ---------- */
  .pfd1-ugc{margin:0 0 28px;border-radius:6px;overflow:hidden;background:#0B1220;position:relative}
  .pfd1-ugc video{width:100%;display:block;aspect-ratio:9/16;max-height:640px;object-fit:cover;background:#0B1220}
  @media(min-width:680px){.pfd1-ugc video{aspect-ratio:4/5;max-height:720px}}
  .pfd1-ugc figcaption{font-size:13px;color:var(--mute);padding:10px 4px 0;line-height:1.4}
  .pfd1-ugc figcaption b{color:var(--ink);font-weight:600}

  /* ---------- FOUNDER BAND ---------- */
  .pfd1-founder{margin:28px 0;padding:22px;background:var(--cream);border-radius:8px;border:1px solid var(--line);display:flex;gap:18px;align-items:center}

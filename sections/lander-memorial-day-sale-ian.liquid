          {%- assign sp_bullets = spot_bullets[idx] | split: '~' -%}
          <a class="lnd-md__spot-tile" href="/products/{{ sp.handle }}" data-handle="{{ sp.handle }}" data-modal-open>
            <span class="lnd-md__spot-ribbon">Bestseller</span>
            {%- if sp.handle == 'wlp-1' or sp.handle == 'weight-management-stack' -%}<span class="lnd-md__spot-lowstock">Low Stock</span>{%- endif -%}
            <div class="lnd-md__spot-tile-img">
              {%- if img_url != blank -%}
                <img src="{{ img_url }}" alt="{{ sp.title | escape }}" loading="lazy" width="600" height="600">
              {%- elsif sp.featured_image -%}
                <img src="{{ sp.featured_image | image_url: width: 600 }}" alt="{{ sp.title | escape }}" loading="lazy" width="600" height="600">
              {%- endif -%}
            </div>
            <h3 class="lnd-md__spot-tile-title">{{ sp.title }}</h3>
            {%- if sp_sub != blank -%}<p class="lnd-md__spot-tile-sub">{{ sp_sub }}</p>{%- endif -%}
            <ul class="lnd-md__spot-tile-bullets">
              {%- for b in sp_bullets -%}<li>{{ b }}</li>{%- endfor -%}

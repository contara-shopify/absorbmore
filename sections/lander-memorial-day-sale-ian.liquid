  {%- comment -%} Best-seller spotlights — WLP-1, Berberine, Magnesium, Vitamin D {%- endcomment -%}
  <div class="lnd-md__spots">
    <div class="lnd-md__spots-head">
      <div class="lnd-md__spots-eyebrow">The Most-Loved Four</div>
      <h2>Bestsellers <span class="lnd-md__spots-pipe">|</span> 35% Off</h2>
      <p>The four our customers reorder most. Designed to be felt, not just taken.</p>
    </div>
    <div class="lnd-md__spots-grid">
      {%- for h in spotlight_handles -%}
        {%- assign sp = nil -%}
        {%- assign sp = all_products[h] -%}
        {%- if sp != blank and sp.handle != blank -%}
          {%- assign idx = forloop.index0 -%}
          {%- assign sale_price = sp.price | times: keep_pct | divided_by: 100 -%}
          {%- assign img_url = '' -%}
          {%- for oh in override_handles -%}
            {%- if oh == sp.handle -%}{%- assign img_url = override_urls[forloop.index0] -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
          {%- assign sp_meta_idx = -1 -%}
          {%- for mh in meta_handles -%}
            {%- if mh == sp.handle -%}{%- assign sp_meta_idx = forloop.index0 -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
          {%- assign sp_rating = '' -%}
          {%- assign sp_reviews = '' -%}
          {%- if sp_meta_idx >= 0 -%}
            {%- assign sp_rating = ratings[sp_meta_idx] -%}
            {%- assign sp_reviews = reviews[sp_meta_idx] -%}
          {%- endif -%}

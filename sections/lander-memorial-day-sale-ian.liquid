  {%- comment -%} Bubble filter row {%- endcomment -%}
  <div class="lnd-md__bubbles-wrap" id="md-bubbles">
    <div class="lnd-md__bubbles-inner">
      <h2 class="lnd-md__bubbles-head">Shop by goal</h2>
      <div class="lnd-md__bubbles" role="tablist" aria-label="Filter by goal">
        <button class="lnd-md__bubble is-active" type="button" data-goal="all" aria-pressed="true">All <span class="lnd-md__bubble-count">{{ meta_handles.size }}</span></button>
        <button class="lnd-md__bubble" type="button" data-goal="longevity" aria-pressed="false">Longevity &amp; Performance <span class="lnd-md__bubble-count">{{ goal_longevity.size }}</span></button>
        <button class="lnd-md__bubble" type="button" data-goal="metab" aria-pressed="false">Metabolism &amp; Hormones <span class="lnd-md__bubble-count">{{ goal_metab.size }}</span></button>
        <button class="lnd-md__bubble" type="button" data-goal="sleep" aria-pressed="false">Sleep &amp; Mood <span class="lnd-md__bubble-count">{{ goal_sleep.size }}</span></button>
        <button class="lnd-md__bubble" type="button" data-goal="immunity" aria-pressed="false">Immunity &amp; Inflammation <span class="lnd-md__bubble-count">{{ goal_immunity.size }}</span></button>

  {%- comment -%} Shop-all product grid {%- endcomment -%}
  <div class="lnd-md__grid-wrap" id="md-grid">
    <div class="lnd-md__grid-head">
      <h2>Shop the sale</h2>
      <span class="lnd-md__grid-count" data-grid-count>{{ meta_handles.size }} products</span>
    </div>
    <div class="lnd-md__grid" data-grid>
      {%- if products_list != blank and products_list.size > 0 -%}
        {%- assign iter_source = products_list -%}
      {%- else -%}
        {%- assign iter_source = display_handles -%}
      {%- endif -%}

      {%- for entry in iter_source -%}
        {%- if products_list != blank and products_list.size > 0 -%}
          {%- assign p = entry -%}
        {%- else -%}
          {%- assign p = all_products[entry] -%}
        {%- endif -%}

        {%- if p != blank and p.handle != blank -%}
          {%- assign meta_idx = -1 -%}
          {%- for mh in meta_handles -%}
            {%- if mh == p.handle -%}{%- assign meta_idx = forloop.index0 -%}{%- break -%}{%- endif -%}
          {%- endfor -%}

          {%- assign pill_text = '' -%}
          {%- assign badge_text = '' -%}
          {%- assign rating_val = '' -%}
          {%- assign reviews_val = '' -%}
          {%- if meta_idx >= 0 -%}
            {%- assign pill_text = pills[meta_idx] -%}
            {%- assign badge_text = badges[meta_idx] -%}
            {%- assign rating_val = ratings[meta_idx] -%}
            {%- assign reviews_val = reviews[meta_idx] -%}
          {%- endif -%}

          {%- assign tile_chips = 'all' -%}
          {%- if goal_longevity contains p.handle -%}{%- assign tile_chips = tile_chips | append: ' longevity' -%}{%- endif -%}
          {%- if goal_metab contains p.handle -%}{%- assign tile_chips = tile_chips | append: ' metab' -%}{%- endif -%}
          {%- if goal_sleep contains p.handle -%}{%- assign tile_chips = tile_chips | append: ' sleep' -%}{%- endif -%}
          {%- if goal_immunity contains p.handle -%}{%- assign tile_chips = tile_chips | append: ' immunity' -%}{%- endif -%}

          {%- assign was_price = p.compare_at_price -%}
          {%- assign now_price = p.price -%}
          {%- if was_price == nil or was_price <= now_price -%}
            {%- assign now_price = p.price | times: keep_pct | divided_by: 100 -%}
            {%- assign was_price = p.price -%}
          {%- endif -%}

          {%- assign tile_img_url = '' -%}
          {%- for oh in override_handles -%}
            {%- if oh == p.handle -%}{%- assign tile_img_url = override_urls[forloop.index0] -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
          {%- assign tile_img = p.featured_image -%}

          {%- assign tile_sub = p.metafields.smart.short_description -%}
          {%- if tile_sub == blank -%}{%- assign tile_sub = p.metafields.smart.tagline -%}{%- endif -%}
          {%- if tile_sub == blank -%}{%- assign tile_sub = p.description | strip_html | truncate: 80 -%}{%- endif -%}

          {%- assign is_low_stock = false -%}
          {%- if p.handle == 'wlp-1' or p.handle == 'weight-management-stack' -%}{%- assign is_low_stock = true -%}{%- endif -%}
          <a class="lnd-md__tile" href="/products/{{ p.handle }}" data-chips="{{ tile_chips }}">
            {%- if pill_text != blank or badge_text != blank or is_low_stock -%}
              <div class="lnd-md__tile-badges">
                {%- if pill_text != blank -%}<span class="lnd-md__tile-pill">{{ pill_text }}</span>{%- endif -%}
                {%- if badge_text != blank -%}<span class="lnd-md__tile-badge">{{ badge_text }}</span>{%- endif -%}
                {%- if is_low_stock -%}<span class="lnd-md__tile-lowstock">Low Stock</span>{%- endif -%}
              </div>
            {%- endif -%}
            <div class="lnd-md__tile-img">
              {%- if tile_img_url != blank -%}
                <img src="{{ tile_img_url }}" alt="{{ p.title | escape }}" loading="lazy" width="600" height="600">
              {%- elsif tile_img -%}
                <img src="{{ tile_img | image_url: width: 600 }}" alt="{{ p.title | escape }}" loading="lazy" width="600" height="600">
              {%- endif -%}
            </div>
            <div class="lnd-md__tile-info">
              <h3 class="lnd-md__tile-title">{{ p.title }}</h3>
              {%- if tile_sub != blank -%}<p class="lnd-md__tile-sub">{{ tile_sub }}</p>{%- endif -%}
              {%- if rating_val != blank -%}
                <div class="lnd-md__tile-stars">
                  <span class="lnd-md__tile-stars-glyphs">★★★★★</span>
                  <span class="lnd-md__tile-stars-meta">{{ rating_val }} ({{ reviews_val }})</span>
                </div>
              {%- endif -%}
              <div class="lnd-md__tile-price">
                <span class="now">{{ now_price | money }}</span>
                <span class="was">{{ was_price | money }}</span>
                <span class="off">{{ discount_pct }}% off</span>
              </div>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Final CTA band {%- endcomment -%}
  <div class="lnd-md__final">
    <div class="lnd-md__countdown" data-countdown>
      <div><b data-d>00</b><span>Days</span></div>
      <div><b data-h>00</b><span>Hours</span></div>
      <div><b data-m>00</b><span>Minutes</span></div>
      <div><b data-s>00</b><span>Seconds</span></div>
    </div>
    <h2>{{ discount_pct }}% off ends soon. <em>The absorption stays.</em></h2>
    <p>One sale a year on the whole catalog. Take the bestsellers home for 35% less.</p>
    <a class="lnd-md__final-cta" href="#md-grid">Shop the sale</a>
  </div>

  {%- comment -%} Sticky mobile CTA {%- endcomment -%}
  <div class="lnd-md__mobile-cta" data-mobile-cta>
    <a href="#md-grid">Shop {{ discount_pct }}% off</a>
  </div>

  {%- comment -%} Quick-add modal {%- endcomment -%}
  <div class="lnd-md__modal" data-modal aria-hidden="true" role="dialog">
    <div class="lnd-md__modal-backdrop" data-modal-close></div>
    <div class="lnd-md__modal-panel">
      <button class="lnd-md__modal-close" data-modal-close aria-label="Close">×</button>
      <div class="lnd-md__modal-panel-inner">
        <div class="lnd-md__modal-media">
          <div class="lnd-md__modal-img"><img data-modal-img src="" alt=""></div>
          <div class="lnd-md__thumbs" data-modal-thumbs></div>

{%- liquid
  assign section_id = section.settings.section_id
  assign custom_css = section.settings.custom_css
  assign container_spacing = section.settings.container_spacing
  assign product_image = section.settings.product_image
  assign product_image_mobile = section.settings.product_image_mobile | default: product_image
-%}

{%- capture selector -%}[data-style-id="{{ section.id }}"]{%- endcapture -%}

{%- capture css -%}
  & {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  & .ctr-two-product__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  & .ctr-two-product__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.56fr);
    gap: 48px;
    align-items: center;
    margin-bottom: 70px;
  }

  & .ctr-two-product__heading {
    max-width: 760px;
    margin: 0;
    font-size: {{ section.settings.heading_size_desktop }}px;
    font-weight: 800;
    line-height: 0.94;
    letter-spacing: 0;
  }

  & .ctr-two-product__heading p,
  & .ctr-two-product__intro p,
  & .ctr-two-product__copy p,
  & .ctr-two-product__tech p {
    margin: 0;
  }

  & .ctr-two-product__intro {
    max-width: 660px;
    font-size: {{ section.settings.intro_size_desktop }}px;
    line-height: 1.25;
  }

  & .ctr-two-product__card {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.82fr) minmax(0, 1fr);
    gap: 26px;
    min-height: {{ section.settings.card_min_height }}px;
    padding: {{ section.settings.card_padding }}px;
    border: 1px solid rgba(255, 255, 255, 0.78);
    border-radius: {{ section.settings.card_radius }}px;
    background: {{ section.settings.card_background }};
    overflow: hidden;
  }

  & .ctr-two-product__product {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  & .ctr-two-product__product--left {
    grid-column: 1;
    grid-row: 1;
  }

  & .ctr-two-product__product--right {
    grid-column: 3;
    grid-row: 1;
    padding-left: 12px;
  }

  & .ctr-two-product__media {
    position: relative;
    z-index: 1;
    grid-column: 2;
    grid-row: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
  }

  & .ctr-two-product__media img {
    display: block;
    width: min(100%, {{ section.settings.image_max_width }}px);
    height: auto;
  }

  & .ctr-two-product__line {
    position: absolute;
    height: 1px;
    border-top: 2px dotted var(--accent);
    opacity: 0.78;
    pointer-events: none;
  }

  & .ctr-two-product__line::after {
    content: "";
    position: absolute;
    top: -8px;
    width: 16px;
    height: 16px;
    border: 3px solid #ffffff;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }

  & .ctr-two-product__line--left {
    top: 0;
    left: 0;
    right: -130px;
    --accent: {{ section.settings.berberine_accent }};
  }

  & .ctr-two-product__line--left::after {
    right: -8px;
  }

  & .ctr-two-product__line--right {
    right: 0;
    bottom: 0;
   left: -130px;
    --accent: {{ section.settings.magnesium_accent }};
  }

  & .ctr-two-product__line--right::after {
    left: -8px;
  }

  & .ctr-two-product__title {
    margin: 0 0 18px;
    font-size: {{ section.settings.product_title_size }}px;
    font-weight: 800;
    line-height: 1;
  }

  & .ctr-two-product__copy {
    margin-bottom: 28px;
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.32;
  }

  & .ctr-two-product__bullets {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 0 0 24px;
    padding: 0;
    list-style: none;
    font-size: {{ section.settings.bullet_size }}px;
    font-weight: 800;
    line-height: 1.2;
  }

  & .ctr-two-product__bullets li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  & .ctr-two-product__drop {
    width: 12px;
    height: 16px;
    flex: 0 0 auto;
    margin-top: 1px;
    color: var(--accent);
  }

  & .ctr-two-product__tech {
    color: var(--accent);
    font-size: {{ section.settings.tech_size }}px;
    font-weight: 800;
    line-height: 1.2;
  }

  & .ctr-two-product__tabs {
    display: none;
  }

  @media (min-width: 1024px) {
    & .ctr-two-product__line--left {
      top: {{ section.settings.left_line_top }}px;
    }

    & .ctr-two-product__line--right {
      bottom: {{ section.settings.right_line_bottom }}px;
    }

    & .ctr-two-product__media img {
      transform: scale({{ section.settings.desktop_image_scale | divided_by: 100.0 }});
      transform-origin: center;
    }
  }

  @media (max-width: 1023px) {
    & {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    & .ctr-two-product__header {
      display: flex;
      flex-direction: column;
      gap: 26px;
      align-items: center;
      margin-bottom: 38px;
      text-align: center;
    }

    & .ctr-two-product__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
      line-height: 0.96;
    }

    & .ctr-two-product__intro {
      font-size: {{ section.settings.intro_size_mobile }}px;
      line-height: 1.35;
    }

    & .ctr-two-product__card {
      display: block;
      min-height: 0;
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      overflow: visible;
    }

    & .ctr-two-product__media {
      grid-column: auto;
      grid-row: auto;
      min-height: {{ section.settings.mobile_image_height }}px;
      margin-bottom: 26px;
      padding: 30px;
      border: 1px solid rgba(255, 255, 255, 0.82);
      border-radius: {{ section.settings.card_radius_mobile }}px;
      background: {{ section.settings.card_background }};
      overflow: hidden;
    }

    & .ctr-two-product__media img {
      width: min(100%, {{ section.settings.image_mobile_max_width }}px);
    }

    & .ctr-two-product__tabs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      margin-bottom: 34px;
    }

    & .ctr-two-product__tab {
      min-height: 34px;
      border: 0;
      border-radius: 999px;
      background: transparent;
      color: rgba(32, 32, 32, 0.48);
      font: inherit;
      font-size: 14px;
      font-weight: 400;
      line-height: 1;
      cursor: pointer;
    }

    & .ctr-two-product__tab.is-active {
      color: #ffffff;
      background: var(--accent);
      font-weight: 700;
    }

    & .ctr-two-product__product {
      grid-column: auto;
      grid-row: auto;
      display: none;
      justify-content: flex-start;
      padding: 0;
    }

    & .ctr-two-product__product.is-active {
      display: flex;
    }

    & .ctr-two-product__line {
      position: relative;
      top: auto;
      right: auto;
      bottom: auto;
      left: auto;
      display: block;
      width: 100%;
      margin-bottom: 36px;
      border-top-width: 2px;
    }

    & .ctr-two-product__line::after {
      top: -8px;
      left: 0;
      right: auto;
    }

    & .ctr-two-product__line--right {
      --accent: {{ section.settings.magnesium_accent }};
    }

    & .ctr-two-product__title {
      margin-bottom: 24px;
      font-size: {{ section.settings.product_title_size_mobile }}px;
    }

    & .ctr-two-product__copy {
      margin-bottom: 30px;
      font-size: {{ section.settings.body_size_mobile }}px;
      line-height: 1.38;
    }

    & .ctr-two-product__bullets {
      gap: 14px;
      margin-bottom: 26px;
      font-size: {{ section.settings.bullet_size_mobile }}px;
    }

    & .ctr-two-product__tech {
      font-size: {{ section.settings.tech_size_mobile }}px;
    }
  }
{%- endcapture -%}

<section
  data-section-type="ctr_two_product_system"
  data-style-id="{{ section.id }}"
  {% if section_id != blank %}id="{{ section_id }}"{% endif %}
  class="ctr-two-product {{ container_spacing }}"
  x-data="{ activeProduct: 'berberine' }"
>
  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  </style>

  <div class="ctr-two-product__inner">
    <div class="ctr-two-product__header">
      {% if section.settings.heading != blank %}
        <div class="ctr-two-product__heading">{{ section.settings.heading }}</div>
      {% endif %}

      {% if section.settings.intro != blank %}
        <div class="ctr-two-product__intro">{{ section.settings.intro }}</div>
      {% endif %}
    </div>

    <div class="ctr-two-product__card">
      <div class="ctr-two-product__media">
        {% if product_image != blank %}
          <picture>
            {% if product_image_mobile != blank %}
              <source
                media="(max-width: 749px)"
                srcset="{{ product_image_mobile | image_url: width: 700 }} 700w, {{ product_image_mobile | image_url: width: 1000 }} 1000w, {{ product_image_mobile | image_url: width: 1400 }} 1400w"
                sizes="100vw"
              >
            {% endif %}
            <img
              src="{{ product_image | image_url: width: 1200 }}"
              alt="{{ section.settings.product_image_alt | default: product_image.alt | escape }}"
              width="{{ product_image.width }}"
              height="{{ product_image.height }}"
              loading="lazy"
            >
          </picture>
        {% endif %}
      </div>

      <div class="ctr-two-product__tabs" role="tablist" aria-label="Products">
        <button
          type="button"
          class="ctr-two-product__tab"
          style="--accent: {{ section.settings.berberine_accent }};"
          :class="activeProduct === 'berberine' ? 'is-active' : ''"
          @click="activeProduct = 'berberine'"
          role="tab"
          :aria-selected="activeProduct === 'berberine' ? 'true' : 'false'"
        >
          {{ section.settings.berberine_title | escape }}
        </button>
        <button
          type="button"
          class="ctr-two-product__tab"
          style="--accent: {{ section.settings.magnesium_accent }};"
          :class="activeProduct === 'magnesium' ? 'is-active' : ''"
          @click="activeProduct = 'magnesium'"
          role="tab"
          :aria-selected="activeProduct === 'magnesium' ? 'true' : 'false'"
        >
          {{ section.settings.magnesium_title | escape }}
        </button>
      </div>

      <div
        class="ctr-two-product__product ctr-two-product__product--left"
        style="--accent: {{ section.settings.berberine_accent }};"
        :class="activeProduct === 'berberine' ? 'is-active' : ''"
      >
        <span class="ctr-two-product__line ctr-two-product__line--left" aria-hidden="true"></span>
        <h3 class="ctr-two-product__title">{{ section.settings.berberine_title | escape }}</h3>
        <div class="ctr-two-product__copy">{{ section.settings.berberine_description }}</div>
        <ul class="ctr-two-product__bullets">
          {%- assign berberine_bullets = section.settings.berberine_bullets | newline_to_br | split: '<br />' -%}
          {% for bullet in berberine_bullets %}
            {%- assign bullet_text = bullet | strip -%}
            {% if bullet_text != blank %}
              <li>
                <svg class="ctr-two-product__drop" viewBox="0 0 12 16" fill="currentColor" aria-hidden="true" focusable="false"><path d="M6 0C4.3 2.25 1 6.55 1 9.75A5 5 0 0 0 11 9.75C11 6.55 7.7 2.25 6 0Z"/></svg>
                <span>{{ bullet_text }}</span>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
        <div class="ctr-two-product__tech">{{ section.settings.berberine_tech }}</div>
      </div>

      <div
        class="ctr-two-product__product ctr-two-product__product--right"
        style="--accent: {{ section.settings.magnesium_accent }};"
        :class="activeProduct === 'magnesium' ? 'is-active' : ''"
      >
        <span class="ctr-two-product__line ctr-two-product__line--right" aria-hidden="true"></span>
        <h3 class="ctr-two-product__title">{{ section.settings.magnesium_title | escape }}</h3>
        <div class="ctr-two-product__copy">{{ section.settings.magnesium_description }}</div>
        <ul class="ctr-two-product__bullets">
          {%- assign magnesium_bullets = section.settings.magnesium_bullets | newline_to_br | split: '<br />' -%}
          {% for bullet in magnesium_bullets %}
            {%- assign bullet_text = bullet | strip -%}
            {% if bullet_text != blank %}
              <li>
                <svg class="ctr-two-product__drop" viewBox="0 0 12 16" fill="currentColor" aria-hidden="true" focusable="false"><path d="M6 0C4.3 2.25 1 6.55 1 9.75A5 5 0 0 0 11 9.75C11 6.55 7.7 2.25 6 0Z"/></svg>
                <span>{{ bullet_text }}</span>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
        <div class="ctr-two-product__tech">{{ section.settings.magnesium_tech }}</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTR Two Product System",
  "tag": "section",
  "class": "shopify_section__ctr_two_product_system",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "container_spacing",
      "label": "Container spacing",
      "default": "px-container-gutter",
      "options": [
        { "value": "px-container-xs", "label": "Extra Small" },
        { "value": "px-container-sm", "label": "Small" },
        { "value": "px-container-md", "label": "Medium" },
        { "value": "px-container-lg", "label": "Large" },
        { "value": "px-container-gutter", "label": "Gutter Only" },
        { "value": "px-container-fullwidth", "label": "Fullwidth" }
      ]
    },
    { "type": "range", "id": "max_width", "label": "Max width", "default": 1720, "min": 980, "max": 1920, "step": 20, "unit": "px" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f0ede7" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#202020" },
    { "type": "range", "id": "padding_top", "label": "Padding top - desktop", "default": 92, "min": 0, "max": 180, "step": 4, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom - desktop", "default": 32, "min": 0, "max": 180, "step": 4, "unit": "px" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top - mobile", "default": 60, "min": 0, "max": 120, "step": 4, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom - mobile", "default": 40, "min": 0, "max": 120, "step": 4, "unit": "px" },

    { "type": "header", "content": "Header" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Two products.<br>One complete system.</p>" },
    { "type": "richtext", "id": "intro", "label": "Supporting description", "default": "<p>Most supplements do one thing. This stack covers the full arc of your day blood sugar handled in the morning, stress and recovery handled at night.</p>" },
    { "type": "range", "id": "heading_size_desktop", "label": "Heading size - desktop", "default": 68, "min": 36, "max": 100, "step": 1, "unit": "px" },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size - mobile", "default": 42, "min": 28, "max": 64, "step": 1, "unit": "px" },
    { "type": "range", "id": "intro_size_desktop", "label": "Intro size - desktop", "default": 24, "min": 14, "max": 34, "step": 1, "unit": "px" },
    { "type": "range", "id": "intro_size_mobile", "label": "Intro size - mobile", "default": 21, "min": 14, "max": 28, "step": 1, "unit": "px" },

    { "type": "header", "content": "Product Card" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#f8f7f4" },
    { "type": "range", "id": "card_min_height", "label": "Card min height", "default": 590, "min": 420, "max": 820, "step": 10, "unit": "px" },
    { "type": "range", "id": "card_padding", "label": "Card padding - desktop", "default": 88, "min": 0, "max": 140, "step": 4, "unit": "px" },
    { "type": "range", "id": "card_radius", "label": "Card radius - desktop", "default": 22, "min": 0, "max": 48, "step": 1, "unit": "px" },
    { "type": "range", "id": "card_radius_mobile", "label": "Image card radius - mobile", "default": 18, "min": 0, "max": 40, "step": 1, "unit": "px" },
    { "type": "image_picker", "id": "product_image", "label": "Product image - desktop" },
    { "type": "image_picker", "id": "product_image_mobile", "label": "Product image - mobile" },
    { "type": "text", "id": "product_image_alt", "label": "Product image alt override" },
    { "type": "range", "id": "image_max_width", "label": "Image max width - desktop", "default": 620, "min": 320, "max": 840, "step": 10, "unit": "px" },
    { "type": "range", "id": "desktop_image_scale", "label": "Image scale - desktop", "default": 100, "min": 50, "max": 160, "step": 5, "unit": "%" },
    { "type": "range", "id": "image_mobile_max_width", "label": "Image max width - mobile", "default": 430, "min": 220, "max": 560, "step": 10, "unit": "px" },
    { "type": "range", "id": "mobile_image_height", "label": "Image card height - mobile", "default": 430, "min": 280, "max": 620, "step": 10, "unit": "px" },
    { "type": "range", "id": "left_line_top", "label": "Left line top offset - desktop", "default": 0, "min": -120, "max": 160, "step": 4, "unit": "px" },
    { "type": "range", "id": "right_line_bottom", "label": "Right line bottom offset - desktop", "default": 0, "min": -120, "max": 160, "step": 4, "unit": "px" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "product_title_size", "label": "Product title size - desktop", "default": 35, "min": 24, "max": 56, "step": 1, "unit": "px" },
    { "type": "range", "id": "product_title_size_mobile", "label": "Product title size - mobile", "default": 34, "min": 24, "max": 48, "step": 1, "unit": "px" },
    { "type": "range", "id": "body_size", "label": "Body size - desktop", "default": 17, "min": 12, "max": 24, "step": 1, "unit": "px" },
    { "type": "range", "id": "body_size_mobile", "label": "Body size - mobile", "default": 18, "min": 12, "max": 24, "step": 1, "unit": "px" },
    { "type": "range", "id": "bullet_size", "label": "Bullet size - desktop", "default": 17, "min": 12, "max": 24, "step": 1, "unit": "px" },
    { "type": "range", "id": "bullet_size_mobile", "label": "Bullet size - mobile", "default": 17, "min": 12, "max": 24, "step": 1, "unit": "px" },
    { "type": "range", "id": "tech_size", "label": "Tech line size - desktop", "default": 18, "min": 12, "max": 26, "step": 1, "unit": "px" },
    { "type": "range", "id": "tech_size_mobile", "label": "Tech line size - mobile", "default": 17, "min": 12, "max": 24, "step": 1, "unit": "px" },

    { "type": "header", "content": "Berberine" },
    { "type": "color", "id": "berberine_accent", "label": "Accent color", "default": "#a5282b" },
    { "type": "text", "id": "berberine_title", "label": "Title", "default": "Berberine" },
    { "type": "richtext", "id": "berberine_description", "label": "Description", "default": "<p>Your daytime anchor. Activates AMPK the metabolic switch that helps your body use blood sugar efficiently. Less spiking. Fewer cravings. Steady energy from breakfast through dinner, without caffeine or stimulants.</p>" },
    { "type": "textarea", "id": "berberine_bullets", "label": "Bullets", "default": "Curbs appetite and sugar cravings\nSupports healthy blood sugar balance\nKills the 3pm energy slump\nSupports healthy weight and metabolism" },
    { "type": "richtext", "id": "berberine_tech", "label": "Tech line", "default": "<p>FenuMat® Technology — 6.2× better absorption</p>" },

    { "type": "header", "content": "Magnesium Glycinate" },
    { "type": "color", "id": "magnesium_accent", "label": "Accent color", "default": "#2c4ed0" },
    { "type": "text", "id": "magnesium_title", "label": "Title", "default": "Magnesium Glycinate" },
    { "type": "richtext", "id": "magnesium_description", "label": "Description", "default": "<p>Your nighttime restore. Fuels the 300+ biochemical processes your body runs while you sleep easing muscle tension, calming your nervous system, and setting up tomorrow's energy before you even wake up.</p>" },
    { "type": "textarea", "id": "magnesium_bullets", "label": "Bullets", "default": "Eases muscle tension and physical stress\nCalms the nervous system\nSupports deeper, more restorative sleep\nStabilizes mood and reduces day-to-day variability" },
    { "type": "richtext", "id": "magnesium_tech", "label": "Tech line", "default": "<p>FenuMat® Technology — 6.2× better absorption</p>" },

    { "type": "header", "content": "Advanced" },
    { "type": "textarea", "id": "custom_css", "label": "Custom CSS", "default": "& {\n}\n" },
    { "type": "text", "id": "section_id", "label": "Section ID" }
  ],
  "presets": [
    {
      "name": "CTR Two Product System",
      "category": "Custom"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "custom.global", "custom.header", "custom.modal", "custom.card", "custom.head", "custom.megamenu"]
  }
}
{% endschema %}

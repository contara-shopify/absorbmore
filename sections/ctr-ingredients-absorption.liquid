{%- liquid
  assign section_id = section.settings.section_id
  assign custom_css = section.settings.custom_css
  assign container_spacing = section.settings.container_spacing
-%}

{%- capture selector -%}[data-style-id="{{ section.id }}"]{%- endcapture -%}

{%- capture css -%}
  & {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;

    @media (max-width: 749px) {
      padding-right: 0 !important;
    }
  }

  & .ctr-ingr__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  /* Header */
  & .ctr-ingr__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.header_inner_gap }}px;
    align-items: start;
    margin-bottom: {{ section.settings.header_gap }}px;
  }

  & .ctr-ingr__heading {
    margin: 0;
    font-size: {{ section.settings.heading_size_desktop }}px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  & .ctr-ingr__heading p { margin: 0; }

  & .ctr-ingr__header-right {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.description_legend_gap }}px;
  }

  & .ctr-ingr__description {
    font-size: {{ section.settings.description_size_desktop }}px;
    line-height: 1.4;
  }

  & .ctr-ingr__description p { margin: 0; }

  & .ctr-ingr__legend {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  & .ctr-ingr__pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    border-radius: 999px;
    background: {{ section.settings.pill_bg }};
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.pill_size_desktop }}px;
    font-weight: 600;
    line-height: 1;
  }

  & .ctr-ingr__pill-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex: 0 0 auto;
  }

  /* Cards grid - desktop: 2x2 grid */
  & .ctr-ingr__cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: {{ section.settings.column_gap }}px;
    row-gap: {{ section.settings.card_gap }}px;
  }

  & .ctr-ingr__card {
    position: relative;
    border-radius: {{ section.settings.card_radius }}px;
    background: var(--card-bg);
    border: 1px solid var(--accent);
    display: flex;
    flex-direction: column;
    padding: {{ section.settings.card_padding }}px;
  }

  /* Card connector dot+line — only above first card in each desktop column */
  & .ctr-ingr__card--top {
    margin-top: {{ section.settings.connector_height }}px;
  }

  & .ctr-ingr__card-marker {
    position: absolute;
    top: -{{ section.settings.connector_height }}px;
    left: 50%;
    transform: translateX(-50%);
    {% comment %} display: none; {% endcomment %}
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }

  & .ctr-ingr__card--top .ctr-ingr__card-marker {
    display: flex;
  }

  & .ctr-ingr__card-marker-line {
    width: 1px;
    height: calc({{ section.settings.connector_height }}px - 10px);
    background: var(--accent);
    opacity: 0.6;
    display: none;
  }

  & .ctr-ingr__card-marker-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    transform: translateY(1px);
  }

  & .ctr-ingr__card-media {
    width: 100%;
    height: {{ section.settings.image_height_desktop }}px;
    margin-bottom: {{ section.settings.card_inner_gap }}px;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.04);
  }

  & .ctr-ingr__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  & .ctr-ingr__card-body {
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  & .ctr-ingr__card-title {
    margin: 0;
    font-size: {{ section.settings.card_title_size_desktop }}px;
    font-weight: 800;
    line-height: 1.2;
  }

  & .ctr-ingr__card-label {
    color: #707070;
    font-size: {{ section.settings.card_label_size_desktop }}px;
    font-weight: 400;
    line-height: 1.2;
  }

  & .ctr-ingr__card-copy {
    font-size: {{ section.settings.card_copy_size_desktop }}px;
    line-height: 1.45;
  }

  & .ctr-ingr__card-copy p { margin: 0; }
  & .ctr-ingr__card-copy p + p { margin-top: 0.6em; }

  /* Progress bar — desktop hidden */
  & .ctr-ingr__progress {
    display: none;
  }

  /* Stats row */
  & .ctr-ingr__stats-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: {{ section.settings.column_gap }}px;
    margin-top: {{ section.settings.stat_gap }}px;
  }

  & .ctr-ingr__stat {
    padding: 0 16px;
    text-align: center;
    font-size: {{ section.settings.stat_size_desktop }}px;
    line-height: 1.4;
  }

  & .ctr-ingr__stat p { margin: 0; }
  & .ctr-ingr__stat strong,
  & .ctr-ingr__stat b { font-weight: 800; }

  @media (max-width: 1023px) {
    & {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    & .ctr-ingr__header {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: {{ section.settings.header_gap_mobile }}px;
    }

    & .ctr-ingr__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }

    & .ctr-ingr__description {
      font-size: {{ section.settings.description_size_mobile }}px;
    }

    & .ctr-ingr__pill {
      font-size: {{ section.settings.pill_size_mobile }}px;
    }

    /* Mobile: horizontal carousel */
    & .ctr-ingr__cards-grid {
      display: flex;
      grid-template-columns: none;
      column-gap: 0;
      gap: {{ section.settings.card_gap_mobile }}px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 4px;
    }

    & .ctr-ingr__cards-grid::-webkit-scrollbar {
      display: none;
    }

    & .ctr-ingr__card {
      flex: 0 0 {{ section.settings.mobile_slide_width }}%;
      scroll-snap-align: start;
      margin-top: {{ section.settings.connector_height_mobile }}px;
    }

    /* On mobile every card gets the connector */
    & .ctr-ingr__card-marker {
      display: flex;
      top: -{{ section.settings.connector_height_mobile }}px;
    }

    & .ctr-ingr__card-marker-line {
      height: calc({{ section.settings.connector_height_mobile }}px - 10px);
      display: none;
    }

    & .ctr-ingr__card--top {
      margin-top: {{ section.settings.connector_height_mobile }}px;
    }

    & .ctr-ingr__card {
      padding: {{ section.settings.card_padding_mobile }}px;
    }

    & .ctr-ingr__card-media {
      height: auto;
      aspect-ratio: {{ section.settings.image_aspect_ratio_mobile }};
      margin-bottom: {{ section.settings.card_inner_gap_mobile }}px;
    }

    & .ctr-ingr__card-title {
      font-size: {{ section.settings.card_title_size_mobile }}px;
    }

    & .ctr-ingr__card-label {
      font-size: {{ section.settings.card_label_size_mobile }}px;
    }

    & .ctr-ingr__card-copy {
      font-size: {{ section.settings.card_copy_size_mobile }}px;
    }

    /* Progress bar — mobile visible */
    & .ctr-ingr__progress {
      display: block;
      position: relative;
      height: 3px;
      margin-top: 18px;
      background: {{ section.settings.progress_track_color }};
      border-radius: 2px;
      overflow: hidden;
    }

    & .ctr-ingr__progress-fill {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 0;
      background: {{ section.settings.progress_thumb_color }};
      border-radius: 2px;
      transition: left 0.08s linear, width 0.08s linear;
    }

    /* Stats stack on mobile */
    & .ctr-ingr__stats-row {
      grid-template-columns: 1fr;
      row-gap: 14px;
      margin-top: {{ section.settings.stat_gap_mobile }}px;
      {% if section.settings.hide_stats_mobile %}
        display: none;
      {% endif %}
    }

    & .ctr-ingr__stat {
      font-size: {{ section.settings.stat_size_mobile }}px;
    }
  }
{%- endcapture -%}

<section
  data-section-type="ctr_ingredients_absorption"
  data-style-id="{{ section.id }}"
  {% if section_id != blank %}id="{{ section_id }}"{% endif %}
  class="ctr-ingr {{ container_spacing }}"
>
  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  </style>

  <div class="ctr-ingr__inner">
    <div class="ctr-ingr__header">
      {% if section.settings.heading != blank %}
        <div class="ctr-ingr__heading">{{ section.settings.heading }}</div>
      {% endif %}

      <div class="ctr-ingr__header-right">
        {% if section.settings.description != blank %}
          <div class="ctr-ingr__description">{{ section.settings.description }}</div>
        {% endif %}

        {% if section.settings.cat1_label != blank or section.settings.cat2_label != blank %}
          <div class="ctr-ingr__legend">
            {% if section.settings.cat1_label != blank %}
              <span class="ctr-ingr__pill">
                <span class="ctr-ingr__pill-dot" style="background: {{ section.settings.cat1_color }};"></span>
                <span>{{ section.settings.cat1_label | escape }}</span>
              </span>
            {% endif %}

            {% if section.settings.cat2_label != blank %}
              <span class="ctr-ingr__pill">
                <span class="ctr-ingr__pill-dot" style="background: {{ section.settings.cat2_color }};"></span>
                <span>{{ section.settings.cat2_label | escape }}</span>
              </span>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ctr-ingr__cards-grid">
      {%- assign cat1_idx = 0 -%}
      {% for block in section.blocks %}
        {% if block.settings.category == '1' %}
          {%- assign cat1_idx = cat1_idx | plus: 1 -%}
          <article
            class="ctr-ingr__card{% if cat1_idx == 1 %} ctr-ingr__card--top{% endif %}"
            style="--accent: {{ section.settings.cat1_color }}; --card-bg: {{ section.settings.cat1_card_bg }}; grid-column: 1; grid-row: {{ cat1_idx }};"
            {{ block.shopify_attributes }}
          >
            <div class="ctr-ingr__card-marker" aria-hidden="true">
              <span class="ctr-ingr__card-marker-line"></span>
              <span class="ctr-ingr__card-marker-dot"></span>
            </div>

            {% if block.settings.image != blank %}
              <div class="ctr-ingr__card-media">
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '400,600,800,1000,1200', sizes: '(max-width: 1023px) 80vw, 50vw', alt: block.settings.title }}
              </div>
            {% endif %}

            <div class="ctr-ingr__card-body">
              {% if block.settings.title != blank %}
                <h3 class="ctr-ingr__card-title">{{ block.settings.title | escape }}</h3>
              {% endif %}

              {% if block.settings.label != blank %}
                <div class="ctr-ingr__card-label">{{ block.settings.label | escape }}</div>
              {% endif %}

              {% if block.settings.content != blank %}
                <div class="ctr-ingr__card-copy">{{ block.settings.content }}</div>
              {% endif %}
            </div>
          </article>
        {% endif %}
      {% endfor %}

      {%- assign cat2_idx = 0 -%}
      {% for block in section.blocks %}
        {% if block.settings.category == '2' %}
          {%- assign cat2_idx = cat2_idx | plus: 1 -%}
          <article
            class="ctr-ingr__card{% if cat2_idx == 1 %} ctr-ingr__card--top{% endif %}"
            style="--accent: {{ section.settings.cat2_color }}; --card-bg: {{ section.settings.cat2_card_bg }}; grid-column: 2; grid-row: {{ cat2_idx }};"
            {{ block.shopify_attributes }}
          >
            <div class="ctr-ingr__card-marker" aria-hidden="true">
              <span class="ctr-ingr__card-marker-line"></span>
              <span class="ctr-ingr__card-marker-dot"></span>
            </div>

            {% if block.settings.image != blank %}
              <div class="ctr-ingr__card-media">
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '400,600,800,1000,1200', sizes: '(max-width: 1023px) 80vw, 50vw', alt: block.settings.title }}
              </div>
            {% endif %}

            <div class="ctr-ingr__card-body">
              {% if block.settings.title != blank %}
                <h3 class="ctr-ingr__card-title">{{ block.settings.title | escape }}</h3>
              {% endif %}

              {% if block.settings.label != blank %}
                <div class="ctr-ingr__card-label">{{ block.settings.label | escape }}</div>
              {% endif %}

              {% if block.settings.content != blank %}
                <div class="ctr-ingr__card-copy">{{ block.settings.content }}</div>
              {% endif %}
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ctr-ingr__progress" aria-hidden="true">
      <div class="ctr-ingr__progress-fill"></div>
    </div>

    <div class="ctr-ingr__stats-row">
      {% if section.settings.cat1_stat != blank %}
        <div class="ctr-ingr__stat" style="--accent: {{ section.settings.cat1_color }};">{{ section.settings.cat1_stat }}</div>
      {% endif %}
      {% if section.settings.cat2_stat != blank %}
        <div class="ctr-ingr__stat" style="--accent: {{ section.settings.cat2_color }};">{{ section.settings.cat2_stat }}</div>
      {% endif %}
    </div>
  </div>

  <script>
    (function () {
      var section = document.querySelector('[data-style-id="{{ section.id }}"]');
      if (!section) return;
      var grid = section.querySelector('.ctr-ingr__cards-grid');
      var fill = section.querySelector('.ctr-ingr__progress-fill');
      if (!grid || !fill) return;

      function update() {
        var max = grid.scrollWidth - grid.clientWidth;
        if (max <= 0) {
          fill.style.width = '0%';
          fill.style.left = '0%';
          return;
        }
        var thumbWidth = (grid.clientWidth / grid.scrollWidth) * 100;
        var scrollRatio = grid.scrollLeft / max;
        var thumbLeft = scrollRatio * (100 - thumbWidth);
        fill.style.width = thumbWidth + '%';
        fill.style.left = thumbLeft + '%';
      }

      grid.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      // run after layout settles
      requestAnimationFrame(update);
    })();
  </script>
</section>

{% schema %}
{
  "name": "CTR Ingredient Cards",
  "tag": "section",
  "class": "shopify_section__ctr_ingredients_absorption",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "container_spacing",
      "label": "Container spacing",
      "default": "px-container-gutter",
      "options": [
        { "value": "px-container-xs", "label": "Extra Small" },
        { "value": "px-container-sm", "label": "Small" },
        { "value": "px-container-md", "label": "Medium" },
        { "value": "px-container-lg", "label": "Large" },
        { "value": "px-container-gutter", "label": "Gutter Only" },
        { "value": "px-container-fullwidth", "label": "Fullwidth" }
      ]
    },
    { "type": "range", "id": "max_width", "label": "Max width", "default": 1280, "min": 760, "max": 1720, "step": 20, "unit": "px" },
    { "type": "color", "id": "background_color", "label": "Background (full width)", "default": "#f0ede7" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#202020" },
    { "type": "range", "id": "padding_top", "label": "Padding top - desktop", "default": 80, "min": 0, "max": 200, "step": 4, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom - desktop", "default": 96, "min": 0, "max": 200, "step": 4, "unit": "px" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top - mobile", "default": 48, "min": 0, "max": 140, "step": 4, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom - mobile", "default": 64, "min": 0, "max": 140, "step": 4, "unit": "px" },

    { "type": "header", "content": "Header" },

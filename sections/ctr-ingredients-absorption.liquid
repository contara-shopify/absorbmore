    { "type": "range", "id": "header_gap", "label": "Header bottom gap - desktop", "default": 56, "min": 12, "max": 140, "step": 2, "unit": "px" },
    { "type": "range", "id": "header_gap_mobile", "label": "Header bottom gap - mobile", "default": 36, "min": 12, "max": 100, "step": 2, "unit": "px" },


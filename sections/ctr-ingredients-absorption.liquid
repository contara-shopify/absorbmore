    { "type": "range", "id": "card_title_size_desktop", "label": "Card title size - desktop", "default": 22, "min": 14, "max": 36, "step": 1, "unit": "px" },
    { "type": "range", "id": "card_title_size_mobile", "label": "Card title size - mobile", "default": 20, "min": 14, "max": 30, "step": 1, "unit": "px" },

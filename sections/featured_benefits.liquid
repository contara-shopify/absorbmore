px;\n    z-index: 1;\n    opacity: 1;\n    transition: all 0.3s ease-in-out;\n  }\n\n  & [data-benefits-icon] svg {\n    width: 8px;\n    height: 8px;\n    color: #000;\n    transition: all 0.3s ease-in-out;\n  }\n  & .active [data-benefits-icon] {\n    background: #fff;\n  }\n  & .active svg {\n    width: 16px;\n    height: 16px;\n    color: #4659ff;\n  }\n\n  & [data-benefits-content] button:not(.active) .richtext-md {\n    opacity: 0.5;\n  }\n\n  & [data-benefits-image] {\n    order: 999;\n  }\n\n  & [data-benefits-content]::after {\n    content: \"\";\n    display: block;\n    width: 1px;\n    background: linear-gradient(\n      180deg,\n      transparent 0%,\n      black 50%,\n      transparent 100%\n    );\n    height: calc(100% - 118px);\n    position: absolute;\n    bottom: 0;\n    left: 18px;\n  }\n}",

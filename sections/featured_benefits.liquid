{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign section_type = "featured_benefits"
  assign title = section.settings.title
  assign content_class = section.settings.content_class
  assign scroll_pagination_class = section.settings.scroll_pagination_class
  assign icon = section.settings.icon
  assign container_spacing = section.settings.container_spacing
  assign text_color = section.settings.text_color
  assign background_color = section.settings.background_color
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture section_content %}
  {% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
  {% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
    {% capture css %}
      & {
      {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
      {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
      }
    {% endcapture %}
  {% endif %}
  
  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  </style>
  
  <section
    data-style-id="{{ section.id }}--{{ block.id }}"
    {% if section_id != blank %}
      id="{{ section_id }}"
    {% endif %}
    class="relative {{ container_spacing }}"
  >
    {% if title != blank %}
      <div class="mb-8 lg:hidden">
        {% render '_input.richtext', content: title, class: content_class %}
      </div>
    {% endif %}
    <div
      class="grid items-center gap-6 lg:grid-cols-2 xl:gap-2"
      x-defer="intersect"
      x-data="{ ...utils.initContentSlider($el, $refs.scrollContainer) }"
    >
      <section data-benefits-image class="flex flex-col justify-center">
        <main
          class="grid snap-mandatory auto-cols-[100%] grid-flow-col gap-4 overflow-x-auto overflow-y-hidden scrollbar-none"
          x-ref="scrollContainer"
          @resize.window="content_slider.handleResize"
          x-init="$nextTick(() => content_slider.handleResize())"
          @scroll="content_slider.handleScroll"
          @scrollend="content_slider.handleInfiniteScroll"
        >
          {% assign index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'feature' %}
              {% render 'featured_benefits.feature', block: block, forloop: forloop, index: index %}
              {% assign index = index | plus: 1 %}
            {% endif %}
          {% endfor %}
        </main>
        {% if scroll_pagination_class != blank %}
          {% render '_components.scroll_pagination', class: scroll_pagination_class %}
        {% endif %}
      </section>
      <section data-benefits-content class="flex h-full flex-col justify-center relative lg:gap-8">
        {% if title != blank %}
          <div class="mb-2 max-lg:hidden">
            {% render '_input.richtext', content: title, class: content_class %}
          </div>
        {% endif %}
        <div class="lg:hidden flex items-center justify-between">
          {% assign index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'feature' %}
              {% liquid
                if block.settings.dynamic_content_type == 'metafield'
                  assign object_namespace_key = block.settings.metafield_namespace_key | replace: ' ', '' | strip | strip_newlines | split: '.'
                  if object_namespace_key[0] == 'metaobjects'
                    assign metafield = metaobjects[object_namespace_key[1]].values
                  else
                    assign metafield = [object_namespace_key[0]].metafields[object_namespace_key[1]][object_namespace_key[2]].value
                  endif
                endif
              %}
  
              {% if block.settings.dynamic_content_type == 'metafield' %}
                {% for item in metafield %}
                  {% assign title = item[block.settings.metafield_title_key].value %}
                  <button
                    :class="content_slider?.state?.current_index !== +`{{ index }}` ? 'opacity-35' : ''"
                    type="button"
                    class="text-left transition-all duration-75 flex items-baseline"
                    :tabindex="window.innerWidth > 768 ? '0' : '-1'"
                    @click="content_slider?.scrollToIndex(+`{{ index }}`)"
                  >
                    {% render '_input.richtext',
                      content: title,
                      class: block.settings.title_class,
                      block: block,
                      forloop: forloop
                    %}
                  </button>
                {% endfor %}
              {% else %}
                <button
                  :class="content_slider?.state?.current_index !== +`{{ index }}` ? 'opacity-35' : ''"
                  type="button"
                  class="text-left transition-all duration-75 flex items-baseline"
                  :tabindex="window.innerWidth > 768 ? '0' : '-1'"
                  @click="content_slider?.scrollToIndex(+`{{ index }}`)"
                >
                  {% render '_input.richtext',
                    content: block.settings.title,
                    class: block.settings.title_class,
                    block: block,
                    forloop: forloop
                  %}
                </button>
              {% endif %}
              {% assign index = index | plus: 1 %}
            {% endif %}
          {% endfor %}
        </div>
  
        {% assign index = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'feature' %}
            {% liquid
              if block.settings.dynamic_content_type == 'metafield'
                assign object_namespace_key = block.settings.metafield_namespace_key | replace: ' ', '' | strip | strip_newlines | split: '.'
                if object_namespace_key[0] == 'metaobjects'
                  assign metafield = metaobjects[object_namespace_key[1]].values
                else
                  assign metafield = [object_namespace_key[0]].metafields[object_namespace_key[1]][object_namespace_key[2]].value
                endif
              endif
            %}
  
            {% if block.settings.dynamic_content_type == 'metafield' %}
              {% for item in metafield %}
                {% assign title = item[block.settings.metafield_title_key].value %}
                {% assign content = item[block.settings.metafield_content_key].value %}
                <button
                  :class="content_slider?.state?.current_index === +`{{ index }}` ? 'active' : ''"
                  type="button"
                  class="text-left transition-all duration-75 flex items-baseline"
                  :tabindex="window.innerWidth > 768 ? '0' : '-1'"
                  @click="content_slider?.scrollToIndex(+`{{ index }}`)"
                >
                  {% if icon != blank %}
                    <span data-benefits-icon class="flex items-center justify-center flex-shrink-0">
                      {% render '_components.icon', icon: icon, class: 'max-lg:hidden' %}
                    </span>
                  {% endif %}
                  <div data-benefits-feature :class="content_slider?.state?.current_index === +`{{ index }}` ? 'active' : ''">
                    <div class="max-lg:hidden ">
                      {% render '_input.richtext',
                        content: title,
                        class: block.settings.title_class,
                        block: block,
                        forloop: forloop
                      %}
                    </div>
                    {% render '_input.richtext',
                      content: content,
                      class: block.settings.content_class,
                      block: block,
                      forloop: forloop
                    %}
                  </div>
                </button>
              {% endfor %}
  
            {% else %}
              <button
                :class="content_slider?.state?.current_index === +`{{ index }}` ? 'active' : ''"
                type="button"
                class="text-left transition-all duration-75 flex items-baseline"
                :tabindex="window.innerWidth > 768 ? '0' : '-1'"
                @click="content_slider?.scrollToIndex(+`{{ index }}`)"
              >
                {% if icon != blank %}
                  <span data-benefits-icon class="flex items-center justify-center flex-shrink-0">
                    {% render '_components.icon', icon: icon, class: 'max-lg:hidden' %}
                  </span>
                {% endif %}
                <div data-benefits-feature :class="content_slider?.state?.current_index === +`{{ index }}` ? 'active' : ''">
                  <div class="max-lg:hidden ">
                    {% render '_input.richtext',
                      content: block.settings.title,
                      class: block.settings.title_class,
                      block: block,
                      forloop: forloop
                    %}
                  </div>
                  {% render '_input.richtext',
                    content: block.settings.content,
                    class: block.settings.content_class,
                    block: block,
                    forloop: forloop
                  %}
                </div>
              </button>
            {% endif %}
            {% assign index = index | plus: 1 %}
          {% endif %}
        {% endfor %}
      </section>
    </div>
  </section>
  
{% endcapture %}

{% if section_content contains '/break"></script>' %}
  {% break %}
{% endif %}
{{ section_content }}


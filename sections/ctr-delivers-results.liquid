{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign section_type = "ctr_delivers_results"

  assign image_position = section.settings.image_position
  assign image_ratio = section.settings.image_ratio
  assign stats_cols_desktop = section.settings.stats_cols_desktop
  assign layout_gap_desktop = section.settings.layout_gap_desktop
  assign layout_gap_mobile = section.settings.layout_gap_mobile
  assign stats_gap_desktop = section.settings.stats_gap_desktop
  assign stats_gap_mobile = section.settings.stats_gap_mobile

  assign accent_color = section.settings.accent_color
  assign card_background = section.settings.card_background

  assign header_size_desktop = section.settings.header_size_desktop
  assign header_size_mobile = section.settings.header_size_mobile
  assign header_line_height = section.settings.header_line_height
  assign subtitle_size = section.settings.subtitle_size
  assign stat_title_size = section.settings.stat_title_size
  assign stat_desc_size = section.settings.stat_desc_size
  assign stat_number_size_desktop = section.settings.stat_number_size_desktop
  assign stat_number_size_mobile = section.settings.stat_number_size_mobile
  assign stat_label_size = section.settings.stat_label_size
  assign footer_size = section.settings.footer_size

  assign container_spacing = section.settings.container_spacing
  assign text_color = section.settings.text_color
  assign background_color = section.settings.background_color
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{%- capture selector -%}[data-style-id="{{ section.id }}--{{ block.id }}"]{%- endcapture -%}
{%- capture css -%}
  & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}

    --dr-header-d: {{ header_size_desktop }}px;
    --dr-header-m: {{ header_size_mobile }}px;
    --dr-header-lh: {{ header_line_height | divided_by: 100.0 }};
    --dr-subtitle: {{ subtitle_size }}px;
    --dr-stat-title: {{ stat_title_size }}px;
    --dr-stat-desc: {{ stat_desc_size }}px;
    --dr-stat-number-d: {{ stat_number_size_desktop }}px;
    --dr-stat-number-m: {{ stat_number_size_mobile }}px;
    --dr-stat-label: {{ stat_label_size }}px;
    --dr-footer: {{ footer_size }}px;

    --dr-accent: {{ accent_color }};
    --dr-card-bg: {{ card_background }};

    --dr-layout-gap-d: {{ layout_gap_desktop }}px;
    --dr-layout-gap-m: {{ layout_gap_mobile }}px;
    --dr-stats-gap-d: {{ stats_gap_desktop }}px;
    --dr-stats-gap-m: {{ stats_gap_mobile }}px;
    --dr-stats-cols-d: {{ stats_cols_desktop }};
    --dr-image-ratio: {{ image_ratio }};
    --dr-image-order: {% if image_position == 'right' %}2{% else %}1{% endif %};
    --dr-stats-order: {% if image_position == 'right' %}1{% else %}2{% endif %};
  }
{%- endcapture -%}

<section
  data-section-type="{{ section_type }}"
  data-style-id="{{ section.id }}--{{ block.id }}"
  {% if section_id != blank %}id="{{ section_id }}"{% endif %}
  class="ctr-delivers-results {{ container_spacing }}">

  <style>{{ css | append: custom_css | replace: '&', selector | strip_newlines }}</style>

  <div class="ctr-dr__inner">
    {% content_for "blocks" %}
  </div>
</section>

{% schema %}

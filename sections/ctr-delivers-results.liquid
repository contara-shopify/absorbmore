    { "type": "color", "alpha": true, "id": "card_background", "label": "Stat card background", "default": "rgba(255,255,255,0.5)" },

    { "type": "header", "content": "Typography" },
    { "type": "paragraph", "content": "Font sizes apply to the matching blocks in the preset. For new blocks, edit the block's Custom CSS." },
    { "type": "range", "id": "header_size_desktop", "label": "Header size (desktop)", "min": 22, "max": 72, "step": 1, "default": 40, "unit": "px" },
    { "type": "range", "id": "header_size_mobile", "label": "Header size (mobile)", "min": 20, "max": 48, "step": 1, "default": 28, "unit": "px" },

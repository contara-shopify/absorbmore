{%- comment -%} Shop All Sale — 35% off site-wide PLP collection page. Prices already discounted in Shopify; this page shows compare-at vs sale. v2: bubble filter, all products. {%- endcomment -%}

{%- liquid
  assign discount_pct = section.settings.discount_pct | default: 35
  assign end_iso = section.settings.end_iso | default: '2026-05-28T23:59:59-04:00'
  assign discount_code = section.settings.discount_code | default: ''
  assign keep_pct = 100 | minus: discount_pct
  assign powder_handles = '|restore|sleep|calm|energy|'
  assign excluded_plan_names = '|Every 2 Week(s)|Every 1 Month(s)|Every 2 Month(s)|Every 3 Month(s)|Every 6 Month(s)|Every 3 months backend|Every 6 months backend|'

  comment
    Metadata for tiles. Parallel arrays keyed off meta_handles index.
    Order = grid display order. Iteration resolves products from the
    `memorial-day-savings` collection (handled below).
  endcomment

  assign meta_handles = 'the-best-sellers-stack,starter-pack,berberine,calm,coq10,curcumin,daily-basics,energy,hormone-metabolism,inflammation-immunity,longevity,magnesium-glycinate,restore,sleep,vitamin-d-k,wlp-1,advanced-sleep-recovery-set,best-sellers-bundle,calm-energy-bundle,glp-1-nutrient-support-stack,magnesium-calm-bundle,magnesium-restore-bundle,magnesium-sleep-bundle,metabolic-balance-stack,rest-recovery-stack,spring-essentials-stack,weight-management-stack' | split: ','

  assign pills = 'Bestseller|Daily Foundations|Metabolism & Hormones|Manage Stress & Cortisol|Energy & Recovery|Immunity & Antioxidant|Daily Foundations|Energy & Focus|Metabolism & Hormones|Immunity & Inflammation|Longevity|Hydrate & Detox|Hydrate & Recovery|Restorative Sleep|Immunity & Mood|Weight Management|Sleep + Recovery|Bestseller Bundle|Mood & Energy|GLP-1 Support|Calm & Magnesium|Hydrate & Recover|Sleep & Magnesium|Metabolic Stack|Rest + Recovery|Spring Essentials|Weight Management' | split: '|'

  assign badges = '|||||||Top Seller|||||||||Best Value|||||||||' | split: '|'

  assign ratings = '4.92|4.89|4.84|4.94|4.82|4.81|4.83|4.86|4.85|4.87|4.83|4.97|4.94|4.88|4.87|4.78|4.91|4.92|4.86|4.84|4.88|4.89|4.87|4.85|4.90|4.86|4.90' | split: '|'

  assign reviews = '412|109|85|300|64|71|88|192|121|142|88|368|246|246|142|154|96|184|72|58|66|74|62|94|82|68|78' | split: '|'

  comment
    Goal buckets — every handle lives in at least one. Bubbles below filter the grid by these.
  endcomment
  assign goal_longevity = 'the-best-sellers-stack,longevity,coq10,energy,curcumin,daily-basics,starter-pack,spring-essentials-stack,vitamin-d-k' | split: ','
  assign goal_metab = 'berberine,hormone-metabolism,wlp-1,weight-management-stack,glp-1-nutrient-support-stack,metabolic-balance-stack' | split: ','
  assign goal_sleep = 'sleep,calm,magnesium-glycinate,advanced-sleep-recovery-set,magnesium-sleep-bundle,magnesium-calm-bundle,rest-recovery-stack,calm-energy-bundle,best-sellers-bundle' | split: ','
  assign goal_immunity = 'restore,curcumin,inflammation-immunity,vitamin-d-k,magnesium-restore-bundle' | split: ','

  comment
    Iteration source: resolve products from the `memorial-day-savings` collection to
    bypass the 20-handle cap on `all_products` lookups (same pattern as MD section).
  endcomment
  assign sale_collection = collections['memorial-day-savings']
  assign display_handles = 'wlp-1,berberine,magnesium-glycinate,daily-basics,weight-management-stack,hormone-metabolism,restore,best-sellers-bundle,metabolic-balance-stack,sleep,calm,coq10,vitamin-d-k,advanced-sleep-recovery-set,curcumin,spring-essentials-stack,magnesium-calm-bundle,rest-recovery-stack,the-best-sellers-stack,magnesium-restore-bundle,starter-pack,longevity,magnesium-sleep-bundle,inflammation-immunity,energy,glp-1-nutrient-support-stack' | split: ','

  comment
    Per-handle tile image overrides. Parallel arrays keyed off override_handles index.
    Used when a product's featured image isn't the right tile shot for this lander.
  endcomment
  assign override_handles = 'restore,sleep,calm,energy,magnesium-sleep-bundle' | split: ','
  assign override_urls = 'https://www.absorbmore.com/cdn/shop/files/TAC_PDP-Image_Restore-Bag_af4e1a3f-f6ca-4ab7-bebf-7e492e6dac9b.png?v=1768255861&width=960|https://www.absorbmore.com/cdn/shop/files/TAC_PDP-Image_Sleep-Bag_9a994c43-7d98-40a8-ab98-2f20070e69d3.png?v=1768256290&width=960|https://www.absorbmore.com/cdn/shop/files/TAC_PDP-Image_Calm-Bag_42e47801-bfd1-4ce0-8f26-de468bc3d559.png?v=1768256004&width=960|https://www.absorbmore.com/cdn/shop/files/TAC_PDP-Image_Energy_3de78348-83c6-475b-aa3f-9df089873398.png?v=1768256691&width=960|https://www.absorbmore.com/cdn/shop/files/sleep-bag-mag-bundle.png?v=1768005885&width=960' | split: '|'

-%}

<style>
  .lnd-sale { font-family: inherit; color: #0D273E; --sale-navy: #0D273E; --sale-red: #DB3519; --sale-navy-2: #143452; --sale-cream: #efe9dd; --sale-bg: #f6f6f4; }
  .lnd-sale * { box-sizing: border-box; }

  /* Sticky promo bar with countdown (incl. seconds) */
  .lnd-sale__bar { position: sticky; top: 0; z-index: 50; background: var(--sale-red); color: #fff; text-align: center; padding: 8px 14px; font-size: 12px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; display: flex; gap: 10px 16px; justify-content: center; align-items: center; flex-wrap: wrap; line-height: 1.2; }
  .lnd-sale__bar-headline { display: inline-flex; align-items: center; }
  .lnd-sale__bar-count { display: inline-flex; gap: 4px; align-items: center; font-variant-numeric: tabular-nums; }
  .lnd-sale__bar-count > span:first-child { margin-right: 4px; font-size: 11px; opacity: 0.9; }
  .lnd-sale__bar-count .chip { display: inline-flex; align-items: baseline; gap: 2px; background: rgba(0,0,0,0.22); border: 1px solid rgba(255,255,255,0.22); border-radius: 6px; padding: 4px 6px; min-width: 34px; justify-content: center; }
  .lnd-sale__bar-count .chip b { font-size: 13px; font-weight: 900; line-height: 1; }
  .lnd-sale__bar-count .chip span { font-size: 9px; font-weight: 700; opacity: 0.85; letter-spacing: 0.04em; }

  /* HERO — mobile: image as inline <img> so it fits naturally; text on top. Desktop: full-bleed bg with overlay. */
  .lnd-sale__hero { position: relative; background-color: var(--sale-navy); color: #fff; overflow: hidden; }
  .lnd-sale__hero-bg { display: block; width: 100%; height: auto; }
  /* Mobile dark gradient so text stays readable over busy product image */
  .lnd-sale__hero::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(13,39,62,0.92) 0%, rgba(13,39,62,0.78) 45%, rgba(13,39,62,0.55) 75%, rgba(13,39,62,0.35) 100%); z-index: 1; pointer-events: none; }
  .lnd-sale__hero-inner { position: absolute; inset: 0; z-index: 2; max-width: 1200px; margin: 0 auto; width: 100%; padding: 24px 20px 28px; }
  .lnd-sale__hero-text { text-align: left; max-width: 560px; }
  .lnd-sale__hero-eyebrow { display: inline-block; background: var(--sale-red); color: #fff; font-size: 10px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; padding: 6px 11px; border-radius: 999px; margin: 0 0 12px; line-height: 1.25; box-shadow: 0 4px 14px rgba(0,0,0,0.25); max-width: 100%; }
  .lnd-sale__hero h1 { font-size: 26px; line-height: 1.04; margin: 0 0 10px; font-weight: 900; letter-spacing: -0.02em; text-shadow: 0 2px 12px rgba(0,0,0,0.6); }
  .lnd-sale__hero h1 em { color: var(--sale-red); font-style: normal; }
  .lnd-sale__hero p.lead { font-size: 14px; opacity: 0.95; margin: 0 0 14px; max-width: 480px; line-height: 1.5; text-shadow: 0 1px 8px rgba(0,0,0,0.6); }
  .lnd-sale__hero p.lead b { color: #fff; font-weight: 800; }
  .lnd-sale__hero-rotator { background: rgba(13,39,62,0.78); border: 1px solid rgba(255,255,255,0.22); border-radius: 14px; padding: 10px 14px; margin: 0 0 14px; max-width: 440px; backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
  .lnd-sale__hero-rotator-line { font-size: 16px; font-weight: 700; letter-spacing: -0.01em; display: flex; flex-wrap: wrap; align-items: baseline; gap: 6px; }
  .lnd-sale__hero-rotator-line .static { opacity: 0.9; }
  .lnd-sale__hero-rotator-line .dynamic { color: var(--sale-red); font-weight: 800; font-size: 18px; transition: opacity 0.35s ease, transform 0.35s ease; display: inline-block; min-width: 110px; }
  .lnd-sale__hero-rotator-line .dynamic.is-out { opacity: 0; transform: translateY(8px); }
  .lnd-sale__hero-bullets { list-style: none; padding: 0; margin: 0 0 18px; display: flex; flex-direction: column; gap: 8px; max-width: 480px; }
  .lnd-sale__hero-bullets li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; font-weight: 700; line-height: 1.35; text-shadow: 0 1px 8px rgba(0,0,0,0.5); }
  .lnd-sale__hero-bullets li em { color: var(--sale-red); font-style: normal; font-weight: 800; }
  .lnd-sale__hero-bullets .check { flex-shrink: 0; width: 22px; height: 22px; background: var(--sale-red); color: #fff; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 900; margin-top: 1px; }
  .lnd-sale__hero-cta { display: inline-block; background: var(--sale-red); color: #fff; text-decoration: none; padding: 14px 28px; border-radius: 999px; font-size: 13px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; }

  /* Value strip */
  .lnd-sale__values { background: #fff; border-top: 1px solid #eee; border-bottom: 1px solid #eee; padding: 18px 16px; }
  .lnd-sale__values-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px 18px; }
  .lnd-sale__value { display: flex; align-items: center; gap: 10px; font-size: 12px; font-weight: 600; color: var(--sale-navy); line-height: 1.3; }
  .lnd-sale__value svg { flex-shrink: 0; color: var(--sale-red); }

  /* Bubble filter row */
  .lnd-sale__bubbles-wrap { background: #fff; padding: 22px 0 6px; }
  .lnd-sale__bubbles-inner { max-width: 1200px; margin: 0 auto; padding: 0 16px; }
  .lnd-sale__bubbles-head { font-size: 13px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: var(--sale-navy); margin: 0 0 12px; opacity: 0.7; }
  .lnd-sale__bubbles { display: flex; gap: 8px; flex-wrap: nowrap; overflow-x: auto; padding: 4px 0 12px; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
  .lnd-sale__bubbles::-webkit-scrollbar { display: none; }
  .lnd-sale__bubble { flex: 0 0 auto; background: var(--sale-cream); color: var(--sale-navy); border: 2px solid transparent; padding: 12px 18px; border-radius: 999px; font-size: 13px; font-weight: 700; letter-spacing: -0.005em; cursor: pointer; font: inherit; min-height: 44px; line-height: 1; display: inline-flex; align-items: center; gap: 6px; transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease; white-space: nowrap; }
  .lnd-sale__bubble[data-goal="all"] { font-weight: 800; }
  .lnd-sale__bubble:hover { border-color: var(--sale-navy); }
  .lnd-sale__bubble.is-active { background: var(--sale-navy); color: #fff; border-color: var(--sale-navy); }
  .lnd-sale__bubble-count { font-size: 11px; font-weight: 600; opacity: 0.6; }
  .lnd-sale__bubble.is-active .lnd-sale__bubble-count { opacity: 0.7; color: #fff; }

  /* Grid */
  .lnd-sale__grid-wrap { background: var(--sale-bg); padding: 20px 16px 36px; }
  .lnd-sale__grid-head { max-width: 1200px; margin: 0 auto 18px; display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 8px; }
  .lnd-sale__grid-head h2 { font-size: 22px; font-weight: 800; margin: 0; letter-spacing: -0.01em; }
  .lnd-sale__grid-count { font-size: 13px; color: #666; }
  .lnd-sale__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; max-width: 1200px; margin: 0 auto; }

  /* Tile */
  .lnd-sale__tile { background: var(--sale-cream); border-radius: 14px; padding: 14px 14px 0; position: relative; display: flex; flex-direction: column; text-align: left; font: inherit; color: inherit; border: none; transition: transform 0.15s ease, box-shadow 0.15s ease; text-decoration: none; }
  .lnd-sale__tile:hover { transform: translateY(-3px); box-shadow: 0 10px 24px rgba(13,39,62,0.08); }
  .lnd-sale__tile-link { position: absolute; inset: 0; z-index: 1; border-radius: 14px; text-indent: -9999px; overflow: hidden; }
  .lnd-sale__tile-labels { position: absolute; top: 14px; left: 14px; right: 14px; display: flex; gap: 6px; flex-wrap: wrap; align-items: center; z-index: 2; pointer-events: none; }
  .lnd-sale__tile-pill { background: #fff; color: var(--sale-navy); font-size: 9px; font-weight: 800; letter-spacing: 0.08em; padding: 6px 11px; border-radius: 999px; text-transform: uppercase; white-space: nowrap; max-width: 100%; overflow: hidden; text-overflow: ellipsis; }
  .lnd-sale__tile-badge { background: var(--sale-red); color: #fff; font-size: 9px; font-weight: 800; letter-spacing: 0.08em; padding: 6px 11px; border-radius: 999px; text-transform: uppercase; white-space: nowrap; }
  .lnd-sale__tile-lowstock { background: #b91d1d; color: #fff; font-size: 9px; font-weight: 800; letter-spacing: 0.08em; padding: 6px 11px; border-radius: 999px; text-transform: uppercase; white-space: nowrap; box-shadow: 0 4px 12px rgba(185,29,29,0.32); display: inline-flex; align-items: center; gap: 6px; flex: 0 0 auto; }
  .lnd-sale__tile-lowstock::before { content: ""; width: 6px; height: 6px; border-radius: 999px; background: #fff; box-shadow: 0 0 0 3px rgba(255,255,255,0.32); }
  .lnd-sale__tile-img { aspect-ratio: 1/1; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .lnd-sale__tile-img img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .lnd-sale__tile-info { padding: 12px 4px 14px; }
  .lnd-sale__tile-title { font-size: 17px; font-weight: 700; line-height: 1.2; margin: 0 0 4px; color: var(--sale-navy); }
  .lnd-sale__tile-sub { font-size: 13px; color: #6b6b6b; line-height: 1.3; margin: 0 0 8px; min-height: 34px; }
  .lnd-sale__tile-stars { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
  .lnd-sale__tile-stars-glyphs { color: var(--sale-navy); font-size: 13px; letter-spacing: 1px; line-height: 1; }
  .lnd-sale__tile-stars-meta { font-size: 12px; color: var(--sale-navy); font-weight: 600; }
  .lnd-sale__tile-price { display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap; }
  .lnd-sale__tile-price .now { font-size: 16px; font-weight: 800; color: var(--sale-navy); font-variant-numeric: tabular-nums; }
  .lnd-sale__tile-price .was { font-size: 13px; color: #9a9a9a; text-decoration: line-through; font-variant-numeric: tabular-nums; }
  .lnd-sale__tile-price .off { font-size: 13px; font-weight: 700; color: var(--sale-red); }
  .lnd-sale__tile-price .off::before { content: "·"; margin-right: 4px; color: #9a9a9a; }

  /* Subscribe band */
  .lnd-sale__sub { background: var(--sale-cream); padding: 36px 16px; text-align: center; }
  .lnd-sale__sub-inner { max-width: 720px; margin: 0 auto; }
  .lnd-sale__sub-eyebrow { font-size: 11px; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sale-red); margin-bottom: 10px; }
  .lnd-sale__sub h2 { font-size: 24px; font-weight: 800; margin: 0 0 10px; letter-spacing: -0.01em; }
  .lnd-sale__sub p { font-size: 14px; color: #444; margin: 0 0 18px; line-height: 1.55; }
  .lnd-sale__sub-cta { display: inline-block; background: var(--sale-navy); color: #fff; padding: 12px 26px; border-radius: 999px; font-size: 13px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; }

  /* Trust strip */
  .lnd-sale__trust { background: #fff; padding: 36px 20px; text-align: center; }
  .lnd-sale__trust-inner { max-width: 760px; margin: 0 auto; }
  .lnd-sale__trust-eyebrow { font-size: 11px; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sale-red); margin-bottom: 10px; }
  .lnd-sale__trust h2 { font-size: 24px; font-weight: 800; margin: 0 0 10px; letter-spacing: -0.01em; }
  .lnd-sale__trust p { font-size: 14px; color: #555; margin: 0; line-height: 1.6; }

  /* FAQ */
  .lnd-sale__faq { background: var(--sale-bg); padding: 36px 16px; }
  .lnd-sale__faq-inner { max-width: 760px; margin: 0 auto; }
  .lnd-sale__faq h2 { font-size: 24px; font-weight: 800; margin: 0 0 18px; text-align: center; letter-spacing: -0.01em; }
  .lnd-sale__faq details { background: #fff; border: 1px solid #ececec; border-radius: 12px; margin-bottom: 10px; }
  .lnd-sale__faq summary { padding: 14px 16px; font-size: 14px; font-weight: 700; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .lnd-sale__faq summary::-webkit-details-marker { display: none; }
  .lnd-sale__faq summary::after { content: "+"; font-size: 20px; font-weight: 300; color: var(--sale-red); }
  .lnd-sale__faq details[open] summary::after { content: "−"; }
  .lnd-sale__faq-body { padding: 0 16px 16px; font-size: 13px; color: #555; line-height: 1.55; }

  /* Final CTA */
  .lnd-sale__final { background: var(--sale-navy); color: #fff; padding: 44px 20px; text-align: center; }
  .lnd-sale__final h2 { font-size: 28px; font-weight: 800; margin: 0 0 12px; letter-spacing: -0.01em; }
  .lnd-sale__final h2 em { color: var(--sale-red); font-style: normal; }
  .lnd-sale__final p { font-size: 14px; opacity: 0.8; margin: 0 0 22px; }
  .lnd-sale__final .lnd-sale__countdown { margin-bottom: 22px; }
  .lnd-sale__final-cta { display: inline-block; background: var(--sale-red); color: #fff; padding: 14px 30px; border-radius: 999px; font-size: 13px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; }

  /* Sticky mobile CTA */
  .lnd-sale__mobile-cta { position: fixed; bottom: 12px; left: 12px; right: 12px; z-index: 60; display: none; }
  .lnd-sale__mobile-cta a { display: block; background: var(--sale-red); color: #fff; text-align: center; padding: 14px; border-radius: 999px; font-size: 13px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
  .lnd-sale__mobile-cta.is-show { display: block; }

  /* Desktop */
  @media (min-width: 720px) {
    .lnd-sale__hero { background-image: var(--hero-bg-desktop, none); background-position: center; background-size: cover; background-repeat: no-repeat; min-height: 460px; display: flex; align-items: center; }
    .lnd-sale__hero::before { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(13,39,62,0.78) 0%, rgba(13,39,62,0.5) 55%, rgba(13,39,62,0.15) 100%); z-index: 1; }
    .lnd-sale__hero::after { display: none; }
    .lnd-sale__hero-bg { display: none; }
    .lnd-sale__hero-inner { position: relative; padding: 56px 40px; }
    .lnd-sale__hero-eyebrow { font-size: 11px; letter-spacing: 0.1em; padding: 7px 12px; }
    .lnd-sale__hero h1 { font-size: 48px; line-height: 1.02; }
    .lnd-sale__hero p.lead { font-size: 16px; }
    .lnd-sale__hero-rotator-line { font-size: 18px; }
    .lnd-sale__hero-rotator-line .dynamic { font-size: 22px; min-width: 140px; }
    .lnd-sale__values-inner { grid-template-columns: repeat(4, 1fr); }
    .lnd-sale__bubbles { flex-wrap: wrap; overflow-x: visible; }
    .lnd-sale__grid { grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .lnd-sale__grid-head h2 { font-size: 28px; }
    .lnd-sale__tile-pill { font-size: 10px; padding: 7px 13px; }
    .lnd-sale__mobile-cta { display: none; }
    .lnd-sale__mobile-cta.is-show { display: none; }
  }
  @media (min-width: 1024px) {
    .lnd-sale__grid { grid-template-columns: repeat(4, 1fr); }
    .lnd-sale__tile-title { font-size: 19px; }
    .lnd-sale__tile-sub { font-size: 14px; }
  }

  /* Tile CTA + Details indicator */
  .lnd-sale__tile-more { display: block; text-align: center; font-size: 11px; font-weight: 700; color: var(--sale-navy); opacity: 0.62; letter-spacing: 0.06em; text-transform: uppercase; margin: 10px 0 8px; line-height: 1; }
  .lnd-sale__tile:hover .lnd-sale__tile-more { opacity: 0.9; color: var(--sale-red); }
  .lnd-sale__tile-cta { position: relative; z-index: 2; display: block; width: 100%; text-align: center; background: var(--sale-navy); color: #fff; text-decoration: none; padding: 11px 12px; border-radius: 999px; font-size: 13px; font-weight: 800; letter-spacing: 0.04em; margin: 0 0 12px; border: none; cursor: pointer; font-family: inherit; transition: background 0.15s ease; }
  .lnd-sale__tile-cta:hover { background: var(--sale-red); }
  .lnd-sale__tile-cta.is-loading { opacity: 0.7; pointer-events: none; }

  /* Quick-view modal */
  .lnd-sale__modal { position: fixed; inset: 0; z-index: 9999; display: none; align-items: flex-end; justify-content: center; }
  .lnd-sale__modal.is-open { display: flex; }
  .lnd-sale__modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.55); animation: lnd-sale-fade 0.2s ease; }
  .lnd-sale__modal-panel { position: relative; background: #fff; width: 100%; max-width: 720px; max-height: 92vh; overflow-y: auto; border-radius: 18px 18px 0 0; animation: lnd-sale-slide 0.25s ease; }
  @keyframes lnd-sale-fade { from { opacity: 0; } to { opacity: 1; } }
  @keyframes lnd-sale-slide { from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  .lnd-sale__modal-close { position: absolute; top: 12px; right: 12px; z-index: 2; background: #fff; border: 1px solid #e6e6e6; width: 36px; height: 36px; border-radius: 50%; font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; line-height: 1; }
  .lnd-sale__modal-img { aspect-ratio: 1/1; background: #fff; max-height: 360px; overflow: hidden; position: relative; display: flex; align-items: center; justify-content: center; }
  .lnd-sale__modal-img img { width: 100%; height: 100%; object-fit: contain; object-position: center; display: block; }
  .lnd-sale__thumbs { display: flex; gap: 6px; padding: 8px; overflow-x: auto; scrollbar-width: none; background: var(--sale-bg); }
  .lnd-sale__thumbs::-webkit-scrollbar { display: none; }
  .lnd-sale__thumbs:empty { display: none; }
  .lnd-sale__thumb { flex: 0 0 56px; width: 56px; height: 56px; border-radius: 8px; overflow: hidden; border: 2px solid transparent; cursor: pointer; padding: 0; background: #fff; }
  .lnd-sale__thumb.is-active { border-color: var(--sale-navy); }
  .lnd-sale__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lnd-sale__modal-body { padding: 18px 20px 24px; }
  .lnd-sale__modal-body h2 { font-size: 22px; font-weight: 800; margin: 0 0 6px; line-height: 1.2; }
  .lnd-sale__modal-price { display: flex; align-items: baseline; gap: 10px; margin-bottom: 14px; }
  .lnd-sale__modal-price .now { font-size: 22px; font-weight: 800; color: var(--sale-red); }
  .lnd-sale__modal-price .was { font-size: 15px; color: #888; text-decoration: line-through; }
  .lnd-sale__modal-price .save { background: var(--sale-red); color: #fff; font-size: 11px; font-weight: 800; padding: 3px 8px; border-radius: 999px; letter-spacing: 0.04em; }
  .lnd-sale__modal-desc { font-size: 14px; color: #444; line-height: 1.55; margin-bottom: 14px; }
  .lnd-sale__bullets { margin: 0 0 18px; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .lnd-sale__bullets li { display: flex; align-items: center; gap: 10px; font-size: 14px; line-height: 1.45; color: var(--sale-navy); }
  .lnd-sale__bullets li svg { flex-shrink: 0; }
  .lnd-sale__opt { margin-bottom: 14px; }
  .lnd-sale__opt-label { display: block; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #555; margin-bottom: 6px; }
  .lnd-sale__opt-values { display: flex; gap: 6px; flex-wrap: wrap; }
  .lnd-sale__opt-btn { background: #fff; border: 1.5px solid #d8d8d8; padding: 8px 14px; border-radius: 999px; font-size: 13px; cursor: pointer; font: inherit; }
  .lnd-sale__opt-btn.is-active { border-color: var(--sale-navy); background: var(--sale-navy); color: #fff; }
  .lnd-sale__opt-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .lnd-sale__buy { margin-bottom: 14px; display: flex; flex-direction: column; gap: 8px; }
  .lnd-sale__buy-opt { display: flex; align-items: center; gap: 10px; border: 1.5px solid #d8d8d8; border-radius: 12px; padding: 12px 14px; cursor: pointer; font-size: 13px; }
  .lnd-sale__buy-opt.is-active { border-color: var(--sale-navy); background: #f6f8fb; }
  .lnd-sale__buy-opt input { accent-color: var(--sale-navy); }
  .lnd-sale__buy-opt-main { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .lnd-sale__buy-opt-title { font-weight: 700; }
  .lnd-sale__buy-opt-sub { font-size: 12px; color: #666; }
  .lnd-sale__buy-opt-price { font-weight: 700; color: var(--sale-red); white-space: nowrap; }
  .lnd-sale__buy-opt-tag { background: var(--sale-red); color: #fff; font-size: 10px; font-weight: 800; padding: 2px 6px; border-radius: 999px; letter-spacing: 0.04em; margin-left: 4px; }
  .lnd-sale__modal-actions { display: flex; flex-direction: column; gap: 10px; margin-top: 18px; }
  .lnd-sale__modal-cta { display: block; text-align: center; background: var(--sale-navy); color: #fff; text-decoration: none; padding: 14px; border-radius: 999px; font-size: 14px; font-weight: 800; letter-spacing: 0.04em; border: none; cursor: pointer; font-family: inherit; }
  .lnd-sale__modal-cta:hover { background: var(--sale-red); }
  .lnd-sale__modal-pdp { text-align: center; font-size: 12px; color: #666; text-decoration: underline; }
  .lnd-sale__toast { display: none; background: #0a5a3e; color: #fff; padding: 12px 14px; border-radius: 10px; margin-bottom: 14px; font-size: 13px; font-weight: 600; text-align: center; }
  .lnd-sale__toast.is-show { display: block; }
  .lnd-sale__toast.is-err { background: #b3261e; }
  @media (min-width: 768px) {
    .lnd-sale__modal { align-items: center; }
    .lnd-sale__modal-panel { border-radius: 18px; max-width: 760px; }
    .lnd-sale__modal-panel-inner { display: grid; grid-template-columns: 1fr 1fr; }
    .lnd-sale__modal-img { aspect-ratio: 1/1.05; max-height: none; border-radius: 18px 0 0 18px; }
    .lnd-sale__modal-img img { object-fit: contain; }
    .lnd-sale__modal-media { display: flex; flex-direction: column; }
    .lnd-sale__thumbs { padding: 8px 10px 10px; }
    .lnd-sale__modal-body { padding: 32px 28px; }
  }
</style>

{%- capture products_json -%}
{
  {%- assign emitted_first = false -%}
  {%- for entry in display_handles -%}
    {%- assign p = blank -%}
    {%- for sp in sale_collection.products -%}
      {%- if sp.handle == entry -%}{%- assign p = sp -%}{%- break -%}{%- endif -%}
    {%- endfor -%}
    {%- if p != blank and p.handle != blank -%}
    {%- if emitted_first -%},{%- endif -%}{%- assign emitted_first = true -%}
    {%- assign sale_price = p.price | times: keep_pct | divided_by: 100 -%}
    {%- assign smart_desc = p.metafields.smart.description | default: p.description | strip_html | truncate: 360 -%}
    {%- capture bullet_color -%}{{ p.metafields.custom.smart_bullet_point_color }}{%- endcapture -%}
    {%- if bullet_color == blank -%}{%- capture bullet_color -%}{{ p.metafields.custom.primary_color }}{%- endcapture -%}{%- endif -%}
    {%- if bullet_color == blank -%}{%- capture bullet_color -%}{{ p.metafields.custom.card_accent_color }}{%- endcapture -%}{%- endif -%}
    {%- if bullet_color == blank -%}{%- assign bullet_color = '#4659FF' -%}{%- endif -%}
    {%- assign main_img_src = p.featured_image | image_url: width: 800 -%}
    {%- case p.handle -%}
      {%- when 'restore' -%}{%- assign main_img_src = 'https://cdn.shopify.com/s/files/1/0821/3997/1873/files/TAC_PDP-Image_Restore-Bag_af4e1a3f-f6ca-4ab7-bebf-7e492e6dac9b.png?v=1768255861&width=800' -%}
      {%- when 'sleep' -%}{%- assign main_img_src = 'https://www.absorbmore.com/cdn/shop/files/TAC_PDP-Image_Sleep-Bag_9a994c43-7d98-40a8-ab98-2f20070e69d3.png?v=1768256290&width=800' -%}
      {%- when 'calm' -%}{%- assign main_img_src = 'https://cdn.shopify.com/s/files/1/0821/3997/1873/files/TAC_PDP-Image_Calm-Bag_42e47801-bfd1-4ce0-8f26-de468bc3d559.png?v=1768256004&width=800' -%}
    {%- endcase -%}
    "{{ p.handle }}": {
      "title": {{ p.title | json }},
      "handle": {{ p.handle | json }},
      "price": {{ p.price }},
      "sale_price": {{ sale_price }},
      "image": {{ main_img_src | json }},
      "images": [{%- for img in p.images limit: 8 -%}{{ img | image_url: width: 800 | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
      "description": {{ smart_desc | json }},
      "bullets": [{%- for b in p.metafields.custom.smart_bullet_points.value -%}{{ b | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
      "bullet_color": {{ bullet_color | json }},
      "options": [{%- for opt in p.options_with_values -%}{"name": {{ opt.name | json }}, "values": [{%- for v in opt.values -%}{{ v | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}],
      "variants": [{%- for v in p.variants -%}{"id": {{ v.id }}, "title": {{ v.title | json }}, "price": {{ v.price }}, "option1": {{ v.option1 | json }}, "option2": {{ v.option2 | json }}, "option3": {{ v.option3 | json }}, "available": {{ v.available }}, "selling_plans": [
        {%- assign first_plan = true -%}
        {%- for spa in v.selling_plan_allocations -%}
          {%- assign plan_lookup = '|' | append: spa.selling_plan.name | append: '|' -%}
          {%- unless excluded_plan_names contains plan_lookup -%}
            {%- unless first_plan -%},{%- endunless -%}
            {"id": {{ spa.selling_plan.id }}, "name": {{ spa.selling_plan.name | json }}, "price": {{ spa.price }}}
            {%- assign first_plan = false -%}
          {%- endunless -%}
        {%- endfor -%}
      ]}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]
    }
    {%- endif -%}
  {%- endfor -%}
}
{%- endcapture -%}

<section class="lnd-sale" data-pct="{{ discount_pct }}" data-end="{{ end_iso }}" data-discount-code="{{ discount_code }}">

  {%- comment -%} Sticky promo bar {%- endcomment -%}
  <div class="lnd-sale__bar">
    <span class="lnd-sale__bar-headline">Memorial Day · {{ discount_pct }}% Off Site-Wide · Free Shipping*</span>
    <span class="lnd-sale__bar-count" data-countdown-bar>
      <span>Ends in</span>
      <span class="chip"><b data-d>00</b><span>d</span></span>
      <span class="chip"><b data-h>00</b><span>h</span></span>
      <span class="chip"><b data-m>00</b><span>m</span></span>
      <span class="chip"><b data-s>00</b><span>s</span></span>
    </span>
  </div>

  {%- comment -%} HERO — mobile <img> fits naturally, desktop full-bleed bg. {%- endcomment -%}
  {%- if section.settings.hero_image -%}
    {%- assign hero_bg_desktop = section.settings.hero_image | image_url: width: 2400 -%}
  {%- else -%}
    {%- assign hero_bg_desktop = 'https://cdn.shopify.com/s/files/1/0821/3997/1873/files/memorial-day-plp-blue-bg.jpg?v=1778730415' -%}
  {%- endif -%}
  {%- if section.settings.hero_image_mobile -%}
    {%- assign hero_bg_mobile = section.settings.hero_image_mobile | image_url: width: 1200 -%}
  {%- else -%}
    {%- assign hero_bg_mobile = 'https://cdn.shopify.com/s/files/1/0821/3997/1873/t/233/assets/lander-sale-hero-mobile.jpg?v=1778738879' -%}
  {%- endif -%}
  <div class="lnd-sale__hero" style="--hero-bg-desktop: url('{{ hero_bg_desktop }}');">
    <img class="lnd-sale__hero-bg" src="{{ hero_bg_mobile }}" alt="" loading="eager" width="1398" height="2000">
    <div class="lnd-sale__hero-inner">
      <div class="lnd-sale__hero-text">
        <div class="lnd-sale__hero-eyebrow">{{ section.settings.eyebrow | default: 'Memorial Day Sale: 35% Sitewide + Free Shipping*' }}</div>
        <h1>{{ section.settings.headline | default: '<p>Save 35% on supplements that <em>actually absorb.</em></p>' }}</h1>
        <p class="lead">{{ section.settings.subhead | default: "Most supplements don't reach your bloodstream. Ours do. Up to 149x better absorption you can actually feel." }}</p>

        <ul class="lnd-sale__hero-bullets">
          <li><span class="check">✓</span><div>Up to <em>149x absorption</em> · clinically formulated</div></li>
          <li><span class="check">✓</span><div>Built for <em>real results you feel</em> · energy, focus, recovery</div></li>
          <li><span class="check">✓</span><div>30-day <em>money-back guarantee</em> · cancel anytime</div></li>
        </ul>

        <div class="lnd-sale__hero-rotator" aria-live="polite">
          <div class="lnd-sale__hero-rotator-line">
            <span class="static">More absorption =</span>
            <span class="dynamic" data-rotator>more energy</span>
          </div>
        </div>

        <a class="lnd-sale__hero-cta" href="#sale-grid">Shop the sale</a>
      </div>
    </div>
  </div>

  {%- comment -%} Value strip {%- endcomment -%}
  <div class="lnd-sale__values">
    <div class="lnd-sale__values-inner">
      <div class="lnd-sale__value"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 2v20M2 12h20"/></svg>Up to 149x more absorption</div>
      <div class="lnd-sale__value"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 22s8-4 8-12V5l-8-3-8 3v5c0 8 8 12 8 12z"/></svg>30-day money-back guarantee</div>
      <div class="lnd-sale__value"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M3 7h13l3 4h2v6h-3a2 2 0 1 1-4 0H10a2 2 0 1 1-4 0H3z"/></svg>Free shipping on $50+</div>
      <div class="lnd-sale__value"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="12" r="9"/><path d="m8 12 3 3 5-6"/></svg>Third-party tested for purity</div>
    </div>
  </div>

  {%- comment -%} Bubble filter — replaces gradient goal cards. Compact, horizontal-scroll on mobile. {%- endcomment -%}
  <div class="lnd-sale__bubbles-wrap" id="sale-bubbles">
    <div class="lnd-sale__bubbles-inner">
      <h2 class="lnd-sale__bubbles-head">Shop by goal</h2>
      <div class="lnd-sale__bubbles" role="tablist" aria-label="Filter by goal">
        <button class="lnd-sale__bubble is-active" type="button" data-goal="all" aria-pressed="true">All <span class="lnd-sale__bubble-count">{{ meta_handles.size }}</span></button>
        <button class="lnd-sale__bubble" type="button" data-goal="longevity" aria-pressed="false">Longevity &amp; Performance <span class="lnd-sale__bubble-count">{{ goal_longevity.size }}</span></button>
        <button class="lnd-sale__bubble" type="button" data-goal="metab" aria-pressed="false">Metabolism &amp; Hormones <span class="lnd-sale__bubble-count">{{ goal_metab.size }}</span></button>
        <button class="lnd-sale__bubble" type="button" data-goal="sleep" aria-pressed="false">Sleep &amp; Mood <span class="lnd-sale__bubble-count">{{ goal_sleep.size }}</span></button>
        <button class="lnd-sale__bubble" type="button" data-goal="immunity" aria-pressed="false">Immunity &amp; Inflammation <span class="lnd-sale__bubble-count">{{ goal_immunity.size }}</span></button>
      </div>
    </div>
  </div>

  {%- comment -%} Product grid. Iterates display_handles against the `memorial-day-savings` collection (bypasses 20-handle cap). {%- endcomment -%}
  <div class="lnd-sale__grid-wrap" id="sale-grid">
    <div class="lnd-sale__grid-head">
      <h2>Shop the sale</h2>
      <span class="lnd-sale__grid-count" data-grid-count>{{ meta_handles.size }} products</span>
    </div>
    <div class="lnd-sale__grid" data-grid>
      {%- assign render_idx = 0 -%}
      {%- for entry in display_handles -%}
        {%- assign p = blank -%}
        {%- for sp in sale_collection.products -%}
          {%- if sp.handle == entry -%}{%- assign p = sp -%}{%- break -%}{%- endif -%}
        {%- endfor -%}

        {%- if p != blank and p.handle != blank -%}
          {%- assign render_idx = render_idx | plus: 1 -%}

          {%- comment -%} Look up parallel-array metadata by matching handle. {%- endcomment -%}
          {%- assign meta_idx = -1 -%}
          {%- for mh in meta_handles -%}
            {%- if mh == p.handle -%}{%- assign meta_idx = forloop.index0 -%}{%- break -%}{%- endif -%}
          {%- endfor -%}

          {%- assign pill_text = '' -%}
          {%- assign badge_text = '' -%}
          {%- assign rating_val = '' -%}
          {%- assign reviews_val = '' -%}
          {%- if meta_idx >= 0 -%}
            {%- assign pill_text = pills[meta_idx] -%}
            {%- assign badge_text = badges[meta_idx] -%}
            {%- assign rating_val = ratings[meta_idx] -%}
            {%- assign reviews_val = reviews[meta_idx] -%}
          {%- endif -%}

          {%- comment -%} First 6 rendered tiles get a red BEST SELLER badge. {%- endcomment -%}
          {%- if render_idx <= 6 -%}{%- assign badge_text = 'BEST SELLER' -%}{%- endif -%}

          {%- assign tile_chips = 'all' -%}
          {%- if goal_longevity contains p.handle -%}{%- assign tile_chips = tile_chips | append: ' longevity' -%}{%- endif -%}
          {%- if goal_metab contains p.handle -%}{%- assign tile_chips = tile_chips | append: ' metab' -%}{%- endif -%}
          {%- if goal_sleep contains p.handle -%}{%- assign tile_chips = tile_chips | append: ' sleep' -%}{%- endif -%}
          {%- if goal_immunity contains p.handle -%}{%- assign tile_chips = tile_chips | append: ' immunity' -%}{%- endif -%}

          {%- comment -%} Pricing: prefer compare_at_price; else compute from discount_pct. {%- endcomment -%}
          {%- assign was_price = p.compare_at_price -%}
          {%- assign now_price = p.price -%}
          {%- if was_price == nil or was_price <= now_price -%}
            {%- assign keep_pct = 100 | minus: discount_pct -%}
            {%- assign now_price = p.price | times: keep_pct | divided_by: 100 -%}
            {%- assign was_price = p.price -%}
          {%- endif -%}

          {%- comment -%} Tile image: per-handle override map first, else featured image. {%- endcomment -%}
          {%- assign tile_img_url = '' -%}
          {%- for oh in override_handles -%}
            {%- if oh == p.handle -%}{%- assign tile_img_url = override_urls[forloop.index0] -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
          {%- assign tile_img = p.featured_image -%}

          {%- comment -%} Subtitle priority: metafield → tagline → trimmed description. {%- endcomment -%}
          {%- assign tile_sub = p.metafields.smart.short_description -%}
          {%- if tile_sub == blank -%}{%- assign tile_sub = p.metafields.smart.tagline -%}{%- endif -%}
          {%- if tile_sub == blank -%}{%- assign tile_sub = p.description | strip_html | truncate: 80 -%}{%- endif -%}

          {%- comment -%} Default variant for direct-ATC on powder products. {%- endcomment -%}
          {%- assign default_variant_id = '' -%}
          {%- assign pipe_handle = '|' | append: p.handle | append: '|' -%}
          {%- if powder_handles contains pipe_handle -%}
            {%- for v in p.variants -%}
              {%- if p.handle == 'energy' -%}
                {%- if v.option1 contains '28 Stick' and v.available -%}{%- assign default_variant_id = v.id -%}{%- break -%}{%- endif -%}
              {%- else -%}
                {%- if v.option1 == 'Bag' and v.option2 contains '28 Serving' and v.available -%}{%- assign default_variant_id = v.id -%}{%- break -%}{%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}

          {%- assign is_low_stock = false -%}
          {%- if p.handle == 'wlp-1' or p.handle == 'weight-management-stack' -%}{%- assign is_low_stock = true -%}{%- endif -%}
          <div class="lnd-sale__tile" data-chips="{{ tile_chips }}" data-handle="{{ p.handle }}"{% if default_variant_id != '' %} data-default-variant="{{ default_variant_id }}"{% endif %}>
            <a class="lnd-sale__tile-link" href="/products/{{ p.handle }}" aria-label="{{ p.title | escape }}">{{ p.title | escape }}</a>
            {%- if pill_text != blank or badge_text != blank or is_low_stock -%}
              <div class="lnd-sale__tile-labels">
                {%- if pill_text != blank -%}<span class="lnd-sale__tile-pill">{{ pill_text }}</span>{%- endif -%}
                {%- if badge_text != blank -%}<span class="lnd-sale__tile-badge">{{ badge_text }}</span>{%- endif -%}
                {%- if is_low_stock -%}<span class="lnd-sale__tile-lowstock">Low Stock</span>{%- endif -%}
              </div>
            {%- endif -%}
            <div class="lnd-sale__tile-img">
              {%- if tile_img_url != blank -%}
                <img src="{{ tile_img_url }}" alt="{{ p.title | escape }}" loading="lazy" width="600" height="600">
              {%- elsif tile_img -%}
                <img src="{{ tile_img | image_url: width: 600 }}" alt="{{ p.title | escape }}" loading="lazy" width="600" height="600">
              {%- endif -%}
            </div>
            <div class="lnd-sale__tile-info">
              <h3 class="lnd-sale__tile-title">{{ p.title }}</h3>
              {%- if tile_sub != blank -%}<p class="lnd-sale__tile-sub">{{ tile_sub }}</p>{%- endif -%}
              {%- if rating_val != blank -%}
                <div class="lnd-sale__tile-stars">
                  <span class="lnd-sale__tile-stars-glyphs">★★★★★</span>
                  <span class="lnd-sale__tile-stars-meta">{{ rating_val }} ({{ reviews_val }})</span>
                </div>
              {%- endif -%}
              <div class="lnd-sale__tile-price">
                <span class="now">{{ now_price | money }}</span>
                <span class="was">{{ was_price | money }}</span>
                <span class="off">{{ discount_pct }}% off</span>
              </div>
              <span class="lnd-sale__tile-more" aria-hidden="true">Details ›</span>
              <button type="button" class="lnd-sale__tile-cta" data-card-atc data-handle="{{ p.handle }}">Add to cart</button>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Subscribe band {%- endcomment -%}
  <div class="lnd-sale__sub">
    <div class="lnd-sale__sub-inner">
      <div class="lnd-sale__sub-eyebrow">Subscribe + Save</div>
      <h2>Subscribe and the {{ discount_pct }}% sticks.</h2>
      <p>Subscribe today and lock in sale pricing on your first order. Every order after saves 15%. Cancel or skip anytime. No commitments.</p>
      <a class="lnd-sale__sub-cta" href="#sale-grid">Pick your stack</a>
    </div>
  </div>

  {%- comment -%} Trust strip {%- endcomment -%}
  <div class="lnd-sale__trust">
    <div class="lnd-sale__trust-inner">
      <div class="lnd-sale__trust-eyebrow">Why we mark down, not water down</div>
      <h2>Same pharmaceutical-grade absorption. Better price.</h2>
      <p>Supplements don't work if they don't absorb. Our liposomes, nanoparticles, and chelated nutrients deliver up to 5x what standard supplements deliver. The sale doesn't change the science. It just makes the science cheaper to test.</p>
    </div>
  </div>

  {%- comment -%} FAQ {%- endcomment -%}
  <div class="lnd-sale__faq">
    <div class="lnd-sale__faq-inner">
      <h2>Sale questions</h2>
      <details>
        <summary>When does the sale end?</summary>
        <div class="lnd-sale__faq-body">Sale ends at midnight on the date in the countdown. After that, prices return to standard.</div>
      </details>
      <details>
        <summary>Does the {{ discount_pct }}% stack with subscribe and save?</summary>
        <div class="lnd-sale__faq-body">Yes. Subscribe today to lock in sale pricing on your first order, then save 15% on every order after.</div>
      </details>
      <details>
        <summary>Do I need a code?</summary>
        <div class="lnd-sale__faq-body">No. Prices on this page are already discounted. Add to cart and check out.</div>
      </details>
      <details>
        <summary>Can I return if it's not for me?</summary>
        <div class="lnd-sale__faq-body">Yes. 60-day money-back guarantee on every order. Sale items included.</div>
      </details>
      <details>
        <summary>Not sure which to pick?</summary>
        <div class="lnd-sale__faq-body">Take the <a href="/pages/absorption-quiz">2-minute absorption quiz</a> and we'll recommend the stack that fits.</div>
      </details>
    </div>
  </div>

  {%- comment -%} Final CTA band {%- endcomment -%}
  <div class="lnd-sale__final">
    <div class="lnd-sale__countdown" data-countdown>
      <div><b data-d>00</b><span>Days</span></div>
      <div><b data-h>00</b><span>Hours</span></div>
      <div><b data-m>00</b><span>Minutes</span></div>
      <div><b data-s>00</b><span>Seconds</span></div>
    </div>
    <h2>Sale ends soon. <em>The absorption stays.</em></h2>
    <p>{{ discount_pct }}% off the whole catalog. Subscribe to keep the savings going.</p>
    <a class="lnd-sale__final-cta" href="#sale-grid">Shop the sale</a>
  </div>

  {%- comment -%} Sticky mobile CTA {%- endcomment -%}
  <div class="lnd-sale__mobile-cta" data-mobile-cta>
    <a href="#sale-grid">Shop {{ discount_pct }}% off</a>
  </div>

  {%- comment -%} Quick-view modal {%- endcomment -%}
  <div class="lnd-sale__modal" data-modal aria-hidden="true" role="dialog">
    <div class="lnd-sale__modal-backdrop" data-modal-close></div>
    <div class="lnd-sale__modal-panel">
      <button class="lnd-sale__modal-close" data-modal-close aria-label="Close">×</button>
      <div class="lnd-sale__modal-panel-inner">
        <div class="lnd-sale__modal-media">
          <div class="lnd-sale__modal-img"><img data-modal-img src="" alt=""></div>
          <div class="lnd-sale__thumbs" data-modal-thumbs></div>
        </div>
        <div class="lnd-sale__modal-body">
          <div class="lnd-sale__toast" data-toast></div>
          <h2 data-modal-title></h2>
          <div class="lnd-sale__modal-price">
            <span class="now" data-modal-now></span>
            <span class="was" data-modal-was></span>
            <span class="save" data-modal-save></span>
          </div>
          <p class="lnd-sale__modal-desc" data-modal-desc></p>
          <ul class="lnd-sale__bullets" data-modal-bullets></ul>
          <div data-modal-options></div>
          <div class="lnd-sale__buy" data-modal-buy></div>
          <div class="lnd-sale__modal-actions">
            <button class="lnd-sale__modal-cta" data-modal-atc type="button">Add to cart</button>
            <a class="lnd-sale__modal-pdp" data-modal-pdp href="#">See full product details</a>
          </div>
        </div>
      </div>
    </div>
  </div>

</section>

<script id="lnd-sale-data" type="application/json">{{ products_json | strip_newlines }}</script>

<script>
(function(){
  var root = document.querySelector('.lnd-sale');
  if (!root) return;

  var END = new Date(root.dataset.end).getTime();
  var PCT = parseInt(root.dataset.pct, 10) || 35;
  var KEEP = (100 - PCT) / 100;
  var DISCOUNT = root.dataset.discountCode;
  var DATA;
  try { DATA = JSON.parse(document.getElementById('lnd-sale-data').textContent); } catch(e) { DATA = {}; }
  var POWDER_HANDLES = { restore:1, sleep:1, calm:1, energy:1 };

  function applyDiscount() {
    if (!DISCOUNT) return Promise.resolve(null);
    return fetch('/discount/' + DISCOUNT + '?redirect=/cart.js', { credentials: 'same-origin' })
      .then(function(r){ return r.ok ? r.json() : null; })
      .catch(function(){ return null; });
  }
  function refreshThemeCart() {
    if (window._cart && typeof window._cart.get === 'function') {
      try { window._cart.get(true); } catch(e){}
    }
  }
  applyDiscount().then(refreshThemeCart);
  setTimeout(function(){ try { document.dispatchEvent(new Event('pointerover')); } catch(e){} }, 600);

  function money(cents){ return '$' + (cents/100).toFixed(2).replace(/\.00$/,''); }
  function pad(n){ return n < 10 ? '0' + n : '' + n; }

  function tick() {
    var diff = Math.max(0, END - Date.now());
    var d = Math.floor(diff / 86400000);
    var h = Math.floor((diff % 86400000) / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    root.querySelectorAll('[data-d]').forEach(function(el){ el.textContent = pad(d); });
    root.querySelectorAll('[data-h]').forEach(function(el){ el.textContent = pad(h); });
    root.querySelectorAll('[data-m]').forEach(function(el){ el.textContent = pad(m); });
    root.querySelectorAll('[data-s]').forEach(function(el){ el.textContent = pad(s); });
  }
  tick();
  setInterval(tick, 1000);

  // Cycling benefits rotator
  var rotator = root.querySelector('[data-rotator]');
  var words = ['more energy', 'more vitality', 'better sleep', 'sharper focus', 'faster recovery', 'stronger immunity', 'deeper rest', 'more benefits'];
  var wi = 0;
  if (rotator) {
    setInterval(function(){
      rotator.classList.add('is-out');
      setTimeout(function(){
        wi = (wi + 1) % words.length;
        rotator.textContent = words[wi];
        rotator.classList.remove('is-out');
      }, 350);
    }, 2200);
  }

  // Bubble filter
  var bubbles = root.querySelectorAll('.lnd-sale__bubble');
  var gridCount = root.querySelector('[data-grid-count]');
  function getTiles(){ return root.querySelectorAll('.lnd-sale__grid .lnd-sale__tile'); }
  function applyFilter(filter) {
    var visible = 0;
    getTiles().forEach(function(t){
      var has = (' ' + (t.dataset.chips || '') + ' ').indexOf(' ' + filter + ' ') !== -1;
      t.style.display = has ? '' : 'none';
      if (has) visible++;
    });
    if (gridCount) gridCount.textContent = visible + ' product' + (visible === 1 ? '' : 's');
  }
  bubbles.forEach(function(b){
    b.addEventListener('click', function(){
      var goal = b.dataset.goal;
      bubbles.forEach(function(x){ x.classList.remove('is-active'); x.setAttribute('aria-pressed','false'); });
      b.classList.add('is-active');
      b.setAttribute('aria-pressed','true');
      applyFilter(goal);
    });
  });

  // Sticky mobile CTA on scroll
  var mobile = root.querySelector('[data-mobile-cta]');
  var hero = root.querySelector('.lnd-sale__hero');
  function onScroll(){
    if (!hero || !mobile) return;
    var heroBottom = hero.getBoundingClientRect().bottom;
    if (heroBottom < 0) { mobile.classList.add('is-show'); }
    else { mobile.classList.remove('is-show'); }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ============ Modal / Quick view ============
  var modal = root.querySelector('[data-modal]');
  if (!modal) return;
  var modalImg = modal.querySelector('[data-modal-img]');
  var modalThumbs = modal.querySelector('[data-modal-thumbs]');
  var modalTitle = modal.querySelector('[data-modal-title]');
  var modalNow = modal.querySelector('[data-modal-now]');
  var modalWas = modal.querySelector('[data-modal-was]');
  var modalSave = modal.querySelector('[data-modal-save]');
  var modalDesc = modal.querySelector('[data-modal-desc]');
  var modalBullets = modal.querySelector('[data-modal-bullets]');
  var modalOptions = modal.querySelector('[data-modal-options]');
  var modalBuy = modal.querySelector('[data-modal-buy]');
  var modalAtc = modal.querySelector('[data-modal-atc]');
  var modalPdp = modal.querySelector('[data-modal-pdp]');
  var toast = modal.querySelector('[data-toast]');
  var currentProduct = null;
  var selected = {};
  var purchaseType = 'subscription';

  function openModal(handle) {
    var p = DATA[handle]; if (!p) return;
    currentProduct = p;
    selected = {};
    if (POWDER_HANDLES[handle]) {
      if (handle === 'energy') {
        selected.option1 = '28 Sticks';
      } else {
        selected.option1 = 'Bag';
        selected.option2 = '28 Servings';
      }
    }
    modalImg.src = p.image || '';
    modalImg.alt = p.title;
    renderThumbs(p);
    modalTitle.textContent = p.title;
    modalDesc.textContent = p.description || '';
    modalBullets.innerHTML = '';
    var color = (p.bullet_color && /^#[0-9a-fA-F]{3,8}$/.test(p.bullet_color)) ? p.bullet_color : '#4659FF';
    var bullets = normalizeBullets(p.bullets);
    bullets.forEach(function(b){
      var li = document.createElement('li');
      li.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><path d="M13.3327 9.33301C13.3327 12.2785 10.9449 14.6663 7.99935 14.6663C5.05383 14.6663 2.66602 12.2785 2.66602 9.33301C2.66602 8.62574 2.80369 7.95063 3.05369 7.33301C3.84488 5.37845 7.99935 1.33301 7.99935 1.33301C7.99935 1.33301 12.1538 5.37845 12.945 7.33301C13.195 7.95063 13.3327 8.62574 13.3327 9.33301Z" fill="' + color + '" stroke="' + color + '" stroke-linecap="round" stroke-linejoin="round"/></svg><span></span>';
      li.querySelector('span').textContent = b;
      modalBullets.appendChild(li);
    });
    modalBullets.style.display = modalBullets.children.length ? 'flex' : 'none';
    modalPdp.href = '/products/' + p.handle;
    toast.className = 'lnd-sale__toast';
    toast.textContent = '';
    modalAtc.disabled = false; modalAtc.textContent = 'Add to cart';
    purchaseType = hasAnySellingPlan(p) ? 'subscription' : 'onetime';
    renderOptions(p);
    renderBuyOptions();
    updatePrice();
    document.body.style.overflow = 'hidden';
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
  }
  function renderThumbs(p) {
    modalThumbs.innerHTML = '';
    var imgs = (p.images || []).filter(function(s){ return !!s; });
    if (imgs.length < 2) return;
    imgs.forEach(function(src, i) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'lnd-sale__thumb' + (i === 0 ? ' is-active' : '');
      btn.innerHTML = '<img src="' + src + '" alt="" loading="lazy">';
      btn.addEventListener('click', function() {
        modalImg.src = src;
        modalThumbs.querySelectorAll('.lnd-sale__thumb').forEach(function(t){ t.classList.remove('is-active'); });
        btn.classList.add('is-active');
      });
      modalThumbs.appendChild(btn);
    });
  }
  function hasAnySellingPlan(p) {
    if (!p || !p.variants) return false;
    return p.variants.some(function(v){ return v.selling_plans && v.selling_plans.length; });
  }
  function variantSellingPlan(v) {
    return (v && v.selling_plans && v.selling_plans.length) ? v.selling_plans[0] : null;
  }
  function updatePrice() {
    if (!currentProduct) return;
    var v = findVariant();
    var basePrice = v ? v.price : currentProduct.price;
    var sp = v ? variantSellingPlan(v) : null;
    if (purchaseType === 'subscription' && sp) {
      modalNow.textContent = money(basePrice * KEEP);
      modalWas.textContent = money(basePrice);
      modalWas.style.display = '';
      modalSave.textContent = 'SAVE ' + PCT + '%';
      modalSave.style.display = '';
    } else {
      modalNow.textContent = money(basePrice);
      modalWas.textContent = '';
      modalWas.style.display = 'none';
      modalSave.textContent = '';
      modalSave.style.display = 'none';
    }
    renderBuyOptions();
  }
  function renderBuyOptions() {
    if (!currentProduct) { modalBuy.innerHTML = ''; return; }
    var v = findVariant();
    var sp = v ? variantSellingPlan(v) : null;
    if (!sp) { modalBuy.innerHTML = ''; modalBuy.style.display = 'none'; return; }
    modalBuy.style.display = 'flex';
    var basePrice = v ? v.price : currentProduct.price;
    var subPrice = money(basePrice * KEEP);
    var oneTimePrice = money(basePrice);
    var planLabel = sp.name || 'Subscribe & save';
    modalBuy.innerHTML =
      '<label class="lnd-sale__buy-opt ' + (purchaseType === 'subscription' ? 'is-active' : '') + '" data-buy="subscription">' +
        '<input type="radio" name="lnd-buy" value="subscription"' + (purchaseType === 'subscription' ? ' checked' : '') + '>' +
        '<span class="lnd-sale__buy-opt-main">' +
          '<span class="lnd-sale__buy-opt-title">' + planLabel + ' <span class="lnd-sale__buy-opt-tag">BEST VALUE</span></span>' +
          '<span class="lnd-sale__buy-opt-sub">Auto-deliver. Cancel anytime.</span>' +
        '</span>' +
        '<span class="lnd-sale__buy-opt-price">' + subPrice + '</span>' +
      '</label>' +
      '<label class="lnd-sale__buy-opt ' + (purchaseType === 'onetime' ? 'is-active' : '') + '" data-buy="onetime">' +
        '<input type="radio" name="lnd-buy" value="onetime"' + (purchaseType === 'onetime' ? ' checked' : '') + '>' +
        '<span class="lnd-sale__buy-opt-main">' +
          '<span class="lnd-sale__buy-opt-title">One-time purchase</span>' +
          '<span class="lnd-sale__buy-opt-sub">Just this once.</span>' +
        '</span>' +
        '<span class="lnd-sale__buy-opt-price">' + oneTimePrice + '</span>' +
      '</label>';
    modalBuy.querySelectorAll('[data-buy]').forEach(function(el){
      el.addEventListener('click', function(){
        purchaseType = el.dataset.buy;
        updatePrice();
      });
    });
  }
  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    document.body.classList.remove('modal-open');
    document.documentElement.classList.remove('!overflow-clip');
  }
  function valueCompatible(p, idx, val) {
    if (!p.variants) return true;
    return p.variants.some(function(v) {
      if (!v.available) return false;
      if (v['option' + (idx + 1)] !== val) return false;
      for (var k = 0; k < p.options.length; k++) {
        if (k === idx) continue;
        var sel = selected['option' + (k + 1)];
        if (sel && v['option' + (k + 1)] !== sel) return false;
      }
      return true;
    });
  }
  function renderOptions(p) {
    modalOptions.innerHTML = '';
    if (!p.options || p.options.length === 0 || (p.options.length === 1 && p.options[0].name === 'Title')) return;
    p.options.forEach(function(opt, idx) {
      var wrap = document.createElement('div'); wrap.className = 'lnd-sale__opt';
      var label = document.createElement('span'); label.className = 'lnd-sale__opt-label';
      label.textContent = opt.name; wrap.appendChild(label);
      var values = document.createElement('div'); values.className = 'lnd-sale__opt-values';
      var visibleVals = opt.values.filter(function(v){ return valueCompatible(p, idx, v); });
      if (!visibleVals.length) visibleVals = opt.values.slice();
      if (selected['option' + (idx + 1)] && visibleVals.indexOf(selected['option' + (idx + 1)]) === -1) {
        selected['option' + (idx + 1)] = visibleVals[0];
      }
      if (!selected['option' + (idx + 1)]) {
        selected['option' + (idx + 1)] = visibleVals[0];
      }
      visibleVals.forEach(function(v) {
        var btn = document.createElement('button');
        btn.type = 'button'; btn.className = 'lnd-sale__opt-btn'; btn.textContent = v;
        btn.dataset.optIdx = idx; btn.dataset.optValue = v;
        if (v === selected['option' + (idx + 1)]) btn.classList.add('is-active');
        btn.addEventListener('click', function() {
          selected['option' + (idx + 1)] = v;
          renderOptions(p);
          updatePrice();
        });
        values.appendChild(btn);
      });
      wrap.appendChild(values);
      modalOptions.appendChild(wrap);
    });
  }
  function findVariant() {
    if (!currentProduct || !currentProduct.variants) return null;
    if (currentProduct.variants.length === 1) return currentProduct.variants[0];
    return currentProduct.variants.find(function(v) {
      return (!selected.option1 || v.option1 === selected.option1)
          && (!selected.option2 || v.option2 === selected.option2)
          && (!selected.option3 || v.option3 === selected.option3);
    }) || null;
  }

  root.addEventListener('click', function(e) {
    var atcBtn = e.target.closest('[data-card-atc]');
    if (atcBtn) { e.preventDefault(); e.stopPropagation(); directAtcFromCard(atcBtn); return; }
    if (e.target.closest('[data-modal-close]')) { e.preventDefault(); closeModal(); return; }
  });

  function directAtcFromCard(btn) {
    var handle = btn.getAttribute('data-handle');
    var prod = DATA[handle];
    if (!prod || !prod.variants || !prod.variants.length) { window.location.href = '/products/' + handle; return; }
    var card = btn.closest('.lnd-sale__tile');
    var defaultVid = card && card.getAttribute('data-default-variant');
    var v = null;
    if (defaultVid) {
      for (var j = 0; j < prod.variants.length; j++) {
        if (String(prod.variants[j].id) === String(defaultVid) && prod.variants[j].available) { v = prod.variants[j]; break; }
      }
    }
    if (!v) {
      for (var i = 0; i < prod.variants.length; i++) { if (prod.variants[i].available) { v = prod.variants[i]; break; } }
    }
    if (!v) v = prod.variants[0];
    var item = { id: v.id, quantity: 1 };
    if (v.selling_plans && v.selling_plans.length) item.selling_plan = v.selling_plans[0].id;
    var origLabel = btn.textContent;
    btn.classList.add('is-loading'); btn.disabled = true; btn.textContent = 'Adding...';
    var payload = { items: [item] };
    var themeAdd = (window._cart && typeof window._cart.add === 'function') ? window._cart.add(payload) : null;
    var p = themeAdd && typeof themeAdd.then === 'function'
      ? themeAdd
      : fetch('/cart/add.js?smart_theme=true', {
          method: 'POST',
          headers: {'Content-Type':'application/json','Accept':'application/json','smart-theme':'true'},
          body: JSON.stringify(payload)
        }).then(function(r){ return r.json().then(function(j){ if(!r.ok) throw j; return j; }); });
    p.then(function(){
      btn.classList.remove('is-loading'); btn.disabled = false; btn.textContent = origLabel;
      refreshThemeCart();
      setTimeout(openCartDrawer, 100);
      applyDiscount().then(refreshThemeCart).catch(function(){});
    }).catch(function(){
      btn.classList.remove('is-loading'); btn.disabled = false; btn.textContent = origLabel;
      window.location.href = '/products/' + handle;
    });
  }

  function normalizeBullets(raw) {
    if (!raw || !raw.length) return [];
    var out = [];
    raw.forEach(function(item) {
      if (item == null) return;
      if (typeof item === 'string') {
        var trimmed = item.trim();
        if (trimmed.charAt(0) === '{' && trimmed.indexOf('"type"') !== -1 && trimmed.indexOf('"children"') !== -1) {
          try { walkRich(JSON.parse(trimmed), out); return; } catch(e) {}
        }
        out.push(item);
      } else if (typeof item === 'object') {
        walkRich(item, out);
      }
    });
    return out.filter(function(s){ return s && s.trim().length; });
  }
  function walkRich(node, out) {
    if (!node) return;
    if (node.type === 'list-item' || node.type === 'listItem' || node.type === 'listitem') {
      out.push(collectText(node));
      return;
    }
    if (node.children && node.children.length) node.children.forEach(function(c){ walkRich(c, out); });
  }
  function collectText(node) {
    if (!node) return '';
    if (typeof node === 'string') return node;
    if (node.type === 'text') return node.value || '';
    if (node.children && node.children.length) {
      return node.children.map(collectText).join('');
    }
    return '';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
  });

  function openCartDrawer() {
    var cartLink = document.querySelector('a[href$="#modal--cart-drawer"]');
    if (cartLink) {
      try { cartLink.click(); return; } catch(e){}
    }
    try {
      var store = window.Alpine && window.Alpine.store && window.Alpine.store('modal');
      if (store && typeof store.setId === 'function' && window.modalsLoaded) {
        store.setId('cart-drawer');
      }
    } catch(e){}
  }
  function showAddError(msg) {
    toast.className = 'lnd-sale__toast is-show is-err';
    toast.textContent = msg || 'Could not add to cart.';
    modalAtc.disabled = false; modalAtc.textContent = 'Add to cart';
  }

  modalAtc.addEventListener('click', function() {
    var v = findVariant();
    if (!v) return showAddError('Please choose all options.');
    if (!v.available) return showAddError('Sold out — try another option.');
    modalAtc.disabled = true; modalAtc.textContent = 'Adding...';

    var item = { id: v.id, quantity: 1 };
    var sp = variantSellingPlan(v);
    if (purchaseType === 'subscription' && sp) item.selling_plan = sp.id;
    var payload = { items: [item] };

    var themeAdd = (window._cart && typeof window._cart.add === 'function') ? window._cart.add(payload) : null;
    var p = themeAdd && typeof themeAdd.then === 'function'
      ? themeAdd
      : fetch('/cart/add.js?smart_theme=true', {
          method: 'POST',
          headers: {'Content-Type':'application/json','Accept':'application/json','smart-theme':'true'},
          body: JSON.stringify(payload)
        }).then(function(r){ return r.json().then(function(j){ if(!r.ok) throw j; return j; }); });

    p.then(function(res) {
      if (res && res.cart_error) return showAddError(res && res.description);
      modalAtc.disabled = false; modalAtc.textContent = 'Add to cart';
      closeModal();
      refreshThemeCart();
      setTimeout(openCartDrawer, 100);
      applyDiscount().then(refreshThemeCart).catch(function(){});
    }).catch(function(err) {
      showAddError(err && (err.description || err.message));
    });
  });
})();
</script>

{% schema %}
{
  "name": "Lander · Shop All Sale",
  "settings": [
    { "type": "header", "content": "Offer" },
    { "type": "number", "id": "discount_pct", "label": "Discount %", "default": 35 },
    { "type": "text", "id": "end_iso", "label": "End date (ISO, e.g. 2026-05-28T23:59:59-04:00)", "default": "2026-05-28T23:59:59-04:00" },
    { "type": "text", "id": "discount_code", "label": "Auto-apply discount code at ATC (optional)" },
    { "type": "header", "content": "Hero copy" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Memorial Day Sale: 35% Sitewide + Free Shipping*" },
    { "type": "richtext", "id": "headline", "label": "Headline (use <em> for red accent)", "default": "<p>Save 35% on supplements that <em>actually absorb.</em></p>" },

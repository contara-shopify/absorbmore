{%- comment -%} Intro Editorial Block {%- endcomment -%}
{%- liquid
  assign body_text = section.settings.body_text
  assign closing_line = section.settings.closing_line
  assign text_color = section.settings.text_color
  assign closing_color = section.settings.closing_color
  assign body_size_desktop = section.settings.body_size_desktop
  assign body_size_mobile = section.settings.body_size_mobile
  assign closing_size_desktop = section.settings.closing_size_desktop
  assign closing_size_mobile = section.settings.closing_size_mobile
  assign text_align = section.settings.text_align
  assign container_width = section.settings.container_width
  assign background_color = section.settings.background_color
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id
-%}

{% capture selector %}[data-style-id="{{ section.id }}"]{% endcapture %}

{% capture css %}
  & {
    width: 100%;
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    padding: 24px;
  }

  & .ie__container {
    max-width: {{ container_width }}px;
    margin: 0 auto;
    text-align: {{ text_align }};
  }

  & .ie__body {
    font-size: {{ body_size_mobile }}px;
    line-height: 1.7;
    {% if text_color != blank %}color: {{ text_color }};{% endif %}
  }
  & .ie__body p {
    margin: 0 0 1em 0;
  }
  & .ie__body p:last-child {
    margin-bottom: 0;
  }

  & .ie__closing {
    font-weight: 800;
    font-size: {{ closing_size_mobile }}px;
    line-height: 1.3;
    margin: 1.2em 0 0 0;
    {% if closing_color != blank %}color: {{ closing_color }};{% endif %}
  }

  @media (min-width: 768px) {
    & {
      padding: 40px 48px;
    }
    & .ie__body {
      font-size: {{ body_size_desktop }}px;
    }
    & .ie__closing {
      font-size: {{ closing_size_desktop }}px;
    }
  }
{% endcapture %}

{% capture section_content %}
  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  </style>

  <section
    data-style-id="{{ section.id }}"
    {% if section_id != blank %}id="{{ section_id }}"{% endif %}
  >
    <div class="ie__container">

      {% if body_text != blank %}
        <div class="ie__body">{{ body_text }}</div>
      {% endif %}

      {% if closing_line != blank %}
        <p class="ie__closing">{{ closing_line }}</p>
      {% endif %}

    </div>
  </section>
{% endcapture %}

{{ section_content }}

{% schema %}
{
  "name": "CTR Intro Editorial",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Most berberine users are underperforming. Not because berberine doesn't work. It does. Decades of research confirm its effect on blood sugar, metabolism, and cravings.</p><p>The issue is how most people take it. Wrong timing. Wrong dose. Wrong form. And most critically, wrong absorption. The difference between \"I tried berberine and it didn't work\" and visible results usually comes down to five factors.</p>"
    },
    {
      "type": "text",
      "id": "closing_line",
      "label": "Closing line",
      "default": "Here's what the research actually says."
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "body_size_desktop",
      "label": "Body size — Desktop (px)",
      "default": 20,
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "label": "Body size — Mobile (px)",
      "default": 17,
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "closing_size_desktop",
      "label": "Closing line size — Desktop (px)",
      "default": 24,
      "min": 16,
      "max": 36,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "closing_size_mobile",
      "label": "Closing line size — Mobile (px)",
      "default": 20,
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "closing_color",
      "label": "Closing line color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width — Desktop (px)",
      "default": 800,
      "min": 480,
      "max": 1200,
      "step": 20,
      "unit": "px"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section Id"
    }
  ],
  "presets": [
    {
      "name": "CTR Intro Editorial",
      "category": "Text"
    }
  ]
}
{% endschema %}

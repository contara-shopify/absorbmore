{%- comment -%} Single Step Section — duplicate for each step {%- endcomment -%}
{%- liquid
  assign step_number = section.settings.step_number
  assign number_align = section.settings.number_align
  assign number_bg = section.settings.number_bg
  assign number_color = section.settings.number_color
  assign headline = section.settings.headline
  assign headline_color = section.settings.headline_color
  assign headline_size_desktop = section.settings.headline_size_desktop
  assign headline_size_mobile = section.settings.headline_size_mobile
  assign body = section.settings.body
  assign body_color = section.settings.body_color
  assign body_size = section.settings.body_size
  assign callout_label = section.settings.callout_label
  assign callout_text = section.settings.callout_text
  assign callout_bg = section.settings.callout_bg
  assign callout_label_color = section.settings.callout_label_color
  assign callout_text_color = section.settings.callout_text_color
  assign pill_1 = section.settings.pill_1
  assign pill_2 = section.settings.pill_2
  assign pill_bg = section.settings.pill_bg
  assign pill_color = section.settings.pill_color
  assign footnote = section.settings.footnote
  assign footnote_color = section.settings.footnote_color
  assign cta_text = section.settings.cta_text
  assign cta_url = section.settings.cta_url
  assign cta_badge_text = section.settings.cta_badge_text
  assign cta_bg = section.settings.cta_bg
  assign cta_text_color = section.settings.cta_text_color
  assign cta_badge_bg = section.settings.cta_badge_bg
  assign cta_badge_text_color = section.settings.cta_badge_text_color
  assign image_desktop = section.settings.image_desktop
  assign image_mobile = section.settings.image_mobile
  assign image_position = section.settings.image_position
  assign image_border_radius = section.settings.image_border_radius
  assign background_color = section.settings.background_color
  assign container_width = section.settings.container_width
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id

-%}

{% capture selector %}[data-style-id="{{ section.id }}"]{% endcapture %}

{% capture css %}
  & {
    width: 100%;
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    padding: 30px 24px;
  }

  & .step__container {
    max-width: {{ container_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  & .step__number-row {
    display: flex;
    justify-content: flex-start;
  }

  & .step__row {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  & .step__image {
    order: -1;
    border-radius: {{ image_border_radius }}px;
    overflow: hidden;
  }
  & .step__image img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  & .step__text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  & .step__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-weight: 800;
    font-size: 18px;
    flex-shrink: 0;
    {% if number_bg != blank %}background-color: {{ number_bg }};{% endif %}
    {% if number_color != blank %}color: {{ number_color }};{% endif %}
  }

  & .step__headline {
    font-weight: 900;
    line-height: 1.1;
    margin: 0;
    font-size: {{ headline_size_mobile }}px;
    {% if headline_color != blank %}color: {{ headline_color }};{% endif %}
  }

  & .step__body {
    line-height: 1.7;
    font-size: {{ body_size }}px;
    {% if body_color != blank %}color: {{ body_color }};{% endif %}
  }
  & .step__body p { margin: 0; }

  & .step__callout {
    border-radius: 16px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    {% if callout_bg != blank %}background-color: {{ callout_bg }};{% endif %}
  }

  & .step__callout-label {
    font-weight: 700;
    margin: 0;
    {% if callout_label_color != blank %}color: {{ callout_label_color }};{% endif %}
  }

  & .step__callout-text {
    font-size: 12px;
    line-height: 1.4;
    {% if callout_text_color != blank %}color: {{ callout_text_color }};{% endif %}
  }
  & .step__callout-text p { margin: 0; }

  & .step__pills {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  & .step__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 14px;
    {% if pill_bg != blank %}background-color: {{ pill_bg }};{% endif %}
    {% if pill_color != blank %}color: {{ pill_color }};{% endif %}
  }

  & .step__footnote {
    font-size: 12px;
    {% comment %} font-style: italic; {% endcomment %}
    opacity: 0.8;
    text-align: center;
    {% if footnote_color != blank %}color: {{ footnote_color }};{% endif %}
  }

  & .step__cta-wrap {
    position: relative;
    display: inline-flex;
    margin-top: 8px;
  }

  & .step__cta {
    display: block;
    width: 100%;
    text-align: center;
    padding: 16px 32px;
    font-weight: 700;
    font-size: 17px;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s;
    {% if cta_bg != blank %}background-color: {{ cta_bg }};{% endif %}
    {% if cta_text_color != blank %}color: {{ cta_text_color }};{% endif %}
  }
  & .step__cta:hover {
    opacity: 0.9;
  }

  & .step__cta-badge {
    position: absolute;
    top: -12px;
    right: -16px;
    padding: 4px 12px;
    font-size: 13px;
    font-weight: 700;
    {% comment %} font-style: italic; {% endcomment %}
    border-radius: 100px;
    white-space: nowrap;
    transform: rotate(6deg);
    z-index: 2;
    {% if cta_badge_bg != blank %}background-color: {{ cta_badge_bg }};{% endif %}
    {% if cta_badge_text_color != blank %}color: {{ cta_badge_text_color }};{% endif %}
  }

  @media (min-width: 768px) {
    & {
      padding: 30px 48px;
    }
    & .step__number-row {
      {% if number_align == 'center' %}justify-content: center;{% endif %}
      {% if number_align == 'right' %}justify-content: flex-end;{% endif %}
      {% if number_align == 'left' %}justify-content: flex-start;{% endif %}
    }
    & .step__row {
      flex-direction: {% if image_position == 'left' %}row-reverse{% else %}row{% endif %};
      gap: 40px;
      align-items: stretch;
    }
    & .step__text {
      flex: 1;
      justify-content: center;
    }
    & .step__image {
      flex: 1;
      order: 0;
    }
    & .step__image img {
      height: 100%;
      object-fit: cover;
    }
    & .step__headline {
      font-size: {{ headline_size_desktop }}px;
    }
    & .step__cta {
      {% comment %} width: auto; {% endcomment %}
    }
  }
{% endcapture %}

{% capture section_content %}
  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  </style>

  <section
    data-style-id="{{ section.id }}"
    {% if section_id != blank %}id="{{ section_id }}"{% endif %}
  >
    <div class="step__container">

      {% if step_number != blank %}
        <div class="step__number-row">
          <div class="step__number">{{ step_number }}</div>
        </div>
      {% endif %}

      <div class="step__row">

        <div class="step__text">

          {% if headline != blank %}
          <h2 class="step__headline">{{ headline }}</h2>
        {% endif %}

        {% if body != blank %}
          <div class="step__body">{{ body }}</div>
        {% endif %}

        {% if callout_label != blank or callout_text != blank %}
          <div class="step__callout">
            {% if callout_label != blank %}
              <p class="step__callout-label">{{ callout_label }}</p>
            {% endif %}
            {% if callout_text != blank %}
              <div class="step__callout-text">{{ callout_text }}</div>
            {% endif %}

            {% if pill_1 != blank or pill_2 != blank %}
              <div class="step__pills">
                {% if pill_1 != blank %}
                  <span class="step__pill">{{ pill_1 }}</span>
                {% endif %}
                {% if pill_2 != blank %}
                  <span class="step__pill">{{ pill_2 }}</span>
                {% endif %}
              </div>
            {% endif %}

            {% if footnote != blank %}
              <div class="step__footnote">{{ footnote }}</div>
            {% endif %}
          </div>
        {% endif %}

        {% if cta_text != blank %}
          <div class="step__cta-wrap">
            <a href="{{ cta_url | default: '#' }}" class="step__cta">
              {{ cta_text }}
            </a>
            {% if cta_badge_text != blank %}
              <span class="step__cta-badge">{{ cta_badge_text }}</span>
            {% endif %}
          </div>
        {% endif %}

      </div>

      {% if image_desktop != blank %}
        <div class="step__image">
          <picture>
            {% if image_mobile != blank %}
              <source media="(max-width: 767px)" srcset="{{ image_mobile | image_url: width: 800 }}">
            {% endif %}
            <img
              src="{{ image_desktop | image_url: width: 1200 }}"
              alt="{{ image_desktop.alt | default: '' }}"
              loading="lazy"
              width="{{ image_desktop.width }}"
              height="{{ image_desktop.height }}"
            >
          </picture>
        </div>
      {% endif %}

      </div>
    </div>
  </section>
{% endcapture %}

{{ section_content }}

{% schema %}

  assign pills = 'GLP-1 Support|Metabolism|Restorative Sleep|Hydrate & Recovery|Weight Management|Hydrate & Detox|Daily Foundations|Metabolism & Hormones|Metabolic Stack|Daily Foundations|Bestseller Bundle|GLP-1 Support|Sleep & Recovery|Rest + Recovery|Sleep & Magnesium|Calm & Magnesium|Restore & Magnesium|Restorative Sleep|Stress Relief|Inflammation Support|Heart & Energy|Energy & Focus|Longevity|Immunity & Inflammation' | split: '|'
  assign badges = 'Best Seller|Best Seller|Best Seller||||||||||||||||||||||' | split: '|'
  assign ratings = '4.78|4.84|4.97|4.88|4.85|4.94|4.83|4.85|4.85|4.87|4.92|4.84|4.91|4.90|4.87|4.88|4.89|4.88|4.94|4.81|4.82|4.86|4.83|4.87' | split: '|'
  assign reviews = '154|85|368|96|121|246|88|121|94|142|412|58|96|82|62|66|74|246|300|71|64|192|88|142' | split: '|'

  comment
    Tile image overrides where the featured image isn't the right tile shot.

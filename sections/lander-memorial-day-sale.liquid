  .lnd-md__mobile-cta a { display: block; background: var(--md-red); color: #fff; text-align: center; padding: 14px; border-radius: 999px; font-size: 13px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; box-shadow: 0 8px 24px rgba(0,0,0,0.2); }

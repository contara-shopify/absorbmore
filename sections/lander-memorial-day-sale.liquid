  assign sale_collection = collections['memorial-day-savings']
  assign display_handles = 'wlp-1,berberine,magnesium-glycinate,summer-ready-stack,weight-management-stack,restore,daily-basics,hormone-metabolism,metabolic-balance-stack,vitamin-d-k-1,the-best-sellers-stack,glp-1-nutrient-support-stack,advanced-sleep-recovery-set,rest-recovery-stack,magnesium-sleep-bundle,magnesium-calm-bundle,magnesium-restore-bundle,sleep,calm,curcumin,coq10,energy,longevity,inflammation-immunity' | split: ','


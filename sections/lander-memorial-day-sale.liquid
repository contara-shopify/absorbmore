  assign override_urls = 'https://www.absorbmore.com/cdn/shop/files/TAC_PDP-Image_Restore-Bag_af4e1a3f-f6ca-4ab7-bebf-7e492e6dac9b.png?v=1768255861&width=960|https://www.absorbmore.com/cdn/shop/files/TAC_PDP-Image_Sleep-Bag_9a994c43-7d98-40a8-ab98-2f20070e69d3.png?v=1768256290&width=960|https://www.absorbmore.com/cdn/shop/files/TAC_PDP-Image_Calm-Bag_42e47801-bfd1-4ce0-8f26-de468bc3d559.png?v=1768256004&width=960|https://www.absorbmore.com/cdn/shop/files/TAC_PDP-Image_Energy_3de78348-83c6-475b-aa3f-9df089873398.png?v=1768256691&width=960|https://www.absorbmore.com/cdn/shop/files/sleep-bag-mag-bundle.png?v=1768005885&width=960' | split: '|'

  comment
    Spotlight pre-canned copy. Parallel arrays indexed by spotlight_handles.
  endcomment
  assign spot_bullets = 'Curbs cravings without a prescription~Supports appetite + metabolism~Liposomal delivery for real absorption||1000mg extra-strength formula~6.2x more absorbable than standard~Supports blood sugar + lipid balance||Chelated for full absorption~Calms the nervous system~Deeper sleep, less morning grog||Foundational nutrients in one stack~High-absorption formulas, no fillers~Daily energy, immunity, recovery' | split: '||'
-%}

<style>
  .lnd-md { font-family: inherit; color: #0D273E; --md-navy: #0D273E; --md-red: #DB3519; --md-navy-2: #143452; --md-cream: #efe9dd; --md-bg: #f6f6f4; --md-blue: #4659FF; }
  .lnd-md * { box-sizing: border-box; }

  /* Sticky promo bar with countdown (incl. seconds) */
  .lnd-md__bar { position: sticky; top: 0; z-index: 50; background: var(--md-red); color: #fff; text-align: center; padding: 8px 14px; font-size: 12px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; display: flex; gap: 10px 16px; justify-content: center; align-items: center; flex-wrap: wrap; line-height: 1.2; }
  .lnd-md__bar-headline { display: inline-flex; align-items: center; }
  .lnd-md__bar-count { display: inline-flex; gap: 4px; align-items: center; font-variant-numeric: tabular-nums; }
  .lnd-md__bar-count > span:first-child { margin-right: 4px; font-size: 11px; opacity: 0.9; }
  .lnd-md__bar-count .chip { display: inline-flex; align-items: baseline; gap: 2px; background: rgba(0,0,0,0.22); border: 1px solid rgba(255,255,255,0.22); border-radius: 6px; padding: 4px 6px; min-width: 34px; justify-content: center; }
  .lnd-md__bar-count .chip b { font-size: 13px; font-weight: 900; line-height: 1; }
  .lnd-md__bar-count .chip span { font-size: 9px; font-weight: 700; opacity: 0.85; letter-spacing: 0.04em; }

  /* HERO — mobile: image as inline <img> so it fits naturally; text on top. Desktop: full-bleed bg with overlay. */
  .lnd-md__hero { position: relative; background-color: var(--md-navy); color: #fff; overflow: hidden; }
  .lnd-md__hero-bg { display: block; width: 100%; height: auto; }
  /* Mobile dark gradient so text stays readable over busy product image */
  .lnd-md__hero::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(13,39,62,0.92) 0%, rgba(13,39,62,0.78) 45%, rgba(13,39,62,0.55) 75%, rgba(13,39,62,0.35) 100%); z-index: 1; pointer-events: none; }
  .lnd-md__hero-inner { position: absolute; inset: 0; z-index: 2; max-width: 1200px; margin: 0 auto; width: 100%; padding: 24px 20px 28px; }
  .lnd-md__hero-text { text-align: left; max-width: 560px; }
  .lnd-md__hero-eyebrow { display: inline-block; background: var(--md-red); color: #fff; font-size: 10px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; padding: 6px 11px; border-radius: 999px; margin: 0 0 12px; line-height: 1.25; box-shadow: 0 4px 14px rgba(0,0,0,0.25); max-width: 100%; }
  .lnd-md__hero h1 { font-size: 26px; line-height: 1.04; margin: 0 0 10px; font-weight: 900; letter-spacing: -0.02em; text-shadow: 0 2px 12px rgba(0,0,0,0.6); }
  .lnd-md__hero h1 em { color: var(--md-red); font-style: normal; }
  .lnd-md__hero p.lead { font-size: 14px; opacity: 0.95; margin: 0 0 14px; max-width: 480px; line-height: 1.5; text-shadow: 0 1px 8px rgba(0,0,0,0.6); }
  .lnd-md__hero p.lead b { color: #fff; font-weight: 800; }
  .lnd-md__hero-rotator { background: rgba(13,39,62,0.78); border: 1px solid rgba(255,255,255,0.22); border-radius: 14px; padding: 10px 14px; margin: 0 0 14px; max-width: 440px; backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
  .lnd-md__hero-rotator-line { font-size: 16px; font-weight: 700; letter-spacing: -0.01em; display: flex; flex-wrap: wrap; align-items: baseline; gap: 6px; }
  .lnd-md__hero-rotator-line .static { opacity: 0.9; }
  .lnd-md__hero-rotator-line .dynamic { color: var(--md-red); font-weight: 800; font-size: 18px; transition: opacity 0.35s ease, transform 0.35s ease; display: inline-block; min-width: 110px; }
  .lnd-md__hero-rotator-line .dynamic.is-out { opacity: 0; transform: translateY(8px); }
  .lnd-md__hero-bullets { list-style: none; padding: 0; margin: 0 0 18px; display: flex; flex-direction: column; gap: 8px; max-width: 480px; }
  .lnd-md__hero-bullets li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; font-weight: 700; line-height: 1.35; text-shadow: 0 1px 8px rgba(0,0,0,0.5); }
  .lnd-md__hero-bullets li em { color: var(--md-red); font-style: normal; font-weight: 800; }
  .lnd-md__hero-bullets .check { flex-shrink: 0; width: 22px; height: 22px; background: var(--md-red); color: #fff; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 900; margin-top: 1px; }
  .lnd-md__hero-cta { display: inline-block; background: var(--md-red); color: #fff; text-decoration: none; padding: 14px 28px; border-radius: 999px; font-size: 13px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; }
  .lnd-md__hero-fineprint { font-size: 11px; opacity: 0.7; margin: 10px 0 0; max-width: 460px; line-height: 1.4; text-shadow: 0 1px 6px rgba(0,0,0,0.5); }

  /* Value strip */
  .lnd-md__values { background: #fff; border-top: 1px solid #eee; border-bottom: 1px solid #eee; padding: 18px 16px; }
  .lnd-md__values-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px 18px; }
  .lnd-md__value { display: flex; align-items: center; gap: 10px; font-size: 12px; font-weight: 600; color: var(--md-navy); line-height: 1.3; }
  .lnd-md__value svg { flex-shrink: 0; color: var(--md-red); }

  /* Absorption brand band */
  .lnd-md__brand { background: var(--md-bg); padding: 40px 20px; }
  .lnd-md__brand-inner { max-width: 980px; margin: 0 auto; }
  .lnd-md__brand-eyebrow { font-size: 11px; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; color: var(--md-red); margin: 0 0 10px; }
  .lnd-md__brand h2 { font-size: 26px; font-weight: 800; margin: 0 0 12px; letter-spacing: -0.01em; line-height: 1.15; }
  .lnd-md__brand h2 em { color: var(--md-blue); font-style: normal; }
  .lnd-md__brand p { font-size: 15px; color: #444; margin: 0 0 16px; line-height: 1.6; }
  .lnd-md__reasons { list-style: none; padding: 0; margin: 18px 0 0; display: flex; flex-direction: column; gap: 12px; }
  .lnd-md__reasons li { display: flex; align-items: flex-start; gap: 14px; background: #fff; border: 1px solid #ececec; border-radius: 12px; padding: 14px 16px; }
  .lnd-md__reasons .num { flex-shrink: 0; width: 28px; height: 28px; background: var(--md-blue); color: #fff; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 900; line-height: 1; }
  .lnd-md__reasons li > div { font-size: 14px; color: #333; line-height: 1.5; }
  .lnd-md__reasons b { color: var(--md-navy); font-weight: 800; }
  .lnd-md__brand-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin: 22px 0 0; }
  .lnd-md__brand-stat { background: #fff; border: 1px solid #ececec; border-radius: 14px; padding: 18px 14px; text-align: center; }
  .lnd-md__brand-stat b { display: block; font-size: 32px; font-weight: 900; color: var(--md-blue); line-height: 1; letter-spacing: -0.02em; margin: 0 0 4px; }
  .lnd-md__brand-stat span { font-size: 12px; color: #555; line-height: 1.35; display: block; }

  /* Testimonials — 3-card row */
  .lnd-md__testimonial { background: var(--md-navy); color: #fff; padding: 44px 20px; }
  .lnd-md__testimonial-inner { max-width: 1200px; margin: 0 auto; text-align: center; }
  .lnd-md__testimonial-eyebrow { font-size: 11px; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; color: var(--md-red); margin: 0 0 8px; }
  .lnd-md__testimonial-heading { font-size: 24px; font-weight: 800; margin: 0 0 22px; letter-spacing: -0.01em; }
  .lnd-md__testimonial-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }
  .lnd-md__testimonial-card { background: var(--md-navy-2); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 22px 20px; text-align: left; }
  .lnd-md__testimonial-stars { color: #f5b800; font-size: 16px; letter-spacing: 2px; margin: 0 0 10px; line-height: 1; }
  .lnd-md__testimonial-quote { font-size: 16px; font-weight: 600; line-height: 1.45; margin: 0 0 14px; letter-spacing: -0.005em; }
  .lnd-md__testimonial-author { font-size: 12px; opacity: 0.7; margin: 0; }

  /* Bestseller tile grid */
  .lnd-md__spots { padding: 40px 16px; background: #fff; }
  .lnd-md__spots-head { max-width: 1200px; margin: 0 auto 22px; text-align: center; }
  .lnd-md__spots-eyebrow { font-size: 11px; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; color: var(--md-red); margin: 0 0 8px; }
  .lnd-md__spots-head h2 { font-size: 26px; font-weight: 800; margin: 0 0 8px; letter-spacing: -0.01em; }
  .lnd-md__spots-pipe { color: var(--md-red); font-weight: 700; margin: 0 6px; opacity: 0.85; }
  .lnd-md__spots-head p { font-size: 14px; color: #555; margin: 0; }
  .lnd-md__spots-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .lnd-md__spot-tile { position: relative; display: flex; flex-direction: column; background: #fff; border: 1px solid #ececec; border-radius: 16px; padding: 12px 12px 14px; text-decoration: none; color: inherit; transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease; overflow: hidden; }
  .lnd-md__spot-tile::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--md-red); border-radius: 16px 16px 0 0; }
  .lnd-md__spot-tile:hover { transform: translateY(-3px); box-shadow: 0 12px 28px rgba(13,39,62,0.1); border-color: var(--md-navy); }
  .lnd-md__spot-ribbon { position: absolute; top: 10px; right: 10px; background: var(--md-navy); color: #fff; font-size: 9px; font-weight: 800; letter-spacing: 0.1em; padding: 5px 9px; border-radius: 999px; text-transform: uppercase; z-index: 2; }
  .lnd-md__spot-tile-img { aspect-ratio: 1/1; background: var(--md-cream); border-radius: 12px; overflow: hidden; display: flex; align-items: center; justify-content: center; margin: 8px 0 12px; }
  .lnd-md__spot-tile-img img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .lnd-md__spot-tile-title { font-size: 16px; font-weight: 800; line-height: 1.2; margin: 0 0 4px; color: var(--md-navy); letter-spacing: -0.01em; }
  .lnd-md__spot-tile-sub { font-size: 12px; color: #6b6b6b; line-height: 1.35; margin: 0 0 10px; min-height: 32px; }
  .lnd-md__spot-tile-bullets { list-style: none; padding: 0; margin: 0 0 10px; display: flex; flex-direction: column; gap: 4px; }
  .lnd-md__spot-tile-bullets li { font-size: 12px; color: #333; line-height: 1.35; padding-left: 16px; position: relative; }
  .lnd-md__spot-tile-bullets li::before { content: ""; position: absolute; left: 0; top: 6px; width: 8px; height: 8px; border-radius: 50%; background: var(--md-red); }
  .lnd-md__spot-tile-stars { display: flex; align-items: center; gap: 6px; margin: 0 0 10px; }
  .lnd-md__spot-tile-stars-glyphs { color: var(--md-navy); font-size: 13px; letter-spacing: 1px; line-height: 1; }
  .lnd-md__spot-tile-stars-meta { font-size: 11px; color: var(--md-navy); font-weight: 600; }
  .lnd-md__spot-tile-price { display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap; margin-top: auto; }
  .lnd-md__spot-tile-price .now { font-size: 17px; font-weight: 800; color: var(--md-navy); font-variant-numeric: tabular-nums; }
  .lnd-md__spot-tile-price .was { font-size: 13px; color: #9a9a9a; text-decoration: line-through; font-variant-numeric: tabular-nums; }
  .lnd-md__spot-tile-price .off { font-size: 12px; font-weight: 800; color: var(--md-red); }

  /* Bubble filter row */
  .lnd-md__bubbles-wrap { background: #fff; padding: 26px 0 6px; }
  .lnd-md__bubbles-inner { max-width: 1200px; margin: 0 auto; padding: 0 16px; }
  .lnd-md__bubbles-head { font-size: 13px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: var(--md-navy); margin: 0 0 12px; opacity: 0.7; }
  .lnd-md__bubbles { display: flex; gap: 8px; flex-wrap: nowrap; overflow-x: auto; padding: 4px 0 12px; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
  .lnd-md__bubbles::-webkit-scrollbar { display: none; }
  .lnd-md__bubble { flex: 0 0 auto; background: var(--md-cream); color: var(--md-navy); border: 2px solid transparent; padding: 12px 18px; border-radius: 999px; font-size: 13px; font-weight: 700; letter-spacing: -0.005em; cursor: pointer; font: inherit; min-height: 44px; line-height: 1; display: inline-flex; align-items: center; gap: 6px; transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease; white-space: nowrap; }
  .lnd-md__bubble[data-goal="all"] { font-weight: 800; }
  .lnd-md__bubble:hover { border-color: var(--md-navy); }
  .lnd-md__bubble.is-active { background: var(--md-navy); color: #fff; border-color: var(--md-navy); }
  .lnd-md__bubble-count { font-size: 11px; font-weight: 600; opacity: 0.6; }
  .lnd-md__bubble.is-active .lnd-md__bubble-count { opacity: 0.7; color: #fff; }

  /* Grid */
  .lnd-md__grid-wrap { background: var(--md-bg); padding: 20px 16px 40px; }
  .lnd-md__grid-head { max-width: 1200px; margin: 0 auto 18px; display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 8px; }
  .lnd-md__grid-head h2 { font-size: 22px; font-weight: 800; margin: 0; letter-spacing: -0.01em; }
  .lnd-md__grid-count { font-size: 13px; color: #666; }
  .lnd-md__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; max-width: 1200px; margin: 0 auto; }

  /* Tile */
  .lnd-md__tile { background: var(--md-cream); border-radius: 14px; padding: 14px 14px 0; position: relative; display: flex; flex-direction: column; cursor: pointer; text-align: left; font: inherit; color: inherit; border: none; transition: transform 0.15s ease, box-shadow 0.15s ease; text-decoration: none; }
  .lnd-md__tile:hover { transform: translateY(-3px); box-shadow: 0 10px 24px rgba(13,39,62,0.08); }
  .lnd-md__tile-tags { position: absolute; top: 14px; left: 14px; right: 14px; display: flex; flex-wrap: wrap; gap: 6px; align-items: center; z-index: 2; }
  .lnd-md__tile-pill { background: #fff; color: var(--md-navy); font-size: 9px; font-weight: 800; letter-spacing: 0.08em; padding: 6px 11px; border-radius: 999px; text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
  .lnd-md__tile-badge { background: var(--md-red); color: #fff; font-size: 9px; font-weight: 800; letter-spacing: 0.08em; padding: 6px 11px; border-radius: 999px; text-transform: uppercase; white-space: nowrap; }
  .lnd-md__tile-lowstock, .lnd-md__spot-lowstock { background: #b91d1d; color: #fff; font-size: 9px; font-weight: 800; letter-spacing: 0.08em; padding: 6px 11px; border-radius: 999px; text-transform: uppercase; white-space: nowrap; box-shadow: 0 4px 12px rgba(185,29,29,0.32); display: inline-flex; align-items: center; gap: 6px; }
  .lnd-md__tile-lowstock::before, .lnd-md__spot-lowstock::before { content: ""; width: 6px; height: 6px; border-radius: 999px; background: #fff; box-shadow: 0 0 0 3px rgba(255,255,255,0.32); }
  .lnd-md__spot-lowstock { position: absolute; top: 10px; left: 10px; z-index: 3; }
  .lnd-md__tile-img { aspect-ratio: 1/1; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .lnd-md__tile-img img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .lnd-md__tile-info { padding: 12px 4px 14px; }
  .lnd-md__tile-title { font-size: 17px; font-weight: 700; line-height: 1.2; margin: 0 0 4px; color: var(--md-navy); }
  .lnd-md__tile-sub { font-size: 13px; color: #6b6b6b; line-height: 1.3; margin: 0 0 8px; min-height: 34px; }
  .lnd-md__tile-stars { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
  .lnd-md__tile-stars-glyphs { color: var(--md-navy); font-size: 13px; letter-spacing: 1px; line-height: 1; }
  .lnd-md__tile-stars-meta { font-size: 12px; color: var(--md-navy); font-weight: 600; }
  .lnd-md__tile-price { display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap; }
  .lnd-md__tile-price .now { font-size: 16px; font-weight: 800; color: var(--md-navy); font-variant-numeric: tabular-nums; }
  .lnd-md__tile-price .was { font-size: 13px; color: #9a9a9a; text-decoration: line-through; font-variant-numeric: tabular-nums; }
  .lnd-md__tile-price .off { font-size: 13px; font-weight: 700; color: var(--md-red); }
  .lnd-md__tile-price .off::before { content: "·"; margin-right: 4px; color: #9a9a9a; }

  /* Countdown (used in final CTA) */
  .lnd-md__countdown { display: flex; gap: 8px; margin: 0 0 18px; font-variant-numeric: tabular-nums; }

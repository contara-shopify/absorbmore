{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign section_type = "featured_benefits_slider"
  assign image_mobile_style = section.settings.image_mobile_style
  assign scroll_pagination_class = section.settings.scroll_pagination_class
  assign content_mobile_style = section.settings.content_mobile_style
  assign icon = section.settings.icon
  assign container_spacing = section.settings.container_spacing
  assign text_color = section.settings.text_color
  assign background_color = section.settings.background_color
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  if image_mobile_style == 'fullscreen'
    assign content_wrapper_classes = 'max-md:-mx-[--gutter]'
  endif
  if content_mobile_style == 'slider'
    assign content_mobile_style_class = 'max-lg:hidden'
  endif
%}

{% capture section_content %}

  {% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
  {% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
    {% capture css %}
      & {
      {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
      {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
      }
    {% endcapture %}
  {% endif %}

  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  </style>

  <section data-style-id="{{ section.id }}--{{ block.id }}"
           {% if section_id != blank %}id="{{ section_id }}"{% endif %}
           class="relative {{ container_spacing }}">
    <div class="grid items-center gap-6 lg:grid-cols-2 md:gap-12 xl:gap-24"
         x-defer="intersect"
         x-data="{ ...utils.initContentSlider($el, $refs.scrollContainer) }" x-defer="intersect">
      <section class="flex flex-col justify-center {{ content_wrapper_classes }}">
        <main class="grid snap-mandatory auto-cols-[100%] grid-flow-col gap-4 overflow-x-auto overflow-y-hidden scrollbar-none"
              x-ref="scrollContainer"
              @resize.window="content_slider.handleResize"
              x-init="$nextTick(() => content_slider.handleResize())"
              @scroll="content_slider.handleScroll"
              @scrollend="content_slider.handleInfiniteScroll">
          {% assign index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'feature' %}
              {% render 'featured_benefits_slider.feature', block: block, forloop: forloop, index: index %}
              {% assign index = index | plus: 1 %}
            {% endif %}
          {% endfor %}
        </main>
        {% if scroll_pagination_class != blank %}
          {% render '_components.scroll_pagination', class: scroll_pagination_class %}
        {% endif %}
      </section>
      <section class="flex h-full flex-col justify-center gap-6 lg:gap-9 {{ content_mobile_style_class }}">
        {% assign index = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'feature' %}
            <button :class="content_slider?.state?.current_index !== +`{{ index }}` ? 'lg:opacity-40' : 'active'"
                    type="button"
                    class="text-left transition-all duration-75 flex items-baseline"
                    :tabindex="window.innerWidth > 768 ? '0' : '-1'"
                    @click="content_slider?.scrollToIndex(+`{{ index }}`)">
              {% if icon != blank %}
                {% render '_components.icon', icon: icon, class: "max-md:hidden" %}
              {% endif %}
              {% render '_input.richtext', content: block.settings.content, class: block.settings.content_class, block: block, forloop: forloop %}
            </button>
            {% assign index = index | plus: 1 %}
          {% endif %}
        {% endfor %}
      </section>
    </div>
  </section>
{% endcapture %}

{% if section_content contains '/break"></script>' %}
  {% break %}
{% endif %}
{{ section_content }}


    <p>{{ section.settings.delivery_text }}</p>

    <div class="wlp1-benefit-list wlp1-fi">
      {%- for i in (1..3) -%}
        {%- assign di_key = 'delivery_bullet_' | append: i | append: '_icon' -%}
        {%- assign dt_key = 'delivery_bullet_' | append: i -%}
        {%- if section.settings[dt_key] != blank -%}
          <div class="wlp1-bl-item">
            <span class="wlp1-bl-icon">{{ section.settings[di_key] }}</span>
            {{ section.settings[dt_key] }}
          </div>
        {%- endif -%}
      {%- endfor -%}

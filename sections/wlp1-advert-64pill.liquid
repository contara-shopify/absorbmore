    <div class="wlp1-callout wlp1-fi">
      <p>
        <strong>{{ section.settings.callout_heading }}</strong>
      </p>
      <div class="wlp1-benefit-list" style="margin-top: 12px; margin-bottom: 0;">
        {%- for i in (1..3) -%}
          {%- assign cb_icon = 'callout_bullet_' | append: i | append: '_icon' -%}
          {%- assign cb_text = 'callout_bullet_' | append: i -%}
          {%- if section.settings[cb_text] != blank -%}
            <div class="wlp1-bl-item">
              <span class="wlp1-bl-icon">{{ section.settings[cb_icon] }}</span>
              {{ section.settings[cb_text] }}
            </div>
          {%- endif -%}

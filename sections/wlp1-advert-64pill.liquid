    <p>{{ section.settings.what_text }}</p>

    <div class="wlp1-benefit-list wlp1-fi">
      {%- for i in (1..6) -%}
        {%- assign icon_key = 'benefit_' | append: i | append: '_icon' -%}
        {%- assign text_key = 'benefit_' | append: i | append: '_text' -%}
        {%- if section.settings[text_key] != blank -%}

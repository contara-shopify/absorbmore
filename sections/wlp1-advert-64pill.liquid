    <h2 class="wlp1-sec-head">{{ section.settings.review_heading }}</h2>

    {%- for i in (1..3) -%}
      {%- assign rt_key = 'review_' | append: i | append: '_text' -%}
      {%- assign rn_key = 'review_' | append: i | append: '_name' -%}
      {%- assign rd_key = 'review_' | append: i | append: '_detail' -%}
      {%- if section.settings[rt_key] != blank -%}
        <div class="wlp1-review wlp1-fi">
          <div class="wlp1-stars">★★★★★</div>
          <blockquote>"{{ section.settings[rt_key] }}"</blockquote>
          <div class="wlp1-attribution">
            {{ section.settings[rn_key] }}
            <span>· {{ section.settings[rd_key] }}</span>
          </div>
          <div class="wlp1-verified">✓ Verified Buyer</div>

              <h4>{{ section.settings[tt_key] }}</h4>
              <p>{{ section.settings[tx_key] }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ─── HOW IT WORKS ─── {%- endcomment -%}
    <div class="wlp1-sec-kicker">{{ section.settings.steps_kicker }}</div>
    <h2 class="wlp1-sec-head">{{ section.settings.steps_heading }}</h2>

    {%- if section.settings.steps_image != blank -%}

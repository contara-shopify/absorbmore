          <div class="wlp1-chip-name">{{ section.settings[name_key] }}</div>
          <div class="wlp1-chip-benefit">{{ section.settings[ben_key] }}</div>
          <div class="wlp1-chip-stat">{{ section.settings[stat_key] }}</div>
        </div>
      {%- endfor -%}

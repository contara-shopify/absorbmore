        <span>📦 Free U.S. shipping</span>
        <span>✓ 3rd-party tested</span>
        <span>🇺🇸 Made in USA</span>
      </div>
    </div>

    {%- comment -%} ─── FAQ ─── {%- endcomment -%}
    <div class="wlp1-sec-kicker">{{ section.settings.faq_kicker }}</div>
    <h2 class="wlp1-sec-head">{{ section.settings.faq_heading }}</h2>

    {%- for i in (1..6) -%}
      {%- assign fq_key = 'faq_' | append: i | append: '_q' -%}
      {%- assign fa_key = 'faq_' | append: i | append: '_a' -%}

<div class="wlp1-section">
  <style type="text/css">
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --cream: #f7f3ed;
      --cream-dark: #ede8df;
      --ink: #1a1a18;
      --ink-light: #3a3a36;
      --ink-muted: #6b6b64;
      --accent: #5e91d5;
      --accent-dark: #4a78b8;
      --warm: #c4a46d;
      --warm-light: #d4bc8e;
      --red-subtle: #c45a3c;
      --green-subtle: #2d8c55;
      --serif: 'EB Garamond', Georgia, serif;
      --sans: 'Inter', -apple-system, sans-serif;
    }

    html {
      scroll-behavior: smooth;
    }
    body {
      font-family: var(--serif);
      background: var(--cream);
      color: var(--ink);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── STICKY BAR ─── */
    .sticky-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--ink);
      padding: 12px 20px;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 16px;
      z-index: 200;
      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.15);
    }
    .sticky-bar p {
      font-family: var(--sans);
      font-size: 14px;
      color: var(--cream);
      font-weight: 500;
    }
    .sticky-bar p span {
      color: var(--warm-light);
      font-weight: 700;
    }
    .sticky-bar .btn {
      font-family: var(--sans);
      font-size: 14px;
      font-weight: 700;
      background: var(--accent);
      color: #fff;
      padding: 12px 28px;
      border-radius: 6px;
      text-decoration: none;
      white-space: nowrap;
      transition: background 0.2s, transform 0.1s;
    }
    .sticky-bar .btn:hover {
      background: var(--accent-dark);
      transform: translateY(-1px);
    }

    /* ─── TOP BANNER ─── */
    .top-banner {
      background: var(--ink);
      color: var(--cream);
      text-align: center;
      padding: 10px 20px;
      font-family: var(--sans);
      font-size: 13px;
      font-weight: 500;
    }
    .top-banner span {
      color: var(--warm-light);
      font-weight: 700;
    }

    /* ─── HERO ─── */
    .hero {
      max-width: 780px;
      margin: 0 auto;
      padding: 48px 24px 0;
      text-align: center;
    }
    .hero .pub-line {
      font-family: var(--sans);
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 20px;
    }
    .hero h1 {
      font-family: var(--serif);
      font-size: clamp(28px, 5.5vw, 48px);
      font-weight: 600;
      line-height: 1.15;
      color: var(--ink);
      margin-bottom: 20px;
    }
    .hero h1 em {
      font-style: normal;
      color: var(--accent);
    }
    .hero .subhead {
      font-family: var(--sans);
      font-size: 16px;
      color: var(--ink-muted);
      line-height: 1.65;
      max-width: 620px;
      margin: 0 auto 28px;
    }
    .hero .hero-cta {
      display: inline-block;
      font-family: var(--sans);
      font-size: 16px;
      font-weight: 700;
      background: var(--accent);
      color: #fff;
      padding: 16px 40px;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
      margin-bottom: 12px;
    }
    .hero .hero-cta:hover {
      background: var(--accent-dark);
      transform: translateY(-1px);
    }
    .hero .hero-sub {
      font-family: var(--sans);
      font-size: 12px;
      color: var(--ink-muted);
    }

    /* ─── TRUST STRIP ─── */
    .trust-strip {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 24px;
      padding: 24px 20px 0;
      max-width: 680px;
      margin: 0 auto;
    }
    .trust-item {
      font-family: var(--sans);
      font-size: 12px;
      font-weight: 600;
      color: var(--ink-light);
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .trust-item .check {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      background: var(--green-subtle);
      color: #fff;
      border-radius: 50%;
      font-size: 11px;
      font-weight: 800;
    }

    /* ─── HERO IMAGE ─── */
    .hero-img {
      max-width: 740px;
      margin: 36px auto 0;
      padding: 0 24px;
    }
    .hero-img img {
      width: 100%;
      border-radius: 10px;
      display: block;
    }

    /* ─── CONTENT WRAPPER ─── */
    .content {
      max-width: 680px;
      margin: 0 auto;
      padding: 48px 24px 100px;
    }
    .content p {
      font-size: 18.5px;
      margin-bottom: 22px;
      color: var(--ink-light);
    }
    .content p strong {
      color: var(--ink);
      font-weight: 600;
    }

    /* ─── SECTION HEADERS ─── */
    .sec-kicker {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 52px 0 10px;
    }
    .sec-head {
      font-family: var(--serif);
      font-size: 28px;
      font-weight: 600;
      line-height: 1.3;
      margin-bottom: 20px;
      color: var(--ink);
    }

    /* ─── CALLOUT BOX ─── */
    .callout {
      background: #fff;
      border-left: 4px solid var(--accent);
      padding: 24px 28px;
      border-radius: 0 10px 10px 0;
      margin: 32px 0;
    }
    .callout p {
      font-family: var(--sans);
      font-size: 15px;
      color: var(--ink-light);
      margin-bottom: 0;
      line-height: 1.65;
    }
    .callout p strong {
      color: var(--ink);
    }

    /* ─── PROBLEM CARDS ─── */
    .problem-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 28px 0;
    }
    .p-card {
      background: #fff;
      border-radius: 10px;
      padding: 24px;
      border: 1px solid rgba(26, 26, 24, 0.08);
    }
    .p-card .p-icon {
      font-size: 28px;
      margin-bottom: 10px;
    }
    .p-card h4 {
      font-family: var(--sans);
      font-size: 14px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 8px;
    }
    .p-card p {
      font-family: var(--sans);
      font-size: 13.5px;
      color: var(--ink-muted);
      margin-bottom: 0;
      line-height: 1.55;
    }

    /* ─── STAT BLOCKS ─── */
    .stat-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 32px 0;
    }
    .stat-block {
      background: var(--ink);
      border-radius: 10px;
      padding: 24px;
      text-align: center;
    }
    .stat-block .num {
      font-family: var(--serif);
      font-size: 40px;
      font-weight: 600;
      color: var(--warm-light);
      line-height: 1;
      margin-bottom: 6px;
    }
    .stat-block .desc {
      font-family: var(--sans);
      font-size: 12px;
      color: rgba(247, 243, 237, 0.6);
      line-height: 1.5;
    }

    /* ─── REVIEW CARDS ─── */
    .review {
      background: #fff;
      border-radius: 10px;
      padding: 24px 28px;
      margin: 20px 0;
      border: 1px solid rgba(26, 26, 24, 0.06);
    }
    .review .stars {
      color: var(--warm);
      font-size: 16px;
      letter-spacing: 2px;
      margin-bottom: 10px;
    }
    .review blockquote {
      font-size: 17px;
      color: var(--ink-light);
      line-height: 1.6;
      margin-bottom: 12px;
      font-style: italic;
    }
    .review .attribution {
      font-family: var(--sans);
      font-size: 13px;
      color: var(--ink-muted);
      font-weight: 600;
    }
    .review .attribution span {
      font-weight: 400;
    }
    .review .verified {
      font-family: var(--sans);
      font-size: 11px;
      color: var(--green-subtle);
      font-weight: 600;
      margin-top: 4px;
    }

    /* ─── STEPS ─── */
    .steps {
      margin: 28px 0;
    }
    .step {
      display: flex;
      gap: 20px;
      margin-bottom: 24px;
      align-items: flex-start;
    }
    .step-num {
      flex-shrink: 0;
      width: 40px;
      height: 40px;
      background: var(--accent);
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--sans);
      font-weight: 800;
      font-size: 16px;
    }
    .step-text h4 {
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 4px;
    }
    .step-text p {
      font-family: var(--sans);
      font-size: 14px;
      color: var(--ink-muted);
      margin-bottom: 0;
      line-height: 1.55;
    }

    /* ─── INGREDIENT CHIPS ─── */
    .ingredient-strip {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
      margin: 28px 0;
    }
    .ing-chip {
      background: #fff;
      border-radius: 10px;
      padding: 20px 16px;
      text-align: center;
      border: 1px solid rgba(26, 26, 24, 0.08);
    }
    .ing-chip .chip-name {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: var(--accent);
      margin-bottom: 6px;
      text-transform: uppercase;
    }
    .ing-chip .chip-benefit {
      font-family: var(--serif);
      font-size: 16px;
      color: var(--ink);
      line-height: 1.35;
      margin-bottom: 8px;
    }
    .ing-chip .chip-stat {
      font-family: var(--sans);
      font-size: 12px;
      font-weight: 600;
      color: var(--green-subtle);
    }

    /* ─── TIMELINE ─── */
    .timeline {
      margin: 28px 0;
    }
    .tl-row {
      display: flex;
      gap: 20px;
      padding: 20px 0;
      border-bottom: 1px solid rgba(26, 26, 24, 0.08);
      align-items: baseline;
    }
    .tl-row:last-child {
      border-bottom: none;
    }
    .tl-when {
      flex-shrink: 0;
      width: 90px;
      font-family: var(--sans);
      font-size: 13px;
      font-weight: 700;
      color: var(--accent);
    }
    .tl-what h4 {
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 3px;
    }
    .tl-what p {
      font-family: var(--sans);
      font-size: 14px;
      color: var(--ink-muted);
      margin-bottom: 0;
      line-height: 1.5;
    }

    /* ─── INLINE CTA ─── */
    .cta-inline {
      background: var(--accent);
      border-radius: 12px;
      padding: 36px 32px;
      text-align: center;
      margin: 40px 0;
    }
    .cta-inline h3 {
      font-family: var(--serif);
      font-size: 24px;
      font-weight: 600;
      color: #fff;
      margin-bottom: 8px;
      line-height: 1.3;
    }
    .cta-inline p {
      font-family: var(--sans);
      font-size: 14px;
      color: rgba(255, 255, 255, 0.75);
      margin-bottom: 20px;
    }
    .cta-inline .btn-w {
      display: inline-block;
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 700;
      background: #fff;
      color: var(--accent);
      padding: 14px 36px;
      border-radius: 8px;
      text-decoration: none;
      transition: transform 0.15s, box-shadow 0.2s;
    }
    .cta-inline .btn-w:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    }
    .cta-inline .sub {
      font-family: var(--sans);
      font-size: 12px;
      color: rgba(255, 255, 255, 0.5);
      margin-top: 12px;
      margin-bottom: 0;
    }

    /* ─── FINAL CTA ─── */
    .final-cta {
      background: var(--ink);
      border-radius: 14px;
      padding: 48px 32px;
      text-align: center;
      margin: 48px 0 24px;
    }
    .final-cta .fc-kicker {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--warm-light);
      margin-bottom: 14px;
    }
    .final-cta h2 {
      font-family: var(--serif);
      font-size: clamp(24px, 4vw, 34px);
      font-weight: 600;
      color: var(--cream);
      margin-bottom: 12px;
      line-height: 1.25;
    }
    .final-cta .guarantee {
      font-family: var(--sans);
      font-size: 14px;
      color: rgba(247, 243, 237, 0.6);
      margin-bottom: 24px;
      line-height: 1.6;
    }
    .final-cta .btn-big {
      display: inline-block;
      font-family: var(--sans);
      font-size: 17px;
      font-weight: 700;
      background: var(--accent);
      color: #fff;
      padding: 17px 48px;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }
    .final-cta .btn-big:hover {
      background: var(--accent-dark);
      transform: translateY(-1px);
    }
    .final-cta .pricing {
      font-family: var(--sans);
      font-size: 13px;
      color: rgba(247, 243, 237, 0.45);
      margin-top: 14px;
    }
    .final-cta .fc-trust {
      display: flex;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
      margin-top: 20px;
    }
    .final-cta .fc-trust span {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 600;
      color: rgba(247, 243, 237, 0.4);
    }

    /* ─── FAQ ─── */
    .faq-item {
      border-bottom: 1px solid rgba(26, 26, 24, 0.08);
      padding: 20px 0;
    }
    .faq-q {
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 700;
      color: var(--ink);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      user-select: none;
    }
    .faq-q .toggle {
      font-size: 20px;
      color: var(--ink-muted);
      transition: transform 0.2s;
      flex-shrink: 0;
    }
    .faq-a {
      font-family: var(--sans);
      font-size: 14px;
      color: var(--ink-muted);
      line-height: 1.65;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease, padding 0.3s ease;
      padding-top: 0;
    }
    .faq-item.open .faq-a {
      max-height: 300px;
      padding-top: 12px;
    }
    .faq-item.open .toggle {
      transform: rotate(45deg);
    }

    /* ─── DISCLAIMER ─── */
    .disclaimer {
      font-family: var(--sans);
      font-size: 11px;
      color: var(--ink-muted);
      line-height: 1.7;
      opacity: 0.6;
      margin-top: 32px;
      padding-top: 20px;
      border-top: 1px solid rgba(26, 26, 24, 0.08);
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 640px) {
      .sticky-bar {
        flex-direction: column;
        gap: 8px;
        padding: 10px 16px;
      }
      .sticky-bar p {
        font-size: 12px;
        text-align: center;
      }
      .problem-grid {
        grid-template-columns: 1fr;
      }
      .stat-row {
        grid-template-columns: 1fr 1fr;
      }
      .ingredient-strip {
        grid-template-columns: 1fr;
      }
      .hero {
        padding-top: 32px;
      }
      .content {
        padding-bottom: 120px;
      }
      .tl-row {
        flex-direction: column;
        gap: 4px;
      }
      .tl-when {
        width: auto;
      }
      .trust-strip {
        gap: 12px;
      }
    }

    /* ─── SECTION IMAGES ─── */
    .sec-img {
      margin: 32px 0;
      border-radius: 10px;
      overflow: hidden;
    }
    .sec-img img {
      width: 100%;
      display: block;
      border-radius: 10px;
    }
    .sec-img-duo {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin: 32px 0;
    }
    .sec-img-duo img {
      width: 100%;
      border-radius: 10px;
      display: block;
      aspect-ratio: 1;
      object-fit: cover;
    }

    /* ─── BULLET LIST ─── */
    .benefit-list {
      margin: 20px 0 28px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .benefit-list .bl-item {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      font-family: var(--sans);
      font-size: 15px;
      color: var(--ink-light);
      line-height: 1.55;
    }
    .benefit-list .bl-icon {
      flex-shrink: 0;
      width: 24px;
      height: 24px;
      background: rgba(71, 89, 255, 0.1);
      color: var(--accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 700;
      margin-top: 1px;
    }

    /* ─── QUIZ CTA BLOCK ─── */
    .quiz-cta {
      background: var(--cream-dark);
      border: 2px solid rgba(71, 89, 255, 0.15);
      border-radius: 14px;
      padding: 36px 32px;
      text-align: center;
      margin: 44px 0;
    }
    .quiz-cta .quiz-emoji {
      font-size: 32px;
      margin-bottom: 12px;
    }
    .quiz-cta h3 {
      font-family: var(--serif);
      font-size: 24px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 8px;
      line-height: 1.3;
    }
    .quiz-cta p {
      font-family: var(--sans);
      font-size: 14px;
      color: var(--ink-muted);
      margin-bottom: 20px;
      line-height: 1.6;
    }
    .quiz-cta .btn-quiz {
      display: inline-block;
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 700;
      background: var(--accent);
      color: #fff;
      padding: 14px 36px;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }
    .quiz-cta .btn-quiz:hover {
      background: var(--accent-dark);
      transform: translateY(-1px);
    }
    .quiz-cta .quiz-sub {
      font-family: var(--sans);
      font-size: 12px;
      color: var(--ink-muted);
      margin-top: 12px;
      margin-bottom: 0;
    }

    /* ─── FADE ─── */
    .fi {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fi.vis {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  {%- comment -%} ═══ TOP BANNER ═══ {%- endcomment -%}
  <div class="wlp1-top-banner">
    {{ section.settings.top_banner_text }}
  </div>

  {%- comment -%} ═══ HERO ═══ {%- endcomment -%}
  <section class="wlp1-hero">
    <div class="wlp1-hero__inner">
      <div class="wlp1-pub-line">{{ section.settings.pub_line }}</div>
      <h1 class="wlp1-hero__title">{{ section.settings.headline }}</h1>
      <p class="wlp1-hero__subhead">{{ section.settings.subhead }}</p>
      <a href="{{ section.settings.hero_cta_url }}" class="wlp1-btn wlp1-btn--hero">
        {{- section.settings.hero_cta_text -}}
      </a>
      <p class="wlp1-hero__sub">{{ section.settings.hero_sub_text }}</p>
    </div>
  </section>

  {%- comment -%} ═══ TRUST STRIP ═══ {%- endcomment -%}
  <div class="wlp1-trust-strip">
    {%- for i in (1..5) -%}
      {%- assign trust_key = 'trust_' | append: i -%}
      {%- if section.settings[trust_key] != blank -%}
        <div class="wlp1-trust-item"><span class="wlp1-check">✓</span> {{ section.settings[trust_key] }}</div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} ═══ HERO IMAGE ═══ {%- endcomment -%}
  {%- if section.settings.hero_image != blank -%}
    <figure class="wlp1-hero-img">
      {{
        section.settings.hero_image
        | image_url: width: 1480
        | image_tag: loading: 'eager', alt: 'WLP-1 by The Absorption Company'
      }}
    </figure>
  {%- endif -%}

  {%- comment -%} ═══ CONTENT ═══ {%- endcomment -%}
  <div class="wlp1-content">
    {%- comment -%} ─── PROBLEM ─── {%- endcomment -%}
    <p>{{ section.settings.problem_intro_1 }}</p>
    <p>
      <strong>{{ section.settings.problem_bold }}</strong>
    </p>
    <p>{{ section.settings.problem_intro_2 }}</p>

    <div class="wlp1-problem-grid wlp1-fi">
      <div class="wlp1-p-card">
        <div class="wlp1-p-icon">{{ section.settings.problem_card_1_icon }}</div>
        <h4>{{ section.settings.problem_card_1_title }}</h4>
        <p>{{ section.settings.problem_card_1_text }}</p>
      </div>

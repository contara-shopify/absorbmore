          "name": "button-primary-outline",
          "settings": {
            "class": "button-primary-outline",
            "text_color": "#272727",
            "background_color": "#ffffff",
            "custom_css": "& {\n  display: inline-flex;\n  border: 2px solid #000000;\n  font-size: 15px;\n  font-weight: 500;\n  line-height: 1;\n  letter-spacing: 0.02em;\n  text-align: center;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  padding: 10px 24px;\n  min-height: 36px; \n  border-radius: 4px;\n  gap: 6px;\n}\n\n@media (max-width: 768px) {\n  & {\n      border-width: 1px;\n    font-size: 14px;\n      padding: 10px 16px;\n  }\n}\n\n&:where(:hover,:focus-visible) {\n  background: #272824;\n  color: #ffffff;\n  border-color: #272824;\n}\n&.active {\n  background:  #272824;\n  color: #ffffff;\n  border-color: #272824;\n}",
            "override_preview_background": ""
          }
        },
        {
          "type": "button",
          "name": "button-primary-sm",
          "settings": {
            "class": "button-primary-sm",
            "text_color": "#ffffff",
            "background_color": "#272824",
            "custom_css": "& {\n  border: 2px solid #373834;\n  font-size: 14px;\n  font-weight: 500;\n  line-height: 1;\n  letter-spacing: 0.02em;\n  text-align: center;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  padding: 4px 16px;\n  min-height: 28px; \n  border-radius: 4px;\n}\n\n@media (max-width: 768px) {\n  & {\n    /*Colors*/\n    border-width: 1px;\n    \n    /*Typography*/\n    font-size: 14px;\n    \n    /*Spacing*/\n    padding: 10px 16px;\n  }\n}\n\n&:where(:hover,:focus-visible) {\n  background: #474844;\n}\n&.active {\n  background:  #474844\n}",
            "override_preview_background": ""
          }
        },
        {
          "type": "button",
          "name": "button-primary-outline-sm",
          "settings": {
            "class": "button-primary-outline-sm",
            "text_color": "#272727",
            "background_color": "#ffffff",
            "custom_css": "& {\n  display: inline-flex;\n  border: 2px solid #000000;\n  font-size: 14px;\n  font-weight: 500;\n  line-height: 1;\n  letter-spacing: 0.02em;\n  text-align: center;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  padding: 4px 16px;\n  min-height: 28px; \n  border-radius: 4px;\n}\n\n@media (max-width: 768px) {\n  & {\n      border-width: 1px;\n    font-size: 14px;\n      padding: 10px 16px;\n  }\n}\n\n&:where(:hover,:focus-visible) {\n  background: #272824;\n  color: #ffffff;\n  border-color: #272824;\n}\n&.active {\n  background:  #272824;\n  color: #ffffff;\n  border-color: #272824;\n}",

{%- comment -%} Variables start {%- endcomment -%}
{%- liquid
  assign section_type = 'ctr-product_split_card'
  assign card_radius = section.settings.card_radius
  assign container_spacing = section.settings.container_spacing
  assign padding_top_desktop = section.settings.padding_top_desktop
  assign padding_bottom_desktop = section.settings.padding_bottom_desktop
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign mobile_image_position = section.settings.mobile_image_position | default: 'bottom'

  assign heading = section.settings.heading
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign description = section.settings.description
  assign description_namespace_key = section.settings.description_namespace_key
  assign heading_namespace_key = section.settings.heading_namespace_key

  assign bg_color_left = section.settings.bg_color_left
  assign bg_color_right = section.settings.bg_color_right
  assign text_color_left = section.settings.text_color_left
  assign text_color_right = section.settings.text_color_right

  assign show_divider = section.settings.show_divider
  assign divider_color = section.settings.divider_color

  assign bullet_icon = section.settings.bullet_icon
  assign bullet_icon_color = section.settings.bullet_icon_color
  assign bullets_columns = section.settings.bullets_columns | default: 2

  assign bullets_namespace_key = section.settings.bullets_namespace_key

  assign image = section.settings.image
  assign image_alt = section.settings.image_alt
  assign image_max_width = section.settings.image_max_width | default: 800
  assign image_placeholder_text = section.settings.image_placeholder_text

  assign show_badge = section.settings.show_badge
  assign badge_text = section.settings.badge_text
  assign badge_bg_color = section.settings.badge_bg_color
  assign badge_text_color = section.settings.badge_text_color
  assign badge_position = section.settings.badge_position | default: 'top-right'

  assign product_override = section.settings.product
  assign collection_override = section.settings.collection
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id

  if product_override != blank
    assign current_product = product_override
  elsif closest.product != blank
    assign current_product = closest.product
  else
    assign current_product = product
  endif

  if collection_override != blank
    assign current_collection = collection_override
  elsif closest.collection != blank
    assign current_collection = closest.collection
  else
    assign current_collection = collection
  endif

  assign bullets = ''
  if bullets_namespace_key != blank
    assign mf_parts = bullets_namespace_key | split: '.'
    assign mf_namespace = mf_parts[0]
    assign mf_key = mf_parts[1]
    if mf_namespace != blank and mf_key != blank
      assign mf = null
      if current_product != blank
        assign candidate = current_product.metafields[mf_namespace][mf_key]
        if candidate and candidate.value
          assign mf = candidate
        endif
      endif
      if mf == null and current_collection != blank
        assign candidate = current_collection.metafields[mf_namespace][mf_key]
        if candidate and candidate.value
          assign mf = candidate
        endif
      endif

      if mf and mf.value
        if mf.type contains 'list.'
          assign bullets = mf.value
        else
          assign bullets_str = mf.value | strip
          if bullets_str != ''
            assign bullets = bullets_str | split: '|~|SPLIT|~|'
            if bullets.size == 1 and bullets_str contains ','
              assign bullets = bullets_str | split: ','
            endif
          endif
        endif
      endif
    endif
  endif

  if bullets == '' or bullets.size == 0
    assign manual = ''
    for i in (1..8)
      assign key_name = 'bullet_' | append: i
      assign val = section.settings[key_name]
      if val != blank
        if manual == ''
          assign manual = val
        else
          assign manual = manual | append: '|~|SPLIT|~|' | append: val
        endif
      endif
    endfor
    if manual != ''
      assign bullets = manual | split: '|~|SPLIT|~|'
    else
      assign bullets = ''
    endif
  endif

  if heading_namespace_key != blank
    assign h_parts = heading_namespace_key | split: '.'
    assign h_ns = h_parts[0]
    assign h_key = h_parts[1]
    if h_ns != blank and h_key != blank
      assign h_mf = null
      if current_product != blank
        assign cand = current_product.metafields[h_ns][h_key]
        if cand and cand.value != blank
          assign h_mf = cand
        endif
      endif
      if h_mf == null and current_collection != blank
        assign cand = current_collection.metafields[h_ns][h_key]
        if cand and cand.value != blank
          assign h_mf = cand
        endif
      endif
      if h_mf and h_mf.value != blank
        assign heading = h_mf.value
      endif
    endif
  endif

  if description_namespace_key != blank
    assign d_parts = description_namespace_key | split: '.'
    assign d_ns = d_parts[0]
    assign d_key = d_parts[1]
    if d_ns != blank and d_key != blank
      assign d_mf = null
      if current_product != blank
        assign cand = current_product.metafields[d_ns][d_key]
        if cand and cand.value != blank
          assign d_mf = cand
        endif
      endif
      if d_mf == null and current_collection != blank
        assign cand = current_collection.metafields[d_ns][d_key]
        if cand and cand.value != blank
          assign d_mf = cand
        endif
      endif
      if d_mf and d_mf.value != blank
        if d_mf.type == 'rich_text_field'
          assign description = d_mf | metafield_tag
        else
          assign description = d_mf.value
        endif
      endif
    endif
  endif
-%}
{%- comment -%} Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}"]{% endcapture %}
{% capture css %}
  & {
    --psc-radius: {{ card_radius }}px;
    --psc-bg-left: {{ bg_color_left | default: '#efece4' }};
    --psc-bg-right: {{ bg_color_right | default: '#1c1c1c' }};
    --psc-text-left: {{ text_color_left | default: '#111111' }};
    --psc-text-right: {{ text_color_right | default: '#cfcfcf' }};
    --psc-divider: {{ divider_color | default: 'rgba(17,17,17,0.12)' }};
    --psc-bullet-color: {{ bullet_icon_color | default: '#5a6dff' }};
    --psc-badge-bg: {{ badge_bg_color | default: '#c2566a' }};
    --psc-badge-text: {{ badge_text_color | default: '#ffffff' }};
  }
{% endcapture %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

<section
  class="ctr-psc {{ container_spacing }}"
  data-style-id="{{ section.id }}"
  {% if section_id != blank %}
    id="{{ section_id }}"
  {% endif %}
>
  <div class="ctr-psc__card" data-mobile-image="{{ mobile_image_position }}">
    <div class="ctr-psc__col ctr-psc__col--left">
      <div class="ctr-psc__col-inner">
        {% if heading != blank %}
          <{{ heading_tag }} class="ctr-psc__heading">{{ heading | escape }}</{{ heading_tag }}>
        {% endif %}

        {% if description != blank %}
          <div class="ctr-psc__description">{{ description }}</div>
        {% endif %}

        {% if show_divider %}
          <hr class="ctr-psc__divider" aria-hidden="true">
        {% endif %}

        {% if bullets != '' and bullets.size > 0 %}
          <ul class="ctr-psc__bullets" style="--psc-bullets-cols: {{ bullets_columns }};">
            {% for bullet in bullets %}
              {%- assign bullet_text = bullet | strip -%}
              {% if bullet_text != blank %}
                <li class="ctr-psc__bullet">
                  <span class="ctr-psc__bullet-icon" aria-hidden="true">
                    {% if bullet_icon != blank %}
                      {{ bullet_icon | image_url: width: 48 | image_tag: alt: '', loading: 'lazy', widths: '24,48,72' }}
                    {% else %}
                      <svg viewBox="0 0 16 20" fill="currentColor" width="14" height="18">
                        <path d="M8 0s7 7.5 7 12a7 7 0 1 1-14 0C1 7.5 8 0 8 0z"/>
                      </svg>
                    {% endif %}
                  </span>
                  <span class="ctr-psc__bullet-text">{{ bullet_text }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>

    <div class="ctr-psc__col ctr-psc__col--right">
      {% if show_badge and badge_text != blank %}
        <div class="ctr-psc__badge ctr-psc__badge--{{ badge_position }}">
          <span>{{ badge_text }}</span>
        </div>
      {% endif %}

      <div class="ctr-psc__media">
        {% if image != blank %}
          {{
            image
            | image_url: width: image_max_width
            | image_tag:
              loading: 'lazy',
              widths: '320,480,720,960,1200',
              sizes: '(max-width: 768px) 100vw, 50vw',
              alt: image_alt
          }}
        {% else %}
          <span class="ctr-psc__media-placeholder">
            {{- image_placeholder_text | default: 'PRODUCT LIFESTYLE IMAGE' | escape -}}
          </span>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="ctr-psc__extra">
    {% content_for 'blocks' %}
  </div>
</section>

<style>
  [data-style-id="{{ section.id }}"].ctr-psc {
    width: 100%;
    padding-top: {{ padding_top_mobile }}px;
    padding-bottom: {{ padding_bottom_mobile }}px;
  }

  @media (min-width: 768px) {
    [data-style-id="{{ section.id }}"].ctr-psc {
      padding-top: {{ padding_top_desktop }}px;
      padding-bottom: {{ padding_bottom_desktop }}px;
    }
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__card {
    display: grid;
    grid-template-columns: 1fr;
    border-radius: var(--psc-radius);
    overflow: hidden;
  }

  @media (max-width: 767px) {
    [data-style-id="{{ section.id }}"] .ctr-psc__card[data-mobile-image="top"] .ctr-psc__col--right {
      order: 0;
    }
    [data-style-id="{{ section.id }}"] .ctr-psc__card[data-mobile-image="top"] .ctr-psc__col--left {
      order: 1;
    }
  }

  @media (min-width: 768px) {
    [data-style-id="{{ section.id }}"] .ctr-psc__card {
      grid-template-columns: 1fr 1fr;
    }
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__col {
    position: relative;
    min-width: 0;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__col--left {
    background: var(--psc-bg-left);
    color: var(--psc-text-left);
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__col--right {
    background: var(--psc-bg-right);
    color: var(--psc-text-right);
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__col-inner {
    padding: 32px 28px;
  }

  @media (min-width: 768px) {
    [data-style-id="{{ section.id }}"] .ctr-psc__col-inner {
      padding: 56px 56px;
    }
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__heading {
    margin: 0 0 18px;
    line-height: 1.02;
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  [data-style-id="{{ section.id }}"] h1.ctr-psc__heading {
    font-size: clamp(36px, 5.4vw, 72px);
  }
  [data-style-id="{{ section.id }}"] h2.ctr-psc__heading {
    font-size: clamp(28px, 4vw, 56px);
  }
  [data-style-id="{{ section.id }}"] h3.ctr-psc__heading {
    font-size: clamp(22px, 3vw, 40px);
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__description {
    font-size: clamp(15px, 1.6vw, 18px);
    line-height: 1.5;
    margin: 0 0 24px;
    max-width: 36ch;
  }
  [data-style-id="{{ section.id }}"] .ctr-psc__description p { margin: 0 0 0.6em; }
  [data-style-id="{{ section.id }}"] .ctr-psc__description p:last-child { margin-bottom: 0; }

  [data-style-id="{{ section.id }}"] .ctr-psc__divider {
    height: 1px;
    width: 100%;
    border: 0;
    background: var(--psc-divider);
    margin: 24px 0;
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 2fr));
    gap: 14px 28px;
  }

  @media (min-width: 640px) {
    [data-style-id="{{ section.id }}"] .ctr-psc__bullets {
      grid-template-columns: repeat(var(--psc-bullets-cols, 2), minmax(0, 1fr));
    }
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__bullet {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    line-height: 1.35;
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__bullet-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 22px;
    color: var(--psc-bullet-color);
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__bullet-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__media {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__media-placeholder {
    font-size: 14px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: currentColor;
    opacity: 0.6;
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__badge {
    position: absolute;
    z-index: 2;
    width: 96px;
    height: 96px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--psc-badge-bg);
    color: var(--psc-badge-text);
    font-size: 13px;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 8px;
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__badge--top-right {
    top: 24px;
    right: 24px;
  }
  [data-style-id="{{ section.id }}"] .ctr-psc__badge--top-left {
    top: 24px;
    left: 24px;
  }
  [data-style-id="{{ section.id }}"] .ctr-psc__badge--top-center {
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
  }

  [data-style-id="{{ section.id }}"] .ctr-psc__extra:empty {
    display: none;
  }
</style>

{% schema %}
{
  "name": "Product Split Card",
  "tag": "section",
  "class": "shopify_section__ctr_product_split_card",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "container_spacing",
      "label": "Container spacing",
      "default": "px-container-md",
      "options": [
        { "value": "px-container-xs", "label": "Extra Small" },
        { "value": "px-container-sm", "label": "Small" },
        { "value": "px-container-md", "label": "Medium" },
        { "value": "px-container-lg", "label": "Large" },
        { "value": "px-container-gutter", "label": "Gutter Only" },
        { "value": "px-container-fullwidth", "label": "Fullwidth" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Left Column"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Weight Management"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" }
      ]
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Clinically backed support that works with your body's natural weight management pathways. Start with one. Build the full stack.</p>"
    },
    {
      "type": "text",
      "id": "heading_namespace_key",
      "label": "Heading metafield (namespace.key)",
      "info": "Optional. Pulls heading text from a product or collection metafield. Overrides the manual heading above when set.",
      "default": "<h1><strong>{{ closest.collection.title }}</strong></h1>"
    },
    {
      "type": "text",
      "id": "description_namespace_key",
      "label": "Description metafield (namespace.key)",
      "info": "Optional. Pulls description from a product or collection metafield (single_line_text, multi_line_text, or rich_text_field). Overrides the manual description above when set.",
      "default": "smart.description"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider",
      "default": true
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "bg_color_left",
      "label": "Background color",
      "default": "#efece4"
    },
    {
      "type": "color",
      "id": "text_color_left",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Bullets"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Source product",
      "info": "Optional. Defaults to the current product when this section is on a product page."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Source collection",
      "info": "Optional. Used when no product is found. Defaults to the current collection on collection pages."
    },
    {
      "type": "text",
      "id": "bullets_namespace_key",
      "label": "Metafield (namespace.key)",
      "info": "List of single-line text on the product or collection. e.g. \"custom.benefits\". Product metafield wins if both exist. Leave blank to use the manual bullets below."
    },
    {
      "type": "image_picker",
      "id": "bullet_icon",
      "label": "Bullet icon",
      "info": "Optional. Falls back to a built-in droplet."
    },
    {
      "type": "color",
      "id": "bullet_icon_color",
      "label": "Bullet icon color",
      "default": "#5a6dff"
    },
    {
      "type": "range",
      "id": "bullets_columns",
      "label": "Bullets columns (desktop)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "paragraph",
      "content": "Manual bullets — used only when no metafield is linked or it is empty."
    },
    {
      "type": "text",
      "id": "bullet_1",
      "label": "Bullet 1",
      "default": "Curbs cravings"
    },
    {
      "type": "text",
      "id": "bullet_2",
      "label": "Bullet 2",
      "default": "Steady energy"
    },
    {
      "type": "text",
      "id": "bullet_3",
      "label": "Bullet 3",
      "default": "Superior absorption"
    },
    { "type": "text", "id": "bullet_4", "label": "Bullet 4" },
    { "type": "text", "id": "bullet_5", "label": "Bullet 5" },
    { "type": "text", "id": "bullet_6", "label": "Bullet 6" },
    { "type": "text", "id": "bullet_7", "label": "Bullet 7" },
    { "type": "text", "id": "bullet_8", "label": "Bullet 8" },
    {
      "type": "header",
      "content": "Right Column"
    },
    {
      "type": "color",
      "id": "bg_color_right",
      "label": "Background color",
      "default": "#1c1c1c"
    },
    {
      "type": "color",
      "id": "text_color_right",
      "label": "Text color",
      "default": "#cfcfcf"
    },
    {
      "type": "select",
      "id": "mobile_image_position",
      "label": "Image position on mobile",
      "default": "bottom",
      "options": [
        { "value": "bottom", "label": "Below text" },
        { "value": "top", "label": "Above text" }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "number",
      "id": "image_max_width",
      "label": "Image max width (px)",
      "default": 1200
    },
    {
      "type": "text",
      "id": "image_placeholder_text",
      "label": "Placeholder text",
      "info": "Shown when no image is set.",
      "default": "PRODUCT LIFESTYLE IMAGE"
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "LOW STOCK"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge background",
      "default": "#c2566a"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "badge_position",
      "label": "Badge position",
      "default": "top-right",
      "options": [
        { "value": "top-right", "label": "Top right" },
        { "value": "top-left", "label": "Top left" },
        { "value": "top-center", "label": "Top center" }
      ]
    },
    {
      "type": "header",
      "content": "Section Globals"
    },
    {
      "type": "textarea",

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign section_type = "global_design_elements"
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% for block in section.blocks %}
  {% if block.type == "header" %}
    {% render 'global_design_elements.header', block: block %}
  {% endif %}
  {% if block.type == "text" %}
    {% render 'global_design_elements.text', block: block %}
  {% endif %}
  {% if block.type == "select" %}
    {% render 'global_design_elements.select', block: block %}
  {% endif %}
  {% if block.type == "paragraph" %}
    {% render 'global_design_elements.paragraph', block: block %}
  {% endif %}
  {% if block.type == "select" %}
    {% render 'global_design_elements.select', block: block %}
  {% endif %}
  {% if block.type == "quantity" %}
    {% render 'global_design_elements.quantity', block: block %}
  {% endif %}
  {% if block.type == "checkbox" %}
    {% render 'global_design_elements.checkbox', block: block %}
  {% endif %}
  {% if block.type == "input" %}
    {% render 'global_design_elements.input', block: block %}
  {% endif %}
  {% if block.type == "textarea" %}
    {% render 'global_design_elements.textarea', block: block %}
  {% endif %}
  {% if block.type == "accordion" %}
    {% render 'global_design_elements.accordion', block: block %}
  {% endif %}
  {% if block.type == "scrollbar" %}
    {% render 'global_design_elements.scrollbar', block: block %}
  {% endif %}
  {% if block.type == "scroll_pagination" %}
    {% render 'global_design_elements.scroll_pagination', block: block %}
  {% endif %}
  {% if block.type == "pagination" %}
    {% render 'global_design_elements.pagination', block: block %}
  {% endif %}
{% endfor %}

{% schema %}

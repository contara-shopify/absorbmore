              },
              "blocks": []
            },
            {
              "type": "_main_blog__empty_state",
              "settings": {
                "custom_css": "& {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-direction: column;\n  padding: 60px 0;\n}"
              },
              "blocks": [
                {
                  "type": "image",
                  "settings": {
                    "url": "",
                    "show_overlay": false,
                    "overlay_color": "linear-gradient(to bottom, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.25) 100%)",

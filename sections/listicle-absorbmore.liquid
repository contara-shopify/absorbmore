<script>
// Countdown Timer
(function() {
  var totalSeconds = 5 * 3600 + 33 * 60 + 48;
  var hoursEl = document.getElementById('hs-hours');
  var minutesEl = document.getElementById('hs-minutes');
  var secondsEl = document.getElementById('hs-seconds');

  setInterval(function() {
    if (totalSeconds <= 0) return;
    totalSeconds--;
    var h = Math.floor(totalSeconds / 3600);
    var m = Math.floor((totalSeconds % 3600) / 60);
    var s = totalSeconds % 60;
    hoursEl.textContent = String(h).padStart(2, '0');
    minutesEl.textContent = String(m).padStart(2, '0');
    secondsEl.textContent = String(s).padStart(2, '0');
  }, 1000);
})();

// Sticky Bottom Bar
(function() {
  var stickyBar = document.getElementById('hs-sticky-bar');
  window.addEventListener('scroll', function() {
    if (window.scrollY > 800) {
      stickyBar.classList.add('visible');
    } else {
      stickyBar.classList.remove('visible');
    }
  });
})();

// FAQ Accordion
function toggleFaq(el) {
  var items = document.querySelectorAll('.hs-faq-item');
  items.forEach(function(item) {
    if (item !== el) item.classList.remove('active');
  });
  el.classList.toggle('active');
}
</script>


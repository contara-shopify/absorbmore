<script>
  function bplpFaq(btn) {
    const item = btn.closest('.bplp-faq-item');
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.bplp-faq-item').forEach(i => i.classList.remove('open'));
    if (!isOpen) item.classList.add('open');
  }

  const bplpTags = {
    'all': ['weight','energy','hormones','longevity','value'],
    'weight': ['weight'],
    'hormones': ['hormones'],
    'energy': ['energy'],
    'longevity': ['longevity'],
    'value': ['value']
  };

  function bplpFilter(tag, btn) {
    document.querySelectorAll('.bplp-filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const allowed = bplpTags[tag];
    document.querySelectorAll('#bplp-grid .bplp-card').forEach(card => {
      const cardTags = card.dataset.tags.split(' ');
      const match = tag === 'all' || cardTags.some(t => allowed.includes(t));
      card.style.display = match ? '' : 'none';
    });
  }

  /**
   * Variant selector (Choose Supply)
   */
  (function() {
    var wrap = document.querySelector('.bplp-wrap');
    if (!wrap) return;

    wrap.addEventListener('change', function(e) {
      var radio = e.target;
      if (radio.type !== 'radio' || !radio.name || radio.name.indexOf('bplp-choose-supply') !== 0) return;
      if (!radio.checked) return;

      var variantId = radio.getAttribute('data-variant-id');
      if (!variantId) return;

      var card = radio.closest('.bplp-card');
      if (!card) return;

      var list = card.querySelector('ul.product-choose-supply-variants');
      if (list) {
        var prev = list.querySelector('li.active');
        if (prev) prev.classList.remove('active');
        radio.closest('li').classList.add('active');
      }

      var btn = card.querySelector('button[data-action="add_to_cart"][data-variant-id]');
      if (!btn) return;

      btn.setAttribute('data-variant-id', variantId);
      if (radio.getAttribute('data-selling-plan-id')) btn.setAttribute('data-selling-plan-id', radio.getAttribute('data-selling-plan-id'));
      if (!radio.getAttribute('data-selling-plan-id')) btn.removeAttribute('data-selling-plan-id');

      var priceFormatted = radio.getAttribute('data-price-formatted');
      if (priceFormatted) btn.textContent = 'Add To Cart — ' + priceFormatted;

      var priceRow = card.querySelector('.bplp-price-row');
      if (priceRow) {
        var priceDisplay = radio.getAttribute('data-price-display');
        if (priceDisplay) priceRow.querySelector('.bplp-price').textContent = priceDisplay;
        var priceOrig = radio.getAttribute('data-price-orig-formatted');
        if (priceOrig) priceRow.querySelector('.bplp-price-orig').textContent = priceOrig;
        var savePct = radio.getAttribute('data-save-pct');
        var saveEl = priceRow.querySelector('.bplp-price-save');
        if (saveEl) saveEl.textContent = savePct ? 'Save ' + savePct + '%' : '';
      }
    });
  })();

  /**
   * Add to Cart
   */
  (function() {
    var wrap = document.querySelector('.bplp-wrap');
    if (!wrap) return;

    wrap.addEventListener('click', function(e) {
      // Get the button element
      var btn = e.target.closest('button[data-action="add_to_cart"][data-variant-id]');

      // Check if the button is found
      if (!btn) return;

      // Prevent default and stop propagation
      e.preventDefault();
      e.stopPropagation();

      // Check if window._cart is defined
      if (!window._cart) return;

      // Get the variant ID and selling plan ID
      var variantId = btn.getAttribute('data-variant-id');

      // Check if the variant ID is defined
      if (!variantId) return;

      // Get the selling plan ID
      var sellingPlanId = btn.getAttribute('data-selling-plan-id');

      // Create the item object
      var item = { id: parseInt(variantId, 10), quantity: 1 };

      // Check if the selling plan ID is defined
      if (sellingPlanId) item.selling_plan = parseInt(sellingPlanId, 10);

      // Add loading class to the button
      btn.classList.add('button-loading');

      // Add the item to the cart
      window._cart.add({ items: [item] }).then(function(data) {
        // Check if the cart error is not present and window._stores and window._stores.modal are defined
        if (!data.cart_error && window._stores && window._stores.modal) window._stores.modal.setId('modal--cart-drawer');

        // Remove loading class from the button
      }).finally(function() {
        // Remove loading class from the button
        btn.classList.remove('button-loading');
      });
    });
  })();
</script>


{% comment %}
  Berberine Collection — Enhanced PLP
  Template: page.berberine-collection.liquid
  To use: In Shopify Admin → Online Store → Pages → Create a new page
  and assign the template "page.berberine-collection"
{% endcomment %}

<style>
  /* Preview bar */
  #preview-bar-iframe, #PBarNextFrameWrapper, #PBarNextFrame {
    display: none !important;
  }

  /* Header */
  [data-style-id*="t6V9FU"],
  [data-style-id*="XcqypW"] {
    display: none !important;
  }

  @media (min-width: 769px) {
    header[data-style-id*="navigation-bar--"] {
      padding-right: 60px;
      padding-left: 60px;
    }
  }

  @media (max-width: 768px) {
    [data-style-id*="77C8id"] {
      display: none;
    }
    
    [data-style-id*="nQb3cY"] {
      margin-right: auto;
    }
  }

  /* ── Scoped to this page only ── */
  .bplp-wrap *, .bplp-wrap *::before, .bplp-wrap *::after { box-sizing: border-box; }
  .bplp-wrap {
    --cream:    #F5F0E8;
    --cream-dk: #EDE8DC;
    --black:    #0A0A0A;
    --red:      #8B1A1A;
    --gray:     #6B6B6B;
    --gray-lt:  #9A9A9A;
    --border:   #D8D2C6;
    --white:    #FFFFFF;
    --green:    #2D6A4F;
    font-family: var(--font-body-family, 'Suisse Intl', sans-serif);
    background: var(--cream);
    color: var(--black);
    -webkit-font-smoothing: antialiased;
  }

  /* ── Hero ── */
  .bplp-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 420px;
    overflow: hidden;
  }
  .bplp-hero-text {
    padding: 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--cream);
  }
  .bplp-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 12px;
  }
  .bplp-hero-title {
    font-family: var(--font-heading-family, 'Suisse Intl', sans-serif);
    font-size: clamp(38px, 5vw, 64px);
    font-weight: 800;
    line-height: 1.05;
    color: var(--black);
    margin-bottom: 20px;
  }
  .bplp-hero-subtitle {
    font-size: 16px;
    color: var(--gray);
    max-width: 420px;
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .bplp-hero-stats {
    display: flex;
    gap: 32px;
  }
  .blp-button-container {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 32px;
  }
  .blp-button {
    width: max-content;
  }
  .bplp-stat-num {
    font-size: 30px;
    font-weight: 800;
    color: var(--black);
    line-height: 1;
  }
  .bplp-stat-label {
    font-size: 12px;
    color: var(--gray);
    margin-top: 4px;
  }
  .bplp-hero-image {
    background: var(--black);
    position: relative;
    overflow: hidden;
    min-height: 360px;
  }
  .bplp-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
  }
  .bplp-hero-badge {
    position: absolute;
    bottom: 28px;
    left: 28px;
    right: 28px;
    display: inline-block;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(8px);
    color: #fff;
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Trust Strip ── */
  .bplp-trust {
    background: var(--black);
    padding: 14px 40px;
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }
  .bplp-trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #fff;
    font-size: 13px;
    font-weight: 500;
  }
  .bplp-trust-item svg { width: 16px; height: 16px; opacity: 0.8; flex-shrink: 0; }

  /* ── Filter Bar ── */
  .bplp-filter {
    background: var(--white);
    border-bottom: 1px solid var(--border);
    padding: 0 40px;
    display: flex;
    align-items: center;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .bplp-filter-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    white-space: nowrap;
    padding-right: 20px;
    border-right: 1px solid var(--border);
    margin-right: 4px;
  }
  .bplp-filter-btn {
    background: none;
    border: none;
    padding: 14px 18px;
    font-size: 13px;
    font-weight: 500;
    color: var(--gray);
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
    font-family: inherit;
  }
  .bplp-filter-btn:hover { color: var(--black); }
  .bplp-filter-btn.active {
    color: var(--black);
    font-weight: 700;
    border-bottom-color: var(--red);
  }

  /* ── Section Header ── */
  .bplp-section-header {
    text-align: center;
    padding: 56px 40px 36px;
  }
  .bplp-section-title {
    font-family: var(--font-heading-family, 'Suisse Intl', sans-serif);
    font-size: clamp(26px, 3.5vw, 40px);
    font-weight: 800;
    line-height: 1.15;
    color: var(--black);
    max-width: 560px;
    margin: 0 auto 14px;
  }
  .bplp-section-sub {
    font-size: 15px;
    color: var(--gray);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Products Grid ── */
  .bplp-products { padding: 0 40px 80px; }
  .bplp-grid {
    display: grid;
    grid-template-columns: none;/*repeat(2, 1fr)*/
    gap: 2px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Product Card ── */
  .bplp-card {
    background: var(--cream);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
  }
  .bplp-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.12);
    z-index: 2;
  }
  .bplp-card-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 280px;
  }
  .bplp-img-wrap {
    background: var(--cream-dk);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 24px;
    position: relative;
    overflow: hidden;
  }
  .bplp-img-wrap img {
    width: 100%;
    max-width: 300px;
    height: auto;
    object-fit: contain;
    transition: transform 0.3s ease;
  }
  .bplp-card:first-child .bplp-img-wrap img { max-width: 100%; }
  .bplp-card:hover .bplp-img-wrap img { transform: scale(1.04); }
  .bplp-badges {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }
  .bplp-badge {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 2px;
  }
  .bplp-badge-cat { background: var(--black); color: #fff; }
  .bplp-badge-stock { background: var(--red); color: #fff; }
  .bplp-badge-value { background: #C8860A; color: #fff; }

  .bplp-card-info {
    padding: 24px 24px 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .bplp-card-name {
    font-family: var(--font-heading-family, 'Suisse Intl', sans-serif);
    font-size: 20px;
    font-weight: 800;
    line-height: 1.2;
    color: var(--black);
    margin-bottom: 5px;
  }
  .bplp-card-tagline {
    font-size: 13px;
    color: var(--gray);
    margin-bottom: 12px;
    line-height: 1.5;
  }
  .bplp-stars {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
  }
  .bplp-stars-icons { color: #C8860A; font-size: 13px; }
  .bplp-stars-text { font-size: 12px; color: var(--gray); font-weight: 500; }
  .bplp-absorption {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 5px 10px;
    margin-bottom: 12px;
  }
  .bplp-abs-num {
    font-size: 18px;
    font-weight: 800;
    color: var(--red);
  }
  .bplp-abs-label { font-size: 11px; color: var(--gray); line-height: 1.3; }
  .bplp-price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 6px;
  }
  .bplp-price { font-size: 22px; font-weight: 700; color: var(--black); }
  .bplp-price-orig { font-size: 14px; color: var(--gray-lt); text-decoration: line-through; }
  .bplp-price-save {
    font-size: 11px;
    font-weight: 600;
    color: var(--green);
    background: rgba(45,106,79,0.1);
    padding: 2px 7px;
    border-radius: 3px;
  }
  .bplp-price-note { font-size: 11px; color: var(--gray); margin-bottom: 14px; }
  .bplp-btn-primary {
    display: block;
    width: 100%;
    background: var(--black);
    color: #fff;
    border: none;
    padding: 13px 16px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    transition: background 0.2s ease;
    border-radius: 2px;
    font-family: inherit;
  }
  .bplp-btn-primary:hover { background: #2A2A2A; color: #fff; }
  .bplp-btn-secondary {
    display: block;
    width: 100%;
    background: transparent;
    color: var(--black);
    border: 1.5px solid var(--black);
    padding: 10px 16px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    transition: all 0.2s ease;
    border-radius: 2px;
    margin-top: 7px;
    font-family: inherit;
  }
  .bplp-btn-secondary:hover { background: var(--black); color: #fff; }

  /* Card expanded bottom */
  .bplp-card-bottom {
    border-top: 1px solid var(--border);
    padding: 22px 24px;
    background: var(--cream);
  }
  .bplp-card-desc {
    font-size: 13px;
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 18px;
  }
  .bplp-benefits {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 9px;
    margin-bottom: 18px;
  }
  .bplp-benefit {
    display: flex;
    align-items: flex-start;
    gap: 7px;
  }
  .bplp-benefit svg { width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; }
  .bplp-benefit-text { font-size: 12px; color: var(--black); font-weight: 500; line-height: 1.4; }
  .bplp-inside { margin-bottom: 18px; }
  .bplp-inside-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 7px;
  }
  .bplp-pills { display: flex; flex-wrap: wrap; gap: 5px; }
  .bplp-pill {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 500;
    color: var(--black);
  }
  .bplp-timeline {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 7px;
  }
  .bplp-month {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 10px 11px;
    text-align: center;
  }
  .bplp-month-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 4px;
  }
  .bplp-month-text { font-size: 11px; color: var(--gray); line-height: 1.4; }

  /* ── Quote Strip ── */
  .bplp-quote {
    background: var(--black);
    padding: 48px 40px;
    text-align: center;
  }
  .bplp-quote blockquote {
    font-size: clamp(17px, 2.2vw, 24px);
    font-style: italic;
    color: #fff;
    max-width: 720px;
    margin: 0 auto 14px;
    line-height: 1.55;
  }
  .bplp-quote-attr {
    font-size: 12px;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Science Strip ── */
  .bplp-science {
    background: var(--cream-dk);
    padding: 56px 40px;
  }
  .bplp-science-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 56px;
    align-items: center;
  }
  .bplp-science-heading {
    font-family: var(--font-heading-family, 'Suisse Intl', sans-serif);
    font-size: clamp(26px, 3vw, 38px);
    font-weight: 800;
    line-height: 1.15;
    color: var(--black);
  }
  .bplp-science-heading em { font-style: normal; color: var(--red); }
  .bplp-science-sub { font-size: 14px; color: var(--gray); margin-top: 14px; line-height: 1.7; }
  .bplp-science-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .bplp-science-stat {
    text-align: center;
    padding: 22px 14px;
    background: var(--white);
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  .bplp-science-num {
    font-size: 38px;
    font-weight: 800;
    color: var(--red);
    line-height: 1;
    margin-bottom: 6px;
  }
  .bplp-science-stat-label { font-size: 12px; color: var(--gray); line-height: 1.4; }

  /* ── Reviews ── */
  .bplp-reviews { padding: 56px 40px; background: var(--white); }
  .bplp-reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    max-width: 1100px;
    margin: 36px auto 0;
  }
  .bplp-review-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 22px;
  }
  .bplp-review-stars { color: #C8860A; font-size: 13px; margin-bottom: 9px; }
  .bplp-review-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 7px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .bplp-review-body { font-size: 13px; color: var(--gray); line-height: 1.6; margin-bottom: 10px; }
  .bplp-review-author { font-size: 12px; font-weight: 600; color: var(--black); }
  .bplp-review-verified { font-size: 11px; color: var(--green); font-weight: 500; }

  /* ── Expert ── */
  .bplp-expert {
    background: var(--cream-dk);
    padding: 52px 40px;
    text-align: center;
  }
  .bplp-expert-quote {
    font-size: clamp(15px, 1.8vw, 20px);
    font-style: italic;
    color: var(--black);
    max-width: 660px;
    margin: 0 auto 14px;
    line-height: 1.65;
  }
  .bplp-expert-name {
    font-size: 13px;
    font-weight: 700;
    color: var(--black);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .bplp-expert-title { font-size: 12px; color: var(--gray); margin-top: 3px; }
  .bplp-expert-note { font-size: 12px; color: var(--gray); margin-top: 18px; font-style: italic; }

  /* ── FAQ ── */
  .bplp-faq { padding: 56px 40px; background: var(--white); }
  .bplp-faq-inner { max-width: 740px; margin: 0 auto; }
  .bplp-faq-item { border-bottom: 1px solid var(--border); }
  .bplp-faq-q {
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    padding: 18px 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--black);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    font-family: inherit;
  }
  .bplp-faq-q:hover { color: var(--red); }
  .bplp-faq-icon { font-size: 20px; font-weight: 300; flex-shrink: 0; transition: transform 0.2s ease; }
  .bplp-faq-a { font-size: 14px; color: var(--gray); line-height: 1.7; padding-bottom: 18px; display: none; }
  .bplp-faq-item.open .bplp-faq-a { display: block; }
  .bplp-faq-item.open .bplp-faq-icon { transform: rotate(45deg); }

  .bplp-divider {
    margin: 36px 0;
    text-align: center;
  }

  .bplp-divider .bplp-section-title {
    margin: 0 15px;
    max-width: none;
    text-align: center;
  }

  .bplp-divider .bplp-card-name {
    margin-top: 10px;
  }

  /* Choose Supply */
  .bplp-choose-supply {
    margin-bottom: 15px;
  }

  ul.product-choose-supply-variants,
  ul.product-choose-supply-variants li {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
  }

  ul.product-choose-supply-variants {
    gap: 15px;
    width: 100%;
  }

  ul.product-choose-supply-variants li {
    flex-direction: column;
    gap: 5px;
    position: relative;
    width: calc(33.33% - 10px);
    background-color: #ffffff;
    border-radius: 8px;
    text-align: center;
  }

  ul.product-choose-supply-variants li div:first-child {
    justify-items: center;
  }

  ul.product-choose-supply-variants li label {
    display: block !important;
    padding: 15px;
    height: 100%;
    background-image: none !important;
    border: 1px solid transparent;
    border-radius: 8px;
  }

  ul.product-choose-supply-variants li img {
    margin: 0 auto;
  }

  ul.product-choose-supply-variants li h3,
  .richtext-md[data-content*="Subscribe & Save"] {
    font-weight: 500;
  }

  ul.product-choose-supply-variants li p.subheading,
  ul.product-choose-supply-variants li p.price-per-unit span.per-unit {
    font-size: 80%;
    color: #6a6a6a;
  }

  ul.product-choose-supply-variants li p.saved {
    margin-top: 15px;
  }

  ul.product-choose-supply-variants li p.price-per-unit span.price {
    font-weight: 500;
  }

  ul.product-choose-supply-variants li p.saved {
    font-size: 120%;
    color: #4659FF;
    font-weight: 500;
  }

  ul.product-choose-supply-variants li span.label-secondary {
    position: absolute;
    top: -12px;
    right: 0;
    left: 0;
    margin: 0 auto;
    max-width: 110px;
    height: 24px;
    background-color: #7d2b2d;
    color: #ffffff;
    text-transform: uppercase;
    line-height: 24px;
  }

  ul.product-choose-supply-variants li.active label,
  ul.product-choose-supply-variants li label:hover {
    border-color: #000000;
  }

  div[data-style-id*="main_product_subscribe_toggle_card"] {
    margin-top: 15px !important;
  }

  /* Choose Supploy Mobile */
  @media (max-width: 768px) {
    ul.product-choose-supply-variants li label {
      padding: 10px;
      width: 100%;
    }

    ul.product-choose-supply-variants li p.price-per-unit span.price,
    ul.product-choose-supply-variants li p.price-per-unit span.per-unit {
      font-size: 75%;
    }

    ul.product-choose-supply-variants li p.saved {
      margin-top: 5px;
      font-size: 100%;
    }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .bplp-hero { grid-template-columns: 1fr; }
    .bplp-hero-image { min-height: 260px; }
    .bplp-grid { grid-template-columns: 1fr; }
    .bplp-card-top { grid-template-columns: 1fr; }
    .bplp-science-inner { grid-template-columns: 1fr; }
    .bplp-science-stats { grid-template-columns: repeat(3, 1fr); }
    .bplp-reviews-grid { grid-template-columns: 1fr; }
    .bplp-hero-text { padding: 36px 20px; }
    .bplp-trust { gap: 20px; padding: 12px 20px; }
    .bplp-products { padding: 0 16px 60px; }
    .bplp-section-header { padding: 40px 20px 28px; }
    .bplp-filter { padding: 0 16px; }
  }
  @media (max-width: 600px) {
    .bplp-benefits { grid-template-columns: 1fr; }
    .bplp-timeline { grid-template-columns: 1fr; }
    .bplp-science-stats { grid-template-columns: 1fr; }
    .bplp-hero-stats { gap: 20px; }
    .blp-button { width: 100%; }
  }
</style>

<div class="bplp-wrap">

  <!-- Hero -->
  <section class="bplp-hero">
    <div class="bplp-hero-text">
      <p class="bplp-eyebrow">Berberine Collection</p>

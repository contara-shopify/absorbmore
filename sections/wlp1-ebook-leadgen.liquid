{% comment %}
  Section: WLP-1 E-book Lead Gen Landing Page
  File: sections/wlp1-ebook-leadgen.liquid
{% endcomment %}

{% style %}
.ebook-lp *, .ebook-lp *::before, .ebook-lp *::after { box-sizing: border-box; margin: 0; padding: 0; }
.ebook-lp {
  --blue: #5e91d5;
  --blue-hover: #4a7dbe;
  --ink: #1A1A1A;
  --ink-muted: #666666;
  --ink-hint: #999999;
  --border: #E0E0E0;
  --border-light: #EEEEEE;
  --surface: #F8F5F2;
  --surface-alt: #F5F4F0;
  --surface-page: #F8F5F2;
  --font: inherit;
  --radius: 8px;
  --radius-lg: 12px;
  font-family: var(--font);
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
  line-height: 1.5;
}
/* Body */
body {
  margin: 0;
  padding: 0;
}

/* Hide header and footer */
header,
footer {
  display: none;
}
.ebook-lp a { text-decoration: none; color: inherit; }
.ebook-lp strong { font-weight: 600; }
.ebook-lp .eyebrow { display: block; font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--blue); }
.ebook-lp .section-title { font-size: 24px; font-weight: 600; letter-spacing: -0.01em; margin-top: 8px; }
.ebook-lp .input { width: 100%; padding: 13px 16px; font-size: 15px; font-family: var(--font); border: 1px solid var(--border); border-radius: var(--radius); background: #FFFFFF; color: var(--ink); outline: none; transition: border-color 0.2s; }
.ebook-lp .input:focus { border-color: var(--blue); }
.ebook-lp .input--sm { padding: 11px 14px; font-size: 14px; width: 220px; }
.ebook-lp .btn { display: inline-flex; align-items: center; justify-content: center; padding: 14px 28px; font-size: 15px; font-weight: 500; font-family: var(--font); border-radius: var(--radius); border: none; cursor: pointer; transition: background 0.2s, transform 0.1s; text-align: center; }
.ebook-lp .btn:active { transform: scale(0.98); }
.ebook-lp .btn--primary { background: var(--blue); color: white; }
.ebook-lp .btn--primary:hover { background: var(--blue-hover); }
.ebook-lp .btn--dark { background: var(--ink); color: white; }
.ebook-lp .btn--dark:hover { background: #333; }
.ebook-lp .btn--outline-blue { background: transparent; color: var(--blue); border: 1px solid var(--blue); padding: 10px 24px; font-size: 14px; white-space: nowrap; }
.ebook-lp .btn--outline-blue:hover { background: rgba(94, 145, 213, 0.08); }
.ebook-lp .btn--sm { padding: 11px 20px; font-size: 14px; }
.ebook-lp .btn--full { width: 100%; }
.ebook-lp .form-note { display: block; text-align: center; font-size: 12px; color: var(--ink-hint); margin-top: 2px; }
.ebook-nav { border-bottom: 1px solid var(--border-light); background: var(--surface); padding: 16px 40px; display: flex; justify-content: space-between; align-items: center; }
.ebook-nav__logo { font-weight: 600; font-size: 14px; letter-spacing: 0.01em; }
.ebook-nav__links { display: flex; gap: 24px; align-items: center; }
.ebook-nav__link { font-size: 13px; color: var(--ink-muted); font-weight: 500; transition: color 0.2s; }
.ebook-nav__link:hover { color: var(--ink); }
.ebook-nav__link--accent { color: var(--blue); }
.ebook-nav__link--accent:hover { color: var(--blue-hover); }
.ebook-nav__pill { display: none; }
.ebook-hero { display: grid; grid-template-columns: 1fr 1fr; min-height: 540px; background: var(--surface); }
.ebook-hero__copy { padding: 56px 48px; display: flex; flex-direction: column; gap: 20px; justify-content: center; }
.ebook-hero__title { display: flex; flex-direction: column; }
.ebook-hero__title-line { font-size: 36px; font-weight: 600; line-height: 1.12; letter-spacing: -0.025em; }
.ebook-hero__sub { font-size: 15px; line-height: 1.65; color: var(--ink-muted); }
.ebook-hero__benefits { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.ebook-hero__benefits li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; line-height: 1.5; }
.ebook-hero__benefits .icon { color: var(--blue); font-weight: 600; font-size: 15px; flex-shrink: 0; margin-top: 1px; }
.ebook-hero__form { display: flex; flex-direction: column; gap: 10px; margin-top: 4px; }
.ebook-hero__visual { background: #EAE6DC; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; overflow: hidden; padding: 0; }
.ebook-hero__visual img { width: 100%; height: auto; display: block; }
.ebook-hero__pills { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; padding: 12px 24px 20px; background: #EAE6DC; width: 100%; }
.ebook-pill { display: inline-flex; align-items: center; padding: 8px 16px; font-size: 12px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; border-radius: 100px; background: var(--surface); color: var(--ink); border: 1px solid var(--border-light); }
.ebook-pill--accent { background: var(--blue); color: white; border-color: var(--blue); }
.ebook-proof { background: var(--surface); border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light); padding: 20px 40px; display: flex; align-items: center; justify-content: center; gap: 32px; flex-wrap: wrap; }
.ebook-proof__item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--ink-muted); }
.ebook-proof__dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ink-hint); display: inline-block; }
.ebook-quiz { background: var(--surface); border-bottom: 1px solid var(--border-light); padding: 28px 40px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
.ebook-quiz__left { display: flex; align-items: center; gap: 16px; }
.ebook-quiz__icon { width: 44px; height: 44px; border-radius: 50%; background: var(--blue); display: flex; align-items: center; justify-content: center; color: white; font-size: 18px; font-weight: 600; flex-shrink: 0; }
.ebook-quiz__title { font-size: 16px; font-weight: 600; }
.ebook-quiz__sub { font-size: 14px; color: var(--ink-muted); margin-top: 2px; }
.ebook-learn { background: var(--surface-page); border-bottom: 1px solid var(--border-light); padding: 56px 40px; }
.ebook-learn__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 28px; }
.ebook-learn__card { background: #EAE6DC; border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 24px; transition: border-color 0.2s; }
.ebook-learn__card:hover { border-color: var(--border); }
.ebook-learn__num { font-size: 12px; font-weight: 600; color: var(--blue); letter-spacing: 0.04em; }
.ebook-learn__card-title { font-size: 15px; font-weight: 600; margin: 8px 0 6px; }
.ebook-learn__card-body { font-size: 13px; color: var(--ink-muted); line-height: 1.55; }
.ebook-product { display: grid; grid-template-columns: 1fr 1fr; background: var(--surface); border-bottom: 1px solid var(--border-light); }
.ebook-product__image { background: var(--surface-alt); display: flex; align-items: center; justify-content: center; padding: 56px; min-height: 400px; }
.ebook-product__copy { padding: 56px 48px; display: flex; flex-direction: column; justify-content: center; gap: 16px; }
.ebook-product__title { font-size: 28px; font-weight: 600; line-height: 1.2; letter-spacing: -0.015em; }
.ebook-product__checks { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.ebook-product__checks li { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--ink-muted); }
.ebook-product__checks .check { color: var(--blue); font-size: 13px; flex-shrink: 0; }
.ebook-product__meta { display: flex; gap: 20px; font-size: 12px; color: var(--ink-hint); }
.ebook-product__cta { display: flex; flex-direction: column; gap: 12px; margin-top: 4px; }
.ebook-product__quiz-link { text-align: center; font-size: 14px; color: var(--blue); transition: opacity 0.2s; }
.ebook-product__quiz-link:hover { opacity: 0.75; }
.ebook-bottom-cta { background: var(--surface); border-bottom: 1px solid var(--border-light); padding: 36px 40px; display: flex; align-items: center; justify-content: space-between; gap: 32px; }
.ebook-bottom-cta__title { font-size: 20px; font-weight: 600; }
.ebook-bottom-cta__sub { font-size: 14px; color: var(--ink-muted); margin-top: 4px; }
.ebook-bottom-cta__form { display: flex; gap: 10px; flex-shrink: 0; }
.ebook-footer { padding: 20px 40px; display: flex; justify-content: space-between; align-items: center; gap: 24px; }
.ebook-footer__disclaimer { font-size: 11px; color: var(--ink-hint); line-height: 1.5; max-width: 600px; }
.ebook-footer__brand { font-size: 12px; color: var(--ink-hint); font-weight: 500; white-space: nowrap; }
@keyframes ebookFadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
.ebook-hero__copy > * { animation: ebookFadeUp 0.5s ease both; }
.ebook-hero__copy > *:nth-child(1) { animation-delay: 0.05s; }
.ebook-hero__copy > *:nth-child(2) { animation-delay: 0.12s; }
.ebook-hero__copy > *:nth-child(3) { animation-delay: 0.18s; }
.ebook-hero__copy > *:nth-child(4) { animation-delay: 0.24s; }
.ebook-hero__copy > *:nth-child(5) { animation-delay: 0.32s; }

@media (max-width: 900px) {
  .ebook-nav { padding: 12px 20px; }
  .ebook-nav__logo { font-size: 12px; }
  .ebook-nav__links { display: none; }
  .ebook-nav__pill { display: flex; gap: 8px; align-items: center; }
  .ebook-nav__pill a { display: inline-flex; align-items: center; padding: 6px 14px; font-size: 11px; font-weight: 600; border-radius: 100px; white-space: nowrap; letter-spacing: 0.02em; }
  .ebook-nav__pill a.pill--outline { background: transparent; color: var(--ink); border: 1px solid var(--border); }
  .ebook-nav__pill a.pill--filled { background: var(--blue); color: white; border: 1px solid var(--blue); }
  .ebook-hero { grid-template-columns: 1fr; }
  .ebook-hero__copy { padding: 28px 20px 24px; gap: 14px; }
  .ebook-hero__title-line { font-size: 28px; }
  .ebook-hero__sub { font-size: 14px; line-height: 1.55; }
  .ebook-hero__benefits li { font-size: 13px; line-height: 1.45; }
  .ebook-hero__benefits .icon { font-size: 13px; }
  .ebook-hero__visual { min-height: auto; }
  .ebook-hero__pills { padding: 10px 20px 16px; gap: 6px; }
  .ebook-pill { padding: 6px 12px; font-size: 10px; }
  .ebook-proof { padding: 14px 20px; gap: 8px 16px; display: grid; grid-template-columns: 1fr 1fr; }
  .ebook-proof__item { font-size: 11px; }
  .ebook-quiz { padding: 20px; flex-direction: column; align-items: flex-start; gap: 14px; }
  .ebook-quiz__icon { width: 36px; height: 36px; font-size: 15px; }
  .ebook-quiz__title { font-size: 14px; }
  .ebook-quiz__sub { font-size: 12px; }
  .ebook-quiz .btn--outline-blue { width: 100%; text-align: center; justify-content: center; }
  .ebook-learn { padding: 32px 20px; }
  .ebook-learn__grid { grid-template-columns: 1fr 1fr; gap: 10px; }
  .ebook-learn__card { padding: 16px; }
  .ebook-learn__card-title { font-size: 13px; margin: 6px 0 4px; }
  .ebook-learn__card-body { font-size: 11px; }
  .ebook-learn__num { font-size: 11px; }
  .ebook-product { grid-template-columns: 1fr; }
  .ebook-product__image { min-height: 240px; padding: 32px 20px; }
  .ebook-product__copy { padding: 28px 20px; }
  .ebook-product__title { font-size: 22px; }
  .ebook-product__checks li { font-size: 13px; }
  .ebook-product__meta { flex-wrap: wrap; gap: 10px; font-size: 11px; }
  .ebook-product__quiz-link { font-size: 13px; }
  .ebook-bottom-cta { padding: 24px 20px; flex-direction: column; align-items: flex-start; gap: 16px; }
  .ebook-bottom-cta__title { font-size: 18px; }
  .ebook-bottom-cta__sub { font-size: 13px; }
  .ebook-bottom-cta__form { width: 100%; flex-direction: column; }
  .ebook-bottom-cta__form .input--sm { width: 100%; }
  .ebook-footer { padding: 16px 20px; flex-direction: column; align-items: flex-start; gap: 8px; }
}
@media (max-width: 480px) {
  .ebook-hero__title-line { font-size: 24px; }
  .ebook-hero__benefits li { font-size: 12px; }
  .ebook-product__title { font-size: 20px; }
  .ebook-learn__grid { grid-template-columns: 1fr; }
}
{% endstyle %}

<div class="ebook-lp">
  <div class="ebook-nav">
    <div class="ebook-nav__logo">{{ section.settings.brand_name }}</div>
    <div class="ebook-nav__links">
      {% if section.settings.quiz_url != blank %}<a href="{{ section.settings.quiz_url }}" class="ebook-nav__link ebook-nav__link--accent">Take the quiz</a>{% endif %}
      {% if section.settings.shop_url != blank %}<a href="{{ section.settings.shop_url }}" class="ebook-nav__link">Shop WLP-1</a>{% endif %}
    </div>
    <div class="ebook-nav__pill">
      {% if section.settings.quiz_url != blank %}<a href="{{ section.settings.quiz_url }}" class="pill--filled">Quiz</a>{% endif %}
      {% if section.settings.shop_url != blank %}<a href="{{ section.settings.shop_url }}" class="pill--outline">Shop</a>{% endif %}
    </div>
  </div>

  <div class="ebook-hero">
    <div class="ebook-hero__copy">
      <span class="eyebrow">{{ section.settings.hero_eyebrow }}</span>
      <h1 class="ebook-hero__title">
        <span class="ebook-hero__title-line">{{ section.settings.hero_title_line1 }}</span>
        <span class="ebook-hero__title-line">{{ section.settings.hero_title_line2 }}</span>
      </h1>
      <p class="ebook-hero__sub">{{ section.settings.hero_description }}</p>
      <ul class="ebook-hero__benefits">
        {% for block in section.blocks %}{% if block.type == 'hero_benefit' %}<li><span class="icon">+</span> {{ block.settings.text }}</li>{% endif %}{% endfor %}
      </ul>
      <form class="ebook-hero__form" id="ebook-hero-form">
        <input type="email" placeholder="{{ section.settings.email_placeholder }}" required class="input" />
        <button type="submit" class="btn btn--primary">{{ section.settings.cta_text }}</button>
        <span class="form-note">{{ section.settings.form_note }}</span>
      </form>
    </div>
    <div class="ebook-hero__visual">
      <img src="{{ section.settings.hero_image | default: 'https://cdn.shopify.com/s/files/1/0821/3997/1873/files/ebookimagehero.jpg?v=1774245611' }}" alt="WLP-1: The Oral GLP-1 Guide" loading="eager">
      <div class="ebook-hero__pills">
        <span class="ebook-pill">321% GLP-1 Increase</span>
        <span class="ebook-pill ebook-pill--accent">12% Body Weight in 10 Wks*</span>
      </div>
    </div>
  </div>

  <div class="ebook-proof">
    {% for block in section.blocks %}{% if block.type == 'proof_item' %}<span class="ebook-proof__item"><span class="ebook-proof__dot"></span> {{ block.settings.text }}</span>{% endif %}{% endfor %}
  </div>

  {% if section.settings.quiz_url != blank %}
  <div class="ebook-quiz" id="quiz-nudge">
    <div class="ebook-quiz__left">
      <div class="ebook-quiz__icon">?</div>
      <div>
        <div class="ebook-quiz__title">{{ section.settings.quiz_title }}</div>
        <div class="ebook-quiz__sub">{{ section.settings.quiz_description }}</div>
      </div>
    </div>
    <a href="{{ section.settings.quiz_url }}" class="btn btn--outline-blue">Take the quiz</a>
  </div>
  {% endif %}

  <div class="ebook-learn">
    <span class="eyebrow">{{ section.settings.learn_eyebrow }}</span>
    <h2 class="section-title">{{ section.settings.learn_title }}</h2>
    <div class="ebook-learn__grid">
      {% assign learn_index = 0 %}
      {% for block in section.blocks %}{% if block.type == 'learn_card' %}{% assign learn_index = learn_index | plus: 1 %}
        <div class="ebook-learn__card">
          <span class="ebook-learn__num">{{ learn_index | prepend: '0' | slice: -2, 2 }}</span>
          <h3 class="ebook-learn__card-title">{{ block.settings.title }}</h3>
          <p class="ebook-learn__card-body">{{ block.settings.body }}</p>
        </div>
      {% endif %}{% endfor %}
    </div>
  </div>

  <div class="ebook-product" id="shop-section">
    <div class="ebook-product__image">
      {% if section.settings.product_image != blank %}
        <img src="{{ section.settings.product_image | image_url: width: 600 }}" alt="WLP-1" loading="lazy" style="max-width: 300px; height: auto;">
      {% else %}
        <div style="text-align: center;">
          <div style="width: 170px; height: 195px; background: white; border-radius: 10px; margin: 0 auto 14px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--border-light);">
            <div style="text-align: center;">
              <div style="font-size: 7.5px; font-weight: 600; letter-spacing: 0.05em; line-height: 1.35; margin-bottom: 14px;">The Absorption<br>Company.</div>
              <div style="font-size: 22px; font-weight: 600; letter-spacing: -0.01em;">WLP-1.</div>
              <div style="font-size: 8px; color: var(--ink-hint); margin-top: 4px;">GLP-1 Mimetic</div>
            </div>
          </div>
        </div>
      {% endif %}
    </div>
    <div class="ebook-product__copy">
      <span class="eyebrow">{{ section.settings.product_eyebrow }}</span>
      <h2 class="ebook-product__title">{{ section.settings.product_title }}</h2>
      <ul class="ebook-product__checks">
        {% for block in section.blocks %}{% if block.type == 'product_benefit' %}<li><span class="check">&#10003;</span> {{ block.settings.text }}</li>{% endif %}{% endfor %}
      </ul>
      <div class="ebook-product__meta">
        <span>Free shipping on subs</span>
        <span>Cancel anytime</span>
        <span>Third-party tested</span>
      </div>
      <div class="ebook-product__cta">
        <a href="{{ section.settings.shop_url }}" class="btn btn--dark btn--full">Shop WLP-1</a>
        {% if section.settings.quiz_url != blank %}<a href="{{ section.settings.quiz_url }}" class="ebook-product__quiz-link">Not sure yet? Take the quiz to see if WLP-1 is right for you &rarr;</a>{% endif %}
      </div>
    </div>
  </div>

  <div class="ebook-bottom-cta">
    <div>
      <h3 class="ebook-bottom-cta__title">{{ section.settings.bottom_cta_title }}</h3>
      <p class="ebook-bottom-cta__sub">{{ section.settings.bottom_cta_description }}</p>
    </div>
    <form class="ebook-bottom-cta__form" id="ebook-bottom-form">
      <input type="email" placeholder="Your email" required class="input input--sm" />
      <button type="submit" class="btn btn--primary btn--sm">Get the guide</button>
    </form>
  </div>

  <div class="ebook-footer">
    <span class="ebook-footer__disclaimer">{{ section.settings.disclaimer }}</span>
    <span class="ebook-footer__brand">{{ section.settings.brand_name }}</span>
  </div>
</div>

<script>

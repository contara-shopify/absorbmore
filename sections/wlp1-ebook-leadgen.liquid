(function() {
  var COMPANY_ID = {{ section.settings.klaviyo_company_id | json }};
  var LIST_ID = {{ section.settings.klaviyo_list_id | json }};

  function trackEvent(name, props) {
    if (typeof window.mixpanel !== 'undefined' && window.mixpanel.track) {
      try { window.mixpanel.track(name, props || {}); } catch(e) { console.error('Mixpanel error:', e); }
    }
  }

  // Page view event
  trackEvent('WLP1 Ebook Landing Page Viewed', {
    source: 'WLP1 Ebook Landing Page',
    page_url: window.location.href
  });

  document.querySelectorAll('#ebook-hero-form, #ebook-bottom-form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var emailInput = this.querySelector('input[type="email"]');
      var btn = this.querySelector('button');
      var email = emailInput.value.trim();
      var formLocation = this.id === 'ebook-hero-form' ? 'hero' : 'bottom';
      if (!email) return;

      if (!COMPANY_ID || !LIST_ID) {
        console.error('Klaviyo Company ID or List ID not set in section settings.');
        return;
      }

      var originalBtnText = btn.textContent;
      btn.textContent = 'Sending...';
      btn.disabled = true;
      emailInput.disabled = true;

      var payload = {
        data: {
          type: 'subscription',
          attributes: {
            profile: {
              data: {
                type: 'profile',
                attributes: { email: email }
              }
            },
            custom_source: 'WLP1 Ebook Landing Page'
          },
          relationships: {
            list: {
              data: { type: 'list', id: LIST_ID }
            }
          }
        }
      };

      fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + encodeURIComponent(COMPANY_ID), {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'revision': '2024-10-15'
        },
        body: JSON.stringify(payload)
      })
      .then(function(response) {
        if (response.ok || response.status === 202) {
          // Identify and track in Mixpanel
          if (typeof window.mixpanel !== 'undefined' && window.mixpanel.identify) {
            try {
              window.mixpanel.identify(email);
              window.mixpanel.people.set({ '$email': email });
            } catch(e) {}
          }
          trackEvent('WLP1 Ebook Submitted', {
            source: 'WLP1 Ebook Landing Page',
            form_location: formLocation,
            email: email
          });

          btn.textContent = 'Success! Redirecting...';
          btn.style.opacity = '0.7';
          setTimeout(function() {
            window.location.href = {{ section.settings.redirect_url | default: 'https://www.absorbmore.com/products/wlp-1?source=ebook' | json }};
          }, 800);
        } else {
          throw new Error('Subscription failed');
        }
      })
      .catch(function(err) {
        console.error('Klaviyo error:', err);
        btn.textContent = 'Try again';
        btn.disabled = false;
        emailInput.disabled = false;
        setTimeout(function() { btn.textContent = originalBtnText; }, 3000);
      });
    });
  });
})();
</script>


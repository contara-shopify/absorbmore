</div><!-- #ses-root -->

<!-- STICKY CTA BAR (outside #ses-root so it's not clipped) -->
<div id="ses-sticky-bar">
  <div class="ses-sticky-inner">
    <div>
      <p class="ses-sticky-label">Spring Stack</p>
      <div class="ses-sticky-price-row">
        <span class="ses-sticky-price">$87.10</span>
        <span class="ses-sticky-old">$130</span>
        <span class="ses-sticky-off">33% OFF</span>
      </div>
    </div>
    <a
      href="https://www.absorbmore.com/products/spring-essentials-stack?variant=52400084713761&selling_plan=691089015073"
      class="ses-sticky-cta"
    >
      Subscribe &amp; Save
    </a>
  </div>
</div>

<script>
  // ============================================
  // SPRING ESSENTIALS STACK — INTERACTIVE JS
  // Namespaced with "ses" prefix to avoid conflicts
  // ============================================

  // Scroll Reveal
  (function() {
    if (!window.IntersectionObserver) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('ses-visible');
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });
    document.querySelectorAll('.ses-reveal').forEach(function(el) {
      observer.observe(el);
    });
  })();

  // Sticky CTA Bar
  window.addEventListener('scroll', function() {
    var bar = document.getElementById('ses-sticky-bar');
    if (bar) {
      bar.classList.toggle('ses-visible', window.scrollY > 500);
    }
  }, { passive: true });

  // Subscribe / One-Time Toggle
  var SUB_URL = 'https://www.absorbmore.com/products/spring-essentials-stack?variant=52400084713761&selling_plan=691089015073';
  var ONE_URL = 'https://www.absorbmore.com/products/spring-essentials-stack?variant=52400084713761';

  function sesSetMode(isSub) {
    var subBtn = document.getElementById('ses-sub-btn');
    var oneBtn = document.getElementById('ses-one-btn');
    var box = document.getElementById('ses-price-box');
    var label = document.getElementById('ses-price-label');
    var priceMain = document.getElementById('ses-price-main');
    var priceOld = document.getElementById('ses-price-old');
    var pricePeriod = document.getElementById('ses-price-period');
    var discBadge = document.getElementById('ses-discount-badge');
    var perks = document.getElementById('ses-sub-perks');
    var buyBtn = document.getElementById('ses-buy-btn');
    if (!subBtn) return;

    if (isSub) {
      subBtn.classList.add('ses-active');
      oneBtn.classList.remove('ses-active');
      box.className = 'ses-price-box ses-sub-mode ses-reveal ses-visible';
      label.style.color = '#D4A820';
      label.innerHTML = 'Subscribe &amp; Save';
      priceMain.style.color = '#F5F2EC';
      priceMain.textContent = '$87.10';
      priceOld.style.display = 'inline';
      priceOld.style.color = 'rgba(245,242,236,0.4)';
      priceOld.textContent = '$130.00';
      pricePeriod.style.display = 'block';
      pricePeriod.style.color = 'rgba(245,242,236,0.7)';
      pricePeriod.textContent = 'Every 30 days \u00b7 Maximize benefits';
      discBadge.style.display = 'block';
      perks.style.display = 'flex';
      buyBtn.style.backgroundColor = '#D4A820';
      buyBtn.style.color = '#0A0A0A';
      buyBtn.textContent = 'Subscribe Now \u2014 $87.10/mo';
      buyBtn.href = SUB_URL;
    } else {
      subBtn.classList.remove('ses-active');
      oneBtn.classList.add('ses-active');
      box.className = 'ses-price-box ses-one-mode ses-reveal ses-visible';
      label.style.color = '#999';
      label.textContent = 'One-Time Purchase';
      priceMain.style.color = '#0A0A0A';
      priceMain.textContent = '$130.00';
      priceOld.style.display = 'none';
      pricePeriod.style.display = 'none';
      discBadge.style.display = 'none';
      perks.style.display = 'none';
      buyBtn.style.backgroundColor = '#0A0A0A';
      buyBtn.style.color = '#F5F2EC';
      buyBtn.textContent = 'Buy Once \u2014 $130.00';
      buyBtn.href = ONE_URL;
    }
  }

  // Month Timeline
  var sesMonths = [
    {
      title: 'Your body starts catching up.',
      points: [
        'Energy starts feeling more consistent, less dependent on caffeine',
        'Morning stiffness eases and daily movement feels less forced',
        'Mood lifts as Vitamin D levels start to replenish after winter',
        'Your body finally feels like it\'s catching up with the season'
      ]
    },
    {
      title: 'You start doing the things.',
      points: [
        'Joints move easier and post-activity soreness fades faster',
        'Steady energy through the afternoon without the crash',
        'Clearer mood and sharper focus become your new normal',
        'You start doing the things you were only thinking about before'
      ]
    },
    {
      title: 'Results that feel locked in.',
      points: [
        'Inflammation is measurably lower and your body feels it',
        'Energy, mood, and immunity are all working together consistently',
        'You recover faster, move better, and stay active longer',
        'Results that feel locked in, not temporary'
      ]
    }
  ];
  var sesActiveMonth = 0;

  function sesRenderMonth() {
    var m = sesMonths[sesActiveMonth];
    var html = '<h3 class="ses-month-title ses-display">' + m.title + '</h3><div class="ses-month-points">';
    m.points.forEach(function(point, i) {
      html += '<div class="ses-month-point"><span class="ses-month-num">0' + (i+1) + '</span><p class="ses-month-text">' + point + '</p></div>';
    });
    html += '</div>';
    var el = document.getElementById('ses-month-content');
    if (el) el.innerHTML = html;
  }

  function sesSetMonth(idx) {
    sesActiveMonth = idx;
    [0,1,2].forEach(function(i) {
      var tab = document.getElementById('ses-tab-' + i);
      if (tab) tab.classList.toggle('ses-active', i === idx);
    });
    sesRenderMonth();
  }
  sesRenderMonth();

  // FAQ Accordion
  var sesActiveFaq = null;
  function sesFaqToggle(idx) {
    var prev = sesActiveFaq;
    if (prev !== null && prev !== idx) {
      var prevEl = document.getElementById('ses-faq-' + prev);
      var prevIcon = document.getElementById('ses-faq-icon-' + prev);
      if (prevEl) prevEl.classList.remove('ses-open');
      if (prevIcon) prevIcon.classList.remove('ses-open');
    }
    var el = document.getElementById('ses-faq-' + idx);
    var icon = document.getElementById('ses-faq-icon-' + idx);
    if (sesActiveFaq === idx) {
      if (el) el.classList.remove('ses-open');
      if (icon) icon.classList.remove('ses-open');
      sesActiveFaq = null;
    } else {
      if (el) el.classList.add('ses-open');
      if (icon) icon.classList.add('ses-open');
      sesActiveFaq = idx;
    }
  }
</script>


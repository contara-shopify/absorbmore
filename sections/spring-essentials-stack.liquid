{% comment %}
  Spring Essentials Stack — Landing Page Section
  The Absorption Company / AbsorbMore
  Design: "Seasonal Shift" — Editorial Warmth
  Mobile-first, conversion-focused, subscription-focused
  NOTE: This section does NOT include a header or announcement bar —
        those are already provided by the Shopify theme.
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,700&display=swap" rel="stylesheet">

<style>
  /* ============================================
     SPRING ESSENTIALS STACK — LANDING PAGE CSS
     All rules scoped to #ses-root to avoid
     conflicts with the Shopify theme.
     Colors:
       Cream bg:       #F5F2EC
       Black:          #0A0A0A
       Vitamin D gold: #D4A820
       Curcumin amber: #E07820
       CoQ10 red:      #D43010
       Spring green:   #3D6B35
  ============================================ */

  /* Break out of Shopify's page content container */
  .ses-full-bleed {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
  }

  #ses-root {
    font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
    color: #0A0A0A;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  #ses-root * {
    box-sizing: border-box;
  }

  #ses-root a { text-decoration: none; cursor: pointer; }
  #ses-root button { border: none; background: none; cursor: pointer; font-family: inherit; }
  #ses-root img { display: block; max-width: 100%; }

  /* Inner content max-width for mobile-focused layout */
  .ses-inner {
    width: 100%;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }

  @media (min-width: 768px) {
    .ses-inner {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  .ses-display {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  /* Scroll reveal */
  .ses-reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .ses-reveal.ses-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Shimmer button */
  @keyframes ses-shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }
  .ses-btn-shimmer {
    background: linear-gradient(90deg, #0A0A0A 0%, #0A0A0A 40%, #3a3a3a 50%, #0A0A0A 60%, #0A0A0A 100%);
    background-size: 200% auto;
    animation: ses-shimmer 3s linear infinite;
    display: block;
    text-align: center;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1.1rem 1.5rem;
    font-size: 0.8rem;
    color: #F5F2EC !important;
    transition: opacity 0.2s;
    font-family: 'DM Sans', sans-serif;
  }
  .ses-btn-shimmer:hover { opacity: 0.9; }

  /* ---- ANNOUNCEMENT BAR ---- */
  #ses-root .ses-announce {
    background-color: #D43010;
    color: #F5F2EC;
    text-align: center;
    padding: 0.6rem 1rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ---- HERO ---- */
  #ses-root .ses-hero {
    position: relative;
    overflow: hidden;
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    background-color: #0A0A0A;
  }
  #ses-root .ses-hero-bg {
    position: absolute;
    inset: 0;
  }
  #ses-root .ses-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  #ses-root .ses-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10,10,10,0.1) 0%, rgba(10,10,10,0.5) 55%, rgba(10,10,10,0.88) 100%);
  }
  #ses-root .ses-hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 2.5rem;
    min-height: 90vh;
  }
  #ses-root .ses-hero-badge {
    display: inline-block;
    background-color: #D4A820;
    color: #0A0A0A;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.75rem;
    margin-bottom: 1rem;
  }
  #ses-root .ses-hero h1 {
    font-size: clamp(2.4rem, 9vw, 3.8rem);
    color: #F5F2EC;
    line-height: 1.0;
    margin: 0 0 1rem 0;
    font-weight: 800;
    letter-spacing: -0.03em;
  }
  #ses-root .ses-hero h1 span { color: #D4A820; }
  #ses-root .ses-hero-sub {
    color: rgba(245,242,236,0.88);
    font-size: 1rem;
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }
  #ses-root .ses-hero-price {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
    flex-wrap: wrap;
  }
  #ses-root .ses-hero-price-main {
    font-size: 2.5rem;
    font-weight: 800;
    color: #F5F2EC;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  #ses-root .ses-hero-price-old {
    font-size: 1.1rem;
    text-decoration: line-through;
    color: rgba(245,242,236,0.5);
  }
  #ses-root .ses-hero-price-badge {
    background-color: #D43010;
    color: #F5F2EC;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
  }
  #ses-root .ses-hero-sub-label {
    font-size: 0.85rem;
    color: rgba(245,242,236,0.7);
    margin-bottom: 1.5rem;
  }
  #ses-root .ses-hero-note {
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: rgba(245,242,236,0.6);
  }

  /* ---- TRUST BAR ---- */
  #ses-root .ses-trust-bar {
    background-color: #0A0A0A;
    border-bottom: 1px solid rgba(212,168,32,0.3);
    padding: 0.9rem 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  #ses-root .ses-trust-bar-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0 1.25rem;
    min-width: max-content;
  }
  #ses-root .ses-trust-item {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #D4A820;
    white-space: nowrap;
  }

  /* ---- SECTIONS ---- */
  #ses-root .ses-section { padding: 4rem 0; }
  #ses-root .ses-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
    display: block;
  }
  #ses-root .ses-h2 {
    font-size: clamp(1.8rem, 7vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 2.5rem;
  }
  #ses-root .ses-product-img {
    width: 100%;
    max-width: 320px;
    margin: 0 auto 2.5rem;
  }

  /* Product cards */
  #ses-root .ses-product-cards { display: flex; flex-direction: column; gap: 1rem; }
  #ses-root .ses-product-card {
    position: relative;
    overflow: hidden;
    background-color: #fff;
    padding: 1.25rem;
  }
  #ses-root .ses-product-card-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
  }
  #ses-root .ses-product-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  #ses-root .ses-product-card h3 {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
  }
  #ses-root .ses-absorption-badge {
    font-size: 0.62rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    margin-left: 0.5rem;
    flex-shrink: 0;
    line-height: 1.4;
  }
  #ses-root .ses-product-tagline {
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }
  #ses-root .ses-product-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #444;
    margin-bottom: 0.75rem;
  }
  #ses-root .ses-product-dose {
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #999;
  }

  /* Benefits */
  #ses-root .ses-benefits-section { background-color: #0A0A0A; }
  #ses-root .ses-benefits-list { display: flex; flex-direction: column; gap: 1.25rem; }
  #ses-root .ses-benefit-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.25rem;
    background-color: rgba(245,242,236,0.05);
  }
  #ses-root .ses-benefit-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 2px; }
  #ses-root .ses-benefit-title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
    flex-wrap: wrap;
  }
  #ses-root .ses-benefit-title {
    font-weight: 700;
    font-size: 0.95rem;
    color: #F5F2EC;
  }
  #ses-root .ses-benefit-badge {
    font-size: 0.62rem;
    font-weight: 600;
    padding: 0.15rem 0.4rem;
  }
  #ses-root .ses-benefit-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(245,242,236,0.7);
    margin: 0;
  }

  /* Lifestyle break */
  #ses-root .ses-lifestyle {
    position: relative;
    overflow: hidden;
    height: 300px;
  }
  #ses-root .ses-lifestyle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #ses-root .ses-lifestyle-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(10,10,10,0.45);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem;
  }
  #ses-root .ses-lifestyle-quote {
    font-size: clamp(1.5rem, 6vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #F5F2EC;
    margin-bottom: 0.5rem;
    line-height: 1.15;
  }
  #ses-root .ses-lifestyle-quote span { color: #D4A820; }
  #ses-root .ses-lifestyle-sub {
    font-size: 0.85rem;
    color: rgba(245,242,236,0.75);
    margin: 0;
  }

  /* Subscription section */
  #ses-root .ses-sub-section { background-color: #F5F2EC; }
  #ses-root .ses-toggle {
    display: flex;
    border: 2px solid #0A0A0A;
    overflow: hidden;
    margin-bottom: 2rem;
  }
  #ses-root .ses-toggle-btn {
    flex: 1;
    padding: 0.75rem;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: background-color 0.2s, color 0.2s;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
  }
  #ses-root .ses-toggle-btn.ses-active { background-color: #0A0A0A; color: #F5F2EC; }
  #ses-root .ses-toggle-btn:not(.ses-active) { background-color: transparent; color: #0A0A0A; }

  #ses-root .ses-price-box {
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: 2px solid #0A0A0A;
  }
  #ses-root .ses-price-box.ses-sub-mode { background-color: #0A0A0A; }
  #ses-root .ses-price-box.ses-one-mode { background-color: #fff; }

  #ses-root .ses-price-box-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1rem;
    gap: 0.75rem;
  }
  #ses-root .ses-price-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.25rem;
  }
  #ses-root .ses-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  #ses-root .ses-price-main {
    font-size: 2.8rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  #ses-root .ses-price-old {
    font-size: 1.1rem;
    text-decoration: line-through;
  }
  #ses-root .ses-price-period {
    font-size: 0.82rem;
    margin-top: 0.25rem;
  }
  #ses-root .ses-discount-badge {
    text-align: center;
    padding: 0.5rem 0.75rem;
    background-color: #D43010;
    flex-shrink: 0;
  }
  #ses-root .ses-discount-badge-num {
    font-size: 1.5rem;
    font-weight: 800;
    color: #F5F2EC;
    line-height: 1;
  }
  #ses-root .ses-discount-badge-label {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #F5F2EC;
  }
  #ses-root .ses-sub-perks { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; }
  #ses-root .ses-sub-perk {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
  }
  #ses-root .ses-sub-perk-check { color: #D4A820; font-weight: 700; }
  #ses-root .ses-buy-btn {
    display: block;
    text-align: center;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1rem;
    font-size: 0.8rem;
    transition: opacity 0.2s;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
  }
  #ses-root .ses-buy-btn:hover { opacity: 0.9; }

  #ses-root .ses-trust-badges {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  #ses-root .ses-trust-badge {
    text-align: center;
    padding: 0.75rem 0.5rem;
    border: 1px solid rgba(10,10,10,0.15);
  }
  #ses-root .ses-trust-badge-icon { font-size: 1.25rem; margin-bottom: 0.25rem; }
  #ses-root .ses-trust-badge-label {
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #444;
  }

  /* Timeline */
  #ses-root .ses-timeline-section { background-color: #3D6B35; }
  #ses-root .ses-month-tabs {
    display: flex;
    border: 2px solid rgba(245,242,236,0.3);
    margin-bottom: 2rem;
    overflow: hidden;
  }
  #ses-root .ses-month-tab {
    flex: 1;
    padding: 0.75rem;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: background-color 0.2s, color 0.2s;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    border: none;
  }
  #ses-root .ses-month-tab.ses-active { background-color: #F5F2EC; color: #0A0A0A; }
  #ses-root .ses-month-tab:not(.ses-active) { background-color: transparent; color: rgba(245,242,236,0.7); }

  #ses-root .ses-month-title {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #F5F2EC;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }
  #ses-root .ses-month-points { display: flex; flex-direction: column; gap: 0.75rem; }
  #ses-root .ses-month-point {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background-color: rgba(245,242,236,0.1);
  }
  #ses-root .ses-month-num {
    color: #D4A820;
    font-weight: 700;
    flex-shrink: 0;
    font-size: 0.85rem;
  }
  #ses-root .ses-month-text {
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(245,242,236,0.9);
    margin: 0;
  }
  #ses-root .ses-timeline-cta {
    margin-top: 2rem;
    display: block;
    text-align: center;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1rem;
    font-size: 0.8rem;
    background-color: #D4A820;
    color: #0A0A0A !important;
    transition: opacity 0.2s;
  }
  #ses-root .ses-timeline-cta:hover { opacity: 0.9; }

  /* Expert quote */
  #ses-root .ses-expert-section { background-color: #0A0A0A; }
  #ses-root .ses-quote {
    font-size: clamp(1.2rem, 4.5vw, 1.7rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #F5F2EC;
    line-height: 1.4;
    font-style: italic;
    margin-bottom: 1.5rem;
  }
  #ses-root .ses-quote-author { font-weight: 700; font-size: 0.9rem; color: #D4A820; }
  #ses-root .ses-quote-title { font-size: 0.75rem; color: rgba(245,242,236,0.5); margin-top: 0.25rem; }
  #ses-root .ses-clinician-box {
    margin-top: 2.5rem;
    padding: 1.25rem;
    border: 1px solid rgba(245,242,236,0.15);
  }
  #ses-root .ses-clinician-title { font-size: 0.9rem; font-weight: 700; color: #F5F2EC; margin-bottom: 0.25rem; }
  #ses-root .ses-clinician-sub { font-size: 0.75rem; color: rgba(245,242,236,0.5); margin: 0; }

  /* Product detail */
  #ses-root .ses-detail-section { background-color: #F5F2EC; }
  #ses-root .ses-detail-img { width: 100%; margin-bottom: 2rem; }
  #ses-root .ses-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  #ses-root .ses-pillar {
    text-align: center;
    padding: 1rem 0.5rem;
    border-top-width: 3px;
    border-top-style: solid;
  }
  #ses-root .ses-pillar-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.4;
    color: #444;
    margin: 0;
  }

  /* FAQ */
  #ses-root .ses-faq-section { background-color: #F5F2EC; }
  #ses-root .ses-faq-list { border-top: 1px solid rgba(10,10,10,0.15); }
  #ses-root .ses-faq-item { border-bottom: 1px solid rgba(10,10,10,0.15); }
  #ses-root .ses-faq-btn {
    width: 100%;
    text-align: left;
    padding: 1.25rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  #ses-root .ses-faq-q { font-weight: 600; font-size: 0.9rem; line-height: 1.4; color: #0A0A0A; margin: 0; }
  #ses-root .ses-faq-icon {
    flex-shrink: 0;
    font-size: 1.2rem;
    font-weight: 300;
    color: #0A0A0A;
    transition: transform 0.2s;
    line-height: 1;
  }
  #ses-root .ses-faq-icon.ses-open { transform: rotate(45deg); }
  #ses-root .ses-faq-answer {
    padding-bottom: 1.25rem;
    font-size: 0.85rem;
    line-height: 1.7;
    color: #555;
    display: none;
    margin: 0;
  }
  #ses-root .ses-faq-answer.ses-open { display: block; }

  /* Final CTA */
  #ses-root .ses-final-section { background-color: #0A0A0A; }
  #ses-root .ses-final-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  #ses-root .ses-final-price-main {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #F5F2EC;
    line-height: 1;
  }
  #ses-root .ses-final-price-old {
    font-size: 1.25rem;
    text-decoration: line-through;
    color: rgba(245,242,236,0.35);
  }
  #ses-root .ses-final-perks { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1.5rem; }
  #ses-root .ses-final-perk {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: rgba(245,242,236,0.7);
    margin: 0;
  }
  #ses-root .ses-final-perk-check { color: #D4A820; }

  /* Footer */
  #ses-root .ses-lp-footer {
    background-color: #0A0A0A;
    border-top: 1px solid rgba(245,242,236,0.1);
    padding: 2.5rem 0;
    text-align: center;
  }
  #ses-root .ses-footer-logo { height: 1.75rem; width: auto; margin: 0 auto 1rem; opacity: 0.85; }
  #ses-root .ses-footer-copy { font-size: 0.7rem; color: rgba(245,242,236,0.4); margin-bottom: 1rem; }
  #ses-root .ses-footer-links { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  #ses-root .ses-footer-link {
    font-size: 0.7rem;
    color: rgba(245,242,236,0.4);
    transition: opacity 0.2s;
  }
  #ses-root .ses-footer-link:hover { opacity: 0.7; }


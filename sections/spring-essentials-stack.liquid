      <img
        src="https://d2xsxph8kpxj0f.cloudfront.net/310519663397667003/KQurDGhXMafSUxMqMFEs4L/logo_white_c15ad721.png"
        alt="The Absorption Company"
        class="ses-footer-logo"
        loading="lazy"

        "min": 14,
        "max": 32,
        "step": 1,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "question_size_mobile",
        "label": "Question size — Mobile (px)",
        "default": 17,
        "min": 14,
        "max": 28,
        "step": 1,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "answer_size",

        "label": "Custom CSS"
      },
      {
        "type": "text",
        "id": "section_id",
        "label": "Section Id"
      }
    ],
    "blocks": [
      {
        "type": "faq",
        "name": "FAQ Item",
        "limit": 8,
        "settings": [
          {

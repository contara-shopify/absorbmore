{%- comment -%} FAQ Accordion Section {%- endcomment -%}
{%- liquid
  assign headline = section.settings.headline
  assign headline_color = section.settings.headline_color
  assign headline_size_desktop = section.settings.headline_size_desktop
  assign headline_size_mobile = section.settings.headline_size_mobile
  assign question_size_desktop = section.settings.question_size_desktop
  assign question_size_mobile = section.settings.question_size_mobile
  assign answer_size = section.settings.answer_size
  assign text_color = section.settings.text_color
  assign divider_color = section.settings.divider_color
  assign background_color = section.settings.background_color
  assign container_width = section.settings.container_width
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id

  assign image = section.settings.image
  assign image_url_alt = section.settings.image_url
  assign image_aspect = section.settings.image_aspect
  assign image_radius = section.settings.image_radius
  assign image_bg = section.settings.image_bg

  assign desktop_image_position = section.settings.desktop_image_position
  assign desktop_image_size = section.settings.desktop_image_size
  assign mobile_image_position = section.settings.mobile_image_position
  assign column_gap_desktop = section.settings.column_gap_desktop
  assign column_gap_mobile = section.settings.column_gap_mobile
  assign two_col_max_width = section.settings.two_col_max_width
  assign align_columns = section.settings.align_columns

  # Resolve image source
  assign img_src = ''
  if image
    assign img_src = image | image_url: width: 1400
  elsif image_url_alt != blank
    assign img_src = image_url_alt
  endif
  assign has_image = false
  if img_src != blank
    assign has_image = true
  endif

  # Resolve column ratios + flex order
  if desktop_image_size == 'larger'
    assign image_flex_d = 7
    assign content_flex_d = 5
  elsif desktop_image_size == 'smaller'
    assign image_flex_d = 5
    assign content_flex_d = 7
  else
    assign image_flex_d = 1
    assign content_flex_d = 1
  endif

  if desktop_image_position == 'left'
    assign image_order_d = 1
    assign content_order_d = 2
  else
    assign image_order_d = 2
    assign content_order_d = 1
  endif

  if mobile_image_position == 'above'
    assign image_order_m = 1
    assign content_order_m = 2
  else
    assign image_order_m = 2
    assign content_order_m = 1
  endif
-%}

{% capture selector %}[data-style-id="{{ section.id }}"]{% endcapture %}

{% capture css %}
  & {
    width: 100%;
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    {% if text_color != blank %}color: {{ text_color }};{% endif %}
    padding: 48px 24px;
  }

  /* Layout wrapper — applies in both modes; only switches to 2-col when image present */
  & .faq__layout {
    display: flex;
    flex-direction: column;
    gap: {{ column_gap_mobile }}px;
    width: 100%;
  }
  & .faq__image-col { order: {{ image_order_m }}; }
  & .faq__content-col { order: {{ content_order_m }}; min-width: 0; }

  /* Image */
  & .faq__image-wrap {
    aspect-ratio: {{ image_aspect }};
    border-radius: {{ image_radius }}px;
    overflow: hidden;
    background: {{ image_bg }};
    width: 100%;
  }
  & .faq__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Default container (single-column mode) */
  & .faq__container {
    max-width: {{ container_width }}px;
    margin: 0 auto;
  }

  /* When 2-col mode: container fills its column instead of being centered at 720px */
  & .faq__layout--has-image .faq__container {
    max-width: none;
    margin: 0;
  }
  & .faq__layout--has-image {
    max-width: {{ two_col_max_width }}px;
    margin: 0 auto;
  }

  & .faq__headline {
    font-weight: 900;
    line-height: 1.1;
    margin: 0 0 24px 0;
    font-size: {{ headline_size_mobile }}px;
    {% if headline_color != blank and headline_color.alpha != 0 %}color: {{ headline_color }};{% endif %}
  }

  & .faq__item {
    border-top: 1px solid {% if divider_color != blank %}{{ divider_color }}{% else %}#d4d4d4{% endif %};
  }
  & .faq__item:last-child {
    border-bottom: 1px solid {% if divider_color != blank %}{{ divider_color }}{% else %}#d4d4d4{% endif %};
  }

  & .faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
    padding: 24px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: inherit;
    font-family: inherit;
  }

  & .faq__question-text {
    font-weight: 700;
    font-size: {{ question_size_mobile }}px;
    line-height: 1.3;
  }

  & .faq__icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    position: relative;
  }

  & .faq__icon span {
    display: block;
    position: absolute;
    background-color: currentColor;
    border-radius: 1px;
    transition: transform 0.3s ease;
  }
  & .faq__icon span:first-child {
    width: 18px;
    height: 2px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  & .faq__icon span:last-child {
    width: 2px;
    height: 18px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  & .faq__icon--open span:last-child {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  & .faq__answer-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }
  & .faq__answer-wrapper--open {
    grid-template-rows: 1fr;
  }

  & .faq__answer {
    overflow: hidden;
  }

  & .faq__answer-inner {
    padding: 0 0 24px 0;
    font-size: {{ answer_size }}px;
    line-height: 1.7;
  }
  & .faq__answer-inner p { margin: 0 0 12px 0; }
  & .faq__answer-inner p:last-child { margin-bottom: 0; }

  @media (min-width: 768px) {
    & {
      padding: 80px 48px;
    }
    & .faq__headline {
      font-size: {{ headline_size_desktop }}px;
      margin-bottom: 32px;
    }
    & .faq__question-text {
      font-size: {{ question_size_desktop }}px;
    }

    /* 2-col activation on desktop */
    & .faq__layout--has-image {
      flex-direction: row;
      gap: {{ column_gap_desktop }}px;
      align-items: {{ align_columns }};
    }
    & .faq__layout--has-image .faq__image-col {
      order: {{ image_order_d }};
      flex: {{ image_flex_d }} 1 0;
      min-width: 0;
    }
    & .faq__layout--has-image .faq__content-col {
      order: {{ content_order_d }};
      flex: {{ content_flex_d }} 1 0;
      min-width: 0;
    }
  }
{% endcapture %}

{% capture section_content %}
  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  </style>

  <section
    data-style-id="{{ section.id }}"
    {% if section_id != blank %}id="{{ section_id }}"{% endif %}
  >
    <div class="faq__layout{% if has_image %} faq__layout--has-image{% else %} faq__layout--single{% endif %}">

      {% if has_image %}
        <div class="faq__image-col">
          <div class="faq__image-wrap">
            <img src="{{ img_src }}" alt="{{ headline | strip_html | escape }}" loading="lazy" class="faq__image" />
          </div>
        </div>
      {% endif %}

      <div class="faq__content-col">
        <div class="faq__container">

          {% if headline != blank %}
            <h2 class="faq__headline">{{ headline }}</h2>
          {% endif %}

          {% for block in section.blocks %}
            {%- liquid
              assign question = block.settings.question
              assign answer = block.settings.answer
            -%}

            <div
              class="faq__item"
              x-data="{ open: false }"
              {{ block.shopify_attributes }}
            >
              <button
                class="faq__question"
                @click="open = !open"
                :aria-expanded="open"
              >
                <span class="faq__question-text">{{ question }}</span>
                <span class="faq__icon" :class="open ? 'faq__icon--open' : ''">
                  <span></span>
                  <span></span>
                </span>
              </button>

              <div class="faq__answer-wrapper" :class="open ? 'faq__answer-wrapper--open' : ''">
                <div class="faq__answer">
                  <div class="faq__answer-inner">{{ answer }}</div>
                </div>
              </div>
            </div>
          {% endfor %}

        </div>
      </div>

    </div>
  </section>
{% endcapture %}

{{ section_content }}


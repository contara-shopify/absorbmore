      {
        "type": "range",
        "id": "headline_size_desktop",
        "label": "Headline size — Desktop (px)",
        "default": 48,
        "min": 20,
        "max": 80,
        "step": 1,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "headline_size_mobile",
        "label": "Headline size — Mobile (px)",
        "default": 32,
        "min": 16,
        "max": 60,
        "step": 1,
        "unit": "px"
      },
      {
        "type": "paragraph",
        "content": "t:all.empty_char"
      },
      {
        "type": "header",
        "content": "Style"
      },
      {
        "type": "range",
        "id": "question_size_desktop",
        "label": "Question size — Desktop (px)",

{%- if current_page != 420420 and current_page != 133737 and request.design_mode != true or settings.development__block_card_sections -%}
  {%- if section.settings.collection_card != blank -%}
    {%- render 'card_collection_card._styles', section: metaobjects.collection_cards[section.settings.collection_card].schema.value -%}
  {%- endif -%}
  {%- break -%}
{%- endif -%}

{%- if settings.development__block_card_sections != true and request.design_mode == true or current_page != 420420 or current_page != 133737 -%}
  {%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign section_type = "card_collection_card"
  assign _handle = section.settings.handle
  assign collection_card = section.settings.collection_card
  assign preview_collection = section.settings.preview_collection
  assign link_to_object = section.settings.link_to_object
  assign dynamic_text_color = section.settings.dynamic_text_color
  assign dynamic_background_color = section.settings.dynamic_background_color
  assign dynamic_border_color = section.settings.dynamic_border_color
  assign container_spacing = section.settings.container_spacing
  assign text_color = section.settings.text_color
  assign background_color = section.settings.background_color
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id
  assign override_preview_background = section.settings.override_preview_background
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
    if request.design_mode or request.visual_preview_mode
      assign _collection = preview_collection | default: collection

      if _collection == blank and request.design_mode
        assign _collection = collections.first
      endif
    endif

    if collection_card != blank
      assign _handle = collection_card | json | handleize
    endif

    assign card_class = _handle | handleize | prepend: "collection-card--"
  %}

  {% if request.design_mode or metaobjects.collection_cards[collection_card] == blank %}
    {% capture selector %}.collection-card--{{ _handle | handleize }}{% endcapture %}

    {% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
      {% capture css %}
        & {
        {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
        {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
        }
      {% endcapture %}
    {% endif %}

    <style>
      {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
      {% if request.design_mode %}
      {% assign query_selector = '[data-section-id="'|append: section.id | append: '"][data-preview-container] ' | append: selector %}
      {{- custom_css | replace: '&', query_selector  | strip_newlines | replace: '@media screen and', '@container'| replace: '@media', '@container' -}}
      {% endif %}
    </style>
  {% endif %}

  {% capture render_card %}
    <article
        data-collection-card="{{ _handle }}"
        data-collection-handle="{{ _collection.handle }}"
        x-data="{ ...(!!$el.getAttribute('data-collection-handle') ? _sections.initCollectionCard($el, $refs, $el.getAttribute('data-collection-handle')) : {}) }"
        x-defer="intersect"
        {% if request.design_mode != true or _collection.handle == blank %}
          x-ignore
        {% endif %}
        {% if link_to_object %}
          :href="card?.url"
          href="{{ _collection.url }}"
          {% if open_in_new_tab %}
            target="_blank"
          {% endif %}
        {% endif %}
        class="block {{ card_class }} card-loading {{ container_spacing }}"
        x-effect="() => { if (card?.hydrated && $el.classList.contains('card-loading')) $el.classList.remove('card-loading') }"
        x-init="utils.barbaPrefetchTargetPage($el, card?.url)"
        :style="`color: ${getDynamicValue(`{{ dynamic_text_color }}`) ?? ''}; background: ${getDynamicValue(`{{ dynamic_background_color }}`) ?? ''}; border-color: ${getDynamicValue(`{{ dynamic_border_color }}`) ?? ''};`">
      {% content_for "blocks" %}
    </article>
  {% endcapture %}

  {% if link_to_object %}
    {% assign render_card = render_card | replace: '<article', '<a' | replace: '</article', '</a' %}
  {% else %}
    {% assign render_card = render_card | replace: '<article', '<div' | replace: '</article', '</div' %}
  {% endif %}

  {% if request.design_mode or request.visual_preview_mode %}
    <script type="application/json"
            data-collection-data="{{ _collection.handle }}">{%- render '_json.collection', collection: _collection -%}</script>
  {% endif %}

  {% render '_components.card_preview', render_card: render_card %}

  {% if request.design_mode or metaobjects.product_cards[product_card] == blank %}
    <script>
      document.querySelectorAll(`[data-collection-card="{{ _handle }}"] style`).forEach(styleEl => document.querySelector('[data-cards-styles-section]')?.appendChild(styleEl));
      document.currentScript?.remove();
    </script>
  {% endif %}
{% endif %}


{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign section_type = "header_navigation_bar"
  assign transparent_templates = section.settings.transparent_templates
  assign transparent_custom_css = section.settings.transparent_custom_css
  assign container_spacing = section.settings.container_spacing
  assign text_color = section.settings.text_color
  assign background_color = section.settings.background_color
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid

  assign transparent_templates_array = transparent_templates | strip | remove: " " | split: ","

  assign transparent = ""
  for transparent_template in transparent_templates_array
    assign transparent_template_prefix = transparent_template | split: "." | first
    assign template_prefix = template | split: "." | first
    assign transparent_template_suffix = transparent_template | split: "." | last
    assign template_suffix = template | split: "." | last

    if transparent_template_prefix != template_prefix
      continue
    endif
    if transparent_template.size == 1 or transparent_template_suffix == template_suffix
      assign transparent = "navigation-bar--transparent"
      break
    endif
  endfor
%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
  {% capture css %}
    & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    }
  {% endcapture %}
{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  {{ transparent_custom_css | replace: '&', '.navigation-bar--transparent' | strip_newlines }}
</style>

<style>
  {% if transparent != blank %}
  :root {
    --navigation-bar-transparent-height: calc(-1 * var(--navigation-bar-height))
  }

  {% endif %}
</style>

<header data-style-id="{{ section.id }}--{{ block.id }}"
        x-data="{ ..._sections.initNavigationBar($el, $refs) }"
        data-navigation-bar
        @scroll.window.passive="$data.toggleTransparent($event, true)"
        @pointerover="$data.toggleTransparent"
        @pointerleave="$data.toggleTransparent"
        data-transparent-templates="{{ transparent_templates }}"
        x-init="$watch('$router.template', value => { $data.toggleTransparent() })"
        class="h-[--navigation-bar-height] @container transition-colors duration-200 {{ transparent }} {{ container_spacing }}">
  <script>
    (() => {
      const scrollPosition = +sessionStorage.getItem('_p_scrollpos') || window.history.state?.states?.[0]?.scroll?.y || window.scrollY || 0;
      if (window.history.scrollRestoration === 'auto' && scrollPosition > 300) {
        const navBar = document.querySelector('[data-style-id="{{ section.id }}--{{ block.id }}"]') ?? document.currentScript.parentElement;
        navBar?.style?.setProperty('transition', 'none', 'important');
        navBar?.classList.remove('navigation-bar--transparent');
        navBar?.style?.removeProperty('transition');
      }
      window.addEventListener("beforeunload", function (e) {
        sessionStorage.setItem('_p_scrollpos', window.scrollY);
      });
      document.currentScript.remove();
    })();
  </script>
  {% content_for 'blocks' %}
</header>



{% comment %}
  Section: WLP-1 Listicle — 5 Reasons You're Doing Everything Right
  File: sections/wlp1-listicle.liquid
{% endcomment %}

{% style %}
  .listicle-lp *,
  .listicle-lp *::before,
  .listicle-lp *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .listicle-lp {
    --cream: #f7f4ef;
    --ink: #1a1a1a;
    --ink-light: #3a3a3a;
    --ink-muted: #6b6b6b;
    --blue: #5e91d5;
    --blue-hover: #4a7dbe;
    --blue-light: #eef0ff;
    --warm-white: #fffdf9;
    --border: #e5e0d8;
    --green: #1a8917;
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* Body */
  body {
    margin: 0;
    padding: 0;
  }

  /* Hide header and footer */
  header,
  footer {
    display: none;
  }

  /* ── STICKY HEADER ── */
  .listicle-lp .sticky-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--ink);
    padding: 10px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
  }
  .listicle-lp .sticky-bar.show {
    transform: translateY(0);
  }
  .listicle-lp .sticky-bar p {
    color: #fff;
    font-size: 14px;
    font-weight: 500;
  }
  .listicle-lp .sticky-bar p span {
    color: #ffd666;
    font-weight: 700;
  }
  .listicle-lp .sticky-btn {
    background: var(--blue);
    color: #fff;
    padding: 8px 24px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .listicle-lp .sticky-btn:hover {
    background: var(--blue-hover);
  }

  /* ── BRAND HEADER ── */
  .listicle-lp .brand-header {
    background: #fff;
    border-bottom: 1px solid var(--border);
    padding: 18px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .listicle-lp .brand-logo {
    font-size: 19px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0.2px;
    text-decoration: none;
  }
  .listicle-lp .brand-logo-mark {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--blue);
    border-radius: 50%;
    margin-right: 10px;
    vertical-align: middle;
  }
  .listicle-lp .brand-nav {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .listicle-lp .brand-nav a {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-light);
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: color 0.2s;
  }
  .listicle-lp .brand-nav a:hover {
    color: var(--blue);
  }
  .listicle-lp .brand-nav .shop-link {
    background: var(--ink);
    color: #fff;
    padding: 9px 20px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    transition: background 0.2s;
  }
  .listicle-lp .brand-nav .shop-link:hover {
    background: var(--blue);
    color: #fff;
  }
  @media (max-width: 600px) {
    .listicle-lp .brand-header {
      padding: 14px 20px;
    }
    .listicle-lp .brand-logo {
      font-size: 17px;
    }
    .listicle-lp .brand-nav {
      gap: 16px;
    }
    .listicle-lp .brand-nav .text-link {
      display: none;
    }
  }

  /* ── HERO ── */
  .listicle-lp .hero {
    background: var(--cream);
    padding: 72px 24px 56px;
    text-align: center;
  }
  .listicle-lp .hero-inner {
    max-width: 680px;
    margin: 0 auto;
  }
  .listicle-lp .hero-eyebrow {
    display: inline-block;
    background: var(--blue-light);
    color: var(--blue);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 24px;
  }
  .listicle-lp .hero h1 {
    font-size: clamp(32px, 6vw, 52px);
    font-weight: 500;
    line-height: 1.15;
    margin-bottom: 20px;
  }
  .listicle-lp .hero h1 .h1-highlight {
    text-decoration: underline;
    text-decoration-color: var(--blue);
    text-underline-offset: 4px;
    text-decoration-thickness: 3px;
  }
  .listicle-lp .hero-sub {
    font-size: 17px;
    color: var(--ink-muted);
    line-height: 1.65;
    max-width: 540px;
    margin: 0 auto 32px;
  }
  .listicle-lp .hero-cta {
    display: inline-block;
    background: var(--blue);
    color: #fff;
    padding: 16px 40px;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: background 0.2s, transform 0.15s;
  }
  .listicle-lp .hero-cta:hover {
    background: var(--blue-hover);
    transform: translateY(-1px);
  }
  .listicle-lp .hero-micro {
    margin-top: 12px;
    font-size: 12px;
    color: var(--ink-muted);
  }
  .listicle-lp .hero-micro span {
    margin: 0 4px;
    opacity: 0.4;
  }

  /* ── TRUST BAR ── */
  .listicle-lp .trust-bar {
    background: #fff;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 20px 24px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .listicle-lp .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-light);
  }
  .listicle-lp .trust-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* ── REASON CARDS ── */
  .listicle-lp .reason-section {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .listicle-lp .reason-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    padding: 64px 0;
    border-bottom: 1px solid var(--border);
  }
  .listicle-lp .reason-card:nth-child(even) .reason-visual {
    order: -1;
  }

  .listicle-lp .reason-num-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--blue);
    color: #fff;
    font-size: 15px;
    font-weight: 800;
    margin-bottom: 14px;
  }
  .listicle-lp .reason-card h2 {
    font-size: 26px;
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 14px;
  }
  .listicle-lp .reason-card .body-text {
    font-size: 15px;
    color: var(--ink-light);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .listicle-lp .wlp-callout {
    background: var(--blue-light);
    border-radius: 8px;
    padding: 18px 20px;
  }
  .listicle-lp .wlp-callout-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 6px;
  }
  .listicle-lp .wlp-callout p {
    font-size: 14px;
    color: var(--ink-light);
    line-height: 1.65;
  }
  .listicle-lp .wlp-callout strong {
    color: var(--ink);
  }

  .listicle-lp .stat-row {
    display: flex;
    gap: 10px;
    margin-top: 14px;
    flex-wrap: wrap;
  }
  .listicle-lp .stat-chip {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 700;
    color: var(--blue);
    white-space: nowrap;
  }

  .listicle-lp .reason-visual {
    border-radius: 12px;
    overflow: hidden;
    background: var(--cream);
    aspect-ratio: 4/5;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .listicle-lp .reason-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── REASON CTA LINK ── */
  .listicle-lp .reason-cta-link {
    display: inline-block;
    margin-top: 20px;
    font-size: 14px;
    font-weight: 700;
    color: var(--blue);
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: opacity 0.2s;
  }
  .listicle-lp .reason-cta-link:hover {
    opacity: 0.75;
  }
  .listicle-lp .reason-cta-link svg {
    display: inline-block;
    vertical-align: middle;
    margin-left: 4px;
    transition: transform 0.2s;
  }
  .listicle-lp .reason-cta-link:hover svg {
    transform: translateX(3px);
  }

  /* ── INLINE CTA (Quiz Banner) ── */
  .listicle-lp .inline-cta {
    background: var(--blue);
    border-radius: 12px;
    padding: 44px 32px;
    text-align: center;
    margin: 48px 0;
    position: relative;
    overflow: hidden;
  }
  .listicle-lp .inline-cta::before {
    content: '';
    position: absolute;
    top: -40px;
    right: -40px;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
  }
  .listicle-lp .inline-cta::after {
    content: '';
    position: absolute;
    bottom: -30px;
    left: -30px;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.04);
  }
  .listicle-lp .inline-cta .quiz-eyebrow {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 12px;
  }
  .listicle-lp .inline-cta h3 {
    font-size: 28px;
    font-weight: 500;
    margin-bottom: 8px;
    color: #fff;
    position: relative;
  }
  .listicle-lp .inline-cta p {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 24px;
    position: relative;
  }
  .listicle-lp .inline-cta .quiz-btn {
    display: inline-block;
    background: #fff;
    color: var(--blue);
    padding: 14px 36px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: transform 0.15s, box-shadow 0.2s;
    position: relative;
  }
  .listicle-lp .inline-cta .quiz-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  /* ── CLINICAL RESULTS ── */
  .listicle-lp .social-proof {
    background: var(--cream);
    padding: 64px 24px;
  }
  .listicle-lp .social-proof-inner {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }
  .listicle-lp .sp-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 12px;
  }
  .listicle-lp .social-proof h2 {
    font-size: 32px;
    font-weight: 500;
    margin-bottom: 40px;
  }
  .listicle-lp .testimonial-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    text-align: left;
  }
  .listicle-lp .testimonial {
    background: #fff;
    border-radius: 10px;
    padding: 28px;
    border: 1px solid var(--border);
    position: relative;
  }
  .listicle-lp .testimonial .quote-mark {
    font-size: 48px;
    line-height: 1;
    color: var(--blue);
    opacity: 0.2;
    position: absolute;
    top: 16px;
    left: 24px;
  }
  .listicle-lp .testimonial .quote {
    font-size: 15px;
    color: var(--ink-light);
    line-height: 1.7;
    margin-bottom: 16px;
    margin-top: 20px;
    font-style: italic;
  }
  .listicle-lp .testimonial .quote strong {
    font-style: normal;
    font-weight: 800;
    color: var(--ink);
    font-size: 16px;
  }
  .listicle-lp .testimonial .source {
    font-size: 11px;
    font-weight: 600;
    color: var(--ink-muted);
    padding-top: 12px;
    border-top: 1px solid var(--border);
    letter-spacing: 0.3px;
  }
  .listicle-lp .testimonial .source-badge {
    display: inline-block;
    background: var(--blue);
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 3px;
    margin-right: 6px;
    vertical-align: middle;
  }

  /* ── COMPARISON ── */
  .listicle-lp .comparison {
    max-width: 680px;
    margin: 0 auto;
    padding: 64px 24px;
  }
  .listicle-lp .comparison h2 {
    font-size: 32px;
    font-weight: 500;
    text-align: center;
    margin-bottom: 32px;
  }
  .listicle-lp .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .listicle-lp .compare-table thead th {
    padding: 14px 16px;
    font-size: 13px;
    font-weight: 700;
    text-align: left;
    border-bottom: 2px solid var(--ink);
  }
  .listicle-lp .compare-table thead th:first-child {
    width: 45%;
  }
  .listicle-lp .compare-table thead th.hl {
    background: var(--blue-light);
    color: var(--blue);
    border-radius: 8px 8px 0 0;
    text-align: center;
  }
  .listicle-lp .compare-table thead th:not(:first-child):not(.hl) {
    text-align: center;
    color: var(--ink-muted);
  }
  .listicle-lp .compare-table tbody td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }
  .listicle-lp .compare-table tbody td:not(:first-child) {
    text-align: center;
  }
  .listicle-lp .compare-table tbody td.hl {
    background: var(--blue-light);
    font-weight: 600;
    color: var(--ink);
  }
  .listicle-lp .ck {
    color: var(--green);
    font-size: 18px;
    font-weight: 700;
  }
  .listicle-lp .cx {
    color: #d93025;
    font-size: 18px;
    font-weight: 700;
    opacity: 0.45;
  }

  /* ── FINAL CTA ── */
  .listicle-lp .final-cta {
    background: var(--ink);
    color: #fff;
    text-align: center;
    padding: 80px 24px;
  }
  .listicle-lp .final-cta h2 {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 500;
    line-height: 1.2;
    max-width: 540px;
    margin: 0 auto 12px;
  }
  .listicle-lp .final-cta > p {
    font-size: 16px;
    color: #ffffff99;
    max-width: 440px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }
  .listicle-lp .cta-white {
    display: inline-block;
    background: #fff;
    color: var(--ink);
    padding: 16px 44px;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: transform 0.15s;
  }
  .listicle-lp .cta-white:hover {
    transform: translateY(-1px);
  }
  .listicle-lp .final-cta .cta-details {
    margin-top: 16px;
    font-size: 12px;
    color: #ffffff66;
  }
  .listicle-lp .final-cta .cta-details span {
    margin: 0 6px;
  }
  .listicle-lp .final-cta .quiz-link {
    color: #ffffffaa;
    font-size: 14px;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .listicle-lp .final-cta .quiz-link:hover {
    color: #fff;
  }

  .listicle-lp .disclaimer {
    text-align: center;
    padding: 32px 24px 56px;
    max-width: 600px;
    margin: 0 auto;
  }
  .listicle-lp .disclaimer p {
    font-size: 10px;
    color: var(--ink-muted);
    line-height: 1.8;
    opacity: 0.65;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 720px) {
    .listicle-lp .reason-card {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 48px 0;
    }
    .listicle-lp .reason-card:nth-child(even) .reason-visual {
      order: 0;
    }
    .listicle-lp .reason-visual {
      aspect-ratio: 16/10;
    }
    .listicle-lp .testimonial-grid {
      grid-template-columns: 1fr;
    }
    .listicle-lp .compare-table {
      font-size: 13px;
    }
    .listicle-lp .compare-table thead th,
    .listicle-lp .compare-table tbody td {
      padding: 10px 10px;
    }
    .listicle-lp .sticky-bar p {
      font-size: 12px;
    }
  }
  @media (max-width: 480px) {
    .listicle-lp .trust-bar {
      gap: 16px;
      padding: 16px;
    }
    .listicle-lp .trust-item {
      font-size: 11px;
    }
    .listicle-lp .hero {
      padding: 56px 20px 44px;
    }
    .listicle-lp .inline-cta {
      padding: 28px 20px;
    }
    .listicle-lp .sticky-bar {
      gap: 10px;
      padding: 8px 16px;
    }
  }
{% endstyle %}

<div class="listicle-lp">
  <!-- STICKY HEADER -->
  <div class="sticky-bar" id="listicleStickyBar">
    <p>GLP-1 support in a pill. <span>No needles. No prescription.</span></p>
    <a href="{{ section.settings.cta_url }}" class="sticky-btn">{{ section.settings.cta_text }}</a>
  </div>

  <!-- BRAND HEADER -->
  <header class="brand-header">
    <a href="{{ section.settings.brand_url | default: '/' }}" class="brand-logo">
      <span class="brand-logo-mark"></span>{{ section.settings.brand_name }}
    </a>
    <nav class="brand-nav">
      {% if section.settings.nav_link_1_text != blank %}
        <a href="{{ section.settings.nav_link_1_url }}" class="text-link">{{ section.settings.nav_link_1_text }}</a>
      {% endif %}
      {% if section.settings.nav_link_2_text != blank %}
        <a href="{{ section.settings.nav_link_2_url }}" class="text-link">{{ section.settings.nav_link_2_text }}</a>
      {% endif %}
      <a href="{{ section.settings.cta_url }}" class="shop-link">Shop</a>
    </nav>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-eyebrow">{{ section.settings.eyebrow }}</div>
      <h1>
        {{ section.settings.headline_top -}}
        <br>
        <span class="h1-highlight">{{ section.settings.headline_bottom }}</span>
      </h1>
      <p class="hero-sub">{{ section.settings.subheadline }}</p>
      <a href="{{ section.settings.cta_url }}" class="hero-cta">{{ section.settings.cta_text }}</a>
      <p class="hero-micro">No needles <span>&middot;</span> No stimulants <span>&middot;</span> No prescription</p>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar" id="listicleTrustBar">
    <div class="trust-item">
      <svg class="trust-icon" viewBox="0 0 20 20" fill="none">
        <path d="M10 1l2.39 4.84L18 6.71l-4 3.9.94 5.5L10 13.58 5.06 16.1l.94-5.5-4-3.89 5.61-.87L10 1z" fill="#F5A623"/>
      </svg>
      4.8 / 5 Rating
    </div>
    <div class="trust-item">
      <svg class="trust-icon" viewBox="0 0 20 20" fill="none">
        <circle cx="10" cy="10" r="8" fill="none" stroke="#1A8917" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="#1A8917" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Clinically Studied
    </div>
    <div class="trust-item">
      <svg class="trust-icon" viewBox="0 0 20 20" fill="none">
        <path d="M10 1L3 5v5c0 4.14 2.99 8.02 7 9 4.01-.98 7-4.86 7-9V5l-7-4z" fill="none" stroke="#5e91d5" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="#5e91d5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      3rd-Party Tested
    </div>
    <div class="trust-item">
      <svg class="trust-icon" viewBox="0 0 20 20" fill="none">
        <rect x="3" y="3" width="14" height="14" rx="3" fill="none" stroke="#5e91d5" stroke-width="1.5"/><path d="M7 10h6M10 7v6" stroke="#5e91d5" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      Clean Ingredients
    </div>
  </div>

  <!-- REASONS -->
  <section class="reason-section">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'reason' %}
          <div class="reason-card" {{ block.shopify_attributes }}>
            <div class="reason-content">
              <div class="reason-num-badge">{{ block.settings.number }}</div>
              <h2>{{ block.settings.title }}</h2>
              <p class="body-text">{{ block.settings.body }}</p>
              <div class="wlp-callout">
                <div class="wlp-callout-label">How WLP-1&trade; fixes this</div>
                <p>{{ block.settings.callout }}</p>

{%- capture json -%}
  {
  "product_count": {{- predictive_search.resources.products.size | json -}},
  "collection_count": {{- predictive_search.resources.collections.size | json -}},
  "article_count": {{- predictive_search.resources.articles.size | json -}},
  "page_count": {{- predictive_search.resources.pages.size | json -}},
  "products": [
  {%- for product in predictive_search.resources.products -%}
    {% render '_json.product', product: product, card: true, meta_product: true %}
    {%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
  ],
  "collections": [
  {%- for collection in predictive_search.resources.collections -%}
    {% render '_json.collection', collection: collection %}
    {%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
  ],
  "articles": [
  {%- for article in predictive_search.resources.articles -%}
    {% render '_json.article', article: article %}
    {%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
  ],
  "pages": [
  {%- for page in predictive_search.resources.pages -%}
    {% render '_json.page', page: page %}
    {%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
  ],
  "types": {{- predictive_search.types | json -}}
  }
{%- endcapture -%}
<script type="application/json" data-predictive-search>{{- json | strip | strip_newlines -}}</script>

{% schema %}
{
  "name": "Predictive Search",
  "class": "shopify_section__data_predictive_search"
}
{% endschema %}

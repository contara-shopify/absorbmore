{%- comment -%} Interstitial CTA Banner {%- endcomment -%}
{%- liquid
  assign headline = section.settings.headline
  assign headline_color = section.settings.headline_color
  assign headline_size_desktop = section.settings.headline_size_desktop
  assign headline_size_mobile = section.settings.headline_size_mobile
  assign body_text = section.settings.body_text
  assign body_color = section.settings.body_color
  assign body_size_desktop = section.settings.body_size_desktop
  assign body_size_mobile = section.settings.body_size_mobile
  assign cta_text = section.settings.cta_text
  assign cta_url = section.settings.cta_url
  assign cta_bg = section.settings.cta_bg
  assign cta_text_color = section.settings.cta_text_color
  assign cta_badge_text = section.settings.cta_badge_text
  assign cta_badge_bg = section.settings.cta_badge_bg
  assign cta_badge_text_color = section.settings.cta_badge_text_color
  assign bg_image_desktop = section.settings.bg_image_desktop
  assign bg_image_mobile = section.settings.bg_image_mobile
  assign bg_overlay_color = section.settings.bg_overlay_color
  assign bg_overlay_opacity = section.settings.bg_overlay_opacity
  assign background_color = section.settings.background_color
  assign container_width = section.settings.container_width
  assign min_height_desktop = section.settings.min_height_desktop
  assign min_height_mobile = section.settings.min_height_mobile
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id
-%}

{% capture selector %}[data-style-id="{{ section.id }}"]{% endcapture %}

{% capture css %}
  & {
    position: relative;
    width: 100%;
    max-width: {{ section.settings.section_width }}px;
    margin-left: auto;
    margin-right: auto;
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    overflow: hidden;
    min-height: {{ min_height_mobile }}px;
    display: flex;
    align-items: center; 
    border-radius: 0;
    overflow: hidden;

    @media (min-width: 768px) {
      border-radius: 16px;
    }
  }

  & .icta__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  & .icta__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  & .icta__bg--desktop {
    display: none;
  }
  & .icta__bg--mobile {
    display: block;
    width: 100%;
    height: 100%;
  }

  & .icta__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    {% if bg_overlay_color != blank %}
      background-color: {{ bg_overlay_color }};
      opacity: {{ bg_overlay_opacity | divided_by: 100.0 }};
    {% endif %}
  }

  & .icta__content {
    position: relative;
    z-index: 2;
    max-width: {{ container_width }}px;
    margin: 0 auto;
    padding: 48px 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  & .icta__headline {
    font-weight: 900;
    line-height: 1.1;
    margin: 0;
    font-size: {{ headline_size_mobile }}px;
    {% if headline_color != blank %}color: {{ headline_color }};{% endif %}
  }

  & .icta__body {
    line-height: 1.6;
    margin: 0;
    font-size: {{ body_size_mobile }}px;
    {% if body_color != blank %}color: {{ body_color }};{% endif %}
  }
  & .icta__body p { margin: 0; }

  & .icta__cta-wrap {
    position: relative;
    display: inline-flex;
    margin-top: 8px;
  }

  & .icta__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    font-weight: 700;
    font-size: 17px;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s;
    {% if cta_bg != blank %}background-color: {{ cta_bg }};{% endif %}
    {% if cta_text_color != blank %}color: {{ cta_text_color }};{% endif %}
  }
  & .icta__cta:hover {
    opacity: 0.9;
  }

  & .icta__cta-badge {
    position: absolute;
    top: -12px;
    right: -16px;
    padding: 4px 12px;
    font-size: 13px;
    font-weight: 700;
    {% comment %} font-style: italic; {% endcomment %}
    border-radius: 100px;
    white-space: nowrap;
    transform: rotate(6deg);
    z-index: 2;
    {% if cta_badge_bg != blank %}background-color: {{ cta_badge_bg }};{% endif %}
    {% if cta_badge_text_color != blank %}color: {{ cta_badge_text_color }};{% endif %}
  }

  @media (min-width: 768px) {
    & {
      min-height: {{ min_height_desktop }}px;
    }
    & .icta__bg--desktop {
      display: block;
      width: 100%;
      height: 100%;
    }
    & .icta__bg--mobile {
      display: none;
    }
    & .icta__content {
      padding: 20px 24px;
    }
    & .icta__headline {
      font-size: {{ headline_size_desktop }}px;
    }
    & .icta__body {
      font-size: {{ body_size_desktop }}px;
    }
    & .icta__cta {
      padding: 12px 24px;
      font-size: 18px;
    }
  }
{% endcapture %}

{% capture section_content %}
  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  </style>

  <section
    data-style-id="{{ section.id }}"
    {% if section_id != blank %}id="{{ section_id }}"{% endif %}
  >

    {% if bg_image_desktop != blank or bg_image_mobile != blank %}
      <div class="icta__bg">
        {% if bg_image_mobile != blank %}
          <img class="icta__bg--mobile" src="{{ bg_image_mobile | image_url: width: 800 }}" alt="" loading="lazy">
        {% elsif bg_image_desktop != blank %}
          <img class="icta__bg--mobile" src="{{ bg_image_desktop | image_url: width: 800 }}" alt="" loading="lazy">
        {% endif %}
        {% if bg_image_desktop != blank %}
          <img class="icta__bg--desktop" src="{{ bg_image_desktop | image_url: width: 2000 }}" alt="" loading="lazy">
        {% endif %}
      </div>
      <div class="icta__overlay"></div>
    {% endif %}

    <div class="icta__content">

      {% if headline != blank %}
        <h2 class="icta__headline">{{ headline }}</h2>
      {% endif %}

      {% if body_text != blank %}
        <div class="icta__body">{{ body_text }}</div>
      {% endif %}

      {% if cta_text != blank %}
        <div class="icta__cta-wrap">
          <a href="{{ cta_url | default: '#' }}" class="icta__cta">{{ cta_text }}</a>
          {% if cta_badge_text != blank %}
            <span class="icta__cta-badge">{{ cta_badge_text }}</span>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </section>
{% endcapture %}

{{ section_content }}

{% schema %}
{

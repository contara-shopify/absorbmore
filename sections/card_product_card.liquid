{%- if current_page != 420420 and current_page != 133737 and request.design_mode != true or settings.development__block_card_sections -%}
  {%- if section.settings.product_card != blank -%}
    {%- render 'card_product_card._styles', section: metaobjects.product_cards[section.settings.product_card].schema.value -%}
  {%- endif -%}
  {%- break -%}
{%- endif -%}

{%- if settings.development__block_card_sections != true and request.design_mode == true or current_page != 420420 or current_page != 133737 -%}
  {%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign section_type = "card_product_card"
  assign _handle = section.settings.handle
  assign product_card = section.settings.product_card
  assign preview_product = section.settings.preview_product
  assign link_to_object = section.settings.link_to_object
  assign open_in_new_tab = section.settings.open_in_new_tab
  assign default_select_selling_plan = section.settings.default_select_selling_plan
  assign default_variant_metafield = section.settings.default_variant_metafield
  assign dynamic_text_color = section.settings.dynamic_text_color
  assign dynamic_background_color = section.settings.dynamic_background_color
  assign dynamic_border_color = section.settings.dynamic_border_color
  assign container_spacing = section.settings.container_spacing
  assign text_color = section.settings.text_color
  assign background_color = section.settings.background_color
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id
  assign override_preview_background = section.settings.override_preview_background
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
    if request.design_mode or request.visual_preview_mode
      assign _product = preview_product | default: product

      if _product == blank
        assign _product = collections.all.products[0]
      endif
    endif

    if product_card != blank
      assign _handle = product_card | json | handleize
    endif

    assign card_class = _handle | handleize | prepend: "product-card--"
  %}

  {% if request.design_mode or metaobjects.product_cards[product_card] == blank %}
    {% capture selector %}.product-card--{{ _handle | handleize }}{% endcapture %}

    {% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
      {% capture css %}
        & {
        {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
        {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
        }
      {% endcapture %}
    {% endif %}

    <style>
      {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
      {% if request.design_mode %}
      {% assign query_selector = '[data-section-id="'|append: section.id | append: '"][data-preview-container] ' | append: selector %}
      {{- custom_css | replace: '&', query_selector  | strip_newlines | replace: '@media screen and', '@container'| replace: '@media', '@container' -}}
      {% endif %}
    </style>
  {% endif %}

  {% capture render_card %}
    <article
        data-product-card="{{ _handle }}"
        data-product-handle="{{ _product.handle }}"
        data-product-id="{{ _product.id }}"
        data-ctr-discount-config='{{ _product.metafields.custom.ctr_discount_config.value | json | escape }}'
        x-data="{ ...(!!$el.getAttribute('data-product-handle') ? _sections.initProductCard($el, $refs, $el.getAttribute('data-product-handle'), +$el.getAttribute('data-product-id'), +$el.getAttribute('data-variant-id'), $el.hasAttribute('data-default-subscription'), $el.hasAttribute('data-show-subscription-price')) : {}) }"
        x-defer="intersect"
        {% if request.design_mode != true or _product.handle == blank %}
          x-ignore
        {% endif %}
        {% if default_select_selling_plan %}
          data-default-subscription="true"
        {% endif %}
        {% if link_to_object %}
          :href="`${_stores.router?.pathname?.replace(/^.*?(\/collections\/[^/]*)?.*$/gi,'$1')?.replace(/^\/$/gi,'') ?? ''}/products/${p_card?.product_handle}?variant=${p_card?.selected_variant?.id}${$el.hasAttribute('data-recommendation-params') ? `&${$el.getAttribute('data-recommendation-params')}` : ''}`"
          href="{{ _product.url | within: collection }}"
          {% if open_in_new_tab %}
            target="_blank"
          {% endif %}
        {% endif %}
        class="block {{ card_class }} card-loading {{ container_spacing }}"
        x-effect="() => { if (p_card?.hydrated && $el.classList.contains('card-loading')) $el.classList.remove('card-loading') }"
        x-init="utils.barbaPrefetchTargetPage($el, `${window.location.origin}/products/${p_card?.product_handle}`)"
        :style="`color: ${getDynamicValue(`{{ dynamic_text_color }}`) ?? ''}; background: ${getDynamicValue(`{{ dynamic_background_color }}`) ?? ''}; border-color: ${getDynamicValue(`{{ dynamic_border_color }}`) ?? ''};`"
        data-settings="{{ section.settings | json | escape }}">
      {% content_for "blocks" %}
    </article>
  {% endcapture %}

  {% if link_to_object %}
    {% assign render_card = render_card | replace: '<article', '<a' | replace: '</article', '</a' %}
  {% else %}
    {% assign render_card = render_card | replace: '<article', '<div' | replace: '</article', '</div' %}
  {% endif %}

  {% if request.design_mode or request.visual_preview_mode %}
    <script type="application/json"
            data-product-data="{{ _product.handle }}">{%- render '_json.product', product: _product, card: true -%}</script>
  {% endif %}

  {% render '_components.card_preview', render_card: render_card %}

  {% if request.design_mode or metaobjects.product_cards[product_card] == blank %}
    <script>
      document.querySelectorAll(`[data-product-card="{{ _handle }}"] style`).forEach(styleEl => document.querySelector('[data-cards-styles-section]')?.appendChild(styleEl));
      document.currentScript?.remove();
    </script>
  {% endif %}
{%- endif -%}


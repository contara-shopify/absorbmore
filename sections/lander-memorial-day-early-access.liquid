  }

  /* Summer Ready Stack buybox — ported from lander-summer-ready-stack-md-sale */
  .lnd-mday .lnd-srs__buybox { --sale-navy: #0D273E; --sale-red: #DB3519; --sale-navy-2: #143452; --sale-cream: #efe9dd; --sale-bg: #f6f6f4; --sale-gold: #d4a23a; background: var(--sale-bg); padding: 36px 16px 44px; font-family: inherit; color: var(--sale-navy); }
  .lnd-mday .lnd-srs__buybox * { box-sizing: border-box; }
  .lnd-mday .lnd-srs__buybox-inner { position: relative; max-width: 780px; margin: 0 auto; background: #fff; border-radius: 22px; padding: 22px 18px 24px; box-shadow: 0 20px 50px rgba(13,39,62,0.10); border: 1px solid #ececec; overflow: hidden; }

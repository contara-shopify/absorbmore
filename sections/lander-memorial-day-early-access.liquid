{%- comment -%} Memorial Day VIP Early Access — 35% off sitewide via Intelligems, ends 2026-05-20 23:59 ET v41 countdown-compact {%- endcomment -%}

{%- liquid
  assign discount_pct = section.settings.discount_pct | default: 35
  assign keep_pct = 100 | minus: discount_pct
  assign end_iso = section.settings.end_iso | default: '2026-05-20T23:59:59-04:00'
  assign srs_url = '/products/summer-ready-stack'
  assign srs_url_3mo = srs_url | append: '?variant=52671161499937'
  assign srs_url_1mo = srs_url | append: '?variant=52671161467169'

  comment
    Shopify's `all_products[handle]` global has a hard 20-unique-product limit per template render.
    Keep the combined list <= 20 unique handles or products beyond the limit render as the previous one.
  endcomment
  assign bestsellers = 'wlp-1,berberine,restore,weight-management-stack,summer-ready-stack,magnesium-glycinate,vitamin-d-k,hormone-metabolism' | split: ','
  assign powder_handles = '|restore|sleep|calm|energy|'
  assign weight = 'weight-management-stack,wlp-1,glp-1-nutrient-support-stack,hormone-metabolism,metabolic-balance-stack,berberine' | split: ','
  assign sleep_mood = 'sleep,magnesium-sleep-bundle,rest-recovery-stack,advanced-sleep-recovery-set,calm' | split: ','
  assign longevity = 'longevity,daily-basics,vitamin-d-k,starter-pack' | split: ','
  assign immunity = 'curcumin,inflammation-immunity' | split: ','
  assign all_handles = bestsellers | concat: weight | concat: sleep_mood | concat: longevity | concat: immunity

  comment
    Matches theme setting `data__product__excluded_pdp_selling_plan_names` so the lander shows the same curated
    subscription cadences as the PDP. Pipe-delimited with leading + trailing pipe so we can use a single `contains` check.
  endcomment
  assign excluded_plan_names = '|Every 2 Week(s)|Every 1 Month(s)|Every 2 Month(s)|Every 3 Month(s)|Every 6 Month(s)|Every 3 months backend|Every 6 months backend|'
-%}

<style>
  .lnd-mday { font-family: inherit; color: #0D273E; --mday-navy: #0D273E; --mday-red: #DB3519; --mday-navy-2: #143452; }
  .lnd-mday * { box-sizing: border-box; }
  .lnd-mday__bar { position: sticky; top: 0; z-index: 50; background: var(--mday-red); color: #fff; text-align: center; padding: 8px 14px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .lnd-mday__hero { background: #0D273E; color: #fff; padding: 36px 20px 48px; }
  .lnd-mday__hero-inner { max-width: 1200px; margin: 0 auto; }
  .lnd-mday__countdown { display: flex; gap: 8px; justify-content: center; margin: 0 auto 20px; }
  .lnd-mday__countdown div { background: var(--mday-red); border: 1px solid rgba(255,255,255,0.18); min-width: 64px; padding: 8px 10px; border-radius: 10px; text-align: center; box-shadow: 0 8px 18px rgba(219,53,25,0.24); }
  .lnd-mday__countdown b { display: block; font-size: 26px; font-weight: 800; line-height: 1; font-variant-numeric: tabular-nums; }
  .lnd-mday__countdown span { font-size: 9px; text-transform: uppercase; opacity: 0.85; letter-spacing: 0.08em; margin-top: 3px; display: block; }
  .lnd-mday__hero-grid { display: grid; grid-template-columns: 1fr; gap: 28px; align-items: center; max-width: 980px; margin: 0 auto; }
  .lnd-mday__hero-media { position: relative; max-width: 320px; margin: 0 auto; aspect-ratio: 1/1; border-radius: 18px; overflow: hidden; background: rgba(255,255,255,0.06); }
  .lnd-mday__hero-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lnd-mday__hero-media .lnd-mday__hero-badge { position: absolute; top: 14px; right: 14px; background: #fff; color: var(--mday-red); border-radius: 14px; padding: 10px 14px; text-align: center; line-height: 1; transform: rotate(6deg); box-shadow: 0 10px 22px rgba(13,39,62,0.28); }
  .lnd-mday__hero-media .lnd-mday__hero-badge b { display: block; font-size: 28px; font-weight: 900; letter-spacing: -0.03em; }
  .lnd-mday__hero-media .lnd-mday__hero-badge span { display: block; font-size: 9px; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; margin-top: 4px; }
  .lnd-mday__hero-media .lnd-mday__hero-ship { position: absolute; left: 14px; bottom: 14px; background: rgba(255,255,255,0.95); color: var(--mday-navy); font-size: 10px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; padding: 6px 10px; border-radius: 999px; }
  .lnd-mday__hero-media .lnd-mday__hero-ship sup { color: var(--mday-red); }
  .lnd-mday__hero-center { text-align: center; }
  .lnd-mday__hero-center .eyebrow { font-size: 11px; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.7; margin-bottom: 8px; }
  .lnd-mday__hero-center h1 { font-size: 40px; line-height: 1.02; margin: 0 0 12px; font-weight: 800; letter-spacing: -0.02em; }
  .lnd-mday__hero-center h1 em { color: var(--mday-red); font-style: normal; }
  .lnd-mday__hero-center p { font-size: 14px; opacity: 0.8; margin: 0 auto; max-width: 380px; line-height: 1.5; }
  .lnd-mday__hero-center .lnd-mday__hero-fine { font-size: 11px; opacity: 0.55; margin-top: 14px; max-width: 380px; }
  .lnd-mday__hero-center .lnd-mday__hero-fine sup { color: var(--mday-red); margin-right: 2px; }
  .lnd-mday__hero-benefits { list-style: none; padding: 0; margin: 14px auto 0; max-width: 380px; display: flex; flex-direction: column; gap: 8px; text-align: left; }
  .lnd-mday__hero-benefits li { position: relative; padding: 0 0 0 26px; font-size: 14px; line-height: 1.35; color: rgba(255,255,255,0.92); font-weight: 500; }
  .lnd-mday__hero-benefits li b { color: var(--mday-red); font-weight: 800; }
  .lnd-mday__hero-benefits li::before { content: ""; position: absolute; left: 0; top: 2px; width: 18px; height: 18px; background: var(--mday-red); border-radius: 999px; }
  .lnd-mday__hero-benefits li::after { content: ""; position: absolute; left: 4px; top: 7px; width: 9px; height: 5px; border-left: 2px solid #fff; border-bottom: 2px solid #fff; transform: rotate(-45deg); }
  .lnd-mday__hero-shop-cta { display: inline-flex; align-items: center; justify-content: center; background: var(--mday-red); color: #fff; text-decoration: none; padding: 14px 28px; border-radius: 999px; font-size: 15px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; margin: 18px 0 0; box-shadow: 0 12px 28px rgba(219,53,25,0.36); transition: transform 0.15s ease, box-shadow 0.15s ease; min-height: 48px; }
  .lnd-mday__hero-shop-cta:hover { transform: translateY(-1px); box-shadow: 0 16px 32px rgba(219,53,25,0.44); color: #fff; }
  .lnd-mday__hero-rotator { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.18); border-radius: 12px; padding: 10px 14px; margin: 16px auto 0; max-width: 380px; backdrop-filter: blur(4px); }
  .lnd-mday__hero-rotator-line { font-size: 15px; font-weight: 700; letter-spacing: -0.01em; display: flex; flex-wrap: wrap; align-items: baseline; gap: 6px; color: #fff; }
  .lnd-mday__hero-rotator-line .static { opacity: 0.85; }
  .lnd-mday__hero-rotator-line .dynamic { color: var(--mday-red); font-weight: 800; font-size: 17px; transition: opacity 0.35s ease, transform 0.35s ease; display: inline-block; min-width: 130px; }
  .lnd-mday__hero-rotator-line .dynamic.is-out { opacity: 0; transform: translateY(8px); }
  .lnd-mday__hero-stack { text-align: center; }
  .lnd-mday__hero-stack-label { font-size: 11px; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase; color: var(--mday-red); margin-bottom: 10px; }
  .lnd-mday__hero-stack-card { background: #fff; border: 1px solid #ececec; border-radius: 16px; padding: 14px; max-width: 320px; margin: 0 auto; cursor: pointer; transition: transform 0.15s ease, box-shadow 0.15s ease; text-align: left; font: inherit; color: #0D273E; width: 100%; display: block; }
  .lnd-mday__hero-stack-card:hover { box-shadow: 0 10px 30px rgba(0,0,0,0.25); transform: translateY(-2px); }
  .lnd-mday__hero-stack-img { aspect-ratio: 1/1; background: #f6f6f4; border-radius: 10px; overflow: hidden; margin-bottom: 12px; }
  .lnd-mday__hero-stack-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lnd-mday__hero-stack-title { font-size: 16px; font-weight: 800; margin: 0 0 6px; color: #0D273E; }
  .lnd-mday__hero-stack-price { display: flex; align-items: baseline; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; }
  .lnd-mday__hero-stack-price .now { font-size: 20px; font-weight: 800; color: #0D273E; }
  .lnd-mday__hero-stack-price .was { font-size: 13px; color: #888; text-decoration: line-through; }
  .lnd-mday__hero-stack-price .off { font-size: 12px; font-weight: 700; color: var(--mday-red); }
  .lnd-mday__hero-stack-cta { display: block; text-align: center; background: var(--mday-red); color: #fff; padding: 10px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }
  @media (min-width: 880px) {
    .lnd-mday__hero { padding: 56px 28px 64px; }
    .lnd-mday__hero-grid { grid-template-columns: 0.9fr 1.3fr; gap: 48px; text-align: left; align-items: center; }
    .lnd-mday__hero-center { text-align: left; }
    .lnd-mday__hero-center p { margin-left: 0; max-width: none; }
    .lnd-mday__hero-media { max-width: 380px; margin: 0; }
    .lnd-mday__hero-media .lnd-mday__hero-badge b { font-size: 36px; }
    .lnd-mday__hero-media .lnd-mday__hero-badge span { font-size: 10px; margin-top: 5px; }
    .lnd-mday__countdown { margin-bottom: 40px; }
    .lnd-mday__countdown div { min-width: 96px; padding: 18px 14px; }
    .lnd-mday__countdown b { font-size: 44px; }
    .lnd-mday__hero-center h1 { font-size: 52px; }
    .lnd-mday__hero-center p { font-size: 15px; }
    .lnd-mday__hero-benefits { margin-left: 0; }
    .lnd-mday__hero-rotator { margin-left: 0; }
  }
  .lnd-mday__row { padding: 28px 0 8px; scroll-margin-top: 60px; }
  .lnd-mday__row-head { padding: 0 20px; }
  .lnd-mday__row-head h2 { font-size: 22px; font-weight: 800; margin: 0 0 4px; letter-spacing: -0.01em; color: var(--mday-red); }
  .lnd-mday__row-head p { font-size: 13px; color: #555; margin: 0; }
  .lnd-mday__scroll { display: flex; gap: 12px; padding: 18px 20px 24px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .lnd-mday__scroll::-webkit-scrollbar { display: none; }
  .lnd-mday__card { flex: 0 0 70%; max-width: 260px; scroll-snap-align: start; background: #fff; border: 1px solid #ececec; border-radius: 14px; overflow: hidden; position: relative; display: flex; flex-direction: column; cursor: pointer; transition: transform 0.15s ease, box-shadow 0.15s ease; text-align: left; padding: 0; font: inherit; color: inherit; }
  .lnd-mday__card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .lnd-mday__card-img { aspect-ratio: 1/1; background: #f6f6f4; overflow: hidden; }
  .lnd-mday__card-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lnd-mday__callout { position: absolute; top: 10px; left: 10px; background: #fff; border: 1px solid #0D273E; color: #0D273E; font-size: 10px; font-weight: 800; letter-spacing: 0.06em; padding: 5px 10px; border-radius: 999px; z-index: 1; text-transform: uppercase; max-width: calc(100% - 20px); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .lnd-mday__low-stock { position: absolute; top: 10px; right: 10px; background: var(--mday-red); color: #fff; font-size: 10px; font-weight: 800; letter-spacing: 0.06em; padding: 5px 10px; border-radius: 999px; z-index: 2; text-transform: uppercase; white-space: nowrap; box-shadow: 0 4px 12px rgba(219,53,25,0.32); }
  .lnd-mday__card-body { padding: 12px 14px 14px; flex: 1; display: flex; flex-direction: column; }
  .lnd-mday__card-title { font-size: 14px; font-weight: 700; line-height: 1.25; margin: 0 0 4px; }
  .lnd-mday__card-sub { font-size: 12px; color: #555; line-height: 1.3; margin: 0 0 10px; min-height: 30px; }
  .lnd-mday__card-price { display: flex; align-items: baseline; gap: 6px; margin-bottom: 12px; flex-wrap: wrap; }
  .lnd-mday__card-price .now { font-size: 17px; font-weight: 800; color: #0D273E; }
  .lnd-mday__card-price .was { font-size: 13px; color: #888; text-decoration: line-through; }
  .lnd-mday__card-price .off { font-size: 12px; font-weight: 700; color: var(--mday-red); }
  .lnd-mday__card-more { display: block; text-align: center; font-size: 11px; font-weight: 700; color: var(--mday-navy); opacity: 0.62; letter-spacing: 0.06em; text-transform: uppercase; margin: auto 0 8px; line-height: 1; }
  .lnd-mday__card:hover .lnd-mday__card-more { opacity: 0.9; color: var(--mday-red); }
  .lnd-mday__cta { display: block; text-align: center; background: #0D273E; color: #fff; text-decoration: none; padding: 10px 12px; border-radius: 999px; font-size: 13px; font-weight: 700; letter-spacing: 0.02em; margin-top: 0; border: none; cursor: pointer; }
  .lnd-mday__cta:hover { background: var(--mday-red); }
  .lnd-mday__footer { background: #f6f6f4; padding: 36px 20px 44px; text-align: center; margin-top: 24px; }
  .lnd-mday__footer h3 { font-size: 22px; margin: 0 0 8px; font-weight: 800; letter-spacing: -0.01em; }
  .lnd-mday__footer p { font-size: 13px; color: #555; margin: 0 auto 18px; max-width: 480px; line-height: 1.5; }
  .lnd-mday__footer a.lnd-mday__cta { display: inline-block; padding: 12px 24px; }
  .lnd-mday__footer-fine { font-size: 11px; color: #888; margin: 22px auto 0; max-width: 520px; line-height: 1.5; }

  /* Modal */
  .lnd-mday__modal { position: fixed; inset: 0; z-index: 9999; display: none; align-items: flex-end; justify-content: center; }
  .lnd-mday__modal.is-open { display: flex; }
  .lnd-mday__modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.55); animation: lnd-fade 0.2s ease; }
  .lnd-mday__modal-panel { position: relative; background: #fff; width: 100%; max-width: 720px; max-height: 92vh; overflow-y: auto; border-radius: 18px 18px 0 0; animation: lnd-slide 0.25s ease; }
  @keyframes lnd-fade { from { opacity: 0; } to { opacity: 1; } }
  @keyframes lnd-slide { from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  .lnd-mday__modal-close { position: absolute; top: 12px; right: 12px; z-index: 2; background: #fff; border: 1px solid #e6e6e6; width: 36px; height: 36px; border-radius: 50%; font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; line-height: 1; }
  .lnd-mday__modal-img { aspect-ratio: 1/1; background: #fff; max-height: 360px; overflow: hidden; position: relative; display: flex; align-items: center; justify-content: center; }
  .lnd-mday__modal-img img { width: 100%; height: 100%; object-fit: contain; object-position: center; display: block; }
  .lnd-mday__thumbs { display: flex; gap: 6px; padding: 8px; overflow-x: auto; scrollbar-width: none; background: #f6f6f4; }
  .lnd-mday__thumbs::-webkit-scrollbar { display: none; }
  .lnd-mday__thumbs:empty { display: none; }
  .lnd-mday__thumb { flex: 0 0 56px; width: 56px; height: 56px; border-radius: 8px; overflow: hidden; border: 2px solid transparent; cursor: pointer; padding: 0; background: #fff; }
  .lnd-mday__thumb.is-active { border-color: var(--mday-navy); }
  .lnd-mday__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lnd-mday__modal-body { padding: 18px 20px 24px; }
  .lnd-mday__modal-body h2 { font-size: 22px; font-weight: 800; margin: 0 0 6px; line-height: 1.2; }
  .lnd-mday__modal-price { display: flex; align-items: baseline; gap: 10px; margin-bottom: 14px; }
  .lnd-mday__modal-price .now { font-size: 22px; font-weight: 800; color: var(--mday-red); }
  .lnd-mday__modal-price .was { font-size: 15px; color: #888; text-decoration: line-through; }
  .lnd-mday__modal-price .save { background: var(--mday-red); color: #fff; font-size: 11px; font-weight: 800; padding: 3px 8px; border-radius: 999px; letter-spacing: 0.04em; }
  .lnd-mday__modal-desc { font-size: 14px; color: #444; line-height: 1.55; margin-bottom: 14px; }
  .lnd-mday__bullets { margin: 0 0 18px; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .lnd-mday__bullets li { display: flex; align-items: center; gap: 10px; font-size: 14px; line-height: 1.45; color: var(--mday-navy); }
  .lnd-mday__bullets li svg { flex-shrink: 0; }
  .lnd-mday__opt { margin-bottom: 14px; }
  .lnd-mday__opt-label { display: block; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #555; margin-bottom: 6px; }
  .lnd-mday__opt-values { display: flex; gap: 6px; flex-wrap: wrap; }
  .lnd-mday__opt-btn { background: #fff; border: 1.5px solid #d8d8d8; padding: 8px 14px; border-radius: 999px; font-size: 13px; cursor: pointer; font: inherit; }
  .lnd-mday__opt-btn.is-active { border-color: #0D273E; background: #0D273E; color: #fff; }
  .lnd-mday__opt-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .lnd-mday__buy { margin-bottom: 14px; display: flex; flex-direction: column; gap: 8px; }
  .lnd-mday__buy-opt { display: flex; align-items: center; gap: 10px; border: 1.5px solid #d8d8d8; border-radius: 12px; padding: 12px 14px; cursor: pointer; font-size: 13px; }
  .lnd-mday__buy-opt.is-active { border-color: var(--mday-navy); background: #f6f8fb; }
  .lnd-mday__buy-opt input { accent-color: var(--mday-navy); }
  .lnd-mday__buy-opt-main { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .lnd-mday__buy-opt-title { font-weight: 700; }
  .lnd-mday__buy-opt-sub { font-size: 12px; color: #666; }
  .lnd-mday__buy-opt-price { font-weight: 700; color: var(--mday-red); white-space: nowrap; }
  .lnd-mday__buy-opt-tag { background: var(--mday-red); color: #fff; font-size: 10px; font-weight: 800; padding: 2px 6px; border-radius: 999px; letter-spacing: 0.04em; margin-left: 4px; }
  .lnd-mday__modal-actions { display: flex; flex-direction: column; gap: 10px; margin-top: 18px; }
  .lnd-mday__modal-actions .lnd-mday__cta { padding: 14px; font-size: 14px; }
  .lnd-mday__modal-pdp { text-align: center; font-size: 12px; color: #666; text-decoration: underline; }
  .lnd-mday__toast { display: none; background: #0a5a3e; color: #fff; padding: 12px 14px; border-radius: 10px; margin-bottom: 14px; font-size: 13px; font-weight: 600; text-align: center; }
  .lnd-mday__toast.is-show { display: block; }
  .lnd-mday__toast.is-err { background: #b3261e; }
  .lnd-mday__toast a { color: #fff; text-decoration: underline; margin-left: 6px; }

  @media (min-width: 768px) {
    .lnd-mday__hero { padding: 72px 32px 80px; }
    .lnd-mday__hero h1 { font-size: 56px; }
    .lnd-mday__hero p { font-size: 17px; }
    .lnd-mday__countdown div { min-width: 84px; padding: 12px 10px; }
    .lnd-mday__countdown b { font-size: 32px; }
    .lnd-mday__row-head { padding: 0 32px; }
    .lnd-mday__row-head h2 { font-size: 28px; }
    .lnd-mday__scroll { padding: 22px 32px 32px; gap: 18px; overflow-x: visible; flex-wrap: wrap; scroll-snap-type: none; }
    .lnd-mday__card { flex: 0 1 calc(25% - 14px); max-width: none; }
    .lnd-mday__modal { align-items: center; }
    .lnd-mday__modal-panel { border-radius: 18px; max-width: 760px; }
    .lnd-mday__modal-panel-inner { display: grid; grid-template-columns: 1fr 1fr; }
    .lnd-mday__modal-img { aspect-ratio: 1/1.05; max-height: none; border-radius: 18px 0 0 18px; }
    .lnd-mday__modal-img img { object-fit: contain; }
    .lnd-mday__modal-media { display: flex; flex-direction: column; }
    .lnd-mday__thumbs { padding: 8px 10px 10px; }

    { "type": "text", "id": "end_iso", "label": "End time (ISO 8601)", "default": "2026-05-20T23:59:59-04:00" },
    { "type": "html", "id": "headline", "label": "Hero headline", "default": "Memorial Day. <em>Early.</em>" },
    { "type": "textarea", "id": "subhead", "label": "Hero subhead", "default": "VIP Early Access: Get first dibs on 35% off site-wide until midnight May 20th. Grab yours before we sell out." },
    { "type": "text", "id": "footer_headline", "label": "Footer headline", "default": "Early access ends midnight, May 20." },
    { "type": "textarea", "id": "footer_sub", "label": "Footer subtext", "default": "After that, the doors open to everyone. Take care of your stack first." }
  ],
  "presets": [{ "name": "Memorial Day Early Access" }]
}

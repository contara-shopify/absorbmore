{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign section_type = "modal_megamenu"
  assign _handle = section.settings.handle
  assign container_spacing = section.settings.container_spacing
  assign text_color = section.settings.text_color
  assign background_color = section.settings.background_color
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture blocks_content %}{% content_for 'blocks' %}{% endcapture %}
{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
  {% capture css %}
    & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    }
  {% endcapture %}
{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

{% if section.location == 'custom.megamenu' %}
  {% capture section_content %}
    <section data-style-id="{{ section.id }}--{{ block.id }}"
             {% if section_id != blank %}id="{{ section_id }}"{% endif %}
             data-megamenu="megamenu--{{ _handle | handleize }}"
             data-modal-id="megamenu--{{ _handle | handleize }}"
             x-data="{ show: $modal.id === 'megamenu--{{ _handle | handleize }}' }"
             x-effect="show = $modal.id === 'megamenu--{{ _handle | handleize }}' || ($editor?.select_section_id === '{{ section.id }}' && !$modal.id);"
             x-show="show"
             x-cloak
             data-megamenu-submenu="{{ _handle }}"
             x-transition:enter-start="-translate-y-full opacity-0 relative"
             x-transition:enter-end="translate-y-0 opacity-100 relative"
             x-transition:leave-start="translate-y-0 opacity-100 absolute left-0 top-0"
             x-transition:leave-end="-translate-y-full opacity-0 absolute left-0 top-0"
             class="overflow-hidden transition-all duration-300 w-full {{ container_spacing }}">
      {{ blocks_content }}
    </section>
  {% endcapture %}
{% else %}
  {% capture section_content %}
    <div data-megamenu="megamenu--{{ _handle | handleize }}"
         data-modal-id="megamenu--{{ _handle | handleize }}"
         x-data="{ show: $modal.id === 'megamenu--{{ _handle | handleize }}' }"
         x-effect="show = $modal.id === 'megamenu--{{ _handle | handleize }}' || ($editor?.select_section_id === '{{ section.id }}' && !$modal.id)"
         x-cloak>
      <div class="bg-modal-backdrop pointer-events-auto fixed inset-x-0 bottom-0 top-[--header-height-offset] z-10 transition duration-75 ease-in-out"
           x-show="show"
           x-cloak
           x-transition:enter-start="opacity-0"
           x-transition:enter-end="opacity-100"
           x-transition:leave-start="opacity-100"
           x-transition:leave-end="opacity-0"
           @click="$modal.setId('')"></div>
      <section class="pointer-events-none fixed inset-x-0 top-[--header-height-offset] z-20 transition-all duration-300 ease-in-out"
               x-transition:enter-start="-translate-y-full"
               x-transition:enter-end="translate-y-0"
               x-transition:leave="translate-y-0"
               x-transition:leave-start="translate-y-0"
               x-transition:leave-end="-translate-y-full"
               x-show="show"
               x-trap.noautofocus="show">
        {% capture core_content %}
          <div data-style-id="{{ section.id }}--{{ block.id }}"
               {% if section_id != blank %}id="{{ section_id }}"{% endif %}
               class="pointer-events-auto relative h-full max-h-[calc(100vh-var(--header-height-offset)-40px)] overflow-auto scrollbar-none {{ container_spacing }}">
            <div class="relative">
              {{ blocks_content }}
            </div>
          </div>
        {% endcapture %}
        {{ core_content }}
      </section>
    </div>
  {% endcapture %}
{% endif %}



{% if request.visual_preview_mode %}
  {{ core_content | replace: 'max-h-[calc(100vh-var(--header-height-offset)-40px)]', '' }}
{% else %}
  {{ section_content }}
{% endif %}


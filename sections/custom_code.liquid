{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign section_type = "custom_code"
  assign container_spacing = section.settings.container_spacing
  assign text_color = section.settings.text_color
  assign background_color = section.settings.background_color
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% for block in section.blocks %}
  {% if block.type == 'css' %}
    <style>{{ block.settings.css }}</style>
  {% endif %}
  {% if block.type == 'liquid' %}
    {{ block.settings.custom_liquid }}
  {% endif %}
  {% if block.type == 'javascript' %}
    <script type="application/javascript">{{ block.settings.javascript }}</script>
  {% endif %}
  {% if block.type == 'json' %}
    <script type="application/json">{{ block.settings.json }}</script>
  {% endif %}
{% endfor %}

{% schema %}
{
  "name": "Custom Code",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Section Globals"
    },
    {
      "type": "select",
      "id": "container_spacing",
      "default": "px-container-md",
      "options": [
        {
          "value": "px-container-xs",
          "label": "Extra Small"
        },
        {
          "value": "px-container-sm",
          "label": "Small"
        },
        {
          "value": "px-container-md",
          "label": "Medium"
        },
        {
          "value": "px-container-lg",
          "label": "Large"
        },
        {
          "value": "px-container-gutter",
          "label": "Gutter Only"
        },
        {
          "value": "px-container-fullwidth",
          "label": "Fullwidth"
        }
      ],
      "label": "Container Spacing"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "default": "& {\n  padding-top: 42px;\n  padding-bottom: 60px;\n}\n@media (max-width: 768px) {\n  & {\n    padding-top: 32px;\n    padding-bottom: 48px;\n  }\n}"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section Id"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "header",
      "content": "Development Integration",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "select",
      "id": "generate_presets",
      "label": "Presets Codegen",
      "default": "never",
      "options": [
        {
          "value": "never",
          "label": "Off"
        },
        {
          "value": "always",
          "label": "On"
        },
        {
          "value": "manual_override",
          "label": "Override"
        }
      ],
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "text",
      "id": "category_name",
      "label": "Category",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "text",
      "id": "hidden_name_backup",
      "label": " Hidden Name Backup",
      "visible_if": "{{ settings.development__dev_mode == 'show_never' }}"
    },
    {
      "type": "paragraph",
      "content": "Setting the preset to 'Override' and running the dev tools will override the existing manual preset if the names match. NB: This should be switched off right after updated a Preset!",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    }
  ],
  "blocks": [
    {
      "name": "CSS",
      "type": "css",
      "settings": [
        {
          "type": "textarea",
          "id": "css",
          "label": "Custom CSS"
        }
      ]
    },
    {
      "name": "Liquid",
      "type": "liquid",
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "Liquid code"
        }
      ]
    },
    {
      "name": "JavaScript",
      "type": "javascript",
      "settings": [
        {
          "type": "textarea",
          "id": "javascript",
          "label": "JavaScript"
        }
      ]
    },
    {
      "name": "JSON",
      "type": "json",
      "settings": [
        {
          "type": "textarea",
          "id": "json",
          "label": "JSON"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Code",
      "settings": {
        "container_spacing": "px-container-md",
        "text_color": "",
        "background_color": "",
        "custom_css": "& {\n  padding-top: 42px;\n  padding-bottom: 60px;\n}\n@media (max-width: 768px) {\n  & {\n    padding-top: 32px;\n    padding-bottom: 48px;\n  }\n}",
        "section_id": ""
      },
      "blocks": [
        {
          "type": "liquid",
          "settings": {
            "custom_liquid": "<link rel=\"preload\" as=\"style\" href=\"https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap\">\n<link href=\"https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap\" rel=\"stylesheet\" media=\"all\">"
          }
        },
        {
          "type": "css",
          "settings": {
            "css": ""
          }
        },
        {
          "type": "liquid",
          "settings": {
            "custom_liquid": "<script> // console.log(document.currentScript?.parentElement)</script>"
          }
        }
      ],
      "category": "Utilities"
    }
  ],
  "disabled_on": {
    "groups": [
      "custom.global",
      "custom.card",
      "custom.megamenu"
    ]
  },
  "class": "shopify_section__custom_code"
}
{% endschema %}

    <div class="wlp-compare-table">
      <div class="wlp-compare-row head">
        <div class="wlp-compare-cell head-cell"></div>
        <div class="wlp-compare-cell head-cell us">
          <span class="head-tag">{{ section.settings.compare_us_tag }}</span>
          <span>{{ section.settings.compare_us_label }}</span>
        </div>
        <div class="wlp-compare-cell head-cell">{{ section.settings.compare_col2_label }}</div>
        <div class="wlp-compare-cell head-cell">{{ section.settings.compare_col3_label }}</div>
      </div>

      {%- assign rows = section.settings.compare_rows | newline_to_br | split: '<br />' -%}
      {%- for row in rows -%}
        {%- assign cells = row | strip | split: '|' -%}
        {%- if cells.size == 4 -%}
          <div class="wlp-compare-row">
            <div class="wlp-compare-cell label">{{ cells[0] | strip }}</div>
            <div class="wlp-compare-cell us-col">{%- assign c1 = cells[1] | strip -%}{%- if c1 == '✓' -%}<span class="check">✓</span>{%- else -%}<span class="x">{{ c1 }}</span>{%- endif -%}</div>
            <div class="wlp-compare-cell">{%- assign c2 = cells[2] | strip -%}{%- if c2 == '✓' -%}<span class="check">✓</span>{%- else -%}<span class="x">{{ c2 }}</span>{%- endif -%}</div>
            <div class="wlp-compare-cell">{%- assign c3 = cells[3] | strip -%}{%- if c3 == '✓' -%}<span class="check">✓</span>{%- else -%}<span class="x">{{ c3 }}</span>{%- endif -%}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>


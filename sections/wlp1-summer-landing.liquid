{%- comment -%}
  WLP-1™ Summer Landing Section
  --------------------------------------------------
  Place this file at: /sections/wlp1-summer-landing.liquid
  Add to a page template (e.g. page.wlp1-summer.json) or include
  via section block on the homepage.

  All CSS is scoped via [data-section-id="{{ section.id }}"] to avoid
  theme conflicts. JS is wrapped in an IIFE for the same reason.
  Editable content is exposed via the schema so the marketing team
  can tweak copy/dates/colors in the customizer.
{%- endcomment -%}

<section
  class="wlp1-summer"
  data-section-id="{{ section.id }}"
  data-countdown-target="{{ section.settings.countdown_target_date }}"
>

<style>
  [data-section-id="{{ section.id }}"] {
    /* Brand tokens */
    --wlp-ink: #16140F;
    --wlp-ink-soft: #2A2620;
    --wlp-paper: #F4EFE6;
    --wlp-paper-warm: #ECE4D4;
    --wlp-paper-deep: #E2D7C2;
    --wlp-blue: {{ section.settings.brand_blue | default: '#5e91d5' }};
    --wlp-blue-deep: #4a7dbe;
    --wlp-sun: {{ section.settings.accent_color | default: '#E8743C' }};
    --wlp-sun-deep: #C95A24;
    --wlp-line: rgba(22,20,15,0.12);
    --wlp-line-soft: rgba(22,20,15,0.06);
    background: var(--wlp-paper);
    color: var(--wlp-ink);
    font-weight: 400;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    display: block;
  }

  [data-section-id="{{ section.id }}"] *,
  [data-section-id="{{ section.id }}"] *::before,
  [data-section-id="{{ section.id }}"] *::after {
    box-sizing: border-box;
  }

  [data-section-id="{{ section.id }}"] .wlp-grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 100;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' /%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* Announce */
  [data-section-id="{{ section.id }}"] .wlp-announce {
    background: var(--wlp-ink);
    color: var(--wlp-paper);
    text-align: center;
    padding: 10px 16px;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
  }
  [data-section-id="{{ section.id }}"] .wlp-announce strong { color: var(--wlp-sun); font-weight: 600; }

  /* Nav */
  [data-section-id="{{ section.id }}"] .wlp-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px 40px;
    border-bottom: 1px solid var(--wlp-line);
    background: var(--wlp-paper);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  [data-section-id="{{ section.id }}"] .wlp-logo {
    font-weight: 500;
    font-size: 17px;
    letter-spacing: -0.01em;
  }
  [data-section-id="{{ section.id }}"] .wlp-nav-cta {
    background: var(--wlp-ink);
    color: var(--wlp-paper);
    padding: 11px 22px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  [data-section-id="{{ section.id }}"] .wlp-nav-cta:hover { background: var(--wlp-sun); color: var(--wlp-paper); }

  /* Hero */
  [data-section-id="{{ section.id }}"] .wlp-hero { position: relative; padding: 60px 40px 100px; overflow: hidden; }
  [data-section-id="{{ section.id }}"] .wlp-hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    max-width: 1400px;
    margin: 0 auto;
    align-items: center;
  }
  [data-section-id="{{ section.id }}"] .wlp-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--wlp-sun-deep);
    margin-bottom: 28px;
  }
  [data-section-id="{{ section.id }}"] .wlp-eyebrow::before {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--wlp-sun-deep);
  }
  [data-section-id="{{ section.id }}"] .wlp-eyebrow-mobile { display: none; }
  [data-section-id="{{ section.id }}"] .wlp-headline {
    font-weight: 500;
    font-size: clamp(36px, 4.4vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--wlp-ink);
    margin: 0 0 28px;
  }
  [data-section-id="{{ section.id }}"] .wlp-headline em {
    font-style: italic;
    font-weight: 500;
    color: var(--wlp-sun-deep);
  }
  [data-section-id="{{ section.id }}"] .wlp-headline .wlp-blue {
    font-style: italic;
    font-weight: 500;
    color: var(--wlp-blue);
  }
  [data-section-id="{{ section.id }}"] .wlp-subhead {
    font-size: 18px;
    line-height: 1.5;
    color: var(--wlp-ink-soft);
    max-width: 520px;
    margin: 0 0 56px;
    font-weight: 400;
  }
  [data-section-id="{{ section.id }}"] .wlp-subhead strong { font-weight: 600; color: var(--wlp-ink); }

  /* Countdown */
  [data-section-id="{{ section.id }}"] .wlp-countdown {
    display: flex;
    gap: 24px;
    margin-top: 8px;
    margin-bottom: 44px;
    padding: 20px 24px;
    background: var(--wlp-paper-warm);
    border: 1px solid var(--wlp-line);
    border-radius: 4px;
    width: fit-content;
  }
  [data-section-id="{{ section.id }}"] .wlp-cd-label {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--wlp-ink-soft);
    margin-bottom: 6px;
    font-weight: 500;
  }
  [data-section-id="{{ section.id }}"] .wlp-cd-unit { text-align: center; min-width: 56px; }
  [data-section-id="{{ section.id }}"] .wlp-cd-num {
    font-size: 38px;
    font-weight: 400;
    line-height: 1;
    color: var(--wlp-ink);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  [data-section-id="{{ section.id }}"] .wlp-cd-divider {
    width: 1px;
    background: var(--wlp-line);
    align-self: stretch;
  }
  [data-section-id="{{ section.id }}"] .wlp-cd-tag {
    align-self: center;
    padding-left: 8px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--wlp-sun-deep);
    font-weight: 500;
    line-height: 1.3;
    max-width: 110px;
  }

  /* Buttons */
  [data-section-id="{{ section.id }}"] .wlp-cta-row {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  [data-section-id="{{ section.id }}"] .wlp-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--wlp-ink);
    color: var(--wlp-paper);
    padding: 18px 32px;
    border-radius: 100px;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: none;
    cursor: pointer;
  }
  [data-section-id="{{ section.id }}"] .wlp-btn:hover {
    background: var(--wlp-sun);
    color: var(--wlp-paper);
    transform: translateY(-1px);
    box-shadow: 0 12px 28px rgba(232, 116, 60, 0.32);
  }
  [data-section-id="{{ section.id }}"] .wlp-btn svg { transition: transform 0.3s ease; }
  [data-section-id="{{ section.id }}"] .wlp-btn:hover svg { transform: translateX(4px); }

  [data-section-id="{{ section.id }}"] .wlp-trust-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--wlp-ink-soft);
  }
  [data-section-id="{{ section.id }}"] .wlp-stars { color: var(--wlp-sun); letter-spacing: 1px; }

  [data-section-id="{{ section.id }}"] .wlp-guarantee {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--wlp-ink-soft);
    margin-top: 14px;
    letter-spacing: 0.02em;
  }
  [data-section-id="{{ section.id }}"] .wlp-guarantee::before {
    content: '✓';
    color: var(--wlp-blue);
    font-weight: 700;
    font-size: 14px;
  }
  [data-section-id="{{ section.id }}"] .wlp-final .wlp-guarantee {
    color: rgba(244,239,230,0.7);
    justify-content: center;
  }
  [data-section-id="{{ section.id }}"] .wlp-final .wlp-guarantee::before {
    color: var(--wlp-sun);
  }
  [data-section-id="{{ section.id }}"] .wlp-buybox-cta + .wlp-guarantee {
    justify-content: center;
    margin-top: 12px;
    margin-bottom: 12px;
  }

  /* Hero visual */
  [data-section-id="{{ section.id }}"] .wlp-hero-visual {
    position: relative;
    aspect-ratio: 4/5;
    border-radius: 6px;
    overflow: hidden;
    background: linear-gradient(135deg, #d4c4a8 0%, #b8a888 100%);
  }
  [data-section-id="{{ section.id }}"] .wlp-hero-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-image:
      linear-gradient(180deg, rgba(22,20,15,0) 40%, rgba(22,20,15,0.35) 100%),
      url('{{ section.settings.hero_image | default: "" }}');
  }
  [data-section-id="{{ section.id }}"] .wlp-stat-card {
    position: absolute;
    background: var(--wlp-paper);
    padding: 18px 22px;
    border-radius: 4px;
    box-shadow: 0 12px 40px rgba(22,20,15,0.18);
  }
  [data-section-id="{{ section.id }}"] .wlp-stat-1 { bottom: 28px; left: 28px; width: 200px; }
  [data-section-id="{{ section.id }}"] .wlp-stat-2 {
    top: 28px;
    right: -16px;
    background: var(--wlp-sun);
    color: var(--wlp-paper);
    width: 170px;
  }
  [data-section-id="{{ section.id }}"] .wlp-stat-num {
    font-size: 36px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
  }
  [data-section-id="{{ section.id }}"] .wlp-stat-label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1.4;
    opacity: 0.85;
  }

  /* What is WLP-1 */
  [data-section-id="{{ section.id }}"] .wlp-what { padding: 120px 40px; background: var(--wlp-paper); position: relative; }
  [data-section-id="{{ section.id }}"] .wlp-what-inner { max-width: 1200px; margin: 0 auto; }
  [data-section-id="{{ section.id }}"] .wlp-section-label {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--wlp-ink-soft);
    margin-bottom: 32px;
    font-weight: 500;
  }
  [data-section-id="{{ section.id }}"] .wlp-section-label::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--wlp-ink-soft);
  }
  [data-section-id="{{ section.id }}"] .wlp-what-headline {
    font-weight: 500;
    font-size: clamp(32px, 3.4vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 28px;
    max-width: 800px;
  }
  [data-section-id="{{ section.id }}"] .wlp-what-headline em {
    font-style: italic;
    color: var(--wlp-blue);
    font-weight: 500;
  }
  [data-section-id="{{ section.id }}"] .wlp-what-lede {
    font-size: 17px;
    line-height: 1.6;
    color: var(--wlp-ink-soft);
    max-width: 640px;
    margin: 0 0 80px;
  }

  /* Pathways */
  [data-section-id="{{ section.id }}"] .wlp-pathways {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--wlp-ink);
    border-bottom: 1px solid var(--wlp-ink);
  }
  [data-section-id="{{ section.id }}"] .wlp-pathway {
    padding: 44px 32px;
    border-right: 1px solid var(--wlp-line);
    position: relative;
  }
  [data-section-id="{{ section.id }}"] .wlp-pathway:last-child { border-right: none; }
  [data-section-id="{{ section.id }}"] .wlp-pathway-num {
    font-style: italic;
    font-size: 14px;
    color: var(--wlp-sun-deep);
    margin-bottom: 16px;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
  [data-section-id="{{ section.id }}"] .wlp-pathway-title {
    font-weight: 380;
    font-size: 36px;
    line-height: 1.0;
    letter-spacing: -0.025em;
    margin: 0 0 20px;
    max-width: 280px;
  }
  [data-section-id="{{ section.id }}"] .wlp-pathway-title em { font-style: italic; color: var(--wlp-blue); }
  [data-section-id="{{ section.id }}"] .wlp-pathway-mech {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--wlp-ink-soft);
    margin-bottom: 10px;
    font-weight: 500;
  }
  [data-section-id="{{ section.id }}"] .wlp-pathway-stat {
    font-size: 52px;
    font-weight: 350;
    line-height: 1;
    color: var(--wlp-ink);
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }
  [data-section-id="{{ section.id }}"] .wlp-pathway-stat-label {
    font-size: 13px;
    color: var(--wlp-ink-soft);
    margin-bottom: 20px;
    font-style: italic;
  }
  [data-section-id="{{ section.id }}"] .wlp-pathway-desc {
    font-size: 15px;
    line-height: 1.55;
    color: var(--wlp-ink-soft);
    margin: 0;
  }
  [data-section-id="{{ section.id }}"] .wlp-pathway-desc strong { color: var(--wlp-ink); font-weight: 600; }
  [data-section-id="{{ section.id }}"] .wlp-pathway-desc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  [data-section-id="{{ section.id }}"] .wlp-pathway-desc li {
    padding-left: 22px;
    position: relative;
    margin-bottom: 12px;
    font-size: 15px;
    line-height: 1.5;
  }
  [data-section-id="{{ section.id }}"] .wlp-pathway-desc li:last-child {
    margin-bottom: 0;
  }
  [data-section-id="{{ section.id }}"] .wlp-pathway-desc li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 12px;
    height: 1px;
    background: var(--wlp-sun-deep);
  }

  /* How strip */
  [data-section-id="{{ section.id }}"] .wlp-how-strip {
    margin-top: 80px;
    padding: 56px 48px;
    background: var(--wlp-ink);
    color: var(--wlp-paper);
    border-radius: 6px;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 60px;
    align-items: center;
  }
  [data-section-id="{{ section.id }}"] .wlp-how-strip h3 {
    font-weight: 350;
    font-size: 36px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
  }
  [data-section-id="{{ section.id }}"] .wlp-how-strip h3 em {
    font-style: italic;
    color: var(--wlp-sun);
    font-weight: 400;
  }
  [data-section-id="{{ section.id }}"] .wlp-how-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px 36px;
  }
  [data-section-id="{{ section.id }}"] .wlp-how-item { display: flex; gap: 14px; align-items: flex-start; }
  [data-section-id="{{ section.id }}"] .wlp-how-check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border: 1px solid var(--wlp-sun);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }
  [data-section-id="{{ section.id }}"] .wlp-how-check::after {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--wlp-sun);
    border-radius: 50%;
  }
  [data-section-id="{{ section.id }}"] .wlp-how-item-text {
    font-size: 15px;
    line-height: 1.45;
    color: rgba(244, 239, 230, 0.85);
  }
  [data-section-id="{{ section.id }}"] .wlp-how-item-text strong { color: var(--wlp-paper); font-weight: 600; }

  /* Testimonials */
  [data-section-id="{{ section.id }}"] .wlp-testimonials { padding: 120px 40px; background: var(--wlp-paper-warm); position: relative; }
  [data-section-id="{{ section.id }}"] .wlp-testi-inner { max-width: 1200px; margin: 0 auto; }
  [data-section-id="{{ section.id }}"] .wlp-testi-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 60px;
    gap: 40px;
    flex-wrap: wrap;
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-headline {
    font-weight: 350;
    font-size: clamp(40px, 4.8vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    max-width: 700px;
    margin: 0;
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-headline em { font-style: italic; color: var(--wlp-sun-deep); font-weight: 400; }
  [data-section-id="{{ section.id }}"] .wlp-testi-meta {
    text-align: right;
    font-size: 14px;
    color: var(--wlp-ink-soft);
    line-height: 1.5;
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-meta .big {
    font-size: 32px;
    color: var(--wlp-sun-deep);
    line-height: 1;
    margin-bottom: 4px;
    letter-spacing: -0.02em;
    font-style: italic;
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-card {
    background: var(--wlp-paper);
    padding: 32px 28px;
    border-radius: 4px;
    border: 1px solid var(--wlp-line);
    display: flex;
    flex-direction: column;
    transition: all 0.3s ease;
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px rgba(22,20,15,0.08);
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-card.featured { background: var(--wlp-ink); color: var(--wlp-paper); }
  [data-section-id="{{ section.id }}"] .wlp-testi-stars {
    color: var(--wlp-sun);
    letter-spacing: 2px;
    font-size: 14px;
    margin-bottom: 10px;
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-verified {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--wlp-blue);
    margin-bottom: 18px;
    font-weight: 500;
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-card.featured .wlp-testi-verified { color: var(--wlp-sun); }
  [data-section-id="{{ section.id }}"] .wlp-testi-title {
    font-weight: 500;
    font-size: 20px;
    line-height: 1.2;
    margin: 0 0 16px;
    letter-spacing: -0.01em;
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-quote {
    font-size: 15px;
    line-height: 1.55;
    margin: 0 0 24px;
    flex: 1;
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-card.featured .wlp-testi-quote { color: rgba(244,239,230,0.92); }
  [data-section-id="{{ section.id }}"] .wlp-testi-attr {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 20px;
    border-top: 1px solid var(--wlp-line);
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-card.featured .wlp-testi-attr { border-top-color: rgba(244,239,230,0.15); }
  [data-section-id="{{ section.id }}"] .wlp-testi-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--wlp-paper-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    color: var(--wlp-ink);
  }
  [data-section-id="{{ section.id }}"] .wlp-testi-name { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
  [data-section-id="{{ section.id }}"] .wlp-testi-detail { font-size: 12px; color: var(--wlp-ink-soft); letter-spacing: 0.04em; }
  [data-section-id="{{ section.id }}"] .wlp-testi-card.featured .wlp-testi-detail { color: rgba(244,239,230,0.6); }

  /* Compare */
  [data-section-id="{{ section.id }}"] .wlp-compare { padding: 120px 40px; background: var(--wlp-paper); }
  [data-section-id="{{ section.id }}"] .wlp-compare-inner { max-width: 1100px; margin: 0 auto; }
  [data-section-id="{{ section.id }}"] .wlp-compare-headline {
    font-weight: 350;
    font-size: clamp(40px, 4.8vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 0 0 60px;
    max-width: 700px;
  }
  [data-section-id="{{ section.id }}"] .wlp-compare-headline em { font-style: italic; color: var(--wlp-sun-deep); font-weight: 400; }
  [data-section-id="{{ section.id }}"] .wlp-compare-table {
    border: 1px solid var(--wlp-ink);
    border-radius: 6px;
    overflow: hidden;
    background: var(--wlp-paper);
  }
  [data-section-id="{{ section.id }}"] .wlp-compare-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;

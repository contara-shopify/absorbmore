<script>
  (function() {
    var root = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!root) return;

    // Countdown
    var targetStr = root.getAttribute('data-countdown-target');
    var target = targetStr ? new Date(targetStr).getTime() : null;

    function pad(n) { return String(n).padStart(2, '0'); }

    function tick() {
      if (!target) return;
      var diff = target - Date.now();
      var days = '00', hrs = '00', min = '00', sec = '00';
      if (diff > 0) {
        days = pad(Math.floor(diff / 86400000));
        hrs = pad(Math.floor((diff % 86400000) / 3600000));
        min = pad(Math.floor((diff % 3600000) / 60000));
        sec = pad(Math.floor((diff % 60000) / 1000));
      }
      root.querySelectorAll('[data-cd="days"]').forEach(function(el){ el.textContent = days; });
      root.querySelectorAll('[data-cd="hrs"]').forEach(function(el){ el.textContent = hrs; });
      root.querySelectorAll('[data-cd="min"]').forEach(function(el){ el.textContent = min; });
      root.querySelectorAll('[data-cd="sec"]').forEach(function(el){ el.textContent = sec; });
    }
    tick();
    setInterval(tick, 1000);

    // Sticky bar reveal
    var sticky = root.querySelector('[data-sticky]');
    if (sticky) {
      window.addEventListener('scroll', function() {
        if (window.scrollY > 600) sticky.classList.add('visible');
        else sticky.classList.remove('visible');
      });
    }

    // Buy box plan selection
    root.querySelectorAll('.wlp-buybox-option').forEach(function(option) {
      option.addEventListener('click', function() {
        root.querySelectorAll('.wlp-buybox-option').forEach(function(o){ o.classList.remove('selected'); });
        option.classList.add('selected');
      });
    });

    // FAQ accordion
    root.querySelectorAll('.wlp-faq-q').forEach(function(q) {
      q.addEventListener('click', function() {
        var item = q.closest('.wlp-faq-item');
        item.classList.toggle('open');
      });
    });

    // Add to cart (Skio subscription)
    var addBtn = root.querySelector('[data-add-to-cart]');
    if (addBtn) {
      addBtn.addEventListener('click', function(e) {
        e.preventDefault();
        if (addBtn.disabled) return;

        var selectedTier = root.querySelector('.wlp-buybox-option.selected') || root.querySelector('.wlp-buybox-option');
        if (!selectedTier) return;

        var variantId = selectedTier.getAttribute('data-variant-id');
        var sellingPlanId = selectedTier.getAttribute('data-selling-plan-id');
        if (!variantId) {
          console.error('WLP-1: missing variant ID on selected tier');
          return;
        }

        var item = { id: parseInt(variantId, 10), quantity: 1 };
        if (sellingPlanId) {
          item.selling_plan = parseInt(sellingPlanId, 10);
        }

        var label = addBtn.querySelector('.wlp-buybox-cta-label');
        var originalLabel = label ? label.textContent : '';
        addBtn.disabled = true;
        if (label) label.textContent = 'Adding...';

        fetch('/cart/add.js', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ items: [item] })
        })
          .then(function(res) {
            if (!res.ok) throw new Error('Cart add failed: ' + res.status);
            return res.json();
          })
          .then(function() { window.location.href = '/cart'; })
          .catch(function(err) {
            console.error('WLP-1 cart add error:', err);
            addBtn.disabled = false;
            if (label) label.textContent = originalLabel;
            alert('Sorry, something went wrong adding to cart. Please try again.');
          });
      });
    }
  })();
</script>

</section>


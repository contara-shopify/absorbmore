<script>
(function(){
  // PDP thumbnail swap (uses data-thumb-src from liquid-rendered images)
  document.querySelectorAll('#wea-root .pdp-thumb').forEach(function(thumb){
    thumb.addEventListener('click', function(){
      var src = thumb.getAttribute('data-thumb-src');
      if(!src) return;
      document.querySelectorAll('#wea-root .pdp-thumb').forEach(function(t){t.classList.remove('active')});
      thumb.classList.add('active');
      var main = document.getElementById('pdpMain');
      if(main) main.src = src;
    });
  });

  // Calculator
  var unit='imperial';
  window.weaSetUnit = function(u){
    unit = u;
    document.getElementById('uImp').classList.toggle('on', u==='imperial');
    document.getElementById('uMet').classList.toggle('on', u==='metric');
    document.getElementById('weaHImpRow').style.display = u==='imperial'?'':'none';
    document.getElementById('weaHMetRow').style.display = u==='metric'?'':'none';
    var ws = document.getElementById('weaSW');
    var gs = document.getElementById('weaSG');
    if(u==='metric'){
      var lbs=parseInt(ws.value); ws.min=45; ws.max=180; ws.value=Math.round(lbs/2.20462);
      var glbs=parseInt(gs.value); gs.min=2; gs.max=45; gs.value=Math.max(2,Math.round(glbs/2.20462));
    } else {
      var kg=parseInt(ws.value); ws.min=120; ws.max=400; ws.value=Math.round(kg*2.20462);
      var gkg=parseInt(gs.value); gs.min=5; gs.max=100; gs.value=Math.max(5,Math.round(gkg*2.20462));
    }
    weaCalc();
  };

  var paceLow = {{ section.settings.calc_pace_low | default: 1 }};
  var paceHigh = {{ section.settings.calc_pace_high | default: 2 }};
  var paceMid = (paceLow + paceHigh) / 2;
  var monthsCap = {{ section.settings.calc_months_cap | default: 12 }};

  window.weaCalc = function(){
    var wRaw = parseInt(document.getElementById('weaSW').value);
    var wLbs = unit==='imperial' ? wRaw : wRaw*2.20462;
    var uL = unit==='imperial'?'lbs':'kg';
    document.getElementById('weaDispW').innerHTML = wRaw+' <span>'+uL+'</span>';
    var hm;
    if(unit==='imperial'){
      var ti = parseInt(document.getElementById('weaSH').value);
      document.getElementById('weaDispH').textContent = Math.floor(ti/12)+"'"+(ti%12)+'"';
      hm = ti*0.0254;
    } else {
      var cm = parseInt(document.getElementById('weaSHC').value);
      document.getElementById('weaDispHC').innerHTML = cm+' <span>cm</span>';
      hm = cm/100;
    }
    var wkg = wLbs/2.20462;
    var bmi = Math.round(wkg/(hm*hm));
    document.getElementById('weaBmiWarn').classList.toggle('show', bmi < 26);
    var goalLbs = parseInt(document.getElementById('weaSG').value);
    document.getElementById('weaDispG').innerHTML = goalLbs+' <span>'+uL+'</span>';
    var threeMoLbs = paceMid * 12;
    var threeMoDisplay = unit==='imperial' ? Math.round(threeMoLbs) : Math.round(threeMoLbs/2.20462);
    var smallGoal = goalLbs < threeMoDisplay;
    var endW, headHtml, lab2;
    if(smallGoal){
      var weeks = Math.ceil(goalLbs / (unit==='imperial' ? paceMid : paceMid/2.20462));
      endW = wRaw - goalLbs;
      document.getElementById('weaOutLab').textContent = 'Your Estimated Timeline';
      headHtml = 'You could reach your goal in <em style="color:var(--blue);font-style:normal">~'+weeks+' weeks</em>';
      lab2 = 'Goal weight';
    } else {
      endW = wRaw - threeMoDisplay;
      document.getElementById('weaOutLab').textContent = 'Your 3-Month Potential';
      headHtml = 'You could lose up to <em style="color:var(--blue);font-style:normal">~'+threeMoDisplay+' '+uL+'</em> in your first 3 months';
      lab2 = 'After 3 months';
      var totalMonths = Math.ceil((goalLbs / (unit==='imperial' ? paceMid : paceMid/2.20462)) / 4.33);
      var timeStr = totalMonths > monthsCap ? monthsCap+'+ months' : '~'+totalMonths+' months';
      headHtml += '<div style="font-size:13px;color:var(--ink-60);font-weight:400;margin-top:8px">Estimated time to full goal: '+timeStr+'</div>';
    }
    document.getElementById('weaOutHead').innerHTML = headHtml;
    document.getElementById('weaOsLab2').textContent = lab2;
    document.getElementById('weaOsStart').innerHTML = wRaw+'<span>'+uL+'</span>';
    document.getElementById('weaOsGoal').innerHTML = endW+'<span>'+uL+'</span>';
    document.getElementById('weaChartMax').textContent = wRaw+' → '+endW+' '+uL;
    document.getElementById('weaTxtStart').textContent = wRaw+' '+uL;
    document.getElementById('weaTxtEnd').textContent = endW+' '+uL;
  };

  weaCalc();
})();
</script>


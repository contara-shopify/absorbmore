                  <defs>
                    <linearGradient id="weaG" x1="0" x2="0" y1="0" y2="1">
                      <stop offset="0%" stop-color="#5e91d5" stop-opacity=".28"/>
                      <stop offset="100%" stop-color="#5e91d5" stop-opacity="0"/>
                    </linearGradient>
                  </defs>
                  <line x1="0" y1="30" x2="300" y2="30" stroke="#1A1A18" stroke-opacity=".06" stroke-dasharray="2 3"/>
                  <line x1="0" y1="60" x2="300" y2="60" stroke="#1A1A18" stroke-opacity=".06" stroke-dasharray="2 3"/>
                  <line x1="0" y1="90" x2="300" y2="90" stroke="#1A1A18" stroke-opacity=".06" stroke-dasharray="2 3"/>
                  <path id="weaArea" d="M12,30 Q87,42 162,62 T288,95 L288,115 L12,115 Z" fill="url(#weaG)"/>
                  <path id="weaLine" d="M12,30 Q87,42 162,62 T288,95" fill="none" stroke="#5e91d5" stroke-width="2.5" stroke-linecap="round"/>
                  <circle cx="12" cy="30" r="4" fill="#5e91d5"/>
                  <circle cx="288" cy="95" r="4" fill="#5e91d5"/>
                  <text x="20" y="22" font-size="10" fill="#1A1A18" font-weight="600" id="weaTxtStart">180 lbs</text>

{% style %}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.section_background }};
  }

  #shopify-section-{{ section.id }} .ctr-dual-split {
    width: min(100%, {{ section.settings.max_width_desktop }}px);
    margin-left: auto;
    margin-right: auto;
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__inner {
    /* max-width: 780px; */
    /* margin: 0 auto; */
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__heading {
    margin: 0 auto 26px;
    max-width: 640px;
    text-align: center;
    font-size: 36px;
    line-height: 0.98;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 28px;
    align-items: start;
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__card {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__image-wrap {
    margin-bottom: 22px;
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    border-radius: 18px;
    /* padding: 20px 24px 16px; */
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__content {
    padding-top: 12px;
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__card--left .ctr-dual-split__title {
    color: {{ section.settings.left_accent_color }};
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__card--left .ctr-dual-split__image-wrap {
    /* box-shadow: inset 0 -4px 0 {{ section.settings.left_accent_color }}, inset 0 0 0 1px rgba(17, 17, 17, 0.04); */
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__card--right .ctr-dual-split__title {
    color: {{ section.settings.right_accent_color }};
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__card--right .ctr-dual-split__image-wrap {
    /* box-shadow: inset 0 -4px 0 {{ section.settings.right_accent_color }}, inset 0 0 0 1px rgba(17, 17, 17, 0.04); */
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__title {
    margin: 0 0 15px;
    font-size: 24px;
    line-height: 1.02;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__intro {
    margin: 0 0 12px;
    font-size: 14px;
    line-height: 1.42;
    color: rgba(17, 17, 17, 0.84);
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__bullets {
    margin: 0;
    padding-left: 18px;
    display: grid;
    gap: 7px;
    font-size: 14px;
    line-height: 1.38;
    font-weight: 600;
    list-style-type: disc;
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__bullets li {
    
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__actions {
    margin-top: 26px;
    display: grid;
    gap: 10px;
    justify-items: center;
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__cta {
    min-width: 340px;
    min-height: 50px;
    padding: 0 28px;
    border-radius: 8px;
    background: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    text-decoration: none;
    font-size: 16px;
    line-height: 1;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    font-size: 10px;
    line-height: 1.3;
    font-weight: 600;
    color: rgba(17, 17, 17, 0.82);
    text-align: center;
  }

  #shopify-section-{{ section.id }} .ctr-dual-split__meta-sep {
    color: rgba(17, 17, 17, 0.4);
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .ctr-dual-split {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__inner {
      /* max-width: 420px; */
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__card {
      padding: 0 20px;
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__heading {
      margin-bottom: 18px;
      max-width: 320px;
      font-size: 28px;
      line-height: 0.98;
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 18px;
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__image-wrap {
      border-radius: 14px;
      /* aspect-ratio: 1.18 / 1; */
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__image-wrap img {
      /* padding: 16px 18px 14px; */
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__content {
      padding-top: 10px;
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__title {
      font-size: 18px;
      margin-bottom: 8px;
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__intro {
      font-size: 11px;
      margin-bottom: 10px;
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__bullets {
      gap: 6px;
      font-size: 10px;
      line-height: 1.34;
      padding-left: 16px;
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__actions {
      margin-top: 18px;
      justify-items: stretch;
      padding: 0 20px;
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__cta {
      width: 100%;
      min-width: 0;
      min-height: 48px;
      font-size: 15px;
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__meta {
      justify-content: center;
      gap: 6px 8px;
      overflow-x: auto;
      /* flex-wrap: nowrap;
      white-space: nowrap; */
      padding-bottom: 2px;
      scrollbar-width: none;
    }

    #shopify-section-{{ section.id }} .ctr-dual-split__meta::-webkit-scrollbar {
      display: none;
    }
  }
{% endstyle %}

<section class="ctr-dual-split">
  <div class="ctr-dual-split__inner">
    {% if section.settings.heading != blank %}
      <h2 class="ctr-dual-split__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <div class="ctr-dual-split__grid">
      <article class="ctr-dual-split__card ctr-dual-split__card--left">
        {% if section.settings.left_image != blank %}
          <div class="ctr-dual-split__image-wrap">
            {{ section.settings.left_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '320,480,720,960,1200', sizes: '(max-width: 989px) 100vw, 50vw', alt: section.settings.left_title }}
          </div>
        {% endif %}

        <div class="ctr-dual-split__content">
          {% if section.settings.left_title != blank %}
            <h3 class="ctr-dual-split__title">{{ section.settings.left_title | escape }}</h3>
          {% endif %}
          {% if section.settings.left_intro != blank %}
            <p class="ctr-dual-split__intro">{{ section.settings.left_intro }}</p>
          {% endif %}
          <ul class="ctr-dual-split__bullets">
            {% if section.settings.left_bullet_1 != blank %}<li>{{ section.settings.left_bullet_1 | escape }}</li>{% endif %}
            {% if section.settings.left_bullet_2 != blank %}<li>{{ section.settings.left_bullet_2 | escape }}</li>{% endif %}
            {% if section.settings.left_bullet_3 != blank %}<li>{{ section.settings.left_bullet_3 | escape }}</li>{% endif %}
            {% if section.settings.left_bullet_4 != blank %}<li>{{ section.settings.left_bullet_4 | escape }}</li>{% endif %}
            {% if section.settings.left_bullet_5 != blank %}<li>{{ section.settings.left_bullet_5 | escape }}</li>{% endif %}
            {% if section.settings.left_bullet_6 != blank %}<li>{{ section.settings.left_bullet_6 | escape }}</li>{% endif %}
          </ul>
        </div>
      </article>

      <article class="ctr-dual-split__card ctr-dual-split__card--right">
        {% if section.settings.right_image != blank %}
          <div class="ctr-dual-split__image-wrap">
            {{ section.settings.right_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '320,480,720,960,1200', sizes: '(max-width: 989px) 100vw, 50vw', alt: section.settings.right_title }}
          </div>
        {% endif %}

        <div class="ctr-dual-split__content">
          {% if section.settings.right_title != blank %}
            <h3 class="ctr-dual-split__title">{{ section.settings.right_title | escape }}</h3>
          {% endif %}
          {% if section.settings.right_intro != blank %}
            <p class="ctr-dual-split__intro">{{ section.settings.right_intro }}</p>
          {% endif %}
          <ul class="ctr-dual-split__bullets">
            {% if section.settings.right_bullet_1 != blank %}<li>{{ section.settings.right_bullet_1 | escape }}</li>{% endif %}
            {% if section.settings.right_bullet_2 != blank %}<li>{{ section.settings.right_bullet_2 | escape }}</li>{% endif %}
            {% if section.settings.right_bullet_3 != blank %}<li>{{ section.settings.right_bullet_3 | escape }}</li>{% endif %}
            {% if section.settings.right_bullet_4 != blank %}<li>{{ section.settings.right_bullet_4 | escape }}</li>{% endif %}
            {% if section.settings.right_bullet_5 != blank %}<li>{{ section.settings.right_bullet_5 | escape }}</li>{% endif %}
            {% if section.settings.right_bullet_6 != blank %}<li>{{ section.settings.right_bullet_6 | escape }}</li>{% endif %}
          </ul>
        </div>
      </article>
    </div>

    <div class="ctr-dual-split__actions">
      {% if section.settings.cta_text != blank %}
        <a class="ctr-dual-split__cta" href="{{ section.settings.cta_url | default: '#' }}">
          {{ section.settings.cta_text | escape }}
        </a>
      {% endif %}

      <div class="ctr-dual-split__meta">
        {% if section.settings.urgency_label_1 != blank %}
          <span>{{ section.settings.urgency_label_1 | escape }}</span>
        {% endif %}
        {% if section.settings.urgency_label_1 != blank and section.settings.urgency_label_2 != blank %}
          <span class="ctr-dual-split__meta-sep">·</span>
        {% endif %}
        {% if section.settings.urgency_label_2 != blank %}
          <span>{{ section.settings.urgency_label_2 | escape }}</span>
        {% endif %}
        {% if section.settings.urgency_label_2 != blank and section.settings.urgency_label_3 != blank %}
          <span class="ctr-dual-split__meta-sep">·</span>
        {% endif %}
        {% if section.settings.urgency_label_3 != blank %}
          <span>{{ section.settings.urgency_label_3 | escape }}</span>
        {% endif %}
      </div>
    </div>
  </div>
</section>


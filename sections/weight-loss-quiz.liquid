<!-- ══════════════════════════════════════════════
     WLP-1™ Quiz — Section
     The Absorption Company
══════════════════════════════════════════════ -->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
/* Body */
body {
  margin: 0;
  padding: 0;
}

/* Hide header and footer */
header,
footer {
  display: none;
}

.wlp1q-root, .wlp1q-root *, .wlp1q-root *::before, .wlp1q-root *::after{ box-sizing: border-box; margin: 0; padding: 0; }

.wlp1q-root{
  --bg:        #EAE6DC;
  --bg-panel:  #E2DDD3;
  --bg-dark:   #DEDAD0;
  --white:     #FFFFFF;
  --black:     #111111;
  --dark:      #1A1A1A;
  --mid:       #555555;
  --light:     #888888;
  --lighter:   #AAAAAA;
  --border:    #D0CCC3;
  --blue:      #5E91D5;
  --blue-lt:   #EBF2FB;
  --selected:  #F0EDE6;
}

.wlp1q-root, .wlp1q-root{
  height: 100%;
  font-family: 'Inter', -apple-system, sans-serif;
  background: var(--bg);
  color: var(--black);
  font-size: 14px;
  overflow-x: hidden;
}

/* ═══════════ LAYOUT ═══════════ */
.wlp1q-root .quiz-shell{
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  max-width: 520px;
  margin: 0 auto;
}

.wlp1q-root .screen{
  display: none;
  flex-direction: column;
  min-height: 100vh;
  padding: 0 0 40px;
  animation: fadeIn 0.3s ease forwards;
}
.wlp1q-root .screen.active{ display: flex; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ═══════════ PROGRESS ═══════════ */
.wlp1q-root .progress-wrap{ padding: 16px 20px 0; display: flex; flex-direction: column; gap: 8px; }
.wlp1q-root .progress-meta{ display: flex; justify-content: space-between; align-items: center; }
.wlp1q-root .progress-label{ font-size: 11px; font-weight: 600; color: var(--lighter); letter-spacing: 0.08em; text-transform: uppercase; }
.wlp1q-root .progress-step{ font-size: 11px; font-weight: 600; color: var(--lighter); }
.wlp1q-root .progress-track{ height: 3px; background: var(--border); border-radius: 100px; overflow: hidden; }
.wlp1q-root .progress-fill{ height: 100%; background: var(--blue); border-radius: 100px; transition: width 0.4s ease; }

/* Back button */
.wlp1q-root .back-btn{
  background: none; border: none; font-family: 'Inter', sans-serif;
  font-size: 12px; font-weight: 600; color: var(--lighter); cursor: pointer;
  padding: 14px 20px 0; display: flex; align-items: center; gap: 6px; width: fit-content;
}
.wlp1q-root .back-btn:hover{ color: var(--mid); }
.wlp1q-root .back-btn svg{ width: 14px; height: 14px; }

/* ═══════════ SHARED COMPONENTS ═══════════ */
.wlp1q-root .q-wrap{ padding: 24px 20px 0; flex: 1; display: flex; flex-direction: column; }

.wlp1q-root .eyebrow{ font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--lighter); margin-bottom: 10px; }
.wlp1q-root .q-title{ font-size: 22px; font-weight: 800; color: var(--black); line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 6px; }
.wlp1q-root .q-sub{ font-size: 13px; color: var(--mid); line-height: 1.55; margin-bottom: 24px; }

/* Option cards */
.wlp1q-root .options{ display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; flex: 1; }

.wlp1q-root .opt-card{
  display: flex; align-items: center; gap: 14px; padding: 16px;
  background: var(--white); border: 1.5px solid var(--border); border-radius: 10px;
  cursor: pointer; transition: border-color 0.15s, background 0.15s;
  text-align: left; width: 100%; font-family: 'Inter', sans-serif;
}
.wlp1q-root .opt-card:hover{ border-color: #AAA; }
.wlp1q-root .opt-card.selected{ border-color: var(--blue); background: var(--blue-lt); }

.wlp1q-root .opt-radio{
  width: 20px; height: 20px; border-radius: 50%; border: 1.5px solid var(--border);
  flex-shrink: 0; display: flex; align-items: center; justify-content: center;
  transition: border-color 0.15s; margin-left: auto;
}
.wlp1q-root .opt-card.selected .opt-radio{ border-color: var(--blue); background: var(--blue); }
.wlp1q-root .opt-radio-dot{
  width: 8px; height: 8px; background: var(--white); border-radius: 50%;
  opacity: 0; transform: scale(0.3); transition: opacity 0.15s, transform 0.15s;
}
.wlp1q-root .opt-card.selected .opt-radio-dot{ opacity: 1; transform: scale(1); }

.wlp1q-root .opt-content{ flex: 1; }
.wlp1q-root .opt-label{ font-size: 14px; font-weight: 700; color: var(--dark); line-height: 1.3; }
.wlp1q-root .opt-desc{ font-size: 12px; color: var(--light); margin-top: 2px; line-height: 1.4; }

/* Custom SVG icon slot */
.wlp1q-root .opt-icon{ width: 36px; height: 36px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.wlp1q-root .opt-icon svg{ width: 28px; height: 28px; }

/* 2-col gender */
.wlp1q-root .options-2col{ display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 24px; }
.wlp1q-root .opt-card-big{
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 12px; padding: 28px 16px; background: var(--white); border: 1.5px solid var(--border);
  border-radius: 10px; cursor: pointer; transition: border-color 0.15s, background 0.15s;
  font-family: 'Inter', sans-serif; text-align: center;
}
.wlp1q-root .opt-card-big:hover{ border-color: #AAA; }
.wlp1q-root .opt-card-big.selected{ border-color: var(--blue); background: var(--blue-lt); }
.wlp1q-root .opt-card-big .big-icon svg{ width: 40px; height: 40px; }
.wlp1q-root .opt-card-big .big-label{ font-size: 15px; font-weight: 700; color: var(--dark); }

/* Primary CTA */
.wlp1q-root .btn-primary{
  width: calc(100% - 40px); margin: 0 20px;
  background: var(--black); color: var(--white); border: none; border-radius: 8px;
  padding: 17px; font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer;
  transition: background 0.15s, opacity 0.15s; flex-shrink: 0;
}
.wlp1q-root .btn-primary:hover{ background: #2a2a2a; }
.wlp1q-root .btn-primary:disabled{ opacity: 0.35; cursor: not-allowed; }

/* Input fields */
.wlp1q-root .input-row-pair{ display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
.wlp1q-root .input-group{ display: flex; flex-direction: column; gap: 6px; margin-bottom: 10px; }
.wlp1q-root .input-label-sm{ font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--lighter); }
.wlp1q-root .input-field-wrap{
  display: flex; align-items: center; background: var(--white);
  border: 1.5px solid var(--border); border-radius: 8px; overflow: hidden; transition: border-color 0.15s;
}
.wlp1q-root .input-field-wrap:focus-within{ border-color: var(--blue); }
.wlp1q-root .input-field{
  flex: 1; border: none; outline: none; padding: 13px 14px;
  font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 600;
  color: var(--dark); background: transparent; -moz-appearance: textfield;
}
.wlp1q-root .input-field::placeholder{ color: var(--lighter); font-weight: 400; }
.wlp1q-root .input-field::-webkit-inner-spin-button, .wlp1q-root .input-field::-webkit-outer-spin-button{ -webkit-appearance: none; }
.wlp1q-root .input-unit{ padding: 13px 14px 13px 0; font-size: 12px; font-weight: 500; color: var(--light); }

/* Unit toggle */
.wlp1q-root .unit-toggle{ display: flex; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; width: fit-content; margin-bottom: 16px; }
.wlp1q-root .unit-btn{
  padding: 7px 16px; font-size: 12px; font-weight: 600; color: var(--mid);
  background: var(--white); border: none; cursor: pointer; font-family: 'Inter', sans-serif;
  transition: background 0.15s, color 0.15s;
}
.wlp1q-root .unit-btn.active{ background: var(--black); color: var(--white); }

/* ═══════════ SPLASH PAGES ═══════════ */
.wlp1q-root .screen.splash-screen{
  background: var(--blue);
  min-height: 100vh;
}

.wlp1q-root .splash{
  flex: 1; display: flex; flex-direction: column; padding: 0; gap: 0;
}

/* Top bar with fact label + counter */
.wlp1q-root .splash-topbar{
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 24px 0;
}
.wlp1q-root .splash-fact-label{
  font-size: 10px; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--blue); background: rgba(94,145,213,0.15);
  padding: 5px 12px; border-radius: 100px;
}
.wlp1q-root .splash-counter{
  font-size: 12px; font-weight: 800; color: rgba(255,255,255,0.9);
  letter-spacing: 0.08em; background: rgba(255,255,255,0.15);
  padding: 4px 12px; border-radius: 100px;
}

.wlp1q-root .splash-screen .back-btn, .wlp1q-root .splash-back-btn{ color: rgba(255,255,255,0.5); padding-top: 10px; font-size: 0; width: 32px; height: 32px; display:flex; align-items:center; justify-content:center; background:none; border:none; cursor:pointer; }
.wlp1q-root .splash-screen .back-btn svg, .wlp1q-root .splash-back-btn svg{ width: 18px; height: 18px; }
.wlp1q-root .splash-screen .back-btn:hover, .wlp1q-root .splash-back-btn:hover{ color: rgba(255,255,255,0.9); }

.wlp1q-root .splash-content{
  flex: 1; display: flex; flex-direction: column; padding: 28px 24px 0;
}

.wlp1q-root .splash-kicker{
  font-size: 13px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase;
  color: white; margin-bottom: 14px;
  display: inline-flex; align-items: center; gap: 6px;
}

.wlp1q-root .splash-title{
  font-size: 30px; font-weight: 900; color: var(--white);
  line-height: 1.08; letter-spacing: -0.025em; margin-bottom: 16px;
}
.wlp1q-root .splash-title .accent{ color: var(--blue); }

.wlp1q-root .splash-body{
  font-size: 15px; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 28px;
}
.wlp1q-root .splash-body strong{ color: var(--white); font-weight: 700; }

/* Inline stat row — no boxes, just numbers separated by dividers */
.wlp1q-root .splash-stats-row{
  display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin-bottom: 28px;
  border-top: 1px solid rgba(255,255,255,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.1);
  padding: 20px 0;
}
.wlp1q-root .splash-stat-item{
  text-align: center; padding: 12px 8px;
  border-right: 1px solid rgba(255,255,255,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.wlp1q-root .splash-stat-item:nth-child(2n){ border-right: none; }
.wlp1q-root .splash-stat-item:nth-last-child(-n+2){ border-bottom: none; }
.wlp1q-root .splash-stat-num{ font-size: 24px; font-weight: 800; color: white; line-height: 1; letter-spacing: -0.02em; }
.wlp1q-root .splash-stat-lbl{ font-size: 10px; color: rgba(255,255,255,0.8); margin-top: 5px; line-height: 1.3; }

/* Muted injectable item */
.wlp1q-root .splash-info-item.muted .splash-info-bullet{ background: rgba(255,255,255,0.2); }
.wlp1q-root .splash-info-item.muted .splash-info-title{ color: rgba(255,255,255,0.4); font-weight: 500; }
.wlp1q-root .splash-info-item.muted .splash-info-desc{ color: rgba(255,255,255,0.25); }

/* Highlighted WLP-1 item */
.wlp1q-root .splash-info-item.highlighted{
  border-left: 3px solid rgba(255,255,255,0.7);
  padding-left: 14px;
  margin-left: -17px;
}
.wlp1q-root .splash-info-item.highlighted .splash-info-bullet{ background: white; }
.wlp1q-root .splash-info-item.highlighted .splash-info-title{ color: var(--white); font-weight: 800; }
.wlp1q-root .splash-info-item.highlighted .splash-info-desc{ color: rgba(255,255,255,0.7); }
  .wlp1q-root display: flex; align-items: center; gap: 12px; margin-bottom: 20px;
}
.splash-divider-line{ flex: 1; height: 1px; background: rgba(255,255,255,0.1); }
.wlp1q-root .splash-divider-text{ font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.25); }

/* Text-only info rows — no boxes */
.wlp1q-root .splash-info-list{ display: flex; flex-direction: column; gap: 16px; margin-bottom: 28px; }
.wlp1q-root .splash-info-item{ display: flex; align-items: flex-start; gap: 14px; }
.wlp1q-root .splash-info-bullet{
  width: 6px; height: 6px; background: var(--blue); border-radius: 50%;
  flex-shrink: 0; margin-top: 6px;
}
.wlp1q-root .splash-info-title{ font-size: 13.5px; font-weight: 700; color: var(--white); margin-bottom: 3px; line-height: 1.3; }
.wlp1q-root .splash-info-desc{ font-size: 12.5px; color: rgba(255,255,255,0.5); line-height: 1.5; }

.wlp1q-root .splash-btn-wrap{ margin-top: auto; padding: 0 24px 32px; }
.wlp1q-root .splash-btn-wrap .btn-primary{
  width: 100%; margin: 0;
  background: var(--blue);
}
.wlp1q-root .splash-btn-wrap .btn-primary:hover{ background: #4a7ec4; }

/* ═══════════ LANDING HERO ═══════════ */
.wlp1q-root .landing-hero{
  background: var(--white);
  border-bottom: 1px solid var(--border);
  padding: 0;
}

/* Slim brand bar */
.wlp1q-root .brand-bar{
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 20px; border-bottom: 1px solid var(--border);
}
.wlp1q-root .brand-bar-name{ font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mid); }
.wlp1q-root .brand-bar-badge{
  background: var(--blue); color: var(--white);
  font-size: 9.5px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 4px 10px; border-radius: 100px;
}

/* Quiz intro section */
.wlp1q-root .hero-quiz-intro{ padding: 24px 20px 20px; }

.wlp1q-root .hero-quiz-label{
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--blue-lt); color: var(--blue);
  font-size: 10.5px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 5px 12px; border-radius: 100px; margin-bottom: 14px;
}

.wlp1q-root .hero-title{
  font-size: 28px; font-weight: 900; color: var(--black);
  line-height: 1.07; letter-spacing: -0.025em; margin-bottom: 10px;
}
.wlp1q-root .hero-title .accent{ color: var(--blue); font-weight: 900; font-style: normal; }

.wlp1q-root .hero-desc{ font-size: 13px; color: var(--mid); line-height: 1.6; margin-bottom: 18px; }

/* Product pill */
.wlp1q-root .product-pill{
  display: flex; align-items: center; gap: 10px;
  background: var(--bg); border: 1px solid var(--border); border-radius: 10px;
  padding: 12px 14px; margin-bottom: 18px;
}
.wlp1q-root .product-pill-dot{ width: 8px; height: 8px; background: var(--blue); border-radius: 50%; flex-shrink: 0; }
.wlp1q-root .product-pill-text{ font-size: 12.5px; color: var(--dark); font-weight: 500; line-height: 1.4; }
.wlp1q-root .product-pill-text strong{ font-weight: 800; color: var(--black); }

.wlp1q-root .hero-stats{
  display: grid; grid-template-columns: repeat(3, 1fr);
  border: 1px solid var(--border); border-radius: 8px; overflow: hidden; background: var(--bg);
}
.wlp1q-root .hero-stat{ padding: 12px 8px; text-align: center; border-right: 1px solid var(--border); }
.wlp1q-root .hero-stat:last-child{ border-right: none; }
.wlp1q-root .hero-stat-num{ font-size: 17px; font-weight: 800; color: var(--black); line-height: 1; }
.wlp1q-root .hero-stat-lbl{ font-size: 9px; color: var(--mid); margin-top: 3px; line-height: 1.3; text-transform: uppercase; letter-spacing: 0.04em; }

/* Q1 embedded below hero */
.wlp1q-root .landing-q{ padding: 20px 20px 0; flex: 1; display: flex; flex-direction: column; }
.wlp1q-root .landing-q .eyebrow{ font-size: 9.5px; color: var(--lighter); margin-bottom: 6px; }

/* ═══════════ EMAIL ═══════════ */
.wlp1q-root .email-wrap{ padding: 32px 20px 0; flex: 1; display: flex; flex-direction: column; }
.wlp1q-root .email-title{ font-size: 24px; font-weight: 800; color: var(--black); line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 8px; }
.wlp1q-root .email-sub{ font-size: 13px; color: var(--mid); line-height: 1.55; margin-bottom: 24px; }
.wlp1q-root .email-privacy{ display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--lighter); margin-top: 12px; justify-content: center; }
.wlp1q-root .email-privacy svg{ width: 12px; height: 12px; }

/* ═══════════ RESULTS ═══════════ */
.wlp1q-root .results-wrap{ padding: 0; flex: 1; display: flex; flex-direction: column; }

.wlp1q-root .results-hero{ background: var(--blue); padding: 24px 20px 20px; }
.wlp1q-root .results-eyebrow{ font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 8px; }
.wlp1q-root .results-title{ font-size: 22px; font-weight: 800; color: var(--white); line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 16px; }

.wlp1q-root .results-stat-row{ display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
.wlp1q-root .r-stat{ background: rgba(255,255,255,0.15); border-radius: 10px; padding: 12px 10px; text-align: center; }
.wlp1q-root .r-stat-num{ font-size: 20px; font-weight: 800; color: var(--white); line-height: 1; }
.wlp1q-root .r-stat-num.blue{ color: var(--white); }
.wlp1q-root .r-stat-lbl{ font-size: 9.5px; color: rgba(255,255,255,0.6); margin-top: 3px; line-height: 1.3; text-transform: uppercase; letter-spacing: 0.04em; }

.wlp1q-root .results-body{ padding: 20px 20px 0; flex: 1; display: flex; flex-direction: column; gap: 20px; }
.wlp1q-root .section-lbl{ font-size: 9.5px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--lighter); margin-bottom: 12px; }

/* ── Goal slider ── */
.wlp1q-root .goal-slider-wrap{ margin-bottom: 24px; }
.wlp1q-root .goal-display{ margin-bottom: 16px; }
.wlp1q-root .goal-lbs{ font-size: 36px; font-weight: 900; color: var(--blue); letter-spacing: -0.03em; line-height: 1; }
.wlp1q-root .goal-pct{ font-size: 13px; font-weight: 600; color: var(--mid); margin-top: 3px; }
.wlp1q-root .goal-desc{ font-size: 13px; color: var(--mid); line-height: 1.5; margin-top: 8px; min-height: 40px; padding: 10px 14px; background: var(--white); border: 1px solid var(--border); border-radius: 8px; }
.wlp1q-root .goal-slider{ -webkit-appearance: none; width: 100%; height: 6px; border-radius: 100px; outline: none; cursor: pointer; margin-bottom: 8px; }
.wlp1q-root .goal-slider::-webkit-slider-thumb{ -webkit-appearance: none; width: 24px; height: 24px; border-radius: 50%; background: var(--blue); border: 3px solid var(--white); box-shadow: 0 0 0 1.5px var(--blue); cursor: pointer; }
.wlp1q-root .goal-slider::-moz-range-thumb{ width: 24px; height: 24px; border-radius: 50%; background: var(--blue); border: 3px solid var(--white); cursor: pointer; }
.wlp1q-root .goal-track-labels{ display: flex; justify-content: space-between; }
.wlp1q-root .goal-track-lbl{ font-size: 10px; font-weight: 600; color: var(--lighter); }
.wlp1q-root .timeline-card{
  background: var(--white); border: 1px solid var(--border);
  border-radius: 10px; overflow: hidden;
}
.wlp1q-root .tl-row{
  padding: 14px 16px; border-bottom: 1px solid var(--border);
  display: flex; flex-direction: column; gap: 7px;
}
.wlp1q-root .tl-row:last-child{ border-bottom: none; }
.wlp1q-root .tl-meta{ display: flex; justify-content: space-between; align-items: center; }
.wlp1q-root .tl-name{ font-size: 12.5px; font-weight: 700; color: var(--dark); }
.wlp1q-root .tl-time{ font-size: 13px; font-weight: 700; color: var(--dark); }
.wlp1q-root .tl-time.blue{ color: var(--blue); }
.wlp1q-root .tl-bar-track{ height: 9px; background: var(--bg-panel); border-radius: 100px; overflow: hidden; }
.wlp1q-root .tl-bar-fill{ height: 100%; border-radius: 100px; transition: width 0.7s cubic-bezier(.16,1,.3,1); }
.wlp1q-root .tl-bar-stack{ background: var(--blue); }
.wlp1q-root .tl-bar-wlp{ background: var(--black); }
.wlp1q-root .tl-bar-base{ background: var(--border); }

/* Product cards */
.wlp1q-root .product-cards{ display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.wlp1q-root .product-card{
  background: var(--white); border: 1.5px solid var(--border);
  border-radius: 10px; overflow: hidden; display: flex; flex-direction: column;
}
.wlp1q-root .product-card.featured{ border-color: var(--blue); }
.wlp1q-root .pc-header{ padding: 14px 14px 12px; border-bottom: 1px solid var(--border); background: var(--bg-panel); }
.wlp1q-root .pc-header.featured{ background: var(--blue); }
.wlp1q-root .pc-badge{
  font-size: 9px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 3px 8px; border-radius: 100px; margin-bottom: 8px; display: inline-block;
}
.wlp1q-root .pc-badge.std{ background: var(--border); color: var(--mid); }
.wlp1q-root .pc-badge.best{ background: rgba(255,255,255,0.25); color: var(--white); }
.wlp1q-root .pc-name{ font-size: 14px; font-weight: 800; color: var(--dark); line-height: 1.2; }
.wlp1q-root .pc-name.white{ color: var(--white); }
.wlp1q-root .pc-sub{ font-size: 11px; color: var(--light); margin-top: 2px; }
.wlp1q-root .pc-sub.white{ color: rgba(255,255,255,0.6); }
.wlp1q-root .pc-body{ padding: 12px 14px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
.wlp1q-root .pc-stat{ text-align: center; padding: 8px 0; border-bottom: 1px solid var(--border); }
.wlp1q-root .pc-stat-num{ font-size: 22px; font-weight: 800; color: var(--black); line-height: 1; }
.wlp1q-root .pc-stat-num.blue{ color: var(--blue); }
.wlp1q-root .pc-stat-lbl{ font-size: 9.5px; color: var(--light); margin-top: 2px; }
.wlp1q-root .pc-features{ display: flex; flex-direction: column; gap: 6px; flex: 1; }
.wlp1q-root .pc-feat{ display: flex; align-items: flex-start; gap: 7px; font-size: 11.5px; color: var(--mid); line-height: 1.4; }
.wlp1q-root .feat-dot{ width: 5px; height: 5px; background: var(--black); border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
.wlp1q-root .feat-dot.blue{ background: var(--blue); }
.wlp1q-root .pc-price{ padding: 12px 14px; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 2px; }
.wlp1q-root .pc-price-main{ font-size: 16px; font-weight: 800; color: var(--dark); line-height: 1.2; }
.wlp1q-root .pc-price-aslow{ font-size: 10px; font-weight: 500; color: var(--light); display: block; margin-bottom: 1px; }
.wlp1q-root .pc-price-mo{ font-size: 12px; font-weight: 500; color: var(--dark); }
.wlp1q-root .pc-price-orig{ font-size: 11px; color: var(--lighter); text-decoration: line-through; }
.wlp1q-root .pc-price-day{ font-size: 10px; color: var(--light); }
.wlp1q-root .pc-cta{
  margin: 0 14px 14px; background: var(--black); color: var(--white); border: none;
  border-radius: 6px; padding: 13px; font-family: 'Inter', sans-serif; font-size: 11px;
  font-weight: 800; letter-spacing: 0.09em; text-transform: uppercase; cursor: pointer;
  width: calc(100% - 28px); transition: background 0.15s;
}
.wlp1q-root .pc-cta:hover{ background: #2a2a2a; }
.wlp1q-root .pc-cta.blue-btn{ background: var(--blue); }
.wlp1q-root .pc-cta.blue-btn:hover{ background: #4a7ec4; }

.wlp1q-root .results-disclaimer{ font-size: 10px; color: var(--lighter); line-height: 1.5; padding-bottom: 20px; }

/* ═══════════ LOADER ═══════════ */
.wlp1q-root .loader-ring{
  width: 56px; height: 56px;
  border-radius: 50%;
  border: 3px solid var(--border);
  border-top-color: var(--blue);
  animation: spin 0.9s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.wlp1q-root .loader-check{
  display: flex; align-items: center; gap: 10px;
  font-size: 12px; color: var(--lighter);
  font-weight: 500;
  transition: color 0.3s ease;
}
.wlp1q-root .loader-check.done{ color: var(--dark); }
.wlp1q-root .loader-check.done .loader-check-icon{ color: var(--blue); }
.wlp1q-root .loader-check-icon{
  width: 18px; height: 18px;
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 800;
  color: var(--lighter);
}

/* Section wrapper: full-bleed reset so the quiz takes over the page */
.wlp1q-root {
  position: relative;
  width: 100%;
  min-height: 100vh;
}
</style>


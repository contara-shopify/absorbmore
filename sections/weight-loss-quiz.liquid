<script>
(function() {
  var root = document.getElementById('wlp1q-{{ section.id }}');
  if (!root) return;

  // Patch DOMContentLoaded to fire immediately if already loaded
  function _ready(fn) {
    if (document.readyState !== 'loading') fn();
    else document.addEventListener('DOMContentLoaded', fn);
  }

let goalPct  = 10;
let bodyUnit = 'imperial';
// Store calculated weeks globally for chart
let _stackWeeks = 8, _wlpWeeks = 10, _baseWeeks = 26;
// Track if quiz_started event has been fired
let _quizStartedFired = false;

// ── ANALYTICS: Mixpanel ──
// Uses Mixpanel's official snippet pattern so track() calls made before
// the SDK finishes loading are queued and replayed automatically.
(function() {
  var token = '{{ section.settings.mixpanel_token }}';
  if (!token) return;

  // Mixpanel official snippet (verbatim from their docs, minified),
  // with our token wired in. Creates window.mixpanel stub that queues calls.
  (function(f,b){if(!b.__SV){var e,g,i,h;window.mixpanel=b;b._i=[];b.init=function(e,f,c){function g(a,d){var b=d.split(".");2==b.length&&(a=a[b[0]],d=b[1]);a[d]=function(){a.push([d].concat(Array.prototype.slice.call(arguments,0)))}}var a=b;"undefined"!==typeof c?a=b[c]=[]:c="mixpanel";a.people=a.people||[];a.toString=function(a){var d="mixpanel";"mixpanel"!==c&&(d+="."+c);a||(d+=" (stub)");return d};a.people.toString=function(){return a.toString(1)+".people (stub)"};i="disable time_event track track_pageview track_links track_forms track_with_groups add_group set_group remove_group register register_once alias unregister identify name_tag set_config reset opt_in_tracking opt_out_tracking has_opted_in_tracking has_opted_out_tracking clear_opt_in_out_tracking start_batch_senders people.set people.set_once people.unset people.increment people.append people.union people.track_charge people.clear_charges people.delete_user people.remove".split(" ");
  for(h=0;h<i.length;h++)g(a,i[h]);var j="set set_once union unset remove delete".split(" ");a.get_group=function(){function b(c){d[c]=function(){call2_args=arguments;call2=[c].concat(Array.prototype.slice.call(call2_args,0));a.push([e,call2])}}for(var d={},e=["get_group"].concat(Array.prototype.slice.call(arguments,0)),c=0;c<j.length;c++)b(j[c]);return d};b._i.push([e,f,c])};b.__SV=1.2;e=f.createElement("script");e.type="text/javascript";e.async=!0;e.src="undefined"!==typeof MIXPANEL_CUSTOM_LIB_URL?MIXPANEL_CUSTOM_LIB_URL:"file:"===f.location.protocol&&"//cdn.mxpnl.com/libs/mixpanel-2-latest.min.js".match(/^\/\//)?"https://cdn.mxpnl.com/libs/mixpanel-2-latest.min.js":"//cdn.mxpnl.com/libs/mixpanel-2-latest.min.js";g=f.getElementsByTagName("script")[0];g.parentNode.insertBefore(e,g)}})(document,window.mixpanel||[]);

  // Initialize with our token
  try {
    window.mixpanel.init(token, {
      debug: false,
      track_pageview: false,
      persistence: 'localStorage'
    });
  } catch (e) { /* silent */ }
})();

function trackEvent(eventName, properties) {
  properties = properties || {};
  properties.source = properties.source || 'WLP-1 Quiz';
  try {
    if (window.mixpanel && window.mixpanel.track) {
      window.mixpanel.track(eventName, properties);
    }
  } catch (e) { /* silent */ }
}

function identifyUser(email, firstName) {
  try {
    if (!window.mixpanel || !window.mixpanel.identify) return;
    window.mixpanel.identify(email);
    window.mixpanel.people.set({
      '$email':      email,
      '$first_name': firstName || ''
    });
  } catch (e) { /* silent */ }
}
// Fire page view as soon as quiz loads
trackEvent('WLP1 Quiz Page Viewed');

// ── NAVIGATION ──
var _currentScreen = 's1';
function goTo(id) {
  var from = _currentScreen;

  // Fire Quiz Fields Entered when leaving S4 (weight/height) or S5 (goal)
  if (from === 's4' && id !== 's4') {
    var weightLbs, heightIn;
    if (bodyUnit === 'imperial') {
      weightLbs = parseFloat(root.querySelector('#weight-lbs').value) || null;
      var ft = parseFloat(root.querySelector('#height-ft').value) || 0;
      var inch = parseFloat(root.querySelector('#height-in').value) || 0;
      heightIn = ft * 12 + inch;
    } else {
      var wk = parseFloat(root.querySelector('#weight-kg').value) || null;
      weightLbs = wk ? Math.round(wk * 2.20462) : null;
      var cm = parseFloat(root.querySelector('#height-cm').value) || 0;
      heightIn = cm ? Math.round(cm / 2.54) : null;
    }
    if (weightLbs || heightIn) {
      trackEvent('WLP1 Quiz Fields Entered', {
        field_group:  'weight_height',
        weight_lbs:   weightLbs,
        height_in:    heightIn,
        unit_system:  bodyUnit
      });
    }
  }
  if (from === 's5' && id !== 's5') {
    var weightForGoal = 180;
    if (bodyUnit === 'imperial') {
      var wl = parseFloat(root.querySelector('#weight-lbs').value);
      if (wl) weightForGoal = wl;
    } else {
      var wkg = parseFloat(root.querySelector('#weight-kg').value);
      if (wkg) weightForGoal = wkg * 2.20462;
    }
    trackEvent('WLP1 Quiz Fields Entered', {
      field_group:    'goal_slider',
      goal_loss_pct:  goalPct,
      goal_loss_lbs:  Math.round(weightForGoal * (goalPct / 100))
    });
  }

  root.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  var target = root.querySelector('#' + id);
  if (target) target.classList.add('active');
  window.scrollTo({ top: 0, behavior: 'instant' });

  _currentScreen = id;

  // Fire Quiz Screen Viewed on every screen change — core of the drop-off funnel
  trackEvent('WLP1 Quiz Screen Viewed', { screen: id });

  // Fire Quiz Started once on first real interaction
  if (!_quizStartedFired && id !== 's1') {
    _quizStartedFired = true;
    trackEvent('WLP1 Quiz Started', {});
  }

  // Fire Quiz Results Viewed when the results page actually loads
  if (id === 'results') {
    trackEvent('WLP1 Quiz Results Viewed', {
      top_goal:       answers.q1 || '',
      goal_loss_pct:  goalPct,
      lifestyle:      answers.q6 || '',
      weight_history: answers.q8 || '',
      timeline:       answers.q9 || ''
    });
  }
}

// ── SINGLE SELECT (auto-advance after brief flash) ──
// Global answer store
const answers = { q1:'', q2:'', q3:'', q6:'', q7:[], q8:'', q9:'' };

function selectOpt(groupId, btn, nextScreen) {
  root.querySelector('#' + groupId).querySelectorAll('.opt-card').forEach(c => c.classList.remove('selected'));
  btn.classList.add('selected');
  // Store answer
  const key = groupId.replace('-opts', '');
  const lbl = btn.querySelector('.opt-label');
  if (lbl && answers.hasOwnProperty(key)) answers[key] = lbl.textContent.trim();
  trackEvent('WLP1 Quiz Question Answered', {
    question_id: key,
    answer: lbl ? lbl.textContent.trim() : ''
  });
  setTimeout(() => goTo(nextScreen), 260);
}

// ── 2-COL BIG SELECT ──
function selectBig(btn, nextScreen) {
  btn.closest('.options-2col').querySelectorAll('.opt-card-big').forEach(c => c.classList.remove('selected'));
  btn.classList.add('selected');
  // Store gender (q2)
  const lbl = btn.querySelector('.opt-label') || btn;
  answers.q2 = (lbl.textContent || '').trim();
  trackEvent('WLP1 Quiz Question Answered', {
    question_id: 'q2',
    answer: answers.q2
  });
  setTimeout(() => goTo(nextScreen), 260);
}

// ── MULTI SELECT ──
function toggleMulti(btn) {
  btn.classList.toggle('selected');
  // Rebuild q7 array from currently selected
  const group = btn.closest('.options');
  if (group && group.id === 'q7-opts') {
    answers.q7 = Array.from(group.querySelectorAll('.opt-card.selected'))
      .map(c => (c.querySelector('.opt-label')?.textContent || '').trim())
      .filter(Boolean);
  }
}

// ── GOAL SLIDER ──
function updateGoalSlider() {
  const slider = root.querySelector('#goal-slider');
  const pct = parseInt(slider.value);
  goalPct = pct;

  // Estimate lbs based on entered weight or default 180
  let weightLbs = 180;
  if (bodyUnit === 'imperial') {
    const w = parseFloat(root.querySelector('#weight-lbs').value);
    if (w) weightLbs = w;
  } else {
    const w = parseFloat(root.querySelector('#weight-kg').value);
    if (w) weightLbs = w * 2.20462;
  }
  const lbs = Math.round(weightLbs * pct / 100);
  const displayLbs = bodyUnit === 'metric' ? Math.round(lbs / 2.20462) + ' kg' : lbs + ' lbs';

  root.querySelector('#goal-lbs-display').textContent = displayLbs;
  root.querySelector('#goal-pct-display').textContent = pct + '% of your body weight';

  // Update track fill (range is 5–25, so divisor is 20)
  const fillPct = ((pct - 5) / 20) * 100;
  slider.style.background = `linear-gradient(to right, #5E91D5 ${fillPct}%, #D0CCC3 ${fillPct}%)`;
}

// init slider on load
document.addEventListener('DOMContentLoaded', updateGoalSlider);

// ── UNIT TOGGLE ──
function setBodyUnit(u) {
  bodyUnit = u;
  root.querySelector('#u-imp').classList.toggle('active', u === 'imperial');
  root.querySelector('#u-met').classList.toggle('active', u === 'metric');
  root.querySelector('#imperial-inputs').style.display = u === 'imperial' ? '' : 'none';
  root.querySelector('#metric-inputs').style.display   = u === 'metric'   ? '' : 'none';
  checkS4();
}

// ── VALIDATE S4 ──
function checkS4() {
  let valid = false;
  if (bodyUnit === 'imperial') {
    const w = root.querySelector('#weight-lbs').value;
    const f = root.querySelector('#height-ft').value;
    const i = root.querySelector('#height-in').value;
    valid = w && f && i !== '';
  } else {
    const w = root.querySelector('#weight-kg').value;
    const h = root.querySelector('#height-cm').value;
    valid = w && h;
  }
  root.querySelector('#s4-next').disabled = !valid;
}

// ── VALIDATE EMAIL ──
function checkEmail() {
  const name  = root.querySelector('#fname').value.trim();
  const email = root.querySelector('#email-input').value.trim();
  const valid = name.length > 0 && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  root.querySelector('#email-next').disabled = !valid;
}

// ── ANALYZING LOADER → RESULTS ──
function startAnalyzing() {
  // Track email submission + identify the user in Mixpanel
  var emailEl = root.querySelector('#email-input');
  var fnameEl = root.querySelector('#fname');
  var emailVal = emailEl ? emailEl.value.trim() : '';
  var fnameVal = fnameEl ? fnameEl.value.trim().split(' ')[0] : '';

  if (emailVal) {
    identifyUser(emailVal, fnameVal);
  }

  trackEvent('WLP1 Quiz Email Submitted', {
    first_name:     fnameVal,
    top_goal:       answers.q1 || '',
    goal_loss_pct:  goalPct,
    lifestyle:      answers.q6 || '',
    weight_history: answers.q8 || '',
    timeline:       answers.q9 || ''
  });

  // Fire-and-forget Klaviyo subscription as soon as they hit "See my results"
  submitToKlaviyo();

  goTo('loader');
  const steps = [
    { id: 'lc1', text: 'Reviewing your responses' },
    { id: 'lc2', text: 'Calculating your metabolic profile' },
    { id: 'lc3', text: 'Matching ingredients to your goals' },
    { id: 'lc4', text: 'Building your personalized plan' }
  ];
  const stepEl = root.querySelector('#loader-step');
  let i = 0;
  function tick() {
    if (i < steps.length) {
      stepEl.textContent = steps[i].text;
      const el = root.querySelector('#' + steps[i].id);
      if (el) {
        el.classList.add('done');
        el.querySelector('.loader-check-icon').textContent = '✓';
      }
      i++;
      setTimeout(tick, 700);
    } else {
      buildResults();
      setTimeout(() => goTo('results'), 350);
    }
  }
  setTimeout(tick, 250);
}

// ── KLAVIYO SUBMISSION ──
function submitToKlaviyo() {
  var KLAVIYO_KEY  = '{{ section.settings.klaviyo_public_key }}';
  var KLAVIYO_LIST = '{{ section.settings.klaviyo_list_id }}';
  if (!KLAVIYO_KEY || !KLAVIYO_LIST) return;

  // Pull the data we want to send
  var emailEl = root.querySelector('#email-input');
  var fnameEl = root.querySelector('#fname');
  var email = emailEl ? emailEl.value.trim() : '';
  var fname = fnameEl ? fnameEl.value.trim().split(' ')[0] : '';
  if (!email) return;

  // Calculate goal weight loss in lbs from current state
  var weightLbs = 180;
  if (bodyUnit === 'imperial') {
    var w = parseFloat(root.querySelector('#weight-lbs').value);
    if (w) weightLbs = w;
  } else {
    var wk = parseFloat(root.querySelector('#weight-kg').value);
    if (wk) weightLbs = wk * 2.20462;
  }
  var goalLossLbs = Math.round(weightLbs * (goalPct / 100));

  // Build the profile properties
  var properties = {
    'Quiz Top Goal':       answers.q1 || '',
    'Quiz Goal Loss Pct':  goalPct,
    'Quiz Goal Loss Lbs':  goalLossLbs,
    'Quiz Source':         'WLP-1 Quiz',
    'Quiz Completed At':   new Date().toISOString()
  };

  var payload = {
    data: {
      type: 'subscription',
      attributes: {
        custom_source: 'WLP-1 Quiz',
        profile: {
          data: {
            type: 'profile',
            attributes: {
              email: email,
              first_name: fname,
              properties: properties
            }
          }
        }
      },
      relationships: {
        list: { data: { type: 'list', id: KLAVIYO_LIST } }
      }
    }
  };

  fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + encodeURIComponent(KLAVIYO_KEY), {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'revision': '2024-10-15'
    },
    body: JSON.stringify(payload)
  }).catch(function(err) { console.warn('Klaviyo submission failed:', err); });
}

// ── BUILD RESULTS (Direction B — personalized) ──
function buildResults() {
  let weightLbs;
  if (bodyUnit === 'imperial') {
    weightLbs = parseFloat(root.querySelector('#weight-lbs').value) || 180;
  } else {
    weightLbs = (parseFloat(root.querySelector('#weight-kg').value) || 82) * 2.20462;
  }

  const lossLbs = weightLbs * (goalPct / 100);
  const goalLbs = weightLbs - lossLbs;
  const scale   = weightLbs / 180;
  const stackRate = 1.55 * scale; // lbs/week, scaled to body weight
  _stackWeeks = Math.max(4, Math.ceil(lossLbs / stackRate));
  const months = Math.max(1, Math.round(_stackWeeks / 4.3));

  const isMetric = bodyUnit === 'metric';
  const fmtWt = lbs => isMetric ? `${Math.round(lbs / 2.20462)} kg` : `${Math.round(lbs)} lbs`;
  const fmtWtNoUnit = lbs => isMetric ? `${Math.round(lbs / 2.20462)}` : `${Math.round(lbs)}`;
  const unitLabel = isMetric ? 'kg' : 'lbs';

  const fname = (root.querySelector('#fname')?.value || '').trim().split(' ')[0];

  // Hero headline
  const monthLabel = months === 1 ? '1 month' : `${months} months`;
  root.querySelector('#r2-hero-title').textContent =
    `${fname ? fname + ', here' : 'Here'}'s how the next ${monthLabel} could look.*`;

  // ── GRAPH LABELS ──
  // Y-axis: top = today's weight, bottom = goal weight, two interpolated mids
  const yTop = weightLbs;
  const yBot = goalLbs;
  const yMid1 = yTop - (yTop - yBot) * (1/3);
  const yMid2 = yTop - (yTop - yBot) * (2/3);
  root.querySelector('#r2-y-top').textContent  = `${fmtWtNoUnit(yTop)} ${unitLabel}`;
  root.querySelector('#r2-y-mid1').textContent = `${fmtWtNoUnit(yMid1)}`;
  root.querySelector('#r2-y-mid2').textContent = `${fmtWtNoUnit(yMid2)}`;
  root.querySelector('#r2-y-bot').textContent  = `${fmtWtNoUnit(yBot)}`;

  // X-axis: 5 month labels starting from today
  const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const now = new Date();
  const startMo = now.getMonth();
  // We have 5 tick positions; spread them across the months range
  for (let i = 0; i < 5; i++) {
    const monthsOut = Math.round((months) * (i / 4));
    const label = monthNames[(startMo + monthsOut) % 12];
    const el = document.getElementById('r2-x-' + i);
    if (el) el.textContent = label;
  }

  // Today and goal labels on the curve
  root.querySelector('#r2-today-label').textContent = `Today · ${fmtWt(yTop)}`;
  root.querySelector('#r2-goal-label').textContent  = `Goal · ${fmtWt(yBot)} ✓`;

  // ── TRAITS (pills) ──
  const inactive = answers.q6 === 'Mostly sedentary' || answers.q6 === 'Lightly active';
  const active   = answers.q6 === 'Moderately active' || answers.q6 === 'Very active';
  const gained   = answers.q8 === "I've gained weight";
  const yoyo     = answers.q8 === 'I keep gaining and losing';
  const lost     = answers.q8 === "I've lost some weight";
  const same     = answers.q8 === 'Stayed roughly the same';
  const impacts  = Array.isArray(answers.q7) ? answers.q7.filter(x => x && x !== 'None of the above') : [];

  const traits = [];
  if (answers.q6) traits.push(answers.q6);
  if (gained)  traits.push('Recent weight gain');
  if (yoyo)    traits.push('Yo-yo cycle');
  if (lost)    traits.push('Made some progress');
  if (same)    traits.push('Stuck at the same weight');
  // Pull a couple of impact traits if they exist
  impacts.slice(0, 2).forEach(impact => {
    const map = {
      'Energy and daily function': 'Wants more energy',
      'Confidence and self-esteem': 'Wants confidence back',
      'Physical health or mobility': 'Wants better mobility',
      'Social life or relationships': 'Affecting social life',
      'Mental health or mood': 'Affecting mood'
    };
    if (map[impact]) traits.push(map[impact]);
  });

  // Goal magnitude trait
  if (goalPct >= 18) traits.push('Ambitious goal');

  const traitsEl = root.querySelector('#r2-traits');
  if (traitsEl) {
    traitsEl.innerHTML = traits.length
      ? traits.map(t => `<div class="r2-pill">${t}</div>`).join('')
      : '<div class="r2-pill">Personalized for you</div>';
  }
}

  // Expose functions used by inline handlers
  window.WLP1Q = window.WLP1Q || {};
  window.WLP1Q.goTo = typeof goTo === "function" ? goTo : window.WLP1Q.goTo;
  window.WLP1Q.selectBig = typeof selectBig === "function" ? selectBig : window.WLP1Q.selectBig;
  window.WLP1Q.selectOpt = typeof selectOpt === "function" ? selectOpt : window.WLP1Q.selectOpt;
  window.WLP1Q.setBodyUnit = typeof setBodyUnit === "function" ? setBodyUnit : window.WLP1Q.setBodyUnit;
  window.WLP1Q.startAnalyzing = typeof startAnalyzing === "function" ? startAnalyzing : window.WLP1Q.startAnalyzing;
  window.WLP1Q.toggleMulti = typeof toggleMulti === "function" ? toggleMulti : window.WLP1Q.toggleMulti;
  window.WLP1Q.checkEmail = typeof checkEmail === "function" ? checkEmail : window.WLP1Q.checkEmail;
  window.WLP1Q.checkS4 = typeof checkS4 === "function" ? checkS4 : window.WLP1Q.checkS4;
  window.WLP1Q.updateGoalSlider = typeof updateGoalSlider === "function" ? updateGoalSlider : window.WLP1Q.updateGoalSlider;
  window.WLP1Q.trackCta = function(which) {
    trackEvent('WLP1 Quiz CTA Clicked', {
      cta:            which,
      top_goal:       answers.q1 || '',
      goal_loss_pct:  goalPct,
      lifestyle:      answers.q6 || ''
    });
  };

})();
</script>


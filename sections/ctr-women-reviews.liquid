    { "type": "range", "id": "panel_inner_gap_desktop", "label": "Panel inner gap - desktop", "default": 18, "min": 8, "max": 40, "step": 2, "unit": "px" },
    { "type": "range", "id": "panel_inner_gap_mobile", "label": "Panel inner gap - mobile", "default": 14, "min": 8, "max": 32, "step": 2, "unit": "px" },
    { "type": "range", "id": "panel_min_height_desktop", "label": "Panel min height - desktop", "default": 280, "min": 180, "max": 420, "step": 10, "unit": "px" },
    { "type": "range", "id": "panel_min_height_mobile", "label": "Panel min height - mobile", "default": 0, "min": 0, "max": 320, "step": 10, "unit": "px", "info": "0 = auto height." },

    { "type": "header", "content": "Typography & badges" },
    { "type": "color", "id": "star_color", "label": "Star color", "default": "#202020" },
    { "type": "range", "id": "star_size_desktop", "label": "Star size - desktop", "default": 18, "min": 12, "max": 24, "step": 1, "unit": "px" },
    { "type": "range", "id": "star_size_mobile", "label": "Star size - mobile", "default": 16, "min": 12, "max": 22, "step": 1, "unit": "px" },
    { "type": "color", "id": "quote_color", "label": "Quote color", "default": "#202020" },
    { "type": "range", "id": "quote_size_desktop", "label": "Quote size - desktop", "default": 20, "min": 14, "max": 28, "step": 1, "unit": "px" },
    { "type": "range", "id": "quote_size_mobile", "label": "Quote size - mobile", "default": 17, "min": 14, "max": 24, "step": 1, "unit": "px" },
    { "type": "color", "id": "author_color", "label": "Author color", "default": "#202020" },
    { "type": "range", "id": "author_size_desktop", "label": "Author size - desktop", "default": 15, "min": 12, "max": 20, "step": 1, "unit": "px" },
    { "type": "range", "id": "author_size_mobile", "label": "Author size - mobile", "default": 14, "min": 12, "max": 18, "step": 1, "unit": "px" },
    { "type": "text", "id": "verified_label", "label": "Verified label", "default": "Verified Buyer" },
    { "type": "color", "id": "verified_icon_color", "label": "Verified icon color", "default": "#4d61ff" },

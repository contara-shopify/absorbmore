{%- liquid
  assign section_id = section.settings.section_id
  assign custom_css = section.settings.custom_css
  assign container_spacing = section.settings.container_spacing
-%}

{%- capture selector -%}[data-style-id="{{ section.id }}"]{%- endcapture -%}

{%- capture star_svg -%}
<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" focusable="false">
  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
</svg>
{%- endcapture -%}

{%- capture verified_svg -%}
<svg viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
  <circle cx="10" cy="10" r="10" fill="currentColor"/>
  <path d="M6 10.2 8.6 12.8 14.2 7.2" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
{%- endcapture -%}

{%- capture css -%}
  & {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;

    @media (max-width: 749px) {
      padding-right: 0 !important;
    }
  }
  

  & .ctr-wreviews__inner {
    max-width: {{ section.settings.max_width }}px;
    margin-left: auto;
    margin-right: auto;
  }

  & .ctr-wreviews__heading {
    margin: 0 0 {{ section.settings.heading_gap }}px;
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.01em;
    text-align: {{ section.settings.heading_align }};

    @media (max-width: 749px) {
      text-align: center;
    }
  }

  & .ctr-wreviews__heading p { margin: 0; }

  & .ctr-wreviews__track-wrap {
    position: relative;
  }

  & .ctr-wreviews__track {
    display: flex;
    gap: {{ section.settings.slide_gap }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 4px;
  }

  & .ctr-wreviews__track::-webkit-scrollbar {
    display: none;
  }

  & .ctr-wreviews__slide {
    flex: 0 0 {{ section.settings.slide_width_mobile }}%;
    scroll-snap-align: start;
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.card_gap_mobile }}px;
    min-width: 0;
  }

  & .ctr-wreviews__media {
    border-radius: {{ section.settings.image_radius_mobile }}px;
    overflow: hidden;
    aspect-ratio: {{ section.settings.image_aspect_mobile }};
    background: rgba(0, 0, 0, 0.06);
  }

  & .ctr-wreviews__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  & .ctr-wreviews__panel {
    background: {{ section.settings.panel_bg }};
    border-radius: {{ section.settings.panel_radius_mobile }}px;
    padding: {{ section.settings.panel_padding_mobile }}px;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.panel_inner_gap_mobile }}px;
    min-height: {{ section.settings.panel_min_height_mobile }}px;
  }

  & .ctr-wreviews__stars {
    display: flex;
    gap: 4px;
    color: {{ section.settings.star_color }};
  }

  & .ctr-wreviews__stars svg {
    width: {{ section.settings.star_size_mobile }}px;
    height: {{ section.settings.star_size_mobile }}px;
    display: block;
  }

  & .ctr-wreviews__quote {
    margin: 0;
    font-size: {{ section.settings.quote_size_mobile }}px;
    font-weight: 700;
    line-height: 1.35;
    color: {{ section.settings.quote_color }};
    flex: 1;
  }

  & .ctr-wreviews__quote p { margin: 0; }

  & .ctr-wreviews__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: auto;
  }

  & .ctr-wreviews__author {
    font-size: {{ section.settings.author_size_mobile }}px;
    font-weight: 400;
    line-height: 1.3;
    color: {{ section.settings.author_color }};
  }

  & .ctr-wreviews__verified {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: {{ section.settings.verified_size_mobile }}px;
    line-height: 1.2;
    color: {{ section.settings.verified_text_color }};
    white-space: nowrap;
  }

  & .ctr-wreviews__verified-icon {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
    color: {{ section.settings.verified_icon_color }};
  }

  & .ctr-wreviews__verified-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  & .ctr-wreviews__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: {{ section.settings.nav_gap_mobile }}px;
    padding: 0 4px;
  }

  & .ctr-wreviews__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border: none;
    background: transparent;
    color: {{ section.settings.arrow_color }};
    cursor: pointer;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  & .ctr-wreviews__arrow:hover:not(:disabled) {
    opacity: 1;
  }

  & .ctr-wreviews__arrow:disabled {
    opacity: 0.25;
    cursor: default;
  }

  & .ctr-wreviews__arrow svg {
    width: 22px;
    height: 22px;
    display: block;
  }

  & .ctr-wreviews__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  & .ctr-wreviews__dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: {{ section.settings.dot_color }};
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  & .ctr-wreviews__dot.is-active {
    background: {{ section.settings.dot_active_color }};
    transform: scale(1.05);
  }

  @media (min-width: 1024px) {
    & {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    & .ctr-wreviews__heading {
      margin-bottom: {{ section.settings.heading_gap_desktop }}px;
      font-size: {{ section.settings.heading_size_desktop }}px;

      @media (max-width: 749px) {
        text-align: center;
      }
    }

    & .ctr-wreviews__slide {
      flex: 0 0 {{ section.settings.slide_width_desktop }}%;
      grid-template-columns: minmax(35%, 1fr) minmax(65%, 1fr);
      gap: {{ section.settings.card_gap_desktop }}px;
      align-items: stretch;
    }

    & .ctr-wreviews__media {
      border-radius: {{ section.settings.image_radius_desktop }}px;
      aspect-ratio: {{ section.settings.image_aspect_desktop }};
    }

    & .ctr-wreviews__panel {
      border-radius: {{ section.settings.panel_radius_desktop }}px;
      padding: {{ section.settings.panel_padding_desktop }}px;
      gap: {{ section.settings.panel_inner_gap_desktop }}px;
      min-height: {{ section.settings.panel_min_height_desktop }}px;
    }

    & .ctr-wreviews__stars svg {
      width: {{ section.settings.star_size_desktop }}px;
      height: {{ section.settings.star_size_desktop }}px;
    }

    & .ctr-wreviews__quote {
      font-size: {{ section.settings.quote_size_desktop }}px;
    }

    & .ctr-wreviews__author {
      font-size: {{ section.settings.author_size_desktop }}px;
    }

    & .ctr-wreviews__verified {
      font-size: {{ section.settings.verified_size_desktop }}px;
    }

    & .ctr-wreviews__nav {
      margin-top: {{ section.settings.nav_gap_desktop }}px;
    }

    & .ctr-wreviews__track-wrap {
      --wreviews-content-inset: max(0px, calc((100% - min({{ section.settings.max_width }}px, 100%)) / 2));
      width: calc(100% + var(--gutter));
      margin-right: calc(-1 * var(--gutter));
      padding-left: var(--wreviews-content-inset);
    }

    & .ctr-wreviews__track {
      scroll-padding-left: var(--wreviews-content-inset);
    }

    & .ctr-wreviews__slide:last-child {
      padding-right: var(--gutter);
    }
  }

  @media (max-width: 1023px) {
    & {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    & .ctr-wreviews__panel {
      min-height: {% if section.settings.panel_min_height_mobile > 0 %}{{ section.settings.panel_min_height_mobile }}px{% else %}auto{% endif %};
    }
  }
{%- endcapture -%}

<section
  data-section-type="ctr_women_reviews"
  data-style-id="{{ section.id }}"
  {% if section_id != blank %}id="{{ section_id }}"{% endif %}
  class="ctr-wreviews {{ container_spacing }}"
>
  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  </style>

  <div class="ctr-wreviews__inner">
    {% if section.settings.heading != blank %}
      <div class="ctr-wreviews__heading">{{ section.settings.heading }}</div>
    {% endif %}
  </div>

  <div class="ctr-wreviews__track-wrap">
    <div class="ctr-wreviews__track" data-wreviews-track>
      {% for block in section.blocks %}
        <article class="ctr-wreviews__slide" data-wreviews-slide {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {%- liquid
                assign review_image_alt = block.settings.image_alt
                if review_image_alt == blank
                  assign review_image_alt = block.settings.author
                endif
              -%}
              <div class="ctr-wreviews__media">
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    widths: '400,600,800,1000,1200',
                    sizes: '(max-width: 1023px) 92vw, 28vw',
                    alt: review_image_alt
                }}
              </div>
            {% endif %}

            <div class="ctr-wreviews__panel">
              {% if block.settings.show_stars %}
                <div class="ctr-wreviews__stars" aria-label="5 out of 5 stars">
                  {% for i in (1..5) %}
                    {{ star_svg }}
                  {% endfor %}
                </div>
              {% endif %}

              {% if block.settings.quote != blank %}
                <div class="ctr-wreviews__quote">{{ block.settings.quote }}</div>
              {% endif %}

              <div class="ctr-wreviews__meta">
                {% if block.settings.author != blank %}
                  <span class="ctr-wreviews__author">{{ block.settings.author | escape }}</span>
                {% endif %}

                {% if block.settings.show_verified %}
                  <span class="ctr-wreviews__verified">
                    <span class="ctr-wreviews__verified-icon">{{ verified_svg }}</span>
                    <span>{{ section.settings.verified_label | escape }}</span>
                  </span>
                {% endif %}
              </div>
            </div>
          </article>
      {% endfor %}
    </div>
  </div>

  {% if section.blocks.size > 1 %}
    <div class="ctr-wreviews__inner">
      <div class="ctr-wreviews__nav">
        <button type="button" class="ctr-wreviews__arrow" data-wreviews-prev aria-label="Previous review">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
        </button>

        <div class="ctr-wreviews__dots" data-wreviews-dots>
          {% for block in section.blocks %}
            <button
              type="button"
              class="ctr-wreviews__dot{% if forloop.first %} is-active{% endif %}"
              data-wreviews-dot="{{ forloop.index0 }}"
              aria-label="Go to review {{ forloop.index }}"
            ></button>
          {% endfor %}
        </div>

        <button type="button" class="ctr-wreviews__arrow" data-wreviews-next aria-label="Next review">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    </div>
  {% endif %}
</section>

<script>
  (function () {
    var root = document.querySelector('[data-style-id="{{ section.id }}"]');
    if (!root) return;

    var track = root.querySelector('[data-wreviews-track]');
    if (!track) return;

    var slides = Array.prototype.slice.call(root.querySelectorAll('[data-wreviews-slide]'));
    if (!slides.length) return;

    var prevBtn = root.querySelector('[data-wreviews-prev]');
    var nextBtn = root.querySelector('[data-wreviews-next]');
    var dots = Array.prototype.slice.call(root.querySelectorAll('[data-wreviews-dot]'));
    var activeIndex = 0;

    function scrollToIndex(index) {
      var slide = slides[index];
      if (!slide) return;
      activeIndex = index;
      track.scrollTo({
        left: slide.offsetLeft - track.offsetLeft,
        behavior: 'smooth'
      });
      updateUi();
    }

    function getClosestIndex() {
      var closest = 0;
      var minDist = Infinity;
      var scrollLeft = track.scrollLeft;

      slides.forEach(function (slide, index) {
        var dist = Math.abs(slide.offsetLeft - track.offsetLeft - scrollLeft);
        if (dist < minDist) {
          minDist = dist;
          closest = index;
        }
      });

      return closest;
    }

    function updateUi() {
      if (prevBtn) prevBtn.disabled = activeIndex <= 0;
      if (nextBtn) nextBtn.disabled = activeIndex >= slides.length - 1;

      dots.forEach(function (dot, index) {
        dot.classList.toggle('is-active', index === activeIndex);
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        if (activeIndex > 0) scrollToIndex(activeIndex - 1);
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        if (activeIndex < slides.length - 1) scrollToIndex(activeIndex + 1);
      });
    }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        var index = parseInt(dot.getAttribute('data-wreviews-dot'), 10);
        if (!isNaN(index)) scrollToIndex(index);
      });
    });

    track.addEventListener(
      'scroll',
      function () {
        window.requestAnimationFrame(function () {
          activeIndex = getClosestIndex();
          updateUi();
        });
      },
      { passive: true }
    );

    updateUi();
  })();
</script>

{% schema %}
{
  "name": "CTR Women Reviews",
  "tag": "section",
  "class": "shopify_section__ctr_women_reviews",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "container_spacing",
      "label": "Container spacing",
      "default": "px-container-gutter",
      "options": [
        { "value": "px-container-xs", "label": "Extra Small" },
        { "value": "px-container-sm", "label": "Small" },
        { "value": "px-container-md", "label": "Medium" },
        { "value": "px-container-lg", "label": "Large" },
        { "value": "px-container-gutter", "label": "Gutter Only" },
        { "value": "px-container-fullwidth", "label": "Fullwidth" }
      ]
    },
    { "type": "range", "id": "max_width", "label": "Max width", "default": 1240, "min": 760, "max": 1720, "step": 20, "unit": "px" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#f0ede7" },
    { "type": "color", "id": "text_color", "label": "Heading color", "default": "#202020" },
    { "type": "range", "id": "padding_top", "label": "Padding top - desktop", "default": 80, "min": 0, "max": 200, "step": 4, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom - desktop", "default": 80, "min": 0, "max": 200, "step": 4, "unit": "px" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top - mobile", "default": 48, "min": 0, "max": 140, "step": 4, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom - mobile", "default": 56, "min": 0, "max": 140, "step": 4, "unit": "px" },

    { "type": "header", "content": "Heading" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>What women are saying.</p>" },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    { "type": "range", "id": "heading_size_desktop", "label": "Heading size - desktop", "default": 48, "min": 24, "max": 72, "step": 1, "unit": "px" },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size - mobile", "default": 32, "min": 22, "max": 48, "step": 1, "unit": "px" },
    { "type": "range", "id": "heading_gap_desktop", "label": "Gap below heading - desktop", "default": 40, "min": 12, "max": 100, "step": 2, "unit": "px" },
    { "type": "range", "id": "heading_gap", "label": "Gap below heading - mobile", "default": 28, "min": 12, "max": 80, "step": 2, "unit": "px" },

    { "type": "header", "content": "Carousel" },
    { "type": "range", "id": "slide_width_desktop", "label": "Slide width - desktop (%)", "default": 72, "min": 55, "max": 100, "step": 1, "unit": "%", "info": "Lower values show a peek of the next slide." },
    { "type": "range", "id": "slide_width_mobile", "label": "Slide width - mobile (%)", "default": 88, "min": 70, "max": 100, "step": 1, "unit": "%" },
    { "type": "range", "id": "slide_gap", "label": "Gap between slides", "default": 20, "min": 8, "max": 48, "step": 2, "unit": "px" },
    { "type": "range", "id": "card_gap_desktop", "label": "Gap image / text - desktop", "default": 16, "min": 8, "max": 40, "step": 2, "unit": "px" },
    { "type": "range", "id": "card_gap_mobile", "label": "Gap image / text - mobile", "default": 12, "min": 8, "max": 32, "step": 2, "unit": "px" },
    { "type": "range", "id": "nav_gap_desktop", "label": "Gap above navigation - desktop", "default": 32, "min": 12, "max": 80, "step": 2, "unit": "px" },
    { "type": "range", "id": "nav_gap_mobile", "label": "Gap above navigation - mobile", "default": 24, "min": 12, "max": 60, "step": 2, "unit": "px" },
    { "type": "color", "id": "arrow_color", "label": "Arrow color", "default": "#202020" },
    { "type": "color", "id": "dot_color", "label": "Dot color", "default": "#d8d4cc" },
    { "type": "color", "id": "dot_active_color", "label": "Active dot color", "default": "#202020" },


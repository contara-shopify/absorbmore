    { "type": "range", "id": "panel_radius_mobile", "label": "Panel radius - mobile", "default": 14, "min": 0, "max": 28, "step": 1, "unit": "px" },
    { "type": "range", "id": "panel_padding_desktop", "label": "Panel padding - desktop", "default": 28, "min": 16, "max": 48, "step": 2, "unit": "px" },

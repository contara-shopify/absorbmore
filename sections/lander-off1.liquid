{%- comment -%} OFF1 - Wedding-Season WLP-1 lander. Drives subscription with live PDP buybox (Monthly 20%, 3-mo 30% MOST POPULAR, 6-mo 35% BEST VALUE). Wedding angle: ~9 lbs in 4 weeks, photos last forever, you're in someone's wedding this year. {%- endcomment -%}

{%- liquid
  assign hero_img    = section.settings.hero_img      | default: 'https://cdn.shopify.com/s/files/1/0821/3997/1873/files/off1-wlp-1-wedding-dress.jpg?v=1779921243'
  assign buy_img     = section.settings.buy_img       | default: 'https://www.absorbmore.com/cdn/shop/files/TAC_PDP-Image_WLP1.png?v=1774483977&width=960'
  assign video_src    = section.settings.video_src     | default: 'https://cdn.shopify.com/videos/c/vp/13058c0a109b42418ff159ad72ee53a9/13058c0a109b42418ff159ad72ee53a9.SD-480p-0.9Mbps-85100409.mp4'
  assign video_poster = section.settings.video_poster  | default: 'https://cdn.shopify.com/s/files/1/0821/3997/1873/files/wedding-dress-fitting-poster.png?v=1779923011'
  assign cart_1mo    = section.settings.cart_1mo      | default: '/cart/52472821121313:1?selling_plan=691162546465'
  assign cart_3mo    = section.settings.cart_3mo      | default: '/cart/52472821154081:1?selling_plan=691162579233'
  assign cart_6mo    = section.settings.cart_6mo      | default: '/cart/52472821186849:1?selling_plan=691166544161'
  assign price_1mo_per = section.settings.price_1mo_per | default: '$79.20/mo'
  assign price_1mo_total = section.settings.price_1mo_total | default: '$79.20'
  assign price_1mo_was = section.settings.price_1mo_was | default: '$99.20'
  assign price_1mo_save = section.settings.price_1mo_save | default: '$20.00'
  assign price_3mo_per = section.settings.price_3mo_per | default: '$69.00/mo'
  assign price_3mo_total = section.settings.price_3mo_total | default: '$207.00'
  assign price_3mo_was = section.settings.price_3mo_was | default: '$296.00'
  assign price_3mo_save = section.settings.price_3mo_save | default: '$89.00'
  assign price_6mo_per = section.settings.price_6mo_per | default: '$64.00/mo'
  assign price_6mo_total = section.settings.price_6mo_total | default: '$384.00'
  assign price_6mo_was = section.settings.price_6mo_was | default: '$594.00'
  assign price_6mo_save = section.settings.price_6mo_save | default: '$210.00'
  assign rating      = section.settings.rating        | default: '4.5'
  assign review_count = section.settings.review_count | default: '1,200+'
-%}

<style>
  .off1 { --cream:#f0ebde; --cream-soft:#faf6ef; --paper:#f5efe1; --blush:#f4e4dc; --blush-soft:#faeee5; --blue-tint:#e8eef7; --blue-tint-soft:#f0f4fa; --ink:#2a2521; --ink-soft:#443e38; --muted:#756e64; --line:#d6cfbf; --line-blue:#c4d3ea; --line-warm:#e0c9bb; --brand:#5e91d5; --brand-hover:#4a7dbe; --brand-deep:#3b6aa8; --accent:#c97b5e; --accent-soft:#d99680; --accent-deep:#a85f44; --navy:#3b6aa8; --red:#c97b5e; --blue:#e8eef7; --blue-deep:#5e91d5; --blue-ink:#3b6aa8; --blue-dark:#4a7dbe; --gold:#c97b5e;
    background:var(--cream); color:var(--ink); font-family:'Inter','Helvetica Neue',Arial,sans-serif; -webkit-font-smoothing:antialiased; line-height:1.5; }
  .off1 *{box-sizing:border-box}
  .off1 img{max-width:100%;display:block}
  .off1 a{color:inherit;text-decoration:none}
  .off1 .wrap{max-width:1180px;margin:0 auto;padding:0 18px}

  /* ---------- HERO QUOTE LOCKUP ---------- */
  .off1-hero__paren{color:var(--brand);font-weight:400;font-size:1.25em;line-height:0;display:inline-block;transform:translateY(.05em);margin:0 .04em}
  .off1-hero__quote-attr{display:inline-flex;align-items:center;gap:6px;background:var(--paper);border:1px solid var(--line-warm);border-radius:999px;padding:5px 11px;margin:0 0 14px;font-size:12px;color:var(--ink-soft);letter-spacing:.02em}
  .off1-hero__quote-attr svg{width:13px;height:13px;color:var(--brand);flex:0 0 auto}
  .off1-hero__quote-attr b{color:var(--ink);font-weight:700}

  /* ---------- STICKY TOP BAR ---------- */
  .off1-bar{position:sticky;top:0;z-index:60;background:var(--brand-deep);color:#fff;border-bottom:1px solid var(--line-warm)}
  .off1-bar__row{display:flex;align-items:center;justify-content:center;gap:10px;padding:10px 14px;font-size:13px;flex-wrap:wrap;text-align:center;line-height:1.3}
  .off1-bar__lead{font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#fff}
  .off1-bar__lead em{font-style:normal;color:#fff;font-weight:700}
  .off1-bar__sep{opacity:.6;color:#fff}
  .off1-bar__cd{font-weight:600;letter-spacing:.04em;color:#fff;text-transform:uppercase}
  @media(max-width:480px){.off1-bar__row{font-size:12px;gap:6px}.off1-bar__sep{display:none}}

  /* ---------- HERO: warm cream ---------- */
  .off1-hero{background:var(--cream);position:relative;overflow:hidden;padding:32px 0 38px;color:var(--ink);border-bottom:1px solid var(--line-warm)}
  .off1-hero__grid{display:grid;grid-template-columns:1fr;gap:22px;align-items:center;position:relative}
  @media(min-width:880px){.off1-hero__grid{grid-template-columns:1.05fr .95fr;gap:40px;padding:18px 0}}
  @media(max-width:879px){
    .off1-hero{padding:14px 0 22px}
    .off1-hero__grid{gap:14px}
    .off1-hero__eyebrow{margin-bottom:8px}
    .off1-hero h1{margin-bottom:8px}
    .off1-hero__quote-attr{margin-bottom:10px}
  }

  .off1-hero__eyebrow{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--ink);font-weight:600;font-size:11px;letter-spacing:.24em;text-transform:uppercase;padding:0;border-radius:0;margin-bottom:18px}
  .off1-hero__eyebrow svg{width:13px;height:13px;color:var(--brand)}

  .off1-hero h1{font-size:clamp(28px,5.4vw,46px);line-height:1.02;letter-spacing:-.035em;font-weight:800;margin:0 0 14px;color:var(--ink)}
  .off1-hero h1 em{font-style:normal;color:var(--brand)}
  .off1-hero h1 .nowrap{white-space:nowrap}
  .off1-hero__sub{font-size:clamp(15px,2vw,18px);max-width:520px;margin:0 0 18px;color:var(--ink-soft);line-height:1.5}
  .off1-hero__sub b{color:var(--ink);font-weight:600}

  .off1-hero__bullets{list-style:none;padding:0;margin:0 0 18px;display:grid;gap:8px;max-width:520px}
  .off1-hero__bullets li{display:flex;align-items:flex-start;gap:10px;font-size:15px;font-weight:500;color:var(--ink);line-height:1.4}
  .off1-hero__bullets li strong{font-weight:700}
  .off1-hero__bullets li svg{width:20px;height:20px;flex:0 0 auto;color:var(--brand);margin-top:2px}

  .off1-hero__pricing{display:flex;align-items:baseline;gap:14px;margin:14px 0 6px;flex-wrap:wrap}
  .off1-hero__price-now{font-weight:800;font-size:clamp(26px,4vw,36px);color:var(--ink);letter-spacing:-.02em;line-height:1}
  .off1-hero__price-was{font-size:clamp(15px,2vw,18px);color:var(--muted);text-decoration:line-through;font-weight:500}
  .off1-hero__price-tag{font-weight:700;color:#fff;background:var(--accent);font-size:11px;text-transform:uppercase;letter-spacing:.06em;padding:4px 8px;border-radius:4px}

  .off1-hero__cta{display:inline-flex;align-items:center;justify-content:center;width:100%;max-width:440px;padding:16px 30px;background:var(--brand);color:#fff !important;font-weight:600;font-size:15px;letter-spacing:.01em;border-radius:2px;border:none;cursor:pointer;transition:background .2s ease;text-decoration:none}
  .off1-hero__cta *{color:#fff !important}
  .off1-hero__cta:hover{background:var(--brand-hover)}
  .off1-hero__cta:after{content:" →";margin-left:10px;color:#fff;transition:transform .2s}
  .off1-hero__cta:hover:after{transform:translateX(3px)}

  .off1-hero__guarantee{display:flex;align-items:center;gap:8px;margin-top:14px;font-size:13px;color:var(--ink-soft)}
  .off1-hero__guarantee svg{width:18px;height:18px;color:var(--brand);flex:0 0 auto}

  .off1-hero__media{position:relative;text-align:center}
  .off1-hero__card{background:var(--cream-soft);border-radius:8px;padding:0;position:relative;width:100%;max-width:360px;margin:0 auto;aspect-ratio:4/5;border:1px solid var(--line-warm)}
  .off1-hero__card>.off1-hero__frame{position:absolute;inset:0;border-radius:8px;overflow:hidden}
  .off1-hero__card video, .off1-hero__card img.off1-hero__poster{width:100%;height:100%;object-fit:cover;object-position:center 65%;display:block;cursor:pointer}
  .off1-hero__play{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(180deg,rgba(0,0,0,0) 40%,rgba(0,0,0,.25) 100%);cursor:pointer;border:0;padding:0;width:100%;height:100%}
  .off1-hero__play__btn{width:64px;height:64px;background:rgba(255,255,255,.95);border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,0,0,.3);transition:transform .2s}
  .off1-hero__play:hover .off1-hero__play__btn{transform:scale(1.08)}
  .off1-hero__play__btn svg{width:22px;height:22px;color:var(--ink);margin-left:3px}
  .off1-hero__playing .off1-hero__play{display:none}
  .off1-hero__inset{position:absolute;bottom:-14px;left:-14px;width:38%;aspect-ratio:1/1;background:var(--cream-soft);border-radius:6px;overflow:hidden;border:4px solid var(--cream);box-shadow:0 6px 16px rgba(42,37,33,.18);z-index:3}
  .off1-hero__inset img{width:100%;height:100%;object-fit:cover;display:block;transform:scale(1.35);transform-origin:center 45%}
  @media(max-width:879px){
    .off1-hero__card{max-width:300px}
    .off1-hero__inset{width:42%;bottom:-12px;left:-10px}
  }
  .off1-hero__badge{position:absolute;top:-12px;right:-12px;background:var(--accent);color:#fff;border-radius:999px;width:96px;height:96px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-weight:700;line-height:1;transform:rotate(-8deg);border:3px solid var(--cream);box-shadow:0 6px 14px rgba(42,37,33,.14);z-index:2}
  .off1-hero__badge big{font-size:22px;color:#fff;letter-spacing:-.01em}
  .off1-hero__badge span{font-size:10px;text-transform:uppercase;letter-spacing:.08em;margin-top:2px;color:#fff}

  /* ---------- URGENCY BAND ---------- */
  .off1-urg{background:var(--brand-deep);color:#fff;padding:48px 0;position:relative;overflow:hidden}
  .off1-urg__inner{text-align:center;position:relative}
  .off1-urg__chip{display:inline-flex;align-items:center;gap:10px;background:transparent;color:#fff;font-weight:600;font-size:11px;letter-spacing:.24em;text-transform:uppercase;padding:0;border-radius:0;margin-bottom:18px}
  .off1-urg__chip::before{content:"";display:inline-block;width:6px;height:6px;background:var(--accent-soft);border-radius:50%}
  .off1-urg__head{font-size:clamp(26px,4.6vw,42px);line-height:.98;letter-spacing:-.035em;font-weight:800;margin:0 0 12px;color:#fff;max-width:920px;margin-left:auto;margin-right:auto}
  .off1-urg__head em{font-style:normal;color:var(--accent-soft)}
  .off1-urg__sub{font-size:clamp(14px,1.8vw,17px);color:rgba(255,255,255,.82);margin:0 0 22px;max-width:640px;margin-left:auto;margin-right:auto;line-height:1.5}
  .off1-urg__cta{display:inline-flex;align-items:center;justify-content:center;padding:16px 30px;background:var(--accent);color:#fff !important;font-weight:600;font-size:14.5px;letter-spacing:.01em;border-radius:2px;text-decoration:none;transition:background .2s}
  .off1-urg__cta:hover{background:var(--accent-deep)}
  .off1-urg__cta:after{content:" →";margin-left:10px;color:#fff}

  /* ---------- TRUST STRIP ---------- */
  .off1-trust{background:var(--cream-soft);border-top:1px solid var(--line-warm);border-bottom:1px solid var(--line-warm);padding:14px 0}
  .off1-trust__row{display:grid;grid-template-columns:1fr;gap:10px 16px;text-align:left;font-size:13px;font-weight:500;color:var(--ink)}
  @media(min-width:520px){.off1-trust__row{grid-template-columns:1fr 1fr;text-align:center}}
  @media(min-width:720px){.off1-trust__row{grid-template-columns:repeat(5,1fr);font-size:13px}}
  .off1-trust__cell{display:flex;align-items:center;justify-content:flex-start;gap:8px}
  @media(min-width:520px){.off1-trust__cell{justify-content:center}}
  .off1-trust__cell svg{width:18px;height:18px;color:var(--brand);flex:0 0 auto}
  .off1-trust__stars{color:var(--accent);letter-spacing:1px;font-size:14px}

  /* ---------- SECTION BASE ---------- */
  .off1-sec{padding:56px 0}
  .off1-sec--blue{background:var(--blue-tint)}
  .off1-sec--cream{background:var(--cream-soft)}
  .off1-sec--navy{background:var(--brand-deep);color:#fff}
  .off1-sec--navy h2,.off1-sec--navy h3{color:#fff}
  .off1-sec__eyebrow{font-size:11px;text-transform:uppercase;letter-spacing:.24em;font-weight:600;color:var(--ink);margin:0 0 12px;display:inline-flex;align-items:center;gap:10px}
  .off1-sec__eyebrow::before{content:"";display:inline-block;width:6px;height:6px;background:var(--brand);border-radius:50%}
  .off1-sec__title{font-size:clamp(26px,4.5vw,38px);font-weight:800;letter-spacing:-.035em;color:var(--ink);margin:0 0 10px;line-height:.98}
  .off1-sec__sub{font-size:16px;color:var(--ink-soft);max-width:680px;margin:0 0 28px;line-height:1.5}
  .off1-sec--navy .off1-sec__title{color:#fff}
  .off1-sec--navy .off1-sec__sub{color:rgba(255,255,255,.82)}
  .off1-sec--navy .off1-sec__eyebrow{color:rgba(255,255,255,.85)}
  .off1-sec--navy .off1-sec__eyebrow::before{background:var(--accent-soft)}

  /* ---------- BENEFITS NUMBERS ---------- */
  .off1-benefits{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
  @media(min-width:720px){.off1-benefits{grid-template-columns:repeat(4,1fr);gap:14px}}
  .off1-benefit{background:var(--cream-soft);border:1px solid var(--line-warm);border-radius:8px;padding:20px 14px;text-align:center;position:relative;overflow:hidden}
  .off1-benefit__num{font-size:clamp(28px,4.5vw,40px);font-weight:800;color:var(--ink);letter-spacing:-.035em;line-height:1}
  .off1-benefit__num em{font-style:normal;color:var(--brand)}
  .off1-benefit__lbl{font-size:13px;font-weight:500;color:var(--ink-soft);margin-top:8px;line-height:1.3}
  .off1-benefit__ref{display:block;font-size:10px;color:var(--muted);margin-top:6px}

  .off1-benefit-list{display:grid;grid-template-columns:repeat(1,1fr);gap:10px;margin-top:28px;max-width:720px;margin-left:auto;margin-right:auto}
  @media(min-width:600px){.off1-benefit-list{grid-template-columns:repeat(2,1fr)}}
  .off1-bl-item{background:var(--cream-soft);border:1px solid var(--line-warm);border-radius:8px;padding:14px 16px;display:flex;align-items:center;gap:12px}
  .off1-bl-item__ico{width:38px;height:38px;border-radius:8px;background:var(--blue-tint);color:var(--brand-deep);display:flex;align-items:center;justify-content:center;flex:0 0 auto}
  .off1-bl-item__ico svg{width:22px;height:22px}
  .off1-bl-item__txt{font-size:14px;font-weight:600;color:var(--ink);line-height:1.3}
  .off1-bl-item__txt small{display:block;font-weight:400;color:var(--ink-soft);font-size:12px;margin-top:2px}

  /* ---------- FEATURED TESTIMONIAL ---------- */
  .off1-feat{background:var(--cream-soft);border:1px solid var(--line-warm);border-radius:8px;padding:32px 28px;max-width:820px;margin:0 auto;position:relative}
  .off1-feat__stars{color:var(--accent);font-size:18px;letter-spacing:2px;margin-bottom:12px;text-align:center}
  .off1-feat__quote{font-size:clamp(20px,2.6vw,26px);line-height:1.3;font-weight:500;color:var(--ink);text-align:center;margin:0 0 20px;letter-spacing:-.02em}
  .off1-feat__quote span{color:var(--accent)}
  .off1-feat__attrib{text-align:center;font-size:13px;color:var(--ink-soft)}
  .off1-feat__attrib b{color:var(--ink);font-weight:600}
  .off1-feat__verif{display:inline-flex;align-items:center;gap:4px;font-size:11px;color:var(--brand-deep);font-weight:600;margin-left:6px}
  .off1-feat__verif svg{width:12px;height:12px}

  .off1-quotes{display:grid;grid-template-columns:1fr;gap:14px;margin-top:26px}
  @media(min-width:720px){.off1-quotes{grid-template-columns:repeat(3,1fr)}}
  .off1-quote{background:var(--cream-soft);border-radius:8px;padding:20px;border:1px solid var(--line-warm)}
  .off1-quote__stars{color:var(--accent);font-size:14px;letter-spacing:1px;margin-bottom:8px}
  .off1-quote__txt{font-size:14px;color:var(--ink);line-height:1.55;margin:0 0 12px}
  .off1-quote__name{font-size:13px;font-weight:600;color:var(--ink)}
  .off1-quote__verif{font-size:11px;color:var(--brand-deep);display:flex;align-items:center;gap:4px;margin-top:2px;font-weight:600}
  .off1-quote__verif svg{width:11px;height:11px}

  /* ---------- BUY BOX ---------- */
  .off1-buy{background:var(--cream-soft);border:1px solid var(--line-warm);border-radius:8px;padding:26px;max-width:600px;margin:0 auto}
  .off1-buy__flag{display:inline-flex;align-items:center;gap:10px;background:transparent;color:var(--ink);font-weight:600;font-size:11px;letter-spacing:.24em;text-transform:uppercase;padding:0;border-radius:0;margin-bottom:14px}
  .off1-buy__flag::before{content:"";display:inline-block;width:6px;height:6px;background:var(--accent);border-radius:50%}
  .off1-buy__hero{background:var(--blue-tint-soft);border:1px solid var(--line-blue);border-radius:8px;padding:14px;margin:0 0 18px;display:flex;align-items:center;justify-content:center;aspect-ratio:16/9;overflow:hidden}
  .off1-buy__hero img{max-width:80%;max-height:100%;width:auto;height:auto}
  .off1-buy h3{font-size:24px;font-weight:800;color:var(--ink);margin:0 0 6px;letter-spacing:-.02em}
  .off1-buy__stars{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--ink-soft);margin:0 0 18px}
  .off1-buy__stars b{color:var(--accent);letter-spacing:1px}

  .off1-buy__sub{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.24em;color:var(--ink);margin:0 0 14px}

  .off1-opts{display:grid;grid-template-columns:1fr;gap:10px;margin:0 0 18px}
  .off1-opt{display:flex;align-items:flex-start;gap:12px;background:var(--paper);border:1px solid var(--line-warm);border-radius:8px;padding:16px;cursor:pointer;transition:border-color .15s, background .15s;position:relative}
  .off1-opt input{position:absolute;opacity:0;pointer-events:none}
  .off1-opt__bullet{width:20px;height:20px;border-radius:50%;border:1.5px solid var(--line-warm);flex:0 0 auto;display:flex;align-items:center;justify-content:center;background:#fff;transition:border-color .15s;margin-top:2px}
  .off1-opt__bullet::after{content:"";width:10px;height:10px;border-radius:50%;background:var(--accent);transform:scale(0);transition:transform .15s}
  .off1-opt__main{flex:1;min-width:0}
  .off1-opt__title{font-size:15px;font-weight:700;color:var(--ink);display:flex;align-items:center;gap:6px;flex-wrap:wrap;line-height:1.25}
  .off1-opt__chip{display:inline-block;background:var(--accent);color:#fff;font-weight:600;font-size:10px;text-transform:uppercase;letter-spacing:.08em;padding:3px 8px;border-radius:2px}
  .off1-opt__chip--blue{background:var(--brand);color:#fff}
  .off1-opt__meta{font-size:12px;color:var(--ink-soft);margin-top:4px;line-height:1.4}
  .off1-opt__fine{font-size:11px;color:var(--muted);margin-top:2px}
  .off1-opt__price{text-align:right;flex:0 0 auto;line-height:1.2;margin-left:8px}
  .off1-opt__price b{display:block;font-size:18px;font-weight:800;color:var(--ink);letter-spacing:-.02em}
  .off1-opt__price-row{display:block;font-size:11px;color:var(--ink-soft);font-weight:500;margin-top:3px}
  .off1-opt__price-row s{color:var(--muted);font-weight:400;margin-right:3px}
  .off1-opt__save{display:block;font-size:11px;color:var(--brand-deep);font-weight:600;margin-top:2px}
  .off1-opt.is-on{border-color:var(--accent);background:var(--blush-soft)}
  .off1-opt.is-on .off1-opt__bullet{border-color:var(--accent)}
  .off1-opt.is-on .off1-opt__bullet::after{transform:scale(1)}

  .off1-buy__list{list-style:none;padding:0;margin:0 0 20px}
  .off1-buy__list li{display:flex;gap:10px;align-items:flex-start;padding:8px 0;font-size:13px;color:var(--ink);border-top:1px solid var(--line-warm)}
  .off1-buy__list li:first-child{border-top:none}
  .off1-buy__list svg{width:18px;height:18px;color:var(--brand);flex:0 0 auto;margin-top:2px}


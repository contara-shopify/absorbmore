<script>
(function(){
  var root = document.querySelector('.off1');
  if(!root) return;

  // Buy box option selector
  var opts = root.querySelectorAll('[data-opt]');
  var buyCta = root.querySelector('[data-buy-cta]');
  var stickCta = root.querySelector('[data-stick-cta]');
  var stickPrice = root.querySelector('[data-stick-price]');

  opts.forEach(function(opt){
    opt.addEventListener('click', function(){
      opts.forEach(function(o){ o.classList.remove('is-on'); });
      opt.classList.add('is-on');
      var radio = opt.querySelector('input');
      if(radio) radio.checked = true;
      var cart = opt.getAttribute('data-cart');
      var price = opt.getAttribute('data-price');
      var period = opt.getAttribute('data-period');
      if(buyCta && cart) buyCta.setAttribute('href', cart);
      if(stickCta && cart) stickCta.setAttribute('href', cart);
      if(stickPrice && price){
        stickPrice.innerHTML = price + ' <small>' + (period || '') + '</small>';
      }
    });
  });

  // Sticky mobile CTA reveal after hero
  var stick = root.querySelector('[data-stick]');
  var hero = root.querySelector('.off1-hero');
  if(stick && hero){
    var heroBottom = function(){ return hero.getBoundingClientRect().bottom; };
    var onScroll = function(){
      if(heroBottom() < 60){ stick.classList.add('is-on'); }
      else { stick.classList.remove('is-on'); }
    };
    window.addEventListener('scroll', onScroll, {passive:true});
    onScroll();
  }
})();
</script>


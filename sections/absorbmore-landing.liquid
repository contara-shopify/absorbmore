<script>
(function() {
  // Shopify Container Breakout (JS fallback for browsers without :has())
  var landing = document.getElementById('tac-landing');
  if (landing) {
    var el = landing.parentElement;
    var depth = 0;
    while (el && el !== document.body && depth < 6) {
      var tag = el.tagName.toLowerCase();
      if (tag === 'main' || tag === 'article') break;
      el.style.maxWidth = '100%';
      el.style.paddingLeft = '0';
      el.style.paddingRight = '0';
      el.style.marginLeft = '0';
      el.style.marginRight = '0';
      el = el.parentElement;
      depth++;
    }
    var rect = landing.getBoundingClientRect();
    if (rect.left <= 2) {
      landing.style.marginLeft = '0';
      landing.style.marginRight = '0';
      landing.style.width = '100%';
    }
  }

  // Scroll-triggered fade animations
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('tac-visible');
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

  document.querySelectorAll('.tac-fade-up, .tac-fade-in').forEach(function(el) {
    observer.observe(el);
  });

  // Sticky CTA bar
  var stickyCta = document.getElementById('tac-sticky-cta');
  if (stickyCta) {
    window.addEventListener('scroll', function() {
      if (window.scrollY > 600) {
        stickyCta.classList.add('tac-sticky-cta--visible');
      } else {
        stickyCta.classList.remove('tac-sticky-cta--visible');
      }
    }, { passive: true });
  }
})();
</script>


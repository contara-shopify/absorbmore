      "label": "Star color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight text color",
      "default": "#4f46e5",
      "info": "Color for bold/strong text in quotes."
    },
    {
      "type": "color",
      "id": "verified_color",
      "label": "Verified badge color",
      "default": "#3b82f6"
    },
    {
      "type": "paragraph",
      "content": "t:all.empty_char"
    },
    {
      "type": "header",
      "content": "Section Globals"
    },
    {
      "type": "color",
      "alpha": true,
      "id": "background_color",
      "label": "Section background",
      "default": "#f7f5f1"
    },
    {
      "type": "range",
      "id": "auto_rotate",
      "label": "Auto rotate",
      "default": 0,
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "s",
      "info": "Set to 0 to disable."
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section Id"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "limit": 8,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_stars",
          "label": "Show stars",
          "default": true
        },
        {
          "type": "text",

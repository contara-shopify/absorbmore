{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign section_type = "modal_sidebar_menu"
  assign _handle = section.settings.handle
  assign limit = section.settings.limit
  assign limit_type = section.settings.limit_type
  assign container_spacing = section.settings.container_spacing
  assign text_color = section.settings.text_color
  assign background_color = section.settings.background_color
  assign custom_css = section.settings.custom_css
  assign section_id = section.settings.section_id
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture selector %}[data-style-id="{{ section.id }}--{{ block.id }}"]{% endcapture %}
{% if text_color != blank or text_color.alpha != 0 or background_color != blank %}
  {% capture css %}
    & {
    {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
    }
  {% endcapture %}
{% endif %}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
</style>

{% capture section_content %}
  <div data-megamenu="megamenu--{{ _handle }}"
       data-modal-id="megamenu--{{ _handle | handleize }}"
       x-data="{ show: $modal.id === 'megamenu--{{ _handle | handleize }}', lastSearchQuery: '' }"
       x-effect="show = $editor?.select_section_id === '{{ section.id }}' || $modal.id === 'megamenu--{{ _handle | handleize }}'"
       x-cloak>
    <div class="fixed pointer-events-auto inset-x-0 bottom-0 inset-0 top-[--header-height-offset] transition duration-75 ease-in-out bg-modal-backdrop"
         x-effect="
         if (show) {
            if ($search.query && !lastSearchQuery) {
              lastSearchQuery = $search.query;
              $search.query = '';
            }
         } else {
           if (!$search.query && lastSearchQuery) {
                $search.query = lastSearchQuery;
            }
            lastSearchQuery = ''
         }"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         :class="clsx(show ? 'z-[2147483645]' : 'z-10')"
         x-show="show"
         x-cloak
         @click="$modal.setId(''); $modal.setSubId('')"></div>
    {% capture core_content %}
      <section data-style-id="{{ section.id }}--{{ block.id }}"
               {% if section_id != blank %}id="{{ section_id }}"{% endif %}
               :class="clsx(show ? 'z-[2147483646]' : 'z-50')"
               x-data="{ ..._sections.initSearchModal($el, 'megamenu--{{ _handle | handleize }}') }"
               x-defer="idle"
               class="fixed pointer-events-auto left-0 min-h-[calc(100%-var(--header-height-offset))] w-max h-[calc(100%-var(--header-height-offset))] top-[--header-height-offset] bottom-0 z-[100] isolate transition-all duration-500 ease-in-out {{ container_spacing }}"
               x-transition:enter-start="-translate-x-full"
               x-transition:enter-end="translate-x-0"
               x-transition:leave-start="translate-x-0"
               x-transition:leave-end="-translate-x-full"
               x-show="show"
               x-cloak
               x-trap.noautofocus="show">
        {% content_for 'blocks' %}
      </section>
    {% endcapture %}
    {{ core_content }}
  </div>
{% endcapture %}

{% if request.visual_preview_mode %}
  <div x-data="{ show: true }">
    {{ core_content }}
  </div>
{% else %}
  {% if section_content contains '/break"></script>' %}
    {% break %}
  {% endif %}
  {{ section_content }}
{% endif %}


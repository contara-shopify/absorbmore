<script>
  (function () {
    // Countdown
    var target = new Date("{{ section.settings.launch_datetime | default: '' }}").getTime();
    if (!target || isNaN(target)) {
      // fallback: 48h from now
      target = Date.now() + 48 * 60 * 60 * 1000;
    }
    function tick() {
      var diff = target - Date.now();
      if (diff < 0) diff = 0;
      var d = Math.floor(diff / (1000 * 60 * 60 * 24));
      var h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      var m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      var s = Math.floor((diff % (1000 * 60)) / 1000);
      var pad = function (n) {
        return (n < 10 ? '0' : '') + n;
      };
      var el;
      if ((el = document.getElementById('cdD'))) el.textContent = pad(d);
      if ((el = document.getElementById('cdH'))) el.textContent = pad(h);
      if ((el = document.getElementById('cdM'))) el.textContent = pad(m);
      if ((el = document.getElementById('cdS'))) el.textContent = pad(s);
    }
    tick();
    setInterval(tick, 1000);

    // Calculator
    var unit = 'imperial';
    window.weaSetUnit = function (u) {
      unit = u;
      document.getElementById('uImp').classList.toggle('on', u === 'imperial');
      document.getElementById('uMet').classList.toggle('on', u === 'metric');
      document.getElementById('weaHImpRow').style.display = u === 'imperial' ? '' : 'none';
      document.getElementById('weaHMetRow').style.display = u === 'metric' ? '' : 'none';
      var ws = document.getElementById('weaSW');
      var gs = document.getElementById('weaSG');
      if (u === 'metric') {
        var lbs = parseInt(ws.value);
        ws.min = 45;
        ws.max = 180;
        ws.value = Math.round(lbs / 2.20462);
        var glbs = parseInt(gs.value);
        gs.min = 2;
        gs.max = 45;
        gs.value = Math.max(2, Math.round(glbs / 2.20462));
      } else {
        var kg = parseInt(ws.value);
        ws.min = 120;
        ws.max = 400;
        ws.value = Math.round(kg * 2.20462);
        var gkg = parseInt(gs.value);
        gs.min = 5;
        gs.max = 100;
        gs.value = Math.max(5, Math.round(gkg * 2.20462));
      }
      weaCalc();
    };

    window.weaCalc = function () {
      var wRaw = parseInt(document.getElementById('weaSW').value);
      var wLbs = unit === 'imperial' ? wRaw : wRaw * 2.20462;
      var uL = unit === 'imperial' ? 'lbs' : 'kg';
      document.getElementById('weaDispW').innerHTML = wRaw + ' <span>' + uL + '</span>';

      var hm;
      if (unit === 'imperial') {
        var ti = parseInt(document.getElementById('weaSH').value);
        document.getElementById('weaDispH').textContent = Math.floor(ti / 12) + "'" + (ti % 12) + '"';
        hm = ti * 0.0254;
      } else {
        var cm = parseInt(document.getElementById('weaSHC').value);
        document.getElementById('weaDispHC').innerHTML = cm + ' <span>cm</span>';
        hm = cm / 100;
      }

      var wkg = wLbs / 2.20462;
      var bmi = Math.round(wkg / (hm * hm));
      document.getElementById('weaBmiWarn').classList.toggle('show', bmi < 26);

      var dl = parseInt(document.getElementById('weaSG').value);
      document.getElementById('weaDispG').innerHTML = dl + ' <span>' + uL + '</span>';

      // cap goal at current weight minus a minimum
      if (dl >= wRaw) {
        dl = Math.max(1, wRaw - 1);
      }
      var goalW = wRaw - dl;

      document.getElementById('weaOutHead').innerHTML =
        'Potential to support a <em style="color:var(--blue);font-style:normal">~' + dl + ' ' + uL + '</em> change';
      document.getElementById('weaOsStart').innerHTML = wRaw + '<span>' + uL + '</span>';
      document.getElementById('weaOsGoal').innerHTML = goalW + '<span>' + uL + '</span>';
      document.getElementById('weaChartMax').textContent = wRaw + ' → ' + goalW + ' ' + uL;
      document.getElementById('weaTxtStart').textContent = wRaw + ' ' + uL;
      document.getElementById('weaTxtEnd').textContent = goalW + ' ' + uL;
    };

    weaCalc();
  })();
</script>


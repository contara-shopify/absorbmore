{% for block in section.blocks %}
  {% if block.type == 'vertical_gallery' %}
    {% render 'modal_media_gallery.vertical_gallery', block: block %}
  {% endif %}
  {% if block.type == 'video_product_gallery' %}
    {% render 'modal_media_gallery.video_product_gallery', block: block %}
  {% endif %}
{% endfor %}

{% schema %}
{
  "name": "Media gallery",
  "settings": [],
  "blocks": [
    {
      "name": "Vertical Gallery",
      "type": "vertical_gallery",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:all.empty_char"
        },
        {
          "type": "paragraph",
          "content": "t:all.empty_char"
        },
        {
          "type": "header",
          "content": "Block Globals"
        },
        {
          "type": "color",
          "alpha": true,
          "id": "text_color",
          "label": "Text color"
        },
        {
          "type": "color",
          "alpha": true,
          "id": "background_color",
          "label": "Background color"
        },
        {
          "type": "textarea",
          "id": "custom_css",
          "label": "Custom CSS",
          "default": "& {\n}\n"
        }
      ]
    },
    {
      "name": "Video Product Gallery",
      "type": "video_product_gallery",
      "settings": [
        {
          "type": "metaobject",
          "id": "product_card_class",
          "label": "Product card",
          "metaobject_type": "product_cards"
        },
        {
          "type": "paragraph",
          "content": "t:all.empty_char"
        },
        {
          "type": "paragraph",
          "content": "t:all.empty_char"
        },
        {
          "type": "header",
          "content": "Block Globals"
        },
        {
          "type": "color",
          "alpha": true,
          "id": "text_color",
          "label": "Text color"
        },
        {
          "type": "color",
          "alpha": true,
          "id": "background_color",
          "label": "Background color"
        },
        {
          "type": "textarea",
          "id": "custom_css",
          "label": "Custom CSS",
          "default": "& {\n}\n"
        }
      ]
    }
  ],
  "enabled_on": {
    "groups": [
      "custom.modal"
    ]
  },
  "class": "shopify_section__modal_media_gallery"
}
{% endschema %}

<style>
  .lnd-srs { font-family: inherit; color: #0D273E; --sale-navy: #0D273E; --sale-red: #DB3519; --sale-navy-2: #143452; --sale-cream: #efe9dd; --sale-bg: #f6f6f4; --sale-gold: #d4a23a; }
  .lnd-srs * { box-sizing: border-box; }

  /* Sticky promo bar */
  .lnd-srs__bar { position: sticky; top: 0; z-index: 50; background: var(--sale-red); color: #fff; text-align: center; padding: 10px 14px; font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; display: flex; gap: 14px; justify-content: center; align-items: center; flex-wrap: wrap; }
  .lnd-srs__bar-count { display: inline-flex; gap: 4px; align-items: baseline; font-variant-numeric: tabular-nums; }
  .lnd-srs__bar-count b { font-size: 14px; }
  .lnd-srs__bar-count span { font-size: 10px; opacity: 0.8; }

  /* Hero — Summer Ready specific: cream/peach gradient, packshot-led */
  .lnd-srs__hero { position: relative; background: linear-gradient(180deg, #FFE9D1 0%, #FAD8B0 60%, #F5C68A 100%); color: var(--sale-navy); overflow: hidden; }
  .lnd-srs__hero-inner { padding: 28px 20px 32px; max-width: 1200px; margin: 0 auto; position: relative; z-index: 2; }
  .lnd-srs__hero-top { display: flex; flex-direction: column; gap: 6px; }
  .lnd-srs__hero-text { text-align: left; }
  .lnd-srs__hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 900; letter-spacing: 0.12em; text-transform: uppercase; padding: 12px 18px; border-radius: 999px; background: var(--sale-red); color: #fff; margin-bottom: 16px; box-shadow: 0 8px 20px rgba(219,53,25,0.32), 0 0 0 3px rgba(219,53,25,0.18); animation: lndsrsPulse 2.4s ease-in-out infinite; }
  .lnd-srs__hero-eyebrow::before { content: ""; width: 8px; height: 8px; border-radius: 999px; background: #fff; box-shadow: 0 0 0 4px rgba(255,255,255,0.35); animation: lndsrsDot 1.2s ease-in-out infinite; }
  @keyframes lndsrsPulse { 0%, 100% { box-shadow: 0 8px 20px rgba(219,53,25,0.32), 0 0 0 3px rgba(219,53,25,0.18); } 50% { box-shadow: 0 10px 26px rgba(219,53,25,0.45), 0 0 0 6px rgba(219,53,25,0.22); } }
  @keyframes lndsrsDot { 0%, 100% { opacity: 1; } 50% { opacity: 0.45; } }
  .lnd-srs .lnd-srs__hero .lnd-srs__hero-text h1 { font-size: 62px !important; line-height: 0.92 !important; margin: 0 0 16px !important; font-weight: 900 !important; letter-spacing: -0.045em !important; color: var(--sale-navy) !important; text-transform: none !important; }
  .lnd-srs .lnd-srs__hero .lnd-srs__hero-text h1 em { color: var(--sale-red) !important; font-style: normal !important; font-size: inherit !important; font-weight: inherit !important; }
  .lnd-srs__hero p { font-size: 15px; color: #2c3e50; margin: 0 0 14px; line-height: 1.5; max-width: 480px; }
  .lnd-srs__hero-sub { font-size: 17px; line-height: 1.35; color: var(--sale-navy); font-weight: 600; margin: 0 0 20px; opacity: 0.86; }
  .lnd-srs__hero-bullets { list-style: none; padding: 0; margin: 0 0 18px; display: flex; flex-direction: column; gap: 10px; }

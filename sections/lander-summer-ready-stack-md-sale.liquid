<script id="lnd-srs-data" type="application/json">{{ srs_products_json | strip_newlines }}</script>

<script>
(function(){
  var root = document.querySelector('.lnd-srs');
  if (!root) return;

  var END = new Date(root.dataset.end).getTime();

  function tick() {
    var now = Date.now();
    var diff = Math.max(0, END - now);
    var d = Math.floor(diff / 86400000);
    var h = Math.floor((diff % 86400000) / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    function pad(n){ return n < 10 ? '0' + n : '' + n; }
    root.querySelectorAll('[data-d]').forEach(function(el){ el.textContent = pad(d); });
    root.querySelectorAll('[data-h]').forEach(function(el){ el.textContent = pad(h); });
    root.querySelectorAll('[data-m]').forEach(function(el){ el.textContent = pad(m); });
    root.querySelectorAll('[data-s]').forEach(function(el){ el.textContent = pad(s); });
  }
  tick();
  setInterval(tick, 1000);

  var bubbles = root.querySelectorAll('.lnd-srs__bubble');
  var tiles = root.querySelectorAll('.lnd-srs__tile');
  var gridCount = root.querySelector('[data-grid-count]');
  function applyFilter(filter) {
    var visible = 0;
    tiles.forEach(function(t){
      var has = (' ' + t.dataset.chips + ' ').indexOf(' ' + filter + ' ') !== -1;
      t.style.display = has ? '' : 'none';
      if (has) visible++;
    });
    if (gridCount) gridCount.textContent = visible + ' product' + (visible === 1 ? '' : 's');
  }
  bubbles.forEach(function(b){
    b.addEventListener('click', function(){
      var goal = b.dataset.goal;
      bubbles.forEach(function(x){ x.classList.remove('is-active'); x.setAttribute('aria-pressed','false'); });
      b.classList.add('is-active');
      b.setAttribute('aria-pressed','true');
      applyFilter(goal);
    });
  });

  var DISCOUNT = root.dataset.discountCode;
  var DATA;
  try { DATA = JSON.parse(document.getElementById('lnd-srs-data').textContent); } catch(e) { DATA = {}; }

  function applyDiscount() {
    if (!DISCOUNT) return Promise.resolve(null);
    return fetch('/discount/' + DISCOUNT + '?redirect=/cart.js', { credentials: 'same-origin' })
      .then(function(r){ return r.ok ? r.json() : null; })
      .catch(function(){ return null; });
  }
  function refreshThemeCart() {
    if (window._cart && typeof window._cart.get === 'function') {
      try { window._cart.get(true); } catch(e){}
    }
  }
  function openCartDrawer() {
    var cartLink = document.querySelector('a[href$="#modal--cart-drawer"]');
    if (cartLink) { try { cartLink.click(); return; } catch(e){} }
    try {
      var store = window.Alpine && window.Alpine.store && window.Alpine.store('modal');
      if (store && typeof store.setId === 'function' && window.modalsLoaded) {
        store.setId('cart-drawer');
      }
    } catch(e){}
  }
  applyDiscount().then(refreshThemeCart);

  var planLabels = root.querySelectorAll('.lnd-srs__bb-plan');
  var bbCta = root.querySelector('#lnd-srs-bb-cta');
  var bbCtaPrice = root.querySelector('#lnd-srs-bb-cta-price');
  planLabels.forEach(function(p){
    p.addEventListener('click', function(){
      planLabels.forEach(function(x){
        x.classList.remove('is-selected');
        var i = x.querySelector('input'); if (i) i.checked = false;
      });
      p.classList.add('is-selected');
      var i = p.querySelector('input'); if (i) i.checked = true;
      var price = p.getAttribute('data-price');
      var variant = p.getAttribute('data-variant');
      if (bbCta && variant) bbCta.setAttribute('data-variant', variant);
      if (bbCtaPrice && price) bbCtaPrice.textContent = price;
    });
  });

  if (bbCta) {
    bbCta.addEventListener('click', function(e){
      e.preventDefault();
      var handle = bbCta.getAttribute('data-handle') || 'summer-ready-stack';
      var variantId = parseInt(bbCta.getAttribute('data-variant'), 10);
      var prod = DATA[handle];
      var selected = root.querySelector('.lnd-srs__bb-plan.is-selected');
      var fallbackUrl = selected ? selected.getAttribute('data-url') : null;
      if (!prod || !prod.variants || !prod.variants.length || !variantId) {
        if (fallbackUrl) window.location.href = fallbackUrl;
        return;
      }
      var v = null;
      for (var k = 0; k < prod.variants.length; k++) { if (prod.variants[k].id === variantId) { v = prod.variants[k]; break; } }
      if (!v) {
        if (fallbackUrl) window.location.href = fallbackUrl;
        return;
      }
      var item = { id: v.id, quantity: 1 };
      if (v.selling_plans && v.selling_plans.length) item.selling_plan = v.selling_plans[0].id;
      var origLabel = bbCta.innerHTML;
      bbCta.classList.add('is-loading'); bbCta.disabled = true; bbCta.textContent = 'Adding...';
      var payload = { items: [item] };
      var themeAdd = (window._cart && typeof window._cart.add === 'function') ? window._cart.add(payload) : null;
      var pr = themeAdd && typeof themeAdd.then === 'function'
        ? themeAdd
        : fetch('/cart/add.js?smart_theme=true', {
            method: 'POST',
            headers: {'Content-Type':'application/json','Accept':'application/json','smart-theme':'true'},
            body: JSON.stringify(payload)
          }).then(function(r){ return r.json().then(function(j){ if(!r.ok) throw j; return j; }); });
      pr.then(function(){
        bbCta.classList.remove('is-loading'); bbCta.disabled = false; bbCta.innerHTML = origLabel;
        refreshThemeCart();
        setTimeout(openCartDrawer, 100);
        applyDiscount().then(refreshThemeCart).catch(function(){});
      }).catch(function(){
        bbCta.classList.remove('is-loading'); bbCta.disabled = false; bbCta.innerHTML = origLabel;
        if (fallbackUrl) window.location.href = fallbackUrl;
      });
    });
  }

  var mobile = root.querySelector('[data-mobile-cta]');
  var hero = root.querySelector('.lnd-srs__hero');
  function onScroll(){
    if (!hero || !mobile) return;
    var heroBottom = hero.getBoundingClientRect().bottom;
    if (heroBottom < 0) { mobile.classList.add('is-show'); }
    else { mobile.classList.remove('is-show'); }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>


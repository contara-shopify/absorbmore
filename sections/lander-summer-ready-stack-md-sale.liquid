  "name": "Lander · Summer Ready MD",
  "settings": [
    { "type": "header", "content": "Offer" },
    { "type": "number", "id": "discount_pct", "label": "Discount %", "default": 35 },
    { "type": "text", "id": "end_iso", "label": "End date (ISO, e.g. 2026-05-26T23:59:59-04:00)", "default": "2026-05-26T23:59:59-04:00" },
    { "type": "text", "id": "discount_code", "label": "Discount code (auto-applied)", "default": "MEMORIALDAY35" },
    { "type": "header", "content": "Hero copy" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Summer Ready Stack" },
    { "type": "richtext", "id": "headline", "label": "Headline (use <em> for red accent)", "default": "<p>Drop <em>~9 lbs</em> by July 1st.</p>" },
    { "type": "image_picker", "id": "hero_packshot", "label": "Hero packshot (3 products, transparent PNG preferred)" },
    { "type": "header", "content": "Sale grid products" },
    { "type": "product_list", "id": "sale_products", "label": "Products in the sale grid", "limit": 50 }
  ],
  "presets": [
    { "name": "Lander · Summer Ready MD" }
  ]
}

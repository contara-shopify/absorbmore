  .lnd-srs__bb-sale-badge { position: absolute; top: 18px; right: 18px; background: var(--sale-red); color: #fff; padding: 12px 16px; border-radius: 14px; text-align: center; line-height: 1; box-shadow: 0 10px 26px rgba(219,53,25,0.32); transform: rotate(6deg); z-index: 3; }
  .lnd-srs__bb-sale-badge b { display: block; font-size: 28px; font-weight: 900; letter-spacing: -0.03em; }
  .lnd-srs__bb-sale-badge span { display: block; font-size: 9px; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; margin-top: 4px; opacity: 0.95; }
  .lnd-srs__bb-limited { display: flex; align-items: center; justify-content: center; gap: 8px; background: linear-gradient(90deg, #0D273E 0%, #1a3854 100%); color: #fff; font-size: 11px; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; padding: 11px 14px; border-radius: 12px; margin: 0 0 18px; text-align: center; line-height: 1.3; }
  .lnd-srs__bb-limited::before { content: ""; width: 7px; height: 7px; border-radius: 999px; background: var(--sale-red); box-shadow: 0 0 0 4px rgba(219,53,25,0.28); animation: lndsrsDot 1.2s ease-in-out infinite; flex: 0 0 auto; }
  .lnd-srs__bb-limited b { font-weight: 900; color: #ffd16e; letter-spacing: 0.16em; }
  .lnd-srs__bb-vit-feature { display: flex; align-items: center; gap: 12px; background: linear-gradient(135deg, #FFF7E0 0%, #FFE9A8 100%); border: 2px solid #ffd16e; border-radius: 14px; padding: 12px 14px; margin: 0 0 12px; }

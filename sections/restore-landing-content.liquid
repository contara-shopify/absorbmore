{% comment %} Restore Landing Page Section {% endcomment %}

<style>
  /* Hide theme header and announcement bar */
  header,
  #shopify-section-header,
  .site-header,
  .header-wrapper,
  .announcement-bar,
  #shopify-section-announcement-bar,
  [id*="announcement"],
  [class*="announcement"],
  [id*="header"]:not(#restore-page),
  .header,
  .nav-bar,
  .site-nav {
    display: none !important;
  }

  /* Remove top padding/margin the theme adds for the header */
  #MainContent,
  main,
  .main-content,
  [id="main-content"] {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }
</style>  
  <style>
    /* ─── RESET & BASE ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Helvetica Neue', Arial, sans-serif;
      background: #f5f0e8;
      color: #1a1a1a;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }

    /* ─── TOKENS ─── */
    :root {
      --cream: #f5f0e8;
      --dark: #1a1a1a;
      --orange: #e8703a;
      --orange-dark: #c9562a;
      --yellow: #f5c842;
      --muted: #6b6560;
      --border: #e0dbd0;
      --white: #ffffff;
      --green: #2e7d32;
      --radius: 14px;
    }

    /* ─── PROMO BAR ─── */
    .promo-bar {
      background: var(--dark);
      color: var(--yellow);
      text-align: center;
      padding: 10px 16px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }
    .promo-bar span { color: #fff; font-weight: 400; }

    /* ─── NAV ─── */
    nav {
      background: var(--cream);
      border-bottom: 1px solid var(--border);
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 200;
    }
    .nav-logo {
      font-size: 15px;
      font-weight: 800;
      letter-spacing: -0.3px;
    }
    .nav-logo span { font-weight: 400; }
    .nav-cta {
      background: var(--dark);
      color: #fff;
      padding: 9px 18px;
      border-radius: 50px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    /* ─── HERO ─── */
    .hero {
      background: var(--dark);
      color: #fff;
      padding: 0;
      overflow: hidden;
    }
    .hero-image-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 1 / 1;
      max-height: 420px;
      overflow: hidden;
      background: #111;
    }
    .hero-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }
    .hero-badge {
      position: absolute;
      top: 16px;
      left: 16px;
      background: var(--orange);
      color: #fff;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 5px 12px;
      border-radius: 50px;
    }
    .hero-rating-pill {
      position: absolute;
      bottom: 16px;
      left: 16px;
      background: rgba(255,255,255,0.12);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff;
      font-size: 12px;
      font-weight: 600;
      padding: 6px 14px;
      border-radius: 50px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .hero-rating-pill .stars { color: var(--yellow); font-size: 11px; }
    .hero-content {
      padding: 28px 20px 24px;
    }
    .hero-eyebrow {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 8px;
    }
    .hero-title {
      font-size: 36px;
      font-weight: 900;
      line-height: 1.0;
      letter-spacing: -1.5px;
      margin-bottom: 10px;
    }
    .hero-subtitle {
      font-size: 15px;
      color: #ccc;
      line-height: 1.5;
      margin-bottom: 24px;
    }
    .hero-subtitle strong { color: #fff; }

    /* ─── SOCIAL PROOF ROW ─── */
    .social-proof-row {
      display: flex;
      gap: 0;
      border-top: 1px solid rgba(255,255,255,0.1);
      border-bottom: 1px solid rgba(255,255,255,0.1);
      margin-bottom: 24px;
    }
    .sp-item {
      flex: 1;
      text-align: center;
      padding: 14px 8px;
      border-right: 1px solid rgba(255,255,255,0.1);
    }
    .sp-item:last-child { border-right: none; }
    .sp-item .sp-num {
      font-size: 18px;
      font-weight: 900;
      color: var(--yellow);
      line-height: 1;
    }
    .sp-item .sp-label {
      font-size: 9px;
      color: #aaa;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-top: 3px;
    }

    /* ─── BUY BOX ─── */
    .buy-box {
      background: var(--cream);
      border-radius: var(--radius) var(--radius) 0 0;
      padding: 24px 20px;
      margin: 0 -0px;
      color: var(--dark);
    }
    .buy-box-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 12px;
    }

    /* Format selector */
    .format-selector {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
    }
    .format-btn {
      flex: 1;
      border: 2px solid var(--border);
      border-radius: 10px;
      padding: 12px 8px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      background: #fff;
    }
    .format-btn.active {
      border-color: var(--dark);
      background: var(--dark);
      color: #fff;
    }
    .format-btn .fmt-name { font-size: 13px; font-weight: 700; }
    .format-btn .fmt-sub { font-size: 10px; color: var(--muted); margin-top: 2px; }
    .format-btn.active .fmt-sub { color: #aaa; }

    /* Supply selector */
    .supply-selector {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 20px;
    }
    .supply-option {
      border: 2px solid var(--border);
      border-radius: 12px;
      padding: 14px 16px;
      cursor: pointer;
      background: #fff;
      transition: all 0.2s;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .supply-option.active {
      border-color: var(--dark);
      background: #fff;
    }
    .supply-option .best-value {
      position: absolute;
      top: -10px;
      right: 14px;
      background: var(--orange);
      color: #fff;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 50px;
    }
    .supply-left { display: flex; align-items: center; gap: 12px; }
    .supply-radio {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      border: 2px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .supply-option.active .supply-radio {
      border-color: var(--dark);
      background: var(--dark);
    }
    .supply-option.active .supply-radio::after {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #fff;
    }
    .supply-name { font-size: 14px; font-weight: 700; }
    .supply-servings { font-size: 11px; color: var(--muted); }
    .supply-right { text-align: right; }
    .supply-price { font-size: 16px; font-weight: 800; }
    .supply-orig { font-size: 12px; color: var(--muted); text-decoration: line-through; }
    .supply-save {
      display: inline-block;
      background: #e8f5e9;
      color: var(--green);
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 50px;
      margin-top: 2px;
    }

    /* Subscribe toggle */
    .subscribe-toggle {
      background: #fff;
      border: 2px solid var(--dark);
      border-radius: 12px;
      padding: 14px 16px;
      margin-bottom: 16px;
    }
    .sub-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .sub-title { font-size: 14px; font-weight: 700; }
    .sub-badge {
      background: var(--orange);
      color: #fff;
      font-size: 10px;
      font-weight: 800;
      padding: 3px 10px;
      border-radius: 50px;
      letter-spacing: 0.5px;
    }
    .sub-perks { list-style: none; }
    .sub-perks li {
      font-size: 12px;
      color: var(--muted);
      padding: 3px 0;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .sub-perks li::before { content: '✓'; color: var(--green); font-weight: 700; font-size: 13px; }

    /* CTA button */
    .cta-btn {
      display: block;
      width: 100%;
      background: var(--dark);
      color: #fff;
      text-align: center;
      padding: 18px 20px;
      border-radius: 50px;
      font-size: 15px;
      font-weight: 800;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      cursor: pointer;
      border: none;
      transition: background 0.2s, transform 0.1s;
      margin-bottom: 12px;
    }
    .cta-btn:active { transform: scale(0.98); }
    .cta-btn.orange { background: var(--orange); }
    .cta-btn.orange:hover { background: var(--orange-dark); }

    .trust-row {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 12px;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      color: var(--muted);
    }
    .trust-item .icon { font-size: 13px; }

    /* ─── SECTION BASE ─── */
    section { padding: 48px 20px; }
    section.dark { background: var(--dark); color: #fff; }
    section.white { background: #fff; }
    section.cream { background: var(--cream); }

    .section-eyebrow {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 10px;
    }
    .section-eyebrow.light { color: var(--yellow); }
    .section-title {
      font-size: 28px;
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -1px;
      margin-bottom: 12px;
    }
    .section-body {
      font-size: 15px;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 28px;
    }
    .section-body.light { color: #bbb; }

    /* ─── REPLACES SECTION ─── */
    .replaces-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 28px;
    }
    .replace-item {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px;
      padding: 14px 12px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .replace-item .ri-icon { font-size: 20px; }
    .replace-item .ri-text { font-size: 12px; font-weight: 600; }
    .replace-item .ri-sub { font-size: 10px; color: #888; margin-top: 1px; }

    .vs-banner {
      background: var(--orange);
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      margin-bottom: 20px;
    }
    .vs-banner .vs-num { font-size: 40px; font-weight: 900; color: #fff; line-height: 1; }
    .vs-banner .vs-label { font-size: 13px; color: rgba(255,255,255,0.85); margin-top: 4px; }

    /* ─── HOW IT WORKS ─── */
    .steps-list { display: flex; flex-direction: column; gap: 0; }
    .step {
      display: flex;
      gap: 16px;
      padding: 20px 0;
      border-bottom: 1px solid var(--border);
      align-items: flex-start;
    }
    .step:last-child { border-bottom: none; }
    .step-num {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--dark);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 800;
      flex-shrink: 0;
    }
    .step-content h3 { font-size: 16px; font-weight: 800; margin-bottom: 4px; }
    .step-content p { font-size: 13px; color: var(--muted); line-height: 1.5; }

    /* ─── BENEFITS TABS ─── */
    .benefit-tabs {
      display: flex;
      overflow-x: auto;
      gap: 8px;
      padding-bottom: 4px;
      margin-bottom: 20px;
      scrollbar-width: none;
    }
    .benefit-tabs::-webkit-scrollbar { display: none; }
    .benefit-tab {
      flex-shrink: 0;
      background: #fff;
      border: 2px solid var(--border);
      border-radius: 50px;
      padding: 8px 16px;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
    }
    .benefit-tab.active {
      background: var(--dark);
      color: #fff;
      border-color: var(--dark);
    }
    .benefit-panel { display: none; }
    .benefit-panel.active { display: block; }
    .benefit-card {
      background: #fff;
      border-radius: var(--radius);
      padding: 24px 20px;
      border: 1px solid var(--border);
    }
    .benefit-card .bc-icon { font-size: 32px; margin-bottom: 12px; }
    .benefit-card h3 { font-size: 20px; font-weight: 800; margin-bottom: 8px; }
    .benefit-card p { font-size: 14px; color: var(--muted); line-height: 1.6; margin-bottom: 16px; }
    .benefit-list { list-style: none; }
    .benefit-list li {
      font-size: 13px;
      padding: 6px 0;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .benefit-list li:last-child { border-bottom: none; }
    .benefit-list li::before { content: '→'; color: var(--orange); font-weight: 700; }

    /* ─── SCIENCE STATS ─── */
    .science-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 24px;
    }
    .science-stat {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 20px 16px;
      text-align: center;
    }
    .science-stat .ss-num {
      font-size: 36px;
      font-weight: 900;
      color: var(--yellow);
      line-height: 1;
    }
    .science-stat .ss-label {
      font-size: 11px;
      color: #aaa;
      margin-top: 6px;
      line-height: 1.4;
    }

    /* ─── TIMELINE ─── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: '';
      position: absolute;
      left: 9px;
      top: 8px;
      bottom: 8px;
      width: 2px;
      background: var(--border);
    }
    .tl-item {
      position: relative;
      margin-bottom: 28px;
    }
    .tl-item:last-child { margin-bottom: 0; }
    .tl-dot {
      position: absolute;
      left: -24px;
      top: 4px;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: var(--orange);
      border: 3px solid var(--cream);
    }
    .tl-month {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 6px;
    }
    .tl-title { font-size: 18px; font-weight: 800; margin-bottom: 8px; }
    .tl-list { list-style: none; }
    .tl-list li {
      font-size: 13px;
      color: var(--muted);
      padding: 4px 0;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .tl-list li::before { content: '✓'; color: var(--green); font-weight: 700; }

    /* ─── INGREDIENTS ─── */
    .ingredient-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .ingredient-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 0;
      border-bottom: 1px solid var(--border);
    }
    .ingredient-row:last-child { border-bottom: none; }
    .ing-left { display: flex; align-items: center; gap: 12px; }
    .ing-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--orange);
      flex-shrink: 0;
    }
    .ing-name { font-size: 14px; font-weight: 700; }
    .ing-sub { font-size: 11px; color: var(--muted); margin-top: 1px; }
    .ing-badge {
      font-size: 10px;
      font-weight: 700;
      color: var(--orange);
      background: #fff3ee;
      padding: 3px 10px;
      border-radius: 50px;
      white-space: nowrap;
    }

    /* ─── EXPERT QUOTE ─── */
    .expert-quote {
      background: var(--dark);
      border-radius: var(--radius);
      padding: 28px 22px;
      margin-bottom: 20px;
      position: relative;
    }
    .eq-mark {
      font-size: 60px;
      color: var(--yellow);
      line-height: 0.8;
      font-family: Georgia, serif;
      margin-bottom: 12px;
    }
    .eq-text {
      font-size: 15px;
      color: #fff;
      line-height: 1.6;
      font-style: italic;
      margin-bottom: 16px;
    }
    .eq-author { display: flex; align-items: center; gap: 12px; }
    .eq-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--orange);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      font-weight: 800;
      color: #fff;
      flex-shrink: 0;
    }
    .eq-name { font-size: 13px; font-weight: 700; color: #fff; }
    .eq-title { font-size: 11px; color: #aaa; margin-top: 2px; }

    /* ─── REVIEWS ─── */
    .review-summary {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
    }
    .rs-big {
      font-size: 52px;
      font-weight: 900;
      line-height: 1;
    }
    .rs-right {}
    .rs-stars { color: var(--orange); font-size: 20px; margin-bottom: 4px; }
    .rs-count { font-size: 13px; color: var(--muted); }

    .review-card {
      background: var(--cream);
      border-radius: 12px;
      padding: 18px;
      margin-bottom: 12px;
      border: 1px solid var(--border);
    }
    .rc-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
    }
    .rc-name { font-size: 13px; font-weight: 700; }
    .rc-stars { color: var(--orange); font-size: 12px; }
    .rc-verified { font-size: 10px; color: var(--green); font-weight: 600; }
    .rc-title { font-size: 14px; font-weight: 700; margin-bottom: 6px; }
    .rc-text { font-size: 13px; color: var(--muted); line-height: 1.5; }

    /* ─── CERTIFICATIONS ─── */
    .cert-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .cert-item {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 18px 14px;
      text-align: center;
    }
    .cert-item .ci-icon { font-size: 28px; margin-bottom: 8px; }
    .cert-item .ci-name { font-size: 12px; font-weight: 700; }
    .cert-item .ci-sub { font-size: 10px; color: var(--muted); margin-top: 2px; }

    /* ─── FAQ ─── */
    .faq-item {
      border-bottom: 1px solid var(--border);
    }
    .faq-q {
      width: 100%;
      background: none;
      border: none;
      text-align: left;
      padding: 18px 0;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      color: var(--dark);
    }
    .faq-q .faq-icon {
      font-size: 20px;
      font-weight: 300;
      flex-shrink: 0;
      transition: transform 0.2s;
      color: var(--muted);
    }
    .faq-q.open .faq-icon { transform: rotate(45deg); }
    .faq-a {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.6;
      padding-bottom: 18px;
      display: none;
    }
    .faq-a.open { display: block; }

    /* ─── STICKY CTA BAR ─── */
    .sticky-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--dark);
      padding: 12px 16px;
      z-index: 300;
      display: flex;
      align-items: center;
      gap: 12px;
      box-shadow: 0 -4px 20px rgba(0,0,0,0.2);
      transform: translateY(100%);
      transition: transform 0.3s ease;
    }
    .sticky-bar.visible { transform: translateY(0); }
    .sticky-bar-info { flex: 1; }
    .sticky-bar-name { font-size: 14px; font-weight: 800; color: #fff; }
    .sticky-bar-price { font-size: 12px; color: #aaa; }
    .sticky-bar-btn {
      background: var(--orange);
      color: #fff;
      padding: 12px 20px;
      border-radius: 50px;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      white-space: nowrap;
      border: none;
      cursor: pointer;
    }

    /* ─── FOOTER ─── */
    footer {
      background: var(--dark);

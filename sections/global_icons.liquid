{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign section_type = "global_icons"
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% capture icons %}
  {% for block in section.blocks %}
    {% assign handle = block.settings.handle | handleize %}
    {% if block.settings.url != blank %}
      --icon-{{ handle }}--url: {{ block.settings.url }};
    {% endif %}
    {% if block.settings.icon != blank %}
      --icon-{{ handle }}: url('{{ block.settings.icon | image_url }}') no-repeat 50% 50% / contain;
      --icon-{{ handle }}-aspect-ratio: {{ block.settings.icon.aspect_ratio }};
      {% continue %}
    {% endif %}
    {% if block.settings.svg_code != blank %}
      {% assign svg_image = "data:image/svg+xml;utf8," | append: block.settings.svg_code | strip_newlines | replace: '<', '%3c' | replace: ">", "%3e" %}
      {% assign viewbox = block.settings.svg_code | split: "viewbox=" | last | replace_first: "'", "|~|split|~|" | replace_first: '"', "|~|split|~|" | split: "|~|split|~|" | last | replace_first: "'", "|~|split|~|" | replace_first: '"', "|~|split|~|" | split: "|~|split|~|" | first %}
      {% assign split = ' ' %}
      {% if viewbox contains ',' %}
        {% assign split = ',' %}
      {% endif %}
      {% assign viewbox_array = viewbox | split: split %}
      {% assign width = viewbox_array[2] | strip | times: 1.00 %}
      {% assign height = viewbox_array[3] | strip | times: 1.00 %}
      {% assign aspect_ratio = width | divided_by: height | round: 3 | json %}
      --icon-{{ handle }}: url('{{ svg_image }}') no-repeat 50% 50% / contain;
      --icon-{{ handle }}-aspect-ratio: {{ aspect_ratio }};
    {% endif %}
  {% endfor %}
{% endcapture %}
<style>
  :root {
  {{ icons }}
  }
</style>
{% if request.design_mode %}
  <div class="fixed inset-0 z-50 flex flex-col items-center justify-center gap-6 overflow-y-auto bg-gray-100 py-16 text-black px-container-sm md:pb-52 @container"
       data-section-id="{{ section.id }}"
       data-preview-container
       x-show="$editor?.select_section_id === `{{ section.id }}`"
       x-cloak>
    <div class="grid grid-cols-3 gap-2 gap-x-5">
      {% for block in section.blocks %}
        <div class="flex items-center gap-3" {{ block.shopify_attributes }}>
          {% render '_components.icon', icon: block.settings.handle, class: "h-5 text-black shrink-0", no_mask: true %}
          <div class="text-lg font-bold text-gray-600">{{ block.settings.handle | handleize }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}


{% schema %}
{
  "name": "Icons",
  "settings": [
    {
      "type": "header",
      "content": "Development Integration",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "select",
      "id": "generate_presets",
      "label": "Presets Codegen",
      "default": "never",
      "options": [
        {
          "value": "never",
          "label": "Off"
        },
        {
          "value": "always",
          "label": "On"
        },
        {
          "value": "manual_override",
          "label": "Override"
        }
      ],
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "text",
      "id": "category_name",
      "label": "Category",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    },
    {
      "type": "text",
      "id": "hidden_name_backup",
      "label": " Hidden Name Backup",
      "visible_if": "{{ settings.development__dev_mode == 'show_never' }}"
    },
    {
      "type": "paragraph",
      "content": "Setting the preset to 'Override' and running the dev tools will override the existing manual preset if the names match. NB: This should be switched off right after updated a Preset!",
      "visible_if": "{{ settings.development__dev_mode == true }}"
    }
  ],
  "blocks": [
    {
      "name": "Icon",
      "type": "icon",
      "settings": [
        {
          "type": "text",
          "id": "handle",
          "label": "Handle"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Url",
          "info": "Use this for Social Icons links."
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "Image takes precedence over the SVG code."
        },
        {
          "type": "textarea",
          "id": "svg_code",
          "label": "SVG code"
        },
        {
          "type": "range",
          "id": "aspect_ratio",
          "label": "Aspect ratio",
          "default": 1,
          "min": 0.1,
          "max": 5,
          "step": 0.1,
          "unit": "/ 1"
        }
      ]
    }
  ],
  "limit": 2,

{%- comment -%} Ingredients LP3 — "What's Inside. And Why It Matters." {%- endcomment -%}
{%- liquid
  assign headline             = section.settings.headline
  assign headline_color       = section.settings.headline_color
  assign headline_size_desk   = section.settings.headline_size_desktop
  assign headline_size_mob    = section.settings.headline_size_mobile
  assign subtext              = section.settings.subtext
  assign subtext_color        = section.settings.subtext_color
  assign subtext_size         = section.settings.subtext_size
  assign enable_tabs          = section.settings.enable_tabs
  assign tab_1_label          = section.settings.tab_1_label
  assign tab_2_label          = section.settings.tab_2_label
  assign tab_dot_1            = section.settings.tab_dot_color_1
  assign tab_dot_2            = section.settings.tab_dot_color_2
  assign card_bg              = section.settings.card_bg
  assign card_border          = section.settings.card_border
  assign card_border_radius   = section.settings.card_border_radius
  assign image_border_radius  = section.settings.image_border_radius
  assign stat_color           = section.settings.stat_color
  assign background_color     = section.settings.background_color
  assign custom_css           = section.settings.custom_css
  assign section_id           = section.settings.section_id
-%}

{% capture selector %}[data-li3-id="{{ section.id }}"]{% endcapture %}

{% capture css %}
  & {
    width: 100%;
    {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
  }

  & .li3__container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 48px 24px;
  }

  /* ── Header ── */
  & .li3__header {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 40px;
  }

  & .li3__header-left {}

  & .li3__headline {
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
    font-size: {{ headline_size_mob }}px;
    {% if headline_color != blank and headline_color.alpha != 0 %}color: {{ headline_color }};{% endif %}
  }
  & .li3__headline p { margin: 0; }

  & .li3__header-right {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  & .li3__subtext {
    line-height: 1.6;
    margin: 0;
    font-size: {{ subtext_size }}px;
    max-width: 520px;
    {% if subtext_color != blank and subtext_color.alpha != 0 %}color: {{ subtext_color }};{% endif %}
  }
  & .li3__subtext p { margin: 0; }

  /* ── Tab pills ── */
  & .li3__tabs {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  & .li3__tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    border: 1px solid #d1d5db;
    background-color: #ffffff;
    cursor: pointer;
    transition: background-color 0.2s, border-color 0.2s, color 0.2s;
    white-space: nowrap;
  }

  & .li3__tab-btn.is-active {
    background-color: #1a1a1a;
    border-color: #1a1a1a;
    color: #ffffff;
  }

  & .li3__tab-btn.is-active .li3__tab-dot {
    background-color: #ffffff !important;
  }

  & .li3__tab-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Grid ── */
  & .li3__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  & .li3__grid[hidden] {
    display: none !important;
  }

  /* ── Card ── */
  & .li3__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 16px;
    border-radius: {{ card_border_radius }}px;
    {% if card_bg != blank %}background-color: {{ card_bg | append: '1a' }};{% endif %}
    {% if card_border != blank %}border: 1px solid {{ card_border }};{% endif %}
    transition: border-color 0.2s;
  }

  & .li3__card-dot {
    position: absolute;
    top: -5px;
    left: 50%;
    transform: translateX(-50%);
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  & .li3__card-image-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    flex-shrink: 0;
    border-radius: 4px
  }

  & .li3__card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ image_border_radius }}px {{ image_border_radius }}px 0 0;
    display: block;
  }

  & .li3__card-image-placeholder {
    width: 100%;
    height: 100%;
    background: #e5e0d8;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #aaa;
    font-size: 12px;
  }

  & .li3__card-body {
    padding: 14px 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  & .li3__card-name {
    font-weight: 700;
    font-size: 14px;
    line-height: 1.25;
    margin: 0;
  }

  & .li3__card-dosage {
    font-size: 12px;
    opacity: 0.55;
    margin: 0;
    line-height: 1.3;
  }

  & .li3__card-desc {
    font-size: 12px;
    line-height: 1.5;
    margin: 6px 0 0;
    opacity: 0.72;
  }
  & .li3__card-desc p { margin: 0; }

  & .li3__stats {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 10px;
  }

  & .li3__stat {
    display: inline-flex;
    align-items: baseline;
    gap: 5px;
    font-size: 11px;
    line-height: 1.4;
    border-radius: 4px;
    {% if stat_color != blank %}color: {{ stat_color }};{% endif %}
  }

  & .li3__stat-value {
    font-weight: 500;
    font-size: 12px;
    white-space: nowrap;
    text-wrap: auto;
  }

  & .li3__stat-label {
    opacity: 0.8;
  }

  /* ── Desktop ── */
  @media (min-width: 768px) {
    & .li3__container {
      padding: 80px 48px;
    }

    & .li3__header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      gap: 48px;
      margin-bottom: 48px;
    }

    & .li3__header-left {
      flex-shrink: 0;
      max-width: 380px;
    }

    & .li3__headline {
      font-size: {{ headline_size_desk }}px;
    }

    & .li3__header-right {
      max-width: 500px;
    }

    & .li3__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }

    & .li3__card-body {
      padding: 16px 16px 20px;
      gap: 8px;
    }

    & .li3__card-name {
      font-size: 15px;
    }

    & .li3__card-dosage {
      font-size: 13px;
    }

    & .li3__card-desc {
      font-size: 13px;
    }

    & .li3__stat {
      font-size: 12px;
    }

    & .li3__stat-value {
      font-size: 13px;
    }

    & .li3__stats {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 12px;
    }
  }
{% endcapture %}

{% capture section_content %}
  <style>
    {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  </style>

  <section
    data-li3-id="{{ section.id }}"
    {% if section_id != blank %}id="{{ section_id }}"{% endif %}
  >
    <div class="li3__container">

      {%- comment -%} Header {%- endcomment -%}
      <div class="li3__header">
        <div class="li3__header-left">
          {% if headline != blank %}
            <h2 class="li3__headline">{{ headline }}</h2>
          {% endif %}
        </div>

        <div class="li3__header-right">
          {% if subtext != blank %}
            <div class="li3__subtext">{{ subtext }}</div>
          {% endif %}

          {% if enable_tabs and tab_1_label != blank %}
            <div class="li3__tabs" role="tablist">
              <button
                class="li3__tab-btn"
                role="tab"
                aria-selected="true"
                data-li3-tab="{{ section.id }}"
                data-tab="tab1"
              >
                {% if tab_dot_1 != blank %}
                  <span class="li3__tab-dot" style="background-color: {{ tab_dot_1 }};"></span>
                {% endif %}
                {{ tab_1_label }}
              </button>
              {% if tab_2_label != blank %}
                <button
                  class="li3__tab-btn"
                  role="tab"
                  aria-selected="false"
                  data-li3-tab="{{ section.id }}"
                  data-tab="tab2"
                >
                  {% if tab_dot_2 != blank %}
                    <span class="li3__tab-dot" style="background-color: {{ tab_dot_2 }};"></span>
                  {% endif %}
                  {{ tab_2_label }}
                </button>
              {% endif %}
            </div>
          {% elsif tab_1_label != blank %}
            {%- comment -%} Single product label — non-interactive pill {%- endcomment -%}
            <div class="li3__tabs">
              <span class="li3__tab-btn" style="cursor:default;">
                {% if tab_dot_1 != blank %}
                  <span class="li3__tab-dot" style="background-color: {{ tab_dot_1 }};"></span>
                {% endif %}
                {{ tab_1_label }}
              </span>
            </div>
          {% endif %}
        </div>
      </div>

      {%- comment -%} Grids {%- endcomment -%}

      {%- assign has_tab2_blocks = false -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.tab_assignment == 'tab2' -%}{%- assign has_tab2_blocks = true -%}{%- endif -%}
      {%- endfor -%}

      {% if enable_tabs and has_tab2_blocks %}
        {%- comment -%} Tab 1 grid {%- endcomment -%}
        <div
          class="li3__grid"
          id="li3-grid-tab1-{{ section.id }}"
          role="tabpanel"
        >
          {% for block in section.blocks %}
            {% if block.settings.tab_assignment == 'tab2' %}{% continue %}{% endif %}
            {%- render 'li3-card', block: block, section: section -%}
          {% endfor %}
        </div>

        {%- comment -%} Tab 2 grid {%- endcomment -%}
        <div
          class="li3__grid"
          id="li3-grid-tab2-{{ section.id }}"
          role="tabpanel"
          hidden
        >
          {% for block in section.blocks %}
            {% unless block.settings.tab_assignment == 'tab2' %}{% continue %}{% endunless %}
            {%- render 'li3-card', block: block, section: section -%}
          {% endfor %}
        </div>

      {% else %}
        {%- comment -%} Single grid — all blocks {%- endcomment -%}
        <div class="li3__grid" role="tabpanel">
          {% for block in section.blocks %}
            {%- render 'li3-card', block: block, section: section -%}
          {% endfor %}
        </div>
      {% endif %}

    </div>
  </section>

  {% if enable_tabs %}
    <script>
      (function () {
        var sid = {{ section.id | json }};
        var btns = document.querySelectorAll('[data-li3-tab="' + sid + '"]');
        btns.forEach(function (btn) {
          btn.addEventListener('click', function () {
            var tab = btn.getAttribute('data-tab');
            btns.forEach(function (b) {
              b.classList.remove('is-active');
              b.setAttribute('aria-selected', 'false');
            });
            btn.classList.add('is-active');
            btn.setAttribute('aria-selected', 'true');
            ['tab1', 'tab2'].forEach(function (t) {
              var grid = document.getElementById('li3-grid-' + t + '-' + sid);
              if (!grid) return;
              if (t === tab) { grid.removeAttribute('hidden'); }
              else { grid.setAttribute('hidden', ''); }
            });
          });
        });
      })();
    </script>
  {% endif %}
{% endcapture %}

{{ section_content }}


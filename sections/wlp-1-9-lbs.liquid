    });
    tiers.forEach(function(t){
      var prefix = m === 'subscribe' ? 'sub' : 'ot';
      var per = t.getAttribute('data-' + prefix + '-permo');
      var total = t.getAttribute('data-' + prefix + '-total');
      var strike = t.getAttribute('data-' + prefix + '-strike');
      var save = t.getAttribute('data-' + prefix + '-save');
      var perEl = t.querySelector('.js-per');
      var totalEl = t.querySelector('.js-total');
      var strikeEl = t.querySelector('.js-strike');
      var saveEl = t.querySelector('.js-save');
      if(perEl) perEl.textContent = per;
      if(totalEl) totalEl.textContent = total;
      if(strikeEl){ strikeEl.textContent = strike ? '$'+strike : ''; strikeEl.style.display = strike ? '' : 'none'; }
      if(saveEl){
        if(save){ saveEl.textContent = 'SAVE '+save; saveEl.style.display=''; }
        else saveEl.style.display='none';
      }
      if(t.getAttribute('data-tier') === 'monthly'){
        var totalLabel = t.querySelector('.js-total-label');
        if(totalLabel) totalLabel.textContent = m === 'subscribe' ? 'Billed monthly · cancel anytime' : 'One-time purchase · no recurring';
      }
    });
  }
  toggleBtns.forEach(function(b){
    b.addEventListener('click', function(){ applyMode(b.getAttribute('data-mode')); });
  });

  function showToast(msg, isError){
    var t = root.querySelector('[data-toast]');
    if(!t) return;
    t.textContent = msg;
    t.style.background = isError ? '#b04a2a' : '#0e1a14';
    t.classList.add('show');
    setTimeout(function(){ t.classList.remove('show'); }, 2200);
  }

  root.querySelectorAll('.js-add-cart').forEach(function(btn){
    btn.addEventListener('click', function(e){
      e.preventDefault();
      var tier = btn.closest('.tier');
      if(!tier) return;
      var variantId = tier.getAttribute('data-variant-id');
      var sellingPlanId = tier.getAttribute('data-selling-plan-id');
      var item = { id: parseInt(variantId, 10), quantity: 1 };
      if(mode === 'subscribe' && sellingPlanId){ item.selling_plan = parseInt(sellingPlanId, 10); }
      btn.disabled = true;
      var orig = btn.textContent;
      btn.textContent = 'Adding…';
      fetch('/cart/add.js', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: [item] })
      })
      .then(function(res){ if(!res.ok) throw new Error('cart_'+res.status); return res.json(); })
      .then(function(){ showToast('Added to cart →'); window.location.href = '/cart'; })
      .catch(function(err){
        btn.disabled = false;
        btn.textContent = orig;
        showToast('Could not add to cart. Please try again.', true);
        console.error(err);
      });
    });
  });
})();
</script>


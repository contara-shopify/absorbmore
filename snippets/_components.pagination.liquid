{% comment %}
    Pagination element

    Accepts:
    - class: {string}
    - pagination_container_ref: {string}

    Usage:
    {% render '_components.pagination',
        class: pagination_class,
        pagination_container_ref: '$refs.scrollContainer'
    %}
{% endcomment %}
{% if paginate.pages > 1 %}
  <nav role="navigation"
       aria-label="Pagination"
       x-defer="intersect"
       x-ignore
       x-data="{ ..._pagination.init($refs.pagination, {{ pagination_container_ref }}) }"
       data-pagination
       x-ref="pagination"
       class="{{ class | default: 'pagination' }}"
      {{ html_attributes }}>
    <button
        type="button" class="prev relative flex h-full items-center justify-center"
        {% unless paginate.previous %}
          disabled="disabled"
        {% endunless %}
        @click.prevent.stop="paginateToUrl('{{ paginate.previous.url }}')"
    >
      <svg class="bg-current"
           style="mask: var(--pagination-button-prev); -webkit-mask: var(--pagination-button-prev); aspect-ratio: var(--pagination-button-prev-aspect-ratio, 1);"
           aria-hidden="true">
      </svg>
      <span class="sr-only">Previous page</span>
    </button>
    {% for part in paginate.parts %}
      <button
          class="relative flex h-full items-center justify-center {% if paginate.current_page == part.title %}active{% endif %}"
          {% if paginate.current_page == part.title %}
            aria-current="page"
          {% endif %}
          type="button"
          {% if part.is_link or paginate.current_page == part.title %}
            x-init="utils.barbaPrefetchTargetPage($el, `${window.location.origin}{{ part.url }}`)"
          {% else %}
            disabled="disabled"
          {% endif %}
          @click.prevent.stop="paginateToUrl('{{ part.url }}')"
      >
        <span class="sr-only">page</span> {{ part.title }}
      </button>
    {% endfor %}
    <button type="button"
            class="next relative flex h-full items-center justify-center"
            {% unless paginate.next %}disabled="disabled"{% endunless %}
            @click.prevent.stop="paginateToUrl('{{ paginate.next.url }}')">
      <svg class="bg-current"
           style="mask: var(--pagination-button-next); -webkit-mask: var(--pagination-button-next); aspect-ratio: var(--pagination-button-next-aspect-ratio, 1);"
           aria-hidden="true">
      </svg>
      <span class="sr-only">Next page</span>
    </button>
  </nav>
{% endif %}


    {% endif %}
    <svg data-icon-handle="{{ icon | handleize }}"
        {{ html_attributes }}
         class="bg-current shrink-0 {{ class | default: "w-5 h-5" }}"
         x-data="{ url: getComputedStyle(document.documentElement).getPropertyValue(`--icon-{{ icon | handleize }}--url`) }"
         :class="url ? 'cursor-pointer hf:opacity-70 transition-all duration-75': ''"
         :role="url ? 'link':''"
         :tabindex="url ? '0' : undefined"
         aria-label="{{ icon }}"
         x-init="if (url) { $el.onclick = (e) => utils.isExternalURL(url) ? window.open(url) : barba.go(url) }"
         style="mask: var(--icon-{{ icon | handleize }}); -webkit-mask: var(--icon-{{ icon | handleize }}); aspect-ratio: var(--icon-{{ icon | handleize }}-aspect-ratio, 1); {{ style }}"></svg>
{% endcase %}

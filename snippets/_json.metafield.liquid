{% comment %}
    Generates JSON data for metafield namespaces

    Accepts:
    - namespace: {Object} Liquid Namespace for an Object
    - with_product_data: {Boolean} Switch to get full metafield data (excluding metafields on 2nd level)

    Usage:
    {%- render '_json.metafield', namespace: product.metafields[namespace], with_product_data: false -%}
{% endcomment %}

{%- capture json -%}
  {
  {%- for key in namespace -%}
    {%- assign metafield = namespace[key[0]] -%}
    {% if meta_keys != blank %}
      {% unless meta_keys contains key[0] %}
        {% continue %}
      {% endunless %}
    {% endif %}
    ,{{- key[0] | json -}}:
    {%- if metafield.type == "list.page_reference" -%}
      {{- metafield -}}
    {%- elsif metafield.type == "dimension" or metafield.type == "weight" or metafield.type == "volume" -%}
      {
      "type": {{- metafield.value.type | json -}},
      "unit": {{- metafield.value.unit | json -}},
      "value": {{- metafield.value.value | json -}}
      }
    {%- elsif metafield.type == "rating" -%}
      {
      "rating": {{- metafield.value.rating | json -}},
      "scale_max": {{- metafield.value.scale_max | json -}},
      "scale_min": {{- metafield.value.scale_min | json -}}
      }
    {%- elsif metafield.type == "rich_text_field" -%}
      {% assign richtextStr = "" %}
      {% assign richtext = metafield | metafield_tag | replace: '<div class="metafield-rich_text_field">', "" | split: "</div>" %}
      {% for htmlBlock in richtext %}
        {% if forloop.last %}
          {% assign richtextStr = richtextStr | append: htmlBlock %}
          {% break %}
        {% endif %}
        {% assign richtextStr = richtextStr | append: htmlBlock | append: "</div>" %}
      {% endfor %}
      {{- richtextStr | json -}}
    {% elsif metafield.type == "file_reference" and metafield.value.media_type == "image" %}
      {%- render '_json.image', input_image: metafield.value -%}
    {% elsif metafield.type == "list.file_reference" %}
      [{% for value in metafield.value %}{% if value.media_type == 'image' %}{%- render '_json.image', input_image: value -%}{% else %}{{ value | json }}{% endif %}{% unless forloop.last %},{% endunless %}{% endfor %}]
    {%- elsif metafield.type == "metaobject_reference" or metafield.type == "mixed_reference" -%}
      {% render '_json.metaobject', input: metafield.value %}
    {%- elsif metafield.type == "list.metaobject_reference" or metafield.type == "list.mixed_reference" -%}
      [{% for value in metafield.value %}{% render '_json.metaobject', input: value %}{% unless forloop.last %},{% endunless %}{% endfor %}]
    {%- elsif metafield.type == "product_reference" -%}
      {% if with_product_data %}
        {%- render '_json.product', product: metafield.value -%}
      {% else %}
        {{ metafield.value.handle | json }}
      {% endif %}
    {%- elsif metafield.type == "list.product_reference" -%}
      {% comment %}{% if with_product_data or key[0] == 'bundle_products' %}{% endcomment %}
      {% if with_product_data %}
        [{% for product in metafield.value %}{%- render '_json.product', product: product, meta_product: true, card: true, section: null -%}{% unless forloop.last %},{% endunless %}{% endfor %}]
      {% else %}
        {{ metafield.value | map: "handle" | json }}
      {% endif %}
    {%- elsif metafield.type == "list.variant_reference" -%}
      {% assign metafield_variants = metafield.value | where: "id" %}
      [{% for variant in metafield_variants %}{%- render '_json.variant', variant: variant, skip_metafields: true, section: null -%}{% unless forloop.last %},{% endunless %}{% endfor %}]
    {%- elsif metafield.type == "collection_reference"
    or metafield.type == "list.collection_reference"
    or metafield.type == "variant_reference"
    or metafield.type == "list.color"
    or metafield.type == "boolean"
    or metafield.type == "number_decimal"
    or metafield.type == "list.number_decimal"
    or metafield.type == "number_integer"
    or metafield.type == "money"
    or metafield.type == "list.number_integer"
    or metafield.type == "single_line_text_field" -%}
      {{- metafield.value | json -}}
    {%- elsif metafield.type == null and metafield.size < 500 -%}
      "{{- metafield | escape -}}"
    {%- else -%}
      {%- if metafield.value.size < 500 or metafield.value contains '<svg' -%}{{- metafield.value | json -}}{%- else -%}null{%- endif -%}
    {%- endif -%}
  {%- endfor -%}
  }
{%- endcapture -%}

{{- json | remove_first: ',' | strip | strip_newlines -}}

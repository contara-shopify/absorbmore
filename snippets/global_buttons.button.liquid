{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "button"
  assign section_type = "global_buttons"
  assign class = block.settings.class
  assign text_color = block.settings.text_color
  assign background_color = block.settings.background_color
  assign custom_css = block.settings.custom_css
  assign override_preview_background = block.settings.override_preview_background
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{%- liquid
  assign first_button_block = section.blocks | where: "type", 'button' | first
  assign selector = '.' | append: class | replace: '\/', '/' | replace: '/', '\/'
%}

{%- capture css -%}
  & {
  position: relative;
  transition: all 75ms;
  overflow: hidden;
  {% if text_color != blank and text_color.alpha != 0 %}color: {{ text_color }};{% endif %}
  {% if background_color != blank %}background-color: {{ background_color }};{% endif %}
  }
  &:not(disabled) {
  cursor: pointer;
  }
{%- endcapture -%}

<style>
  {{ css | append: custom_css  | replace: '&', selector | strip_newlines }}
  {% if request.design_mode %}
  {% assign query_selector = '[data-section-id="'|append: section.id | append: '"][data-preview-container] ' | append: selector %}
  {{- css | append: custom_css | replace: '&', query_selector  | strip_newlines | replace: '@media screen and', '@container'| replace: '@media', '@container' -}}
  {% endif %}
</style>

{% if request.design_mode %}
  {% if override_preview_background == blank or override_preview_background.alpha == 0 %}
    {% assign override_preview_background = '#ffffff' %}
  {% endif %}
  <section class="fixed inset-0 z-50 flex flex-col gap-16 overflow-y-auto bg-white py-16 text-black px-container-sm @container"
           data-section-id="{{ section.id }}"
           data-preview-container
           x-data="{tab: 'single-type'}"
           style="background: {{ override_preview_background }};"
           x-show="$editor?.select_block_id === '{{ block.id }}'"
           x-cloak {{ block.shopify_attributes }}>

    <header class="flex gap-3 font-mono">
      <button @click="tab='single-type'"
              type="button"
              :class="tab === 'single-type' ? 'bg-gray-600 text-gray-50 border-gray-900 hf:bg-gray-700':'border-gray-200/70 bg-gray-100 text-gray-700 hf:text-gray-900 hf:border-gray-300/80 hf:bg-gray-200/90'"
              class="rounded-sm border px-3 text-sm font-medium py-1.5">{{ selector }}
      </button>
    </header>

    <main class="mt-8">
      <header class="mt-12 grid gap-8 lg:grid-cols-[1fr_320px]">
        <div class="text-lg font-bold text-gray-600">Desktop</div>
        <div class="text-lg font-bold text-gray-600">Mobile</div>
      </header>
      <section x-show="tab === 'single-type'" class="mt-6 grid gap-8 lg:grid-cols-[1fr_320px]">
        <div class="{{ class }}">
          Shop now
        </div>
        <div class=" @container max-w-lg">
          <div class="{{ class }}">Shop now</div>
        </div>
      </section>
      <header class="mt-12 grid gap-8 lg:grid-cols-[1fr_320px]">
        <div class="text-lg font-bold text-gray-600">Desktop - Long</div>
        <div class="text-lg font-bold text-gray-600">Mobile - Long</div>
      </header>
      <section x-show="tab === 'single-type'" class="mt-6 grid gap-8 lg:grid-cols-[1fr_320px]">
        <div class="{{ class }}">
          Learn more about our products
        </div>
        <div class="@container max-w-lg">
          <div class="{{ class }}">Learn more about our products</div>
        </div>
      </section>
    </main>
    <main class="mt-4">
      <header class="mt-12 grid gap-8 lg:grid-cols-[1fr_320px]">
        <div class="text-lg font-bold text-gray-600">Desktop Active</div>
        <div class="text-lg font-bold text-gray-600">Mobile Active</div>
      </header>
      <section x-show="tab === 'single-type'" class="mt-6 grid gap-8 lg:grid-cols-[1fr_320px]">
        <div class="{{ class }} active">
          Shop now
        </div>
        <div class=" @container max-w-lg">
          <div class="{{ class }} active">Shop now</div>
        </div>
      </section>
      <header class="mt-12 grid gap-8 lg:grid-cols-[1fr_320px]">
        <div class="text-lg font-bold text-gray-600">Desktop Active - Long</div>
        <div class="text-lg font-bold text-gray-600">Mobile Active - Long</div>
      </header>
      <section x-show="tab === 'single-type'" class="mt-6 grid gap-8 lg:grid-cols-[1fr_320px]">
        <div class="{{ class }} active">
          Learn more about our products
        </div>
        <div class="@container max-w-lg">
          <div class="{{ class }} active">Learn more about our products</div>
        </div>
      </section>
    </main>
  </section>
{% endif %}

{% if block.id == first_button_block.id %}
  <style>
    {{- css | append: custom_css  | replace: '&', selector | replace: class, 'shopify-challenge__button' | strip_newlines  -}}
  </style>
{% endif %}

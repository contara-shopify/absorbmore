{% if template contains 'collection' and collection.products_count > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": {{ collection.title | json }},
    "url": {{ collection.url | json }},
    "itemListElement": [
      {% assign counter = 0 %}
      {% for product in collection.products %}
        {% if counter == 15 %}{% break %}{% endif %}
        {% assign counter = counter | plus: 1 %}
        {
          "@type": "Product",
          "position": {{ counter }},
          "name": {{ product.title | json }},
          "description": {{ product.description | strip_html | truncate: 160 | json }},
          "url": {{ product.url | json }},
          "image": {{ product.featured_image | image_url: '800x' | json }},
          "offers": {
            "@type": "Offer",
            "priceCurrency": "{{ shop.currency }}",
            "price": {{ product.price | divided_by: 100.0 | remove: ','  }},
            "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}"
          }
          {% if product.metafields.reviews.rating.value and product.metafields.reviews.rating_count.value and product.metafields.reviews.rating_count.value > 0 %},
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "{{ product.metafields.reviews.rating.value }}",
            "reviewCount": "{{ product.metafields.reviews.rating_count.value }}"
          }
          {% endif %}
        }{% unless counter == 15 or forloop.last or counter == collection.products_count %},{% endunless %}
      {% endfor %}
    ]
  }
  </script>
{% endif %}


{%- comment -%}
  FAQPage schema for blog articles (extract from article.content)


  Assumes FAQ block is in article.content using a pattern like:
    <h2>FAQ ...</h2> OR <h2>Frequently Asked Questions ...</h2>
    <h3>Question</h3>
    <p>Answer...</p>


  Logic:
  - Detect if the article HTML contains an FAQ heading marker (FAQ / Frequently Asked Questions)
  - Split content by <h3 ...> blocks (each question)
  - For each <h3>, use the first <p> after it as the answer
  - If no valid Q/A pairs, output nothing


  Notes:
  - This is server-side (Liquid), so Google can see it without relying on JS.
{%- endcomment -%}


{%- if request.page_type == 'article' and article and article.content != blank -%}
  {%- assign content = article.content -%}


  {%- comment -%} Detect presence of FAQ heading (broader matching) {%- endcomment -%}
  {%- assign has_faq = false -%}
  {%- if content contains '>FAQ'
     or content contains 'FAQ -'
     or content contains 'FAQ –'
     or content contains 'Frequently Asked Questions'
  -%}
    {%- assign has_faq = true -%}
  {%- endif -%}


  {%- if has_faq -%}
    {%- comment -%}
      Split by <h3 ...> which contains each question.
      We'll grab the text before </h3> as question,
      and the first <p ...>...</p> after as answer.
    {%- endcomment -%}


    {%- assign parts = content | split: '<h3' -%}
    {%- assign emitted = 0 -%}


    {%- capture entities -%}
      {%- for part in parts -%}
        {%- if forloop.first -%}{%- continue -%}{%- endif -%}


        {%- comment -%} Recover the <h3 ...> tag start {%- endcomment -%}
        {%- assign h3_block = '<h3' | append: part -%}


        {%- comment -%} Extract question inner text (strip tags) {%- endcomment -%}
        {%- assign q_html = h3_block | split: '</h3>' | first -%}
        {%- assign q = q_html | strip_html | strip -%}


        {%- comment -%} Extract answer: first paragraph after </h3> {%- endcomment -%}
        {%- assign after_h3 = h3_block | split: '</h3>' -%}
        {%- if after_h3.size > 1 -%}
          {%- assign rest = after_h3[1] -%}
          {%- assign p_split = rest | split: '<p' -%}
          {%- if p_split.size > 1 -%}
            {%- assign p_block = '<p' | append: p_split[1] -%}
            {%- assign a_html = p_block | split: '</p>' | first -%}
            {%- assign a = a_html | strip_html | strip -%}
          {%- else -%}
            {%- assign a = '' -%}
          {%- endif -%}
        {%- else -%}
          {%- assign a = '' -%}
        {%- endif -%}


        {%- if q != blank and a != blank -%}
          {%- if emitted > 0 -%},{%- endif -%}
          {
            "@type": "Question",
            "name": {{ q | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ a | json }}
            }
          }
          {%- assign emitted = emitted | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endcapture -%}


    {%- if emitted > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "{{ shop.url }}{{ article.url }}#faq",
  "mainEntity": [
    {{ entities | strip }}
  ]
}
</script>
    {%- endif -%}
  {%- endif -%}
{%- endif -%}


{% comment %}
  QCK FAQPage Schema (JSON-LD)
  Renders FAQPage structured data from collection accordion metafields.
  Handles rich text metafields by converting to plain text.
  Usage: {% render 'qck-faqpage-schema' %}
{% endcomment %}

{% assign faq_data = collection.metafields.custom.qck_accordion.value %}

{% if faq_data %}
  {% assign questions = "" %}

  {% if faq_data.question_1 != blank and faq_data.answer_1 != blank %}
    {% assign questions = questions | append: "1," %}
  {% endif %}
  {% if faq_data.question_2 != blank and faq_data.answer_2 != blank %}
    {% assign questions = questions | append: "2," %}
  {% endif %}
  {% if faq_data.question_3 != blank and faq_data.answer_3 != blank %}
    {% assign questions = questions | append: "3," %}
  {% endif %}
  {% if faq_data.question_4 != blank and faq_data.answer_4 != blank %}
    {% assign questions = questions | append: "4," %}
  {% endif %}
  {% if faq_data.question_5 != blank and faq_data.answer_5 != blank %}
    {% assign questions = questions | append: "5," %}
  {% endif %}
  {% if faq_data.question_6 != blank and faq_data.answer_6 != blank %}
    {% assign questions = questions | append: "6," %}
  {% endif %}

  {% assign questions_arr = questions | split: "," | compact %}

  {% if questions_arr.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for num in questions_arr %}
      {% case num %}
        {% when "1" %}
          {% assign q = faq_data.question_1 %}
          {% capture raw_a %}{{ faq_data.answer_1 | metafield_tag }}{% endcapture %}
        {% when "2" %}
          {% assign q = faq_data.question_2 %}
          {% capture raw_a %}{{ faq_data.answer_2 | metafield_tag }}{% endcapture %}
        {% when "3" %}
          {% assign q = faq_data.question_3 %}
          {% capture raw_a %}{{ faq_data.answer_3 | metafield_tag }}{% endcapture %}
        {% when "4" %}
          {% assign q = faq_data.question_4 %}
          {% capture raw_a %}{{ faq_data.answer_4 | metafield_tag }}{% endcapture %}
        {% when "5" %}
          {% assign q = faq_data.question_5 %}
          {% capture raw_a %}{{ faq_data.answer_5 | metafield_tag }}{% endcapture %}
        {% when "6" %}
          {% assign q = faq_data.question_6 %}
          {% capture raw_a %}{{ faq_data.answer_6 | metafield_tag }}{% endcapture %}
      {% endcase %}
      {% assign clean_a = raw_a | strip_html | strip_newlines | strip %}
      {
        "@type": "Question",
        "name": {{ q | strip_html | strip_newlines | strip | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ clean_a | json }}
        }
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>
  {% endif %}
{% endif %}
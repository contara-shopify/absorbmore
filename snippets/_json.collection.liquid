{% liquid

  unless collection
    break
  endunless

  assign collection_namespaces = settings.data__collection__metafield | prepend: 'smart,' | split: ',' | uniq

  for product in collection.products
    if product.featured_media != blank
      assign featured_media = product.featured_media
      break
    endif
  endfor
%}

{% capture json %}
  {
  "default_sort_by": "{{ collection.default_sort_by }}",
  "description": {{ collection.description | json }},
  "featured_image": {{ featured_media | json }},
  "handle": "{{ collection.handle }}",
  "id": "{{ collection.id }}",
  "image": {{ collection.image | default: featured_media | json }},
  "published_at": "{{ collection.published_at | date: "%Y-%m-%dT%H:%M:%S%z" }}",
  "template_suffix": "{{ collection.template_suffix }}",
  "title": {{ collection.title | json }},
  "tags": {{ collection.tags | json }},
  "products_count": {{ collection.products_count }},
  "products": "{{ collection.products | map: "handle" | join: ',' }}",
  "url": "{{ collection.url }}",
  "metafields": {
  {%- for namespace in collection_namespaces -%}
    "{{- namespace -}}": {%- render '_json.metafield', namespace: collection.metafields[namespace], with_product_data: settings.data__collection__load_product_data -%}{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
  }
  }
{% endcapture %}
{{- json | strip | strip_newlines -}}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "_card_product_card__gallery"
  assign section_type = "card_product_card"
  assign filter_images = block.settings.filter_images
  assign max_images = block.settings.max_images
  assign hide_image_alt = block.settings.hide_image_alt
  assign scroll_to_selected_variant_image = block.settings.scroll_to_selected_variant_image
  assign slider_scroll_snap = block.settings.slider_scroll_snap
  assign slider_overflow_container = block.settings.slider_overflow_container
  assign scrollbar_class = block.settings.scrollbar_class
  assign scroll_pagination_class = block.settings.scroll_pagination_class
  assign show_overlay = block.settings.show_overlay
  assign overlay_color = block.settings.overlay_color
  assign sizes = block.settings.sizes
  assign max_width = block.settings.max_width
  assign custom_css = block.settings.custom_css
  assign show_conditionally = block.settings.show_conditionally
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{% liquid
  if show_conditionally == 'with_subscriptions' and product.selling_plan_groups.size <= 0
    break
  endif
  if show_conditionally == 'no_subscriptions' and product.selling_plan_groups.size > 0
    break
  endif
  if show_conditionally == 'with_variants' and product.variants.size <= 1
    break
  endif
  if show_conditionally == 'no_variants' and product.variants.size > 1
    break
  endif
  if show_conditionally == 'bundle' and is_bundle
    break
  endif
  if show_conditionally == 'no_bundle' and is_bundle != true
    break
  endif
%}

{% liquid
  assign container_spacing = section.settings.container_spacing
  case slider_overflow_container
    when 'all'
      assign slider_overflow = container_spacing | replace: 'px', '-mx' | append: " scroll-" | append: container_spacing | append: " " | append: container_spacing
    when 'mobile'
      assign slider_overflow = container_spacing | replace: 'px', 'max-md:-mx' | append: " max-md:scroll-" | append: container_spacing | append: " max-md:" | append: container_spacing
    when 'desktop'
      assign slider_overflow = container_spacing | replace: 'px', 'md:-mx' | append: " md:scroll-" | append: container_spacing | append: " md:" | append: container_spacing
  endcase
%}

<div
    data-style-id="{{ style_id }}"
    {% if show_conditionally != blank and show_conditionally != 'always' %}
      x-cloak
      x-show="$editor.select_block_id === `{{ block_id }}` || $data.showConditionally('{{ show_conditionally }}', $data?.bundle)"
    {% endif %}
    class="relative"
    data-product-card-gallery
    x-data="{ ...utils.initContentSlider($el, $el.firstElementChild, undefined, `{{ infinite_scroll }}`) }"
    x-defer="intersect"
    {% if scroll_to_selected_variant_image %}
      x-init="$watch('p_card.selected_variant', () => scrollToMediaById(p_card.selected_variant?.featured_media?.id, $el.firstElementChild))"
    {% endif %}
    data-settings="{{ block.settings | json | escape }}">
  <div
      class="gallery-container flex snap-mandatory overflow-x-auto scrollbar-none max-lg:order-first {{ slider_scroll_snap }} {{ slider_overflow }}"
      @resize.window="content_slider.handleResize"
      x-data="{ initVariants: () => { p_card.gallery_media = $data?.handleImageSelection(`{{ filter_images }}`, p_card.selected_variant); $nextTick(() =>{ $data.content_slider.handleResize() }); } }"
      x-init="initVariants(); $watch('p_card.selected_variant', $data.initVariants); utils.hydrateImages(true, $el)"
      @scroll="(e) => { content_slider.handleScroll(e); const mediaId = [...$el.querySelectorAll(':scope > div:not(.hidden):not(.\\!hidden)')].find(pic => pic?.classList?.contains('centered'))?.getAttribute('data-media-id'); if (mediaId && mediaId !== p_card.selected_media_id) { p_card.selected_media_id = mediaId }}"
      @scrollend="content_slider.handleInfiniteScroll"
      x-effect="() => {
        if (p_card?.selected_variant?.id && p_card?.selected_variant?.id !== p_card?.initial_variant_id && !p_card?.images_cleaned) {
          $el.querySelectorAll(':scope > div:not([\\:data-media-id])').forEach(el => el.remove())
          p_card.images_cleaned = true
        }
      }"
      x-ref="scrollContainer">
    <template x-for="(value, i) in (p_card.images_cleaned ? (p_card?.gallery_media?.slice(0, +{{ max_images | default: 'p_card?.gallery_media?.length ?? 9999' }}) || []) : [])">
      <div :data-media-id="p_card?.gallery_media[i].id"
           tabindex="-1"
           :style="`--order: ${i * 10};`"
           class="image-wrapper snap-start relative flex w-full shrink-0 overflow-hidden h-full order-[--order]">
        <template x-if="p_card?.gallery_media[i]?.media_type === 'image'">
          <img class="h-full w-full object-[inherit] transition-opacity duration-300 ease-in"
               :class="i !== 0 ? '!opacity-0' : ''"
               src=""
               alt=""
               onload="this.classList.remove('!opacity-0')"
               :srcset="utils.getImageSrcSet(p_card?.gallery_media[i]?.src ?? '', +`{{ max_width }}`)"
               :src="p_card?.gallery_media[i]?.src"
               :alt="p_card?.gallery_media[i]?.alt"
               sizes="{{ sizes }}" />
        </template>
        <template x-if="p_card?.gallery_media[i]?.media_type === 'video'">
          <video playsinline
                 controls
                 x-effect="() => { if (!$el.paused && ($mediaGallery.scrollIndex !== i || !$modal.id === 'media-gallery--vertical-gallery')) { $el.pause() } }"
                 loop
                 preload="none"
                 class="h-full w-full object-[inherit]"
                 :aria-label="p_card?.gallery_media[i]?.alt"
                 :poster="p_card?.gallery_media[i]?.preview_image?.src">
            <template x-for="(source, index) in [...(p_card?.gallery_media[i]?.sources || [])].sort((a, b) => a.width - b.width)">
              <source data-loop-item
                      src=""
                      :src="source?.url"
                      :type="source?.mime_type"
                      :media="index === 0 ? 'all' : `(min-width: ${[...(p_card?.gallery_media[i]?.sources || [])].sort((a, b) => a.width - b.width)[index - 1].width + 1}px)`"
                      type="video/mp4" />
            </template>
            <img x-show="p_card?.gallery_media[i]?.preview_image?.src"
                 :src="p_card?.gallery_media[i]?.preview_image.src"
                 :alt="p_card?.gallery_media[i]?.alt" />
          </video>
        </template>
        <template x-if="p_card?.gallery_media[i]?.media_type === 'external_video'">
          <iframe allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  class="relative h-full w-full object-contain js-youtube"
                  loading="lazy"
                  :src="p_card?.gallery_media[i].host === 'youtube'
                           ? `https://www.youtube.com/embed/${p_card?.gallery_media[i].external_id}?autoplay=${$mediaGallery.scrollIndex === i ? '1' : '0'}&controls=1&muted=${$mediaGallery.scrollIndex === i ? '0' : '1'}&enablejsapi=1&loop=${1}&modestbranding=1&playsinline=1&rel=0`
                           : `https://player.vimeo.com/video/${p_card?.gallery_media[i].external_id}`"
                  :title="p_card?.gallery_media[i].alt"></iframe>
        </template>
        <template x-if="p_card?.gallery_media[i]?.media_type === 'model'">
          <div class="relative aspect-1 h-full w-full">
            <div x-html="`
                    <model-viewer
                      class='inset-0 h-full w-full object-contain md:absolute'
                      style='--poster-color: transparent; position: absolute;'
                      src='${p_card?.gallery_media[i]?.sources?.find((source) => source.format === 'glb')?.url}'
                      camera-controls='true'
                      data-shopify-feature='1.12'
                      alt='${p_card?.gallery_media[i]?.alt}'
                      poster='${p_card?.gallery_media[i]?.preview_image.src}'
                      data-js-focus-visible='
                      ar-status='not-presenting'
                      ></model-viewer>
                  `"></div>
          </div>
        </template>
      </div>
    </template>
    {% liquid
      assign variant_media_id = variant.featured_media.id | default: product.media.first.id
      assign variant_media_ids = product.variants | map: "featured_media" | map: "id" | uniq
      assign max_images = max_images | default: 9999 | at_least: 1
      assign images_rendered = 0
      assign start_index = 0
      case filter_images
        when "show_all"
          assign media_array = product.media
        when "selected_variant"
          assign media_array = variant.featured_media | uniq
        when "variant_images_by_order"
          assign media_array = product.media
          assign start_index = product.media | find_index: 'id', variant.featured_media.id
        when "variant_images_by_metafield"
          assign media_array = variant.featured_media | uniq
          assign additional_media_array = variant.metafields.smart.images.value | uniq
          assign media_array = media_array | concat: additional_media_array
        when "variant_images_and_unassigned"
          assign media_array = product.media
        when "only_unassigned"
          assign media_array = product.media
        when "first_or_selected_image"
          assign media_array = product.media | first | uniq
      endcase

      if media_array.size <= 0 and product.featured_media
        assign media_array = product.featured_media | uniq
      endif
    %}

    {% for i in (start_index..media_array.size) %}
      {% assign media = media_array[i] %}
      {% if media == blank %}{% continue %}{% endif %}
      {% if filter_images == 'only_unassigned' and variant_media_ids contains media.id %}{% continue %}{% endif %}
      {% if filter_images == 'variant_images_and_unassigned' and media.id != variant_media_id and variant_media_ids contains media.id %}{% continue %}{% endif %}
      {% if filter_images == 'variant_images_by_order' and media.id != variant_media_id and variant_media_ids contains media.id %}{% break %}{% endif %}
      {% if preload_images %}
        {% assign preload = true %}
      {% endif %}
      {% if images_rendered > 0 %}
        {% assign data_src = true %}
        {% assign preload = false %}
      {% endif %}

      <div data-media-id="{{ media.id }}"
           tabindex="-1"
           style="--order: {{ images_rendered | times: 10 }};"
           class="image-wrapper snap-start relative flex w-full shrink-0 overflow-hidden h-full order-[--order]">
        {% render '_object.media',
            media: media,
            data_src: data_src,
            class: "w-full h-full object-cover transition-opacity duration-300 ease-in",
            sizes: sizes,
            max_width: max_width,
            preload: preload
        %}
      </div>
      {% assign images_rendered = images_rendered | plus: 1 %}
      {% if images_rendered >= max_images %}{% break %}{% endif %}
    {% endfor %}
  </div>
  {% if scrollbar_class != blank %}
    {% render '_components.scrollbar', class: scrollbar_class %}
  {% endif %}
  {% if scroll_pagination_class != blank %}
    {% render '_components.scroll_pagination', class: scroll_pagination_class %}
  {% endif %}
</div>

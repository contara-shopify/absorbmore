{% liquid

  unless blog
    break
  endunless

  assign blog_namespaces = settings.data__blog__metafield | prepend: 'smart,' | split: ',' | uniq
%}
{% capture json %}
  {
  "all_tags": {{ blog.all_tags | json }},
  "articles": {{ blog.articles | map: "handle" | json }},
  "articles_count": {{ blog.articles_count }},
  "comments_enabled": {{ blog.comments_enabled? | json }},
  "handle": "{{ blog.handle }}",
  "id": {{ blog.id }},
  "moderated": {{ blog.moderated? | json }},
  "tags": "{{ blog.tags }}",
  "template_suffix": "{{ blog.template_suffix }}",
  "title": "{{ blog.title }}",
  "url": "{{ blog.url }}",
  "metafields": {
  {%- for namespace in blog_namespaces -%}
    "{{- namespace -}}": {%- render '_json.metafield', namespace: blog.metafields[namespace], with_product_data: settings.data__blog__load_product_data -%}{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
  }
  }
{% endcapture %}
{{- json | strip | strip_newlines -}}

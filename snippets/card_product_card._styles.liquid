{% if block != blank %}
  {% assign _settings = block.settings %}

  {% capture css %}
    & {
    {% if _settings.text_color != 'rgba(0,0,0,0)' and _settings.text_color != blank %}color: {{ _settings.text_color }};{% endif %}
    {% if _settings.background_color != 'rgba(0,0,0,0)' and _settings.background_color != blank %}background-color: {{ _settings.background_color }};{% endif %}
    }
  {% endcapture %}

  {% if block.type == '_card_product_card__gallery' %}
    {% if _settings.show_overlay %}
      {% capture additional_css %}
        & [data-media-id]:after {
        content: '';
        position: absolute;
        inset: 0;
        background: {{ _settings.overlay_color }};
        pointer-events: none;
        }
      {% endcapture %}
    {% endif %}
  {% endif %}

  {% if block.type == '_card_product_card__image' %}
    {% if _settings.show_overlay %}
      {% capture additional_css %}
        &:after {
        content: '';
        position: absolute;
        inset: 0;
        background: {{ _settings.overlay_color }};
        pointer-events: none;
        }
      {% endcapture %}
    {% endif %}
  {% endif %}

  {% if block.type == '_card_product_card__rating' %}
    {% capture additional_css %}
      & {
      --star-size: 20px;
      --star-gap: 3px;
      }
      & meter {
      --star-size-with-gap: calc(var(--star-size) + var(--star-gap));

      display: block;
      position: relative;
      width: calc(var(--star-size-with-gap) * 5 - var(--star-gap));
      height: var(--star-size);
      background: var(--color-review-stars-base--hex);
      mask: var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }});
      mask-position: calc(var(--star-size-with-gap) * 0) 0, calc(var(--star-size-with-gap) * 1) 0, calc(var(--star-size-with-gap) * 2) 0, calc(var(--star-size-with-gap) * 3) 0, calc(var(--star-size-with-gap) * 4) 0;
      }

      & meter:-moz-meter-optimum::-moz-meter-bar {
      height: var(--star-size);
      background: var(--color-review-stars--hex);
      mask: var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }});
      mask-position: calc(var(--star-size-with-gap) * 0) 0, calc(var(--star-size-with-gap) * 1) 0, calc(var(--star-size-with-gap) * 2) 0, calc(var(--star-size-with-gap) * 3) 0, calc(var(--star-size-with-gap) * 4) 0;
      }

      /* The gray background in Webkit browsers */

      & meter::-webkit-meter-bar {
      background: transparent;
      border-radius: 0;
      border: 0;
      height: var(--star-size);
      }

      /* The bar in Webkit browsers */

      & meter::-webkit-meter-optimum-value {
      height: var(--star-size);
      background: var(--color-review-stars--hex);
      mask: var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }}), var(--icon-{{ _settings.icon | handleize }});
      mask-position: calc(var(--star-size-with-gap) * 0) 0, calc(var(--star-size-with-gap) * 1) 0, calc(var(--star-size-with-gap) * 2) 0, calc(var(--star-size-with-gap) * 3) 0, calc(var(--star-size-with-gap) * 4) 0;
      }
    {% endcapture %}
  {% endif %}

  {{ css | append: additional_css | append: _settings.custom_css | replace: '&', selector | strip_newlines }}

  {% for block_id in block.block_order %}
    {% assign _block = block.blocks[block_id] %}
    {% if _block.disabled %}{% continue %}{% endif %}
    {% assign style_id = block_id %}
    {% capture selector %}[data-style-id="{{ style_id }}"]{% endcapture %}
    {% render 'card_product_card._styles', block: _block, block_id: block_id, section: section, style_id, selector: selector %}
  {% endfor %}
  {% break %}
{% endif %}

{% if section != blank %}
  {% capture styles %}
    {% assign _settings = section.settings %}
    {% assign section_id = _settings.product_card | default: _settings.handle | handleize %}
    {% capture selector %}.product-card--{{ section_id }}{% endcapture %}

    {% capture css %}
      & {
      {% if _settings.text_color != 'rgba(0,0,0,0)' and _settings.text_color != blank %}color: {{ _settings.text_color }};{% endif %}
      {% if _settings.background_color != 'rgba(0,0,0,0)' and _settings.background_color != blank %}background-color: {{ _settings.background_color }};{% endif %}
      }
    {% endcapture %}
    {{ css | append: _settings.custom_css | replace: '&', selector | strip_newlines }}

    {% for block_id in section.block_order %}
      {% assign block = section.blocks[block_id] %}
      {% if block.disabled %}{% continue %}{% endif %}
      {% assign style_id = block_id %}
      {% capture selector %}[data-style-id="{{ style_id }}"]{% endcapture %}
      {% render 'card_product_card._styles', block: block, block_id: block_id, section: section, style_id, selector: selector %}
    {% endfor %}
  {% endcapture %}

  <style>
    {{ styles | strip | strip_newlines }}
  </style>
  {% break %}
{% endif %}

{% capture styles %}
  {% for card in metaobjects.product_cards.values %}
    {% assign section = card.schema.value %}
    {% assign _settings = section.settings %}
    {% assign section_id = _settings.product_card | default: _settings.handle | handleize %}
    {% capture selector %}.product-card--{{ section_id }}{% endcapture %}

    {% capture css %}
      & {
      {% if _settings.text_color != 'rgba(0,0,0,0)' and _settings.text_color != blank %}color: {{ _settings.text_color }};{% endif %}
      {% if _settings.background_color != 'rgba(0,0,0,0)' and _settings.background_color != blank %}background-color: {{ _settings.background_color }};{% endif %}
      }
    {% endcapture %}
    {{ css | append: _settings.custom_css | replace: '&', selector | strip_newlines }}

    {% for block_id in section.block_order %}
      {% assign block = section.blocks[block_id] %}
      {% if block.disabled %}{% continue %}{% endif %}
      {% assign style_id = block_id %}
      {% capture selector %}[data-style-id="{{ style_id }}"]{% endcapture %}
      {% render 'card_product_card._styles', block: block, block_id: block_id, section: section, style_id, selector: selector %}
    {% endfor %}
  {% endfor %}
{% endcapture %}

<style>
  {{ styles | strip | strip_newlines }}
</style>

    {% capture css_content %}
      {{ css | replace: '&', selector }}
    {% endcapture %}
    {% render '_components.editor_preview_base_css', block: block, class: class, selector: selector, css: css_content, filename: 'snippets/_components.collapsible' %}
    {% render '_components.editor_preview', block: block, css: css_content, class: class, selector: selector, filename: 'snippets/_components.collapsible' %}

{%- comment -%} Auto Generated Variables start {%- endcomment -%}
{%- liquid
  assign block_type = "accordion"
  assign section_type = "global_design_elements"
  assign class = block.settings.class
  assign custom_css = block.settings.custom_css
  assign icon_style = block.settings.icon_style
  assign icon = block.settings.icon
  assign richtext_class = block.settings.richtext_class
  assign override_preview_background = block.settings.override_preview_background
-%}
{%- comment -%} Auto Generated Variables end {%- endcomment -%}

{%- liquid
  assign selector = '.' | append: class | replace: '\/', '/' | replace: '/', '\/'
%}

{%- capture css -%}
  & {
  position: relative;
  transition: all 150ms;
  --richtext-class: {{ richtext_class }};
  }

  {% case icon_style %}
    {% when "plus" %}
      & > summary [data-simple-icon] {
      display: none !important;
      }


    {% when "icon_plain" %}
      & > summary [data-animated-icon] {
      display: none !important;
      }
      & {
      --accordion-icon: var(--icon-{{ icon | handleize }});
      --accordion-icon-aspect-ratio: var(--icon-{{ icon | handleize }}-aspect-ratio);
      }

    {% when "icon_rotating" %}
      & > summary [data-animated-icon] {
      display: none !important;
      }
      & {
      --accordion-icon: var(--icon-{{ icon | handleize }});
      --accordion-icon-aspect-ratio: var(--icon-{{ icon | handleize }}-aspect-ratio);
      --accordion-icon-rotate: -180deg;
      }
    {% when "icon_rotating" %}
      & > summary [data-animated-icon] {
      display: none !important;
      }
      & {
      --accordion-icon: var(--icon-{{ icon | handleize }});
      --accordion-icon-aspect-ratio: var(--icon-{{ icon | handleize }}-aspect-ratio);
      --accordion-icon-rotate: -180deg;
      }
    {% when "none" %}
      & > summary [data-animated-icon] {
      display: none !important;
      }
      & > summary [data-simple-icon] {
      display: none !important;
      }
  {% endcase %}

{%- endcapture -%}

<style>
  {{ css | append: custom_css | replace: '&', selector | strip_newlines }}
  {% if request.design_mode %}
  {% assign query_selector = '[data-section-id="'|append: section.id | append: '"][data-preview-container] ' | append: selector %}
  {{- css | append: custom_css | replace: '&', query_selector  | strip_newlines | replace: '@media screen and', '@container'| replace: '@media', '@container' -}}
  {% endif %}
</style>


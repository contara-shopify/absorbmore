{% style %}
  /* Choose Supply */
  .bplp-choose-supply {
    margin-bottom: 15px;
  }

  ul.product-choose-supply-variants,
  ul.product-choose-supply-variants li {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
  }

  ul.product-choose-supply-variants {
    gap: 15px;
    width: 100%;
  }

  ul.product-choose-supply-variants li {
    flex-direction: column;
    gap: 5px;
    position: relative;
    width: calc(33.33% - 10px);
    background-color: #ffffff;
    border-radius: 8px;
    text-align: center;
  }

  ul.product-choose-supply-variants li div:first-child {
    justify-items: center;
  }

  ul.product-choose-supply-variants li label {
    display: block !important;
    padding: 15px;
    height: 100%;
    background-image: none !important;
    border: 1px solid transparent;
    border-radius: 8px;
  }

  ul.product-choose-supply-variants li img {
    margin: 0 auto;
  }

  ul.product-choose-supply-variants li h3,
  .richtext-md[data-content*="Subscribe & Save"] {
    font-weight: 500;
  }

  ul.product-choose-supply-variants li p.subheading,
  ul.product-choose-supply-variants li p.price-per-unit span.per-unit {
    font-size: 80%;
    color: #6a6a6a;
  }

  ul.product-choose-supply-variants li p.saved {
    margin-top: 15px;
  }

  ul.product-choose-supply-variants li p.price-per-unit span.price {
    font-weight: 500;
  }

  ul.product-choose-supply-variants li p.saved {
    font-size: 120%;
    color: #4659FF;
    font-weight: 500;
  }

  ul.product-choose-supply-variants li span.label-secondary {
    position: absolute;
    top: -12px;
    right: 0;
    left: 0;
    margin: 0 auto;
    max-width: 110px;
    height: 24px;
    background-color: #7d2b2d;
    color: #ffffff;
    text-transform: uppercase;
    line-height: 24px;
  }

  ul.product-choose-supply-variants li.active label,
  ul.product-choose-supply-variants li label:hover {
    border-color: #000000;
  }

  div[data-style-id*="main_product_subscribe_toggle_card"] {
    margin-top: 15px !important;
  }

  /* Choose Supploy Mobile */
  @media (max-width: 768px) {
    ul.product-choose-supply-variants li label {
      padding: 10px;
      width: 100%;
    }

    ul.product-choose-supply-variants li p.price-per-unit span.price,
    ul.product-choose-supply-variants li p.price-per-unit span.per-unit {
      font-size: 75%;
    }

    ul.product-choose-supply-variants li p.saved {
      margin-top: 5px;
      font-size: 100%;
    }
  }
{% endstyle %}

{% assign bplp_choose_supply_name = input_name | default: 'choose-supply' %}
<div class="bplp-choose-supply" data-bplp-choose-supply="{{ bplp_choose_supply_name }}">
  <fieldset class="relative w-full flex scrollbar-none" aria-labelledby="legend-choose-supply">
    <ul class="product-choose-supply-variants">
      {% assign current_value = product.selected_or_first_available_variant.id %}

      {% for variant in product.variants %}
        {% liquid
          assign _value = variant.title | handleize
          assign image = variant.image | image_url: width: 180, height: 180, crop: 'center' | escape
          assign primary_swatch = "--primary-swatch: url(" | append: image | append: ") center center/cover no-repeat"
          assign variant_bottles = variant.title | split: " " | first | times: 1
          assign skio_price = variant.metafields.custom.choose_supply_variant_price.value
          assign price_per_bottle = skio_price | divided_by: variant_bottles
        %}
        {% assign bplp_price_display = variant.price | money %}

        {% if skio_price < variant.price %}
          {% assign bplp_price_display = skio_price | money %}
        {% endif %}

        {% assign bplp_save_pct = '' %}
        
        {% if skio_price < variant.price %}
          {% assign bplp_save_pct = variant.price | minus: skio_price | times: 100 | divided_by: variant.price | round %}
        {% endif %}

        <li{% if variant.id == current_value %} class="active"{% endif %}>
          <label
          class="shrink-0 flex border-gray-300 cursor-pointer relative{% if variant.id == current_value %} active{% endif %}"
          aria-label="{{ variant.title }}"
          style="{{ primary_swatch }};background: var(--primary-swatch, var(--fallback-swatch, {{ _value }}))">
            <input
              type="radio"
              class="sr-only"
              name="{{ bplp_choose_supply_name }}"
              value="{{ variant.id }}"
              data-variant-id="{{ variant.id }}"
              data-price-formatted="{{ bplp_price_display | strip }}"
              data-price-display="{{ bplp_price_display | strip }}"
              data-price-orig-formatted="{{ variant.price | money }}"
              {% if bplp_save_pct %}data-save-pct="{{ bplp_save_pct }}"{% endif %}
              {% if variant.selling_plan_allocations.size > 0 %}data-selling-plan-id="{{ variant.selling_plan_allocations.first.selling_plan.id }}"{% endif %}
              {% if variant.id == current_value %}checked{% endif %}
            >
            
            <div>
              <img src="{{ variant.featured_image | image_url: width: 200, height: 200 }}" alt="{{ variant.title | escape }}" width="100" height="100">
            </div>
            <div>
              <h3 title="{{ variant.title | escape }}">{{ variant.title }}</h3>
              <p class="subheading">{{ variant.metafields.custom.choose_supply_variant_subheading }}</p>
              <p class="price" data-price="{{ variant.price }}" data-bottles="{{ variant_bottles }}" data-skio-price-per-bottle="{{ price_per_bottle }}" style="display: none;">
                <span class="price">{{ variant.price | money }}</span>

                {% if variant.compare_at_price > variant.price %}
                  <span class="compare-at-price line-through">{{ variant.compare_at_price | money }}</span>
                  <span class="saved">Save {{ variant.compare_at_price | minus: variant.price | money }}</span>
                {% endif %}

                {% if skio_price < variant.price %}
                  <span class="compare-at-price line-through">{{ skio_price | money }}</span>
                  <span class="saved">Save {{ skio_price | minus: variant.price | money }}</span>
                {% endif %}
              </p>

              {% if variant.compare_at_price > variant.price %}
                <p class="saved">
                  Save {{ variant.compare_at_price | minus: variant.price | money }}
                </p>
              {% endif %}

              {% if skio_price < variant.price %}
                <p class="saved" data-skio-price="{{ skio_price }}">
                  {{ variant.price | minus: skio_price | times: 100 | divided_by: variant.price | round }}% off
                </p>
              {% endif %}

              <p class="price-per-unit">
                <span class="price">{{ price_per_bottle | money }}</span><span class="per-unit">/bottle</span>
              </p>
            </div>

            {% unless variant.metafields.custom.choose_supply_variant_label == blank %}
              <span class="empty:hidden label-secondary">{{ variant.metafields.custom.choose_supply_variant_label }}</span>
            {% endunless %}
          </label>
        </li>
      {% endfor %}
    </ul>
  </fieldset>
</div>

<script type="text/javascript">
  /**
   * Variant selector (Choose Supply)
   */
  (function() {
    var wrap = document.querySelector('.shopify_block__pre_order');
    if (!wrap) return;

    wrap.addEventListener('change', function(e) {
      var radio = e.target;
      if (radio.type !== 'radio' || !radio.name || radio.name.indexOf('bplp-choose-supply') !== 0) return;
      if (!radio.checked) return;

      var variantId = radio.getAttribute('data-variant-id');
      if (!variantId) return;

      var card = radio.closest('.bplp-choose-supply');
      if (!card) return;

      var list = card.querySelector('ul.product-choose-supply-variants');
      if (list) {
        var prev = list.querySelector('li.active');
        if (prev) prev.classList.remove('active');
        radio.closest('li').classList.add('active');
      }

      var btn = card.parentElement.parentElement.querySelector('button[data-action="add_to_cart"][data-variant-id]');
      if (!btn) return;

      btn.setAttribute('data-variant-id', variantId);
      if (radio.getAttribute('data-selling-plan-id')) btn.setAttribute('data-selling-plan-id', radio.getAttribute('data-selling-plan-id'));
      if (!radio.getAttribute('data-selling-plan-id')) btn.removeAttribute('data-selling-plan-id');

      var priceFormatted = radio.getAttribute('data-price-formatted');
      if (priceFormatted) btn.textContent = 'Reserve Yours · ' + priceFormatted;

      var priceRow = card.querySelector('.bplp-price-row');
      if (priceRow) {
        var priceDisplay = radio.getAttribute('data-price-display');
        if (priceDisplay) priceRow.querySelector('.bplp-price').textContent = priceDisplay;
        var priceOrig = radio.getAttribute('data-price-orig-formatted');
        if (priceOrig) priceRow.querySelector('.bplp-price-orig').textContent = priceOrig;
        var savePct = radio.getAttribute('data-save-pct');
        var saveEl = priceRow.querySelector('.bplp-price-save');
        if (saveEl) saveEl.textContent = savePct ? 'Save ' + savePct + '%' : '';
      }
    });
  })();
</script>
        "card_T9bn4i": {
          "type": "card",
          "settings": {
            "category": "1",
            "image": "shopify://shop_images/image_733-1.jpg",
            "title": "Capsoil® Nanotechnology",
            "label": "Gentle Delivery",
            "content": "<p>Breaks the formula into nano-sized particles for maximum absorption without the GI distress. Standard berberine commonly causes cramping and nausea. Most customers on our formula report zero stomach issues.</p>"
          }
        },
        "card_Fg6ttg": {
          "type": "card",
          "settings": {
            "category": "2",
            "image": "shopify://shop_images/image_733-2.jpg",
            "title": "Chelamax® Magnesium Bisglycinate Chelate",
            "label": "Chelamax® Chelation",
            "content": "<p>Magnesium bound to glycine for maximum absorption and gut-friendliness. Sourced from Dead Sea mineral-rich waters not synthesized in industrial labs. Supports over 300 enzymatic reactions that influence energy, rest, muscle function, and nervous system balance.</p>"
          }
        },
        "card_yiNjdh": {
          "type": "card",
          "settings": {
            "category": "2",
            "image": "shopify://shop_images/image_733-3.jpg",
            "title": "Capsoil® Liposomal Delivery",
            "label": "Liposomal Technology",
            "content": "<p>A fat-based delivery system that helps magnesium cross the gut wall with far greater efficiency, achieving a record 64% absorption rate. Two of our capsules are equivalent to roughly 320mg of standard magnesium glycinate or 960mg of magnesium oxide.</p>"
          }
        }
      },

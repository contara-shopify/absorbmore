          "settings": {
            "category": "1",
            "image": "shopify://shop_images/image_733.jpg",
            "title": "Berberine HCl · 1000mg",
            "label": "FenuMat® Technology",
            "content": "<p>The active compound from Berberis plants, clinically studied for blood sugar regulation and AMPK activation. FenuMat® delivers 6.2× more free berberine than standard capsules meaning your body actually uses what you take. Standard berberine absorbs at just 5%. We fixed that.</p>"
          }

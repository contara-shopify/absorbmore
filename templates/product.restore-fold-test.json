              "settings": {
                "custom_liquid": "<style>\n/* Hide rows by data attribute. !important survives Alpine re-renders. */\nbody[data-restore-type=\"Bag\"]    [data-restore-row-type=\"Sticks\"] { display: none !important; }\nbody[data-restore-type=\"Sticks\"] [data-restore-row-type=\"Bag\"]    { display: none !important; }\n[data-restore-row-size=\"7 Servings\"] { display: none !important; }\n/* Previous dev added flexbox `order:` to shuffle plan rows — neutralize so DOM order wins */\n.product-choose-supply-variants > li,\n.product-choose-supply-variants li:first-child,\n.product-choose-supply-variants li:nth-child(2),\n.product-choose-supply-variants li:last-child {\n  order: 0 !important;\n}\n/* SAVE % badge → yellow */\n.product-choose-plan__badge {\n  background-color: #FFCC01 !important;\n  color: #111111 !important;\n}\n/* Secondary badge (\"MOST POPULAR\" / \"BEST VALUE\") → black */\n.restore-extra-badge {\n  display: inline-block;\n  margin-left: 6px;\n  padding: 2px 8px;\n  background-color: #000000;\n  color: #ffffff;\n  font-size: 10px;\n  font-weight: 700;\n  letter-spacing: 0.04em;\n  text-transform: uppercase;\n  border-radius: 4px;\n  vertical-align: middle;\n  line-height: 1.4;\n  white-space: nowrap;\n}\n/* Blue \"save $X.XX\" line below pricing */\n.restore-save-line {\n  color: #4659FF !important;\n  font-size: 13px;\n  font-weight: 600;\n  margin-top: 2px;\n  text-align: right;\n}\n/* Force-show the strike+total row even when Alpine wants to hide it */\n[data-restore-row-vid] .product-choose-plan__total-saved {\n  display: block !important;\n}\n/* Stack strikethrough on its own line above the total */\n[data-restore-row-vid] .restore-strike,\n[data-restore-row-vid] .restore-total-line {\n  display: block !important;\n  text-align: right;\n}\n[data-restore-row-vid] .restore-strike {\n  color: #6a6a6a;\n  text-decoration: line-through;\n}\n/* 2-line subtitle */\n[data-restore-row-vid] .restore-perks-line1,\n[data-restore-row-vid] .restore-perks-line2 {\n  display: block;\n}\n[data-restore-row-vid] .restore-perks-line2 {\n  margin-top: 2px;\n  opacity: 0.85;\n}\n/* Hide the bogus \"100% off\" line */\n[data-restore-row-vid] .product-choose-plan__pricing > p.saved {\n  display: none !important;\n}\n/* Type selector label */\n.restore-type-label {\n  font-size: 12px;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  color: #6a6a6a;\n  margin-bottom: 8px;\n}\n</style>\n<script>\n(function(){\n  var byId = null, typeValues = {}, sizeIdx = -1, typeIdx = -1;\n\n  function loadProduct(){\n    var m = window.location.pathname.match(/\\/products\\/([^\\/?#]+)/);\n    return fetch('/products/' + m[1] + '.js', {credentials:'same-origin'}).then(function(r){return r.json();});\n  }\n\n  function build(product){\n    var opts = (product.options || []).map(function(o){ return (typeof o === 'string' ? o : o.name) || ''; });\n    opts.forEach(function(n,i){\n      var ln = n.toLowerCase();\n      if (ln === 'type') typeIdx = i;\n      if (ln === 'size') sizeIdx = i;\n    });\n    if (typeIdx < 0) return false;\n    byId = {};\n    variantOrder = [];\n    (product.variants || []).forEach(function(v){\n      var keys = ['option1','option2','option3'];\n      var t = v[keys[typeIdx]];\n      var s = sizeIdx >= 0 ? v[keys[sizeIdx]] : '';\n      byId[String(v.id)] = { type: t, size: s, price: v.price };\n      typeValues[t] = true;\n      variantOrder.push(String(v.id));\n    });\n    return true;\n  }\n\n  var variantOrder = [];\n  var sortedLists = new WeakSet();\n  var mo = null;\n\n  // Per-row data. Keyed by \"Type|Size\" so it survives variant-id changes.\n  // months drives /mo math (Sticks/14 = 0.5 mo cadence).\n  var ROW_DATA = {\n    'Bag|28 Servings':    { title: '1 Month',  pct: 25, months: 1,   sub1: 'A 1-month/28 serving supply with 1 bag delivered every 1 month',    sub2: 'Free shipping + free gifts ($70 value). Pause or cancel anytime.' },\n    'Bag|56 Servings':    { title: '2 Months', pct: 30, months: 2,   sub1: 'A 2-month/56 serving supply with 2 bags delivered every 2 months',  sub2: 'Free shipping + free gifts ($70 value). Pause or cancel anytime.', extra: 'MOST POPULAR' },\n    'Bag|84 Servings':    { title: '3 Months', pct: 35, months: 3,   sub1: 'A 3-month/84 serving supply with 3 bags delivered every 3 months',  sub2: 'Free shipping + free gifts ($70 value). Pause or cancel anytime.', extra: 'BEST VALUE' },\n    'Sticks|14 Servings': { title: '2 Weeks',  pct: 25, months: 0.5, sub1: 'A 2-week/14 stick supply with 14 sticks delivered every 2 weeks',   sub2: 'Free shipping. Pause or cancel anytime.' },\n    'Sticks|28 Servings': { title: '1 Month',  pct: 25, months: 1,   sub1: 'A 1-month/28 stick supply with 28 sticks delivered every 1 month',  sub2: 'Free shipping + free gifts ($70 value). Pause or cancel anytime.' },\n    'Sticks|56 Servings': { title: '2 Months', pct: 30, months: 2,   sub1: 'A 2-month/56 stick supply with 56 sticks delivered every 2 months', sub2: 'Free shipping + free gifts ($70 value). Pause or cancel anytime.', extra: 'MOST POPULAR' },\n    'Sticks|84 Servings': { title: '3 Months', pct: 35, months: 3,   sub1: 'A 3-month/84 stick supply with 84 sticks delivered every 3 months', sub2: 'Free shipping + free gifts ($70 value). Pause or cancel anytime.', extra: 'BEST VALUE' }\n  };\n\n  function money(cents){\n    return '$' + (cents / 100).toFixed(2);\n  }\n\n  function updateBadges(){\n    document.querySelectorAll('[data-restore-row-vid]').forEach(function(row){\n      var t = row.getAttribute('data-restore-row-type');\n      var s = row.getAttribute('data-restore-row-size');\n      var key = t + '|' + s;\n      var data = ROW_DATA[key];\n      if (!data) return;\n\n      // 1) SAVE % badge\n      var badge = row.querySelector('.product-choose-plan__badge');\n      if (badge){\n        var want = 'Save ' + data.pct + '%';\n        if (badge.textContent.trim() !== want) badge.textContent = want;\n        // 2) MOST POPULAR / BEST VALUE\n        if (data.extra){\n          var existing = row.querySelector('.restore-extra-badge');\n          if (!existing){\n            var el = document.createElement('span');\n            el.className = 'restore-extra-badge';\n            el.textContent = data.extra;\n            badge.parentNode.insertBefore(el, badge.nextSibling);\n          } else if (existing.textContent.trim() !== data.extra){\n            existing.textContent = data.extra;\n          }\n        }\n      }\n\n      // 3) Title\n      if (data.title){\n        var titleEl = row.querySelector('.product-choose-plan__title');\n        if (titleEl && titleEl.textContent.trim() !== data.title){\n          titleEl.textContent = data.title;\n          titleEl.setAttribute('title', data.title);\n        }\n      }\n\n      // 4) Subtitle (perks line) — 2-line format\n      if (data.sub1){\n        var perksEl = row.querySelector('.product-choose-plan__perks');\n        if (perksEl){\n          var newPerksHtml = '<span class=\"restore-perks-line1\">' + data.sub1 + '</span><span class=\"restore-perks-line2\">' + (data.sub2 || '') + '</span>';\n          if (perksEl.innerHTML.replace(/\\s+/g,'') !== newPerksHtml.replace(/\\s+/g,'')){\n            perksEl.innerHTML = newPerksHtml;\n          }\n        }\n      }\n\n      // 5) Pricing column — subscription math\n      var vid = row.getAttribute('data-restore-row-vid');\n      var info = byId && byId[vid];\n      if (!info || typeof info.price !== 'number') return;\n      var fullCents = info.price;\n      var subCents = Math.round(fullCents * (100 - data.pct) / 100);\n      var perMoCents = Math.round(subCents / data.months);\n      var saveCents = fullCents - subCents;\n\n      // 5a) Strip Alpine x-text and set price-main\n      var priceMain = row.querySelector('.product-choose-plan__price-main');\n      if (priceMain){\n        if (priceMain.hasAttribute('x-text')) priceMain.removeAttribute('x-text');\n        var newPrice = money(perMoCents) + '/mo';\n        if (priceMain.textContent.trim() !== newPrice) priceMain.textContent = newPrice;\n      }\n\n      // 5b) Strike + total. Strip Alpine x-show, then rewrite inner spans.\n      var totalSaved = row.querySelector('.product-choose-plan__total-saved');\n      if (totalSaved){\n        if (totalSaved.hasAttribute('x-show')) totalSaved.removeAttribute('x-show');\n        var val = totalSaved.querySelector('.product-choose-plan__total-savings-value');\n        var newHtml = '<span class=\"strike-through restore-strike\">' + money(fullCents) + '</span><span class=\"restore-total-line\">' + money(subCents) + ' total</span>';\n        if (val && val.innerHTML.replace(/\\s+/g,'') !== newHtml.replace(/\\s+/g,'')){\n          val.innerHTML = newHtml;\n        }\n      }\n\n      // 5c) Hide the bogus \"100% off\" .saved line (also covered by CSS, belt + braces)\n      var savedLine = row.querySelector('.product-choose-plan__pricing > p.saved');\n      if (savedLine && savedLine.hasAttribute('x-show')) savedLine.removeAttribute('x-show');\n\n      // 5d) Blue \"save $X.XX\" line\n      var pricing = row.querySelector('.product-choose-plan__pricing');\n      if (pricing){\n        var saveEl = pricing.querySelector('.restore-save-line');\n        if (!saveEl){\n          saveEl = document.createElement('p');\n          saveEl.className = 'restore-save-line';\n          pricing.appendChild(saveEl);\n        }\n        var saveText = 'save ' + money(saveCents);\n        if (saveEl.textContent.trim() !== saveText) saveEl.textContent = saveText;\n      }\n    });\n  }\n\n  function tagRows(){\n    if (!byId) return false;\n    var changed = false;\n    document.querySelectorAll('input[type=radio]').forEach(function(inp){\n      var info = byId[String(inp.value)];\n      if (!info) return;\n      var row = inp.closest('li') || inp.closest('label') || inp.parentElement;\n      if (row && !row.hasAttribute('data-restore-row-type')){\n        row.setAttribute('data-restore-row-type', info.type);\n        row.setAttribute('data-restore-row-size', info.size || '');\n        row.setAttribute('data-restore-row-vid', String(inp.value));\n        changed = true;\n      }\n    });\n    updateBadges();\n    return changed;\n  }\n\n  function sortLists(){\n    if (!byId) return;\n    var uls = new Set();\n    document.querySelectorAll('[data-restore-row-vid]').forEach(function(row){\n      if (row.parentElement && row.parentElement.tagName === 'UL') uls.add(row.parentElement);\n    });\n    uls.forEach(function(ul){\n      if (sortedLists.has(ul)) return;\n      var rows = Array.prototype.slice.call(ul.children).filter(function(c){\n        return c.hasAttribute && c.hasAttribute('data-restore-row-vid');\n      });\n      if (!rows.length) return;\n      rows.sort(function(a, b){\n        var ai = variantOrder.indexOf(a.getAttribute('data-restore-row-vid'));\n        var bi = variantOrder.indexOf(b.getAttribute('data-restore-row-vid'));\n        if (ai < 0) ai = 999;\n        if (bi < 0) bi = 999;\n        return ai - bi;\n      });\n      // Detach observer during reorder to avoid loops\n      if (mo) mo.disconnect();\n      rows.forEach(function(r){ ul.appendChild(r); });\n      sortedLists.add(ul);\n      if (mo) mo.observe(document.body, { childList: true, subtree: true });\n    });\n  }\n\n  function setBodyType(t){\n    if (!t) return;\n    document.body.setAttribute('data-restore-type', t);\n    // If the currently-selected variant row is now hidden, click first visible one\n    var visibleInputs = Array.prototype.slice.call(document.querySelectorAll('input[type=radio]'))\n      .filter(function(inp){\n        var info = byId[String(inp.value)];\n        if (!info) return false;\n        return info.type === t && info.size !== '7 Servings';\n      });\n    var anyChecked = visibleInputs.some(function(inp){ return inp.checked; });\n    if (!anyChecked && visibleInputs[0]){\n      visibleInputs[0].checked = true;\n      visibleInputs[0].dispatchEvent(new Event('change', { bubbles: true }));\n      visibleInputs[0].click();\n    }\n  }\n\n  function detectAndApply(){\n    tagRows();\n    sortLists();\n    // Find currently checked Type-value radio\n    var radios = document.querySelectorAll('input[type=radio]');\n    for (var i=0;i<radios.length;i++){\n      if (typeValues[radios[i].value] && radios[i].checked){\n        setBodyType(radios[i].value);\n        return;\n      }\n    }\n    // Fallback: look at label with class 'active' near a Bag/Sticks input\n    var labels = document.querySelectorAll('label[aria-label=\"Bag\"], label[aria-label=\"Sticks\"]');\n    for (var j=0;j<labels.length;j++){\n      if (labels[j].classList.contains('active')){\n        setBodyType(labels[j].getAttribute('aria-label'));\n        return;\n      }\n    }\n    // Default\n    setBodyType('Bag');\n  }\n\n  function moveTypeSelector(){\n    var typeFieldset = document.querySelector('fieldset[aria-labelledby*=\"option_radio_Dhpq4V\"]');\n    if (!typeFieldset) return;\n    var form = typeFieldset.closest('form.shopify-product-form');\n    if (!form) return;\n    // Find the flex container that is the direct child of form and contains the type fieldset\n    var flexContainer = null;\n    Array.prototype.slice.call(form.children).forEach(function(c){\n      if (c.contains(typeFieldset) && getComputedStyle(c).display === 'flex') flexContainer = c;\n    });\n    if (!flexContainer) return;\n    var typeWrap = typeFieldset;\n    while (typeWrap && typeWrap.parentElement !== flexContainer) typeWrap = typeWrap.parentElement;\n    if (!typeWrap) return;\n    var planFieldset = flexContainer.querySelector('fieldset[aria-labelledby*=\"choose_plan_HcYtEL\"]');\n    if (!planFieldset) return;\n    var planWrap = planFieldset;\n    while (planWrap && planWrap.parentElement !== flexContainer) planWrap = planWrap.parentElement;\n    if (!planWrap) return;\n    if (!typeWrap.querySelector('.restore-type-label')){\n      var lbl = document.createElement('div');\n      lbl.className = 'restore-type-label';\n      lbl.textContent = 'Choose your format';\n      typeWrap.insertBefore(lbl, typeWrap.firstChild);\n    }\n    if (typeWrap.nextElementSibling !== planWrap){\n      flexContainer.insertBefore(typeWrap, planWrap);\n    }\n  }\n\n  function attach(){\n    // Click delegation: when user clicks Bag/Sticks label\n    document.addEventListener('click', function(e){\n      var label = e.target.closest && e.target.closest('label[aria-label=\"Bag\"], label[aria-label=\"Sticks\"]');\n      if (label){\n        setBodyType(label.getAttribute('aria-label'));\n        setTimeout(detectAndApply, 50);\n        setTimeout(detectAndApply, 250);\n      }\n    }, true);\n    document.addEventListener('change', function(e){\n      var el = e.target;\n      if (el && el.tagName === 'INPUT' && el.type === 'radio'){\n        if (typeValues[el.value]) setBodyType(el.value);\n        setTimeout(detectAndApply, 30);\n      }\n    }, true);\n    // Mutation observer: only re-tag (cheap), never auto-reorder\n    var pending = false;\n    mo = new MutationObserver(function(){\n      if (pending) return;\n      pending = true;\n      requestAnimationFrame(function(){\n        pending = false;\n        var newTags = tagRows();\n        if (newTags) sortLists();\n      });\n    });\n    mo.observe(document.body, { childList: true, subtree: true });\n    [0, 150, 500, 1200, 3000].forEach(function(d){\n      setTimeout(detectAndApply, d);\n      setTimeout(moveTypeSelector, d);\n    });\n  }\n\n  loadProduct().then(function(p){\n    if (build(p)){\n      window.__restoreVariantMap = byId;\n      attach();\n    }\n  }).catch(function(err){ console && console.warn && console.warn('[restore filter]', err); });\n})();\n</script>",

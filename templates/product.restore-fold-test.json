            "custom_liquid_KzXWCK": {
              "type": "custom_liquid",
              "name": "Custom Liquid Code",
              "disabled": true,
              "settings": {
                "custom_liquid": "{%- liquid\n  assign percent = 98\n  assign urgency_label = 'Selling fast'\n  assign units_display = ''\n  assign fill_color = '#cf3a60'\n  assign empty_color = '#EAE6DC'\n  assign filled = percent | divided_by: 10\n-%}\n\n<div class=\"scarcity-bar\">\n  <div class=\"scarcity-bar__header\">\n    <div class=\"scarcity-bar__label\">\n      <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"{{ fill_color }}\" aria-hidden=\"true\">\n        <path d=\"M13 2L4.5 13.5h6L9 22l8.5-11.5h-6L13 2z\"/>\n      </svg>\n      <span>{{ urgency_label }} · {{ percent }}% sold</span>\n    </div>\n    {% if units_display != blank %}\n      <span class=\"scarcity-bar__time\">{{ units_display }}</span>\n    {% endif %}\n  </div>\n <div class=\"scarcity-bar__track\" role=\"progressbar\" aria-valuenow=\"{{ percent }}\" aria-valuemin=\"0\" aria-valuemax=\"100\" aria-label=\"{{ urgency_label }} {{ percent }}% sold\">\n    {% for i in (1..10) %}\n      {% assign next_segment_index = filled | plus: 1 %}\n      {% if forloop.index <= filled %}\n        <div class=\"scarcity-bar__segment\" style=\"background: {{ fill_color }};\"></div>\n      {% elsif forloop.index == next_segment_index %}\n        <div class=\"scarcity-bar__segment scarcity-bar__segment--pulsing\" style=\"--pulse-color: {{ fill_color }}; --empty-color: {{ empty_color }};\"></div>\n      {% else %}\n        <div class=\"scarcity-bar__segment\" style=\"background: {{ empty_color }};\"></div>\n      {% endif %}\n    {% endfor %}\n  </div>\n</div>\n\n<style>\n  .scarcity-bar { border-radius: 8px; padding: 12px 14px; border: 1px solid #EAE6DC; background: #f7f5f1; margin-top: 16px; margin-bottom: 16px; }\n  .scarcity-bar__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; gap: 8px; flex-wrap: wrap; }\n  .scarcity-bar__label { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 500; color: #1A1A18; }\n  .scarcity-bar__time { font-size: 12px; color: #6a6a6a; white-space: nowrap; }\n  .scarcity-bar__track { display: flex; gap: 2px; }\n  .scarcity-bar__segment { flex: 1; height: 5px; border-radius: 2px; transition: background-color 300ms ease; }\n  .scarcity-bar__segment--pulsing {\n    background: var(--empty-color);\n    position: relative;\n    overflow: hidden;\n  }\n  .scarcity-bar__segment--pulsing::after {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    bottom: 0;\n    width: 40%;\n    background: var(--pulse-color);\n    border-radius: 2px;\n    animation: scarcity-pulse 1.6s ease-in-out infinite;\n  }\n  @keyframes scarcity-pulse {\n    0%   { opacity: 0.3; width: 20%; }\n    50%  { opacity: 1;   width: 60%; }\n    100% { opacity: 0.3; width: 20%; }\n  }\n</style>",
                "custom_css": ""
              },
              "blocks": {}
            },

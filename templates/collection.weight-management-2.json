              "blocks": {
                "richtext_trMLKy": {
                  "type": "richtext",
                  "name": "Richtext",
                  "settings": {
                    "title": "<h2><strong>FAQs.</strong></h2>",
                    "text_alignment": "inherit",
                    "content_class": "richtext-md h1",
                    "text_color": "",

  {%- comment -%} Sticky mobile CTA bar (appears after hero scrolls out) {%- endcomment -%}
  <div class="sticky-cta" id="wlp1ev-sticky">
    <a href="#buy-box" class="sticky-cta-btn">Shop WLP-1™ · $64/mo →</a>
  </div>
</div>

<script>
  (function () {
    // FAQ accordion
    var faqItems = document.querySelectorAll('.wlp1ev .faq-q');
    for (var i = 0; i < faqItems.length; i++) {
      faqItems[i].addEventListener('click', function () {
        this.parentElement.classList.toggle('open');
      });
    }

    // Sticky mobile CTA — show after hero leaves view
    var stickyEl = document.getElementById('wlp1ev-sticky');
    var heroEl = document.querySelector('.wlp1ev .hero');
    if (stickyEl && heroEl) {
      var ticking = false;
      function updateSticky() {
        var heroBottom = heroEl.getBoundingClientRect().bottom;
        if (heroBottom < 0) {
          stickyEl.classList.add('visible');
        } else {
          stickyEl.classList.remove('visible');
        }
        ticking = false;
      }
      window.addEventListener(
        'scroll',
        function () {
          if (!ticking) {
            window.requestAnimationFrame(updateSticky);
            ticking = true;
          }
        },
        { passive: true }
      );
    }

    // Smooth scroll for #buy-box anchors
    var anchorLinks = document.querySelectorAll('.wlp1ev a[href="#buy-box"]');
    for (var j = 0; j < anchorLinks.length; j++) {
      anchorLinks[j].addEventListener('click', function (e) {
        var target = document.getElementById('buy-box');
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    // Buy box tier selection
    var tiers = document.querySelectorAll('.wlp1ev .tier');
    for (var k = 0; k < tiers.length; k++) {
      tiers[k].addEventListener('click', function () {
        for (var m = 0; m < tiers.length; m++) {
          tiers[m].classList.remove('selected');
        }
        this.classList.add('selected');
      });
    }

    // Add to cart
    var addBtn = document.getElementById('wlp1ev-add-to-cart');
    if (addBtn) {
      addBtn.addEventListener('click', function (e) {
        e.preventDefault();
        var selectedTier = document.querySelector('.wlp1ev .tier.selected');
        if (!selectedTier) return;

        var variantId = selectedTier.getAttribute('data-variant-id');
        var sellingPlanId = selectedTier.getAttribute('data-selling-plan-id');

        var payload = {
          items: [{ id: parseInt(variantId, 10), quantity: 1 }],
        };
        if (sellingPlanId) {
          payload.items[0].selling_plan = parseInt(sellingPlanId, 10);
        }

        var originalText = addBtn.textContent;
        addBtn.disabled = true;
        addBtn.textContent = 'Adding...';

        fetch('/cart/add.js', {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify(payload),
        })
          .then(function (res) {
            if (!res.ok) throw new Error('Cart add failed');
            return res.json();
          })
          .then(function () {
            window.location.href = '/cart';
          })
          .catch(function (err) {
            console.error('Cart add failed:', err);
            addBtn.disabled = false;
            addBtn.textContent = originalText;
            alert('Sorry, there was an error adding to cart. Please try again.');
          });
      });
    }
  })();
</script>

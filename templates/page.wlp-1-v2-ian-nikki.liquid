{% layout 'theme' %}

{%- comment -%}
  WLP-1 Founder Story Landing Page
  Template: page.wlp1-founder.liquid
  Variant of evergreen v2, anchored on Ian Somerhalder + Nikki Reed
  Driven by paid ads using "Nature's Ozempic" angle (compliant on-site)
{%- endcomment -%}

<style>
    /* Hide theme header/footer + reset body */
    body {
      margin: 0;
      padding: 0;
    }
    header,
    footer {
      display: none;
    }

    .wlp1ev {
      --blue: #5e91d5;
      --blue-hover: #4a7dbe;
      --cream: #f8f5f2;
      --cream-alt: #eae6dc;
      --ink: #1a1a18;
      --ink-soft: #4a4a46;
      --line: #d9d4c8;
      --white: #ffffff;

      color: var(--ink);
      background: var(--cream);
      font-family: inherit;
      line-height: 1.5;
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
    }

    .wlp1ev *,
    .wlp1ev *::before,
    .wlp1ev *::after {
      box-sizing: border-box;
    }

    .wlp1ev img {
      max-width: 100%;
      display: block;
    }

    .wlp1ev .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .wlp1ev .container-narrow {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ===== Inline CTA (between sections) ===== */
    .wlp1ev .inline-cta {
      text-align: center;
      padding: 60px 0 20px;
    }
    .wlp1ev .inline-cta-micro {
      font-size: 12px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--blue);
      font-weight: 600;
      margin-bottom: 14px;
    }
    .wlp1ev .inline-cta-title {
      font-size: clamp(22px, 2.4vw, 28px);
      font-weight: 500;
      letter-spacing: -0.01em;
      margin: 0 0 24px;
      color: var(--ink);
      line-height: 1.25;
      font-style: italic;
    }
    .wlp1ev .inline-cta-btn {
      display: inline-block;
      background: var(--blue);
      color: var(--white);
      border: none;
      padding: 16px 44px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s;
      text-decoration: none;
      font-family: inherit;
    }
    .wlp1ev .inline-cta-btn:hover {
      background: var(--blue-hover);
      color: var(--white);
    }
    .wlp1ev .inline-cta-sub {
      margin-top: 14px;
      font-size: 12px;
      color: var(--ink-soft);
      letter-spacing: 0.05em;
    }

    /* ===== Micro-CTA (inside benefit rows / included section) ===== */
    .wlp1ev .micro-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 22px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--blue);
      text-decoration: none;
      padding-bottom: 4px;
      border-bottom: 1px solid var(--blue);
      transition: gap 0.2s, color 0.2s, border-color 0.2s;
      font-family: inherit;
    }
    .wlp1ev .micro-cta:hover {
      color: var(--blue-hover);
      border-color: var(--blue-hover);
      gap: 12px;
    }
    .wlp1ev .micro-cta::after {
      content: '→';
      font-weight: 400;
      font-size: 15px;
      line-height: 1;
    }

    /* ===== Announcement bar ===== */
    .wlp1ev .announce {
      background: var(--ink);
      color: var(--cream);
      padding: 11px 0;
      font-size: 13px;
      letter-spacing: 0.02em;
      overflow: hidden;
      white-space: nowrap;
    }
    .wlp1ev .announce-track {
      display: inline-flex;
      align-items: center;
      gap: 36px;
      padding-left: 36px;
      animation: wlp1ev-announce-scroll 120s linear infinite;
      will-change: transform;
    }
    .wlp1ev .announce-item {
      display: inline-block;
      font-weight: 500;
    }
    .wlp1ev .announce-dot {
      color: var(--blue);
      font-size: 9px;
      opacity: 0.8;
    }
    @keyframes wlp1ev-announce-scroll {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-50%);
      }
    }
    .wlp1ev .announce:hover .announce-track {
      animation-play-state: paused;
    }

    /* ===== Buy Box ===== */
  .wlp1ev .buybox {
    background: var(--cream-alt);
    padding: 100px 0;
    scroll-margin-top: 20px;
  }
  .wlp1ev .buybox-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 60px;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
  }
  .wlp1ev .buybox-image {
    background: var(--white);
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
  }
  .wlp1ev .buybox-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .wlp1ev .buybox-image-tag {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--ink);
    color: var(--cream);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 4px;
  }
  .wlp1ev .buybox-title {
    font-size: clamp(36px, 4.5vw, 56px);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
    color: var(--ink);
  }
  .wlp1ev .buybox-title em {
    color: var(--blue);
    font-style: normal;
  }
  .wlp1ev .buybox-sub {
    font-size: 16px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0 0 28px;
    max-width: 520px;
  }
  .wlp1ev .buybox-tiers {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }
  .wlp1ev .tier {
    background: var(--white);
    border: 2px solid var(--white);
    border-radius: 8px;
    padding: 22px 24px;
    cursor: pointer;
    position: relative;
    transition: border-color 0.2s, background 0.2s;
    display: grid;
    grid-template-columns: 24px 1fr auto;
    gap: 16px;
    align-items: start;
  }
  .wlp1ev .tier:hover {
    border-color: var(--blue);
  }
  .wlp1ev .tier.selected {
    border-color: var(--blue);
    background: var(--cream-alt);
  }
  .wlp1ev .tier-radio {
    width: 22px;
    height: 22px;
    border: 2px solid #c8c2b4;
    border-radius: 50%;
    background: var(--white);
    position: relative;
    flex-shrink: 0;
    transition: border-color 0.2s;
    margin-top: 2px;
  }
  .wlp1ev .tier.selected .tier-radio {
    border-color: var(--blue);
  }
  .wlp1ev .tier.selected .tier-radio::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 12px;
    height: 12px;
    background: var(--blue);
    border-radius: 50%;
  }
  .wlp1ev .tier-info {
    min-width: 0;
  }
  .wlp1ev .tier-header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 6px;
  }
  .wlp1ev .tier-name {
    font-size: 19px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .wlp1ev .tier-save {
    background: var(--ink);
    color: var(--cream);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 9px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .wlp1ev .tier-pill {
    background: var(--blue);
    color: var(--white);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .wlp1ev .tier-desc {
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.45;
    margin-bottom: 6px;
  }
  .wlp1ev .tier-meta {
    font-size: 13px;
    color: var(--ink-soft);
    letter-spacing: 0.01em;
  }
  .wlp1ev .tier-price {
    text-align: right;
    white-space: nowrap;
  }
  .wlp1ev .tier-price-now {
    font-size: 26px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.02em;
    display: block;
    line-height: 1;
    margin-bottom: 6px;
  }
  .wlp1ev .tier-price-now span {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-soft);
  }
  .wlp1ev .tier-price-line {
    font-size: 13px;
    color: var(--ink-soft);
    margin-bottom: 4px;
  }
  .wlp1ev .tier-price-line s {
    color: var(--ink-soft);
    margin-right: 4px;
  }
  .wlp1ev .tier-savings {
    font-size: 13px;
    color: var(--blue);
    font-weight: 500;
  }
  .wlp1ev .buybox-cta {
    display: block;
    width: 100%;
    background: var(--blue);
    color: var(--white);
    border: none;
    padding: 22px 24px;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background 0.2s;
    text-align: center;
    font-family: inherit;
    border-radius: 8px;
  }
  .wlp1ev .buybox-cta:hover {
    background: var(--blue-hover);
  }
  .wlp1ev .buybox-cta:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* ===== Logo bar ===== */
    .wlp1ev .logobar {
      background: var(--cream);
      border-bottom: 1px solid var(--line);
      padding: 20px 0;
    }
    .wlp1ev .logobar-inner {
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .wlp1ev .logobar-logo {
      display: inline-flex;
      align-items: center;
    }
    .wlp1ev .logobar-logo img {
      height: 28px;
      width: auto;
      display: block;
    }
    .wlp1ev .logobar-cta {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
      padding: 10px 20px;
      border: 1px solid var(--ink);
      transition: background 0.2s, color 0.2s;
      white-space: nowrap;
      font-family: inherit;
    }
    .wlp1ev .logobar-cta:hover {
      background: var(--ink);
      color: var(--cream);
    }

    @media (max-width: 520px) {
      .wlp1ev .logobar {
        padding: 14px 0;
      }
      .wlp1ev .logobar-logo img {
        height: 22px;
      }
      .wlp1ev .logobar-cta {
        font-size: 11px;
        padding: 8px 14px;
        letter-spacing: 0.12em;
      }
    }

    /* ===== 1. HERO ===== */
    .wlp1ev .hero {
      padding: 60px 0 40px;
      background: var(--cream);
    }
    .wlp1ev .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }
    .wlp1ev .hero-image {
      aspect-ratio: 1 / 1;
      background: var(--cream-alt);
      border-radius: 4px;
      position: relative;
      overflow: visible;
    }
    .wlp1ev .hero-image-main {
      width: 100%;
      height: 100%;
      border-radius: 4px;
      overflow: hidden;
      background: var(--cream-alt);
    }
    .wlp1ev .hero-image-main img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .wlp1ev .hero-image-bottle {
      position: absolute;
      bottom: -20px;
      left: -20px;
      width: 42%;
      aspect-ratio: 1 / 1;
      background: var(--cream-alt);
      border: 6px solid var(--cream);
      border-radius: 4px;
      overflow: hidden;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    }
    .wlp1ev .hero-image-bottle img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .wlp1ev .eyebrow {
      font-size: 12px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--blue);
      font-weight: 600;
      margin-bottom: 20px;
    }
    .wlp1ev h1 {
      font-size: clamp(40px, 5vw, 64px);
      line-height: 1.05;
      font-weight: 500;
      letter-spacing: -0.02em;
      margin: 0 0 20px;
      color: var(--ink);
    }
    .wlp1ev h1 em {
      font-style: italic;
      color: var(--blue);
    }
    .wlp1ev .hero-sub {
      font-size: 20px;
      line-height: 1.5;
      color: var(--ink-soft);
      margin: 0 0 24px;
      max-width: 520px;
    }
    .wlp1ev .hero-bullets {
      list-style: none;
      padding: 0;
      margin: 0 0 30px;
      max-width: 520px;
    }
    .wlp1ev .hero-bullets li {
      position: relative;
      padding: 8px 0 8px 28px;
      font-size: 15px;
      color: var(--ink);
      line-height: 1.45;
      border-bottom: 1px solid var(--line);
    }
    .wlp1ev .hero-bullets li:first-child {
      border-top: 1px solid var(--line);
    }
    .wlp1ev .hero-bullets li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 15px;
      width: 14px;
      height: 14px;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 14 14' fill='none'><path d='M2 7.5L5.5 11L12 3' stroke='%235e91d5' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/></svg>");
      background-repeat: no-repeat;
    }
    .wlp1ev .hero-price-anchor {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 12px 14px;
      margin: 0 0 24px;
      font-size: 14px;
      color: var(--ink);
    }
    .wlp1ev .anchor-strike {
      font-size: 18px;
      color: var(--ink-soft);
      text-decoration: line-through;
      font-weight: 500;
    }
    .wlp1ev .anchor-now {
      font-size: 14px;
      color: var(--ink);
    }
    .wlp1ev .anchor-now strong {
      font-size: 22px;
      color: var(--blue);
      font-weight: 700;
      letter-spacing: -0.01em;
      margin: 0 1px;
    }
    .wlp1ev .anchor-label {
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--blue);
      font-weight: 600;
      padding: 4px 10px;
      border: 1px solid var(--blue);
      border-radius: 100px;
    }
    .wlp1ev .hero-cta {
      display: inline-block;
      background: var(--blue);
      color: var(--white);
      border: none;
      padding: 18px 48px;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s;
      margin-bottom: 4px;
      text-decoration: none;
      font-family: inherit;
    }
    .wlp1ev .hero-cta:hover {
      background: var(--blue-hover);
      color: var(--white);
    }
    .wlp1ev .hero-stars {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 20px 0 16px;
      font-size: 14px;
      color: var(--ink-soft);
    }
    .wlp1ev .stars {
      color: var(--blue);
      letter-spacing: 2px;
      font-size: 18px;
    }
    .wlp1ev .hero-micro {
      font-size: 13px;
      color: var(--ink-soft);
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
    }
    .wlp1ev .hero-micro span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .wlp1ev .hero-micro span::before {
      content: '✓';
      color: var(--blue);
      font-weight: 700;
    }

    /* ===== Section base ===== */
    .wlp1ev .section {
      padding: 100px 0;
    }
    .wlp1ev .section-label {
      font-size: 12px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--blue);
      font-weight: 600;
      margin-bottom: 14px;
      text-align: center;
    }
    .wlp1ev .section-title {
      font-size: clamp(32px, 4vw, 48px);
      line-height: 1.1;
      font-weight: 500;
      letter-spacing: -0.02em;
      text-align: center;
      margin: 0 0 16px;
      color: var(--ink);
    }
    .wlp1ev .section-intro {
      font-size: 19px;
      line-height: 1.6;
      color: var(--ink-soft);
      text-align: center;
      max-width: 620px;
      margin: 0 auto 60px;
    }

    /* ===== FOUNDER'S NOTE ===== */
    .wlp1ev .founder-section {
      background: var(--cream-alt);
      padding: 100px 0;
    }
    .wlp1ev .founder-grid {
      display: grid;
      grid-template-columns: 0.85fr 1fr;
      gap: 70px;
      align-items: center;
    }
    .wlp1ev .founder-image {
      aspect-ratio: 4 / 5;
      background: var(--cream);
      border-radius: 4px;
      overflow: hidden;
    }
    .wlp1ev .founder-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .wlp1ev .founder-copy .eyebrow {
      margin-bottom: 24px;
    }
    .wlp1ev .founder-title {
      font-size: clamp(28px, 3.4vw, 42px);
      line-height: 1.2;
      font-weight: 500;
      letter-spacing: -0.02em;
      margin: 0 0 28px;
      color: var(--ink);
      font-style: italic;
    }
    .wlp1ev .founder-body {
      font-size: 17px;
      color: var(--ink-soft);
      line-height: 1.7;
      margin: 0 0 18px;
    }
    .wlp1ev .founder-signature {
      margin-top: 32px;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--ink);
      padding-top: 24px;
      border-top: 1px solid var(--line);
    }
    .wlp1ev .founder-signature span {
      display: block;
      margin-top: 4px;
      font-weight: 400;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-soft);
    }

    /* ===== TRANSFORMATION ===== */
    .wlp1ev .transformation {
      background: var(--white);
    }
    .wlp1ev .transform-steps {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 40px;
      position: relative;
      margin-top: 30px;
    }
    .wlp1ev .transform-steps::before {
      content: '';
      position: absolute;
      top: 40px;
      left: 16.66%;
      right: 16.66%;
      height: 1px;
      background: var(--line);
      z-index: 0;
    }
    .wlp1ev .step {
      text-align: center;
      position: relative;
      z-index: 1;
    }
    .wlp1ev .step-num {
      width: 80px;
      height: 80px;
      margin: 0 auto 24px;
      background: var(--cream);
      border: 1px solid var(--line);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-style: italic;
      font-size: 28px;
      color: var(--blue);
    }
    .wlp1ev .step h3 {
      font-size: 24px;
      font-weight: 500;
      margin: 0 0 10px;
      letter-spacing: -0.01em;
      color: var(--ink);
    }
    .wlp1ev .step p {
      color: var(--ink-soft);
      font-size: 15px;
      max-width: 260px;
      margin: 0 auto;
    }

    /* ===== 3. BENEFITS ===== */
    .wlp1ev .benefits {
      background: var(--cream);
    }
    .wlp1ev .benefit-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      margin-bottom: 100px;
    }
    .wlp1ev .benefit-row:last-child {
      margin-bottom: 0;
    }
    .wlp1ev .benefit-row.reverse .benefit-media {
      order: 2;
    }
    .wlp1ev .benefit-media {
      aspect-ratio: 4 / 5;
      background: var(--cream-alt);
      border-radius: 4px;
      position: relative;
      overflow: hidden;
    }
    .wlp1ev .benefit-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .wlp1ev .benefit-eyebrow {
      font-size: 12px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--blue);
      font-weight: 600;
      margin-bottom: 16px;
    }
    .wlp1ev .benefit-copy h3 {
      font-size: clamp(28px, 3vw, 40px);
      line-height: 1.15;
      font-weight: 500;
      letter-spacing: -0.02em;
      margin: 0 0 20px;
      color: var(--ink);
    }
    .wlp1ev .benefit-copy p {
      font-size: 17px;
      color: var(--ink-soft);
      line-height: 1.6;
      margin: 0 0 20px;
    }
    .wlp1ev .stat-pair {
      display: flex;
      gap: 16px;
      margin-top: 8px;
    }
    .wlp1ev .stat-block {
      flex: 1;
      background: var(--white);
      border: 1px solid var(--line);
      padding: 20px 18px;
      text-align: left;
      max-width: 220px;
    }

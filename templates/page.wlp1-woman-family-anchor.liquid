<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #f0ebde;
    --cream-soft: #faf6ef;
    --paper: #f5efe1;
    --blush: #f4e4dc;
    --blush-soft: #faeee5;
    --blue-tint: #e8eef7;
    --blue-tint-soft: #f0f4fa;
    --ink: #2a2521;
    --ink-soft: #443e38;
    --muted: #756e64;
    --line: #d6cfbf;
    --line-blue: #c4d3ea;
    --line-warm: #e0c9bb;
    --brand: #5e91d5;
    --brand-hover: #4a7dbe;
    --brand-deep: #3b6aa8;
    --accent: #c97b5e;
    --accent-soft: #d99680;
    --accent-deep: #a85f44;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--cream);
    color: var(--ink);
    line-height: 1.5;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .container-narrow {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 40px;
  }

  h2 {
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 0.98;
    color: var(--ink);
  }
  h2 .highlight {
    color: var(--brand);
  }

  .eyebrow {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-weight: 600;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .eyebrow .dot {
    width: 6px;
    height: 6px;
    background: var(--brand);
    border-radius: 50%;
  }

  .btn-primary {
    background: var(--brand);
    color: white;
    padding: 16px 30px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 14.5px;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: none;
    cursor: pointer;
  }
  .btn-primary:hover {
    background: var(--brand-hover);
  }
  .btn-primary .arrow {
    font-size: 16px;
    transition: transform 0.2s;
  }
  .btn-primary:hover .arrow {
    transform: translateX(3px);
  }

  .btn-secondary {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 4px;
    font-size: 14.5px;
    font-weight: 500;
  }

  /* ========== QUIZ BANNER (in-body) ========== */
  .quiz-banner {
    background: var(--brand);
    color: white;
    padding: 24px 0;
    position: relative;
    overflow: hidden;
  }
  .quiz-banner::before {
    content: '';
    position: absolute;
    top: -80px;
    right: -40px;
    width: 260px;
    height: 260px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, transparent 65%);
    pointer-events: none;
  }
  .quiz-banner-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
  }
  .quiz-banner-left {
    display: flex;
    align-items: center;
    gap: 20px;
    flex: 1;
    min-width: 0;
  }
  .quiz-banner-icon {
    width: 44px;
    height: 44px;
    background: white;
    border-radius: 50%;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    font-size: 18px;
    font-weight: 800;
    color: var(--brand);
  }
  .quiz-banner-text {
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.9);
  }
  .quiz-banner-text strong {
    color: white;
    font-weight: 700;
    display: block;
    font-size: 18px;
    margin-bottom: 2px;
    letter-spacing: -0.015em;
  }
  .quiz-banner-link {
    background: white;
    color: var(--brand-deep);
    padding: 14px 24px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .quiz-banner-link:hover {
    background: var(--cream);
    color: var(--brand-deep);
  }
  .quiz-banner-link .arrow {
    display: inline-block;
    transition: transform 0.2s;
  }
  .quiz-banner-link:hover .arrow {
    transform: translateX(3px);
  }

  /* ========== NAV ========== */
  .nav {
    padding: 20px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(234, 230, 220, 0.94);
    backdrop-filter: blur(8px);
  }
  .nav-logo {
    font-weight: 800;
    font-size: 15px;
    letter-spacing: -0.02em;
  }
  .nav-logo .mark {
    color: var(--brand);
  }
  .nav-cta {
    font-size: 13px;
    padding: 10px 20px;
    border: 1px solid var(--ink);
    border-radius: 2px;
    text-decoration: none;
    color: var(--ink);
    font-weight: 600;
    transition: all 0.2s;
  }
  .nav-cta:hover {
    background: var(--ink);
    color: var(--cream);
  }

  /* ========== HERO ========== */
  .hero {
    padding: 72px 0 96px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(94, 145, 213, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    text-align: center;
  }
  @media (max-width:640px){
    .hero-stack{gap:22px}
  }
  .hero-content {
    max-width: 720px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-eyebrow {
    margin-bottom: 14px;
  }
  .hero h1 {
    font-size: clamp(30px, 3.8vw, 48px);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.04;
    margin-bottom: 14px;
  }
  .hero h1 .line {
    display: block;
  }
  .hero h1 .highlight {
    color: var(--brand);
  }
  .hero-sub {
    font-size: 15.5px;
    line-height: 1.45;
    color: var(--ink-soft);
    max-width: 540px;
    margin-bottom: 16px;
  }
  .hero-sub strong {
    color: var(--ink);
    font-weight: 600;
  }
  .hero-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 24px 0;
    display: inline-flex;
    flex-direction: column;
    gap: 12px;
    background: transparent !important;
    text-align: left;
  }
  .hero-bullets li {
    font-size: 15px;
    line-height: 1.4;
    color: var(--ink);
    padding-left: 30px;
    position: relative;
    font-weight: 500;
    background: transparent !important;
    list-style: none;
  }
  .hero-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 6px;
    width: 16px;
    height: 16px;
    background: var(--brand);
    border-radius: 50%;
  }
  .hero-bullets li::after {
    content: '✓';
    position: absolute;
    left: 3.5px;
    top: 4px;
    color: white;
    font-size: 10px;
    font-weight: 800;
  }
  .hero-bullets li strong {
    color: var(--ink);
    font-weight: 700;
  }
  .hero-stats {
    display: inline-flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    max-width: 520px;
    margin: 0 0 18px 0;
    border-top: 1px solid var(--line);
    text-align: left;
  }
  .hero-stats .stat-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 9px 0;
    border-bottom: 1px solid var(--line);
    background: transparent;
  }
  .hero-stats .num {
    font-size: 24px;
    font-weight: 800;
    color: var(--brand);
    letter-spacing: -0.025em;
    line-height: 1;
    flex-shrink: 0;
    min-width: 78px;
  }
  .hero-stats .label {
    font-size: 13.5px;
    color: var(--ink-soft);
    font-weight: 500;
    line-height: 1.4;
  }
  .hero-ctas {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero-micro {
    margin-top: 16px;
    font-size: 12px;
    color: var(--muted);
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    font-weight: 500;
    letter-spacing: 0.02em;
    justify-content: center;
  }
  .hero-micro span {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .hero-micro span::before {
    content: '';
    width: 14px;
    height: 1px;
    background: var(--brand);
  }
  /* Hero image - square, above headline */
  .hero-image {
    position: relative;
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: 4px;
    max-width: 560px;
    width: 100%;
    justify-self: center;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .hero-image-tag {
    position: absolute;
    top: 16px;
    right: 16px;
    background: var(--cream);
    padding: 8px 12px;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    border-radius: 2px;
    box-shadow: 0 4px 14px rgba(0,0,0,.18);
  }
  @media (max-width:640px){
    .hero-image-tag{top:12px;right:12px;padding:6px 10px;font-size:10px;letter-spacing:.14em}
  }
  .hero-image-tag .highlight {
    color: var(--brand);
  }

  /* ========== TRUST STRIP ========== */
  .trust-strip {
    padding: 22px 0;
    background: var(--ink);
    color: var(--cream);
  }
  .trust-strip-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .trust-item {
    font-size: 12px;
    font-weight: 600;
    color: var(--cream);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .trust-item::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--brand);
    border-radius: 50%;
  }

  /* ========== TRUTH TELL (compact band) ========== */
  .truth {
    padding: 64px 0;
    background: var(--blush-soft);
    border-top: 1px solid var(--line-warm);
    border-bottom: 1px solid var(--line-warm);
  }
  .truth-band {
    display: grid;
    grid-template-columns: auto 1fr 1.4fr;
    gap: 40px;
    align-items: center;
    max-width: 100%;
  }
  .truth-band .eyebrow {
    color: var(--accent-deep);
  }
  .truth-band .eyebrow .dot {
    background: var(--accent);
  }
  .truth h2 {
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--ink);
  }
  .truth h2 .highlight {
    color: var(--brand);
  }
  .truth-band p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 480px;
  }
  .truth-band p strong {
    color: var(--ink);
    font-weight: 700;
  }

  /* ========== 5 REASONS (warm paper with grid) ========== */
  .reasons {
    padding: 120px 0;
    background: linear-gradient(to bottom, var(--paper), var(--paper)),
      repeating-linear-gradient(0deg, transparent 0 39px, rgba(26, 26, 24, 0.04) 39px 40px),
      repeating-linear-gradient(90deg, transparent 0 39px, rgba(26, 26, 24, 0.04) 39px 40px);
    background-blend-mode: multiply;
    position: relative;
  }
  .reasons::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent 0 39px, rgba(26, 26, 24, 0.035) 39px 40px),
      repeating-linear-gradient(90deg, transparent 0 39px, rgba(26, 26, 24, 0.035) 39px 40px);
    pointer-events: none;
  }
  .reasons > .container {
    position: relative;
    z-index: 2;
  }
  .reasons-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-bottom: 64px;
    align-items: end;
  }
  .reasons-head .eyebrow {
    margin-bottom: 24px;
  }
  .reasons-head h2 {
    font-size: clamp(42px, 5.6vw, 72px);
  }
  .reasons-head h2 .highlight {
    color: var(--brand);
  }
  .reasons-head p {
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .reasons-head p strong {
    color: var(--ink);
    font-weight: 600;
  }

  .reason-list {
    border-top: 2px solid var(--ink);
    background: var(--paper);
  }
  .reason {
    display: grid;
    grid-template-columns: 120px 1fr 1.6fr;
    gap: 40px;
    padding: 36px 20px;
    border-bottom: 1px solid var(--line);
    align-items: start;
    transition: all 0.25s;
  }
  .reason:hover {
    background: var(--cream);
    padding-left: 32px;
    padding-right: 32px;
  }
  .reason-num {
    font-size: 72px;
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 0.85;
    color: var(--brand);
    font-feature-settings: 'tnum';
  }
  .reason-h3 {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--ink);
  }
  .reason-h3 .highlight {
    color: var(--brand);
  }
  .reason-body {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--ink-soft);
  }
  .reason-body strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* ========== CLINICAL STUDIES ========== */
  .clinical {
    background: var(--ink);
    color: var(--cream);
    padding: 120px 0;
  }
  .clinical-head {
    margin-bottom: 64px;
    max-width: 800px;
  }
  .clinical-head .eyebrow {
    color: var(--cream);
    margin-bottom: 28px;
  }
  .clinical-head h2 {
    color: var(--cream);
    font-size: clamp(42px, 5.6vw, 72px);
    margin-bottom: 20px;
  }
  .clinical-head h2 .highlight {
    color: var(--brand);
  }
  .clinical-head p {
    font-size: 17px;
    color: rgba(234, 230, 220, 0.7);
    line-height: 1.55;
    max-width: 600px;
  }
  .clinical-head p strong {
    color: var(--cream);
    font-weight: 600;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(234, 230, 220, 0.12);
    border: 1px solid rgba(234, 230, 220, 0.12);
    margin-bottom: 40px;
  }
  .stat {
    background: var(--ink);
    padding: 40px 28px 36px;
  }
  .stat-num {
    font-size: clamp(52px, 5.5vw, 72px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--brand);
    margin-bottom: 12px;
  }
  .stat-num .unit {
    font-size: 0.42em;
    color: rgba(234, 230, 220, 0.5);
    margin-left: 2px;
  }
  .stat-label {
    font-size: 15px;
    font-weight: 700;
    color: var(--cream);
    margin-bottom: 8px;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .stat-fine {
    font-size: 12.5px;
    color: rgba(234, 230, 220, 0.55);
    line-height: 1.5;
  }

  .clinical-foot {
    font-size: 11px;
    color: rgba(234, 230, 220, 0.5);
    line-height: 1.6;
    max-width: 780px;
  }
  .clinical-foot strong {
    color: rgba(234, 230, 220, 0.75);
    font-weight: 600;
  }

  /* ========== MECHANISM (DARK) ========== */
  .mechanism {
    padding: 120px 0;
    background: var(--ink);
    color: var(--cream);
    position: relative;
    overflow: hidden;
  }
  .mechanism::before {
    content: '';
    position: absolute;
    top: -100px;
    left: -150px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(94, 145, 213, 0.12) 0%, transparent 60%);
    pointer-events: none;
  }
  .mech-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-bottom: 56px;
    align-items: end;
    position: relative;
  }
  .mech-head .eyebrow {
    margin-bottom: 24px;
    color: var(--cream);
  }
  .mech-head h2 {
    font-size: clamp(38px, 5vw, 60px);
    color: var(--cream);
  }
  .mech-head h2 .highlight {
    color: var(--brand);
  }
  .mech-head p {
    font-size: 16px;
    line-height: 1.55;
    color: rgba(234, 230, 220, 0.7);
  }
  .mech-head p strong {
    color: var(--cream);
    font-weight: 600;
  }

  .pathways {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    position: relative;
  }
  .pathway {
    background: rgba(234, 230, 220, 0.04);
    border: 1px solid rgba(234, 230, 220, 0.15);
    padding: 32px 28px;
    transition: all 0.25s;
  }
  .pathway:hover {
    border-color: var(--brand);
    transform: translateY(-3px);
    background: rgba(94, 145, 213, 0.08);
  }
  .pathway-num {
    font-size: 11px;
    font-weight: 600;
    color: var(--brand);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .pathway-title {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-bottom: 14px;
    color: var(--cream);
  }
  .pathway-title .highlight {
    color: var(--brand);
  }
  .pathway-desc {
    font-size: 14.5px;
    line-height: 1.55;
    color: rgba(234, 230, 220, 0.7);
  }
  .pathway-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pathway-bullets li {
    font-size: 14.5px;
    line-height: 1.45;
    color: rgba(234, 230, 220, 0.7);
    padding-left: 22px;
    position: relative;
  }
  .pathway-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 10px;
    height: 2px;
    background: var(--brand);
  }
  .pathway-bullets li strong {
    color: var(--cream);
    font-weight: 600;
  }

  /* ========== CLINICAL HIGHLIGHTS (paper) ========== */
  .love {
    background: var(--paper);
    padding: 120px 0;
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .love-head {
    max-width: 800px;
    margin-bottom: 56px;
  }
  .love-head .eyebrow {
    margin-bottom: 24px;
  }
  .love-head h2 {
    font-size: clamp(42px, 5.6vw, 68px);
    margin-bottom: 20px;
  }
  .love-head h2 .highlight {
    color: var(--brand);
  }
  .love-head p {
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 560px;
  }

  .love-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .love-card {
    background: white;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 36px 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
    transition: transform 0.25s, box-shadow 0.25s;
    min-height: 320px;
  }
  .love-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 40px -20px rgba(26, 26, 24, 0.15);
  }
  .love-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 32px;
    width: 36px;
    height: 3px;
    background: var(--brand);
  }
  .love-tag {
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand);
  }
  .love-quote {
    font-size: 22px;
    font-weight: 500;
    font-style: italic;
    letter-spacing: -0.015em;
    line-height: 1.3;
    color: var(--ink);
    flex: 1;
  }
  .love-quote strong {
    font-weight: 800;
    font-style: italic;
    color: var(--ink);
  }
  .love-proof {
    border-top: 1px solid var(--line);
    padding-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .love-proof-label {
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--ink);
  }
  .love-proof-body {
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-soft);
    font-weight: 500;
  }
  .love-proof-body strong {
    color: var(--ink);
    font-weight: 700;
  }
  .love-meta {
    font-size: 11.5px;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0;
    text-transform: none;
    padding-top: 0;
    border-top: none;
    line-height: 1.5;
    margin-top: 4px;
  }

  /* ========== IMAGE DIVIDER ========== */
  .image-divider {
    position: relative;
    height: 44vh;
    min-height: 360px;
    overflow: hidden;
  }
  .image-divider img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .image-divider-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(26, 26, 24, 0.35) 0%, rgba(26, 26, 24, 0) 60%);
    display: flex;
    align-items: center;
  }
  .image-divider-text {
    color: white;
    padding: 0 40px;
    max-width: 640px;
    font-size: clamp(28px, 3.4vw, 46px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .image-divider-text .highlight {
    color: var(--brand);
  }

  /* ========== FAQ (cream-soft with sidebar) ========== */
  .faq {
    padding: 120px 0;
    background: var(--cream-soft);
    border-top: 1px solid var(--line);
  }
  .faq-inner {
    display: grid;
    grid-template-columns: 0.85fr 1.5fr;
    gap: 80px;
    align-items: start;
  }
  .faq-sidebar {
    position: sticky;
    top: 100px;
  }
  .faq-head {
    max-width: 360px;
    margin-bottom: 40px;
  }
  .faq-head .eyebrow {
    margin-bottom: 24px;
  }
  .faq-head h2 {
    font-size: clamp(40px, 4.6vw, 56px);
    margin-bottom: 20px;
  }
  .faq-head h2 .highlight {
    color: var(--brand);
  }
  .faq-head p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .faq-badge {
    display: inline-block;
    padding: 14px 20px;
    background: var(--ink);
    color: var(--cream);
    font-size: 12px;
    letter-spacing: 0.02em;
    font-weight: 500;
    max-width: 320px;
    line-height: 1.5;
  }
  .faq-badge strong {
    color: var(--brand);
    font-weight: 700;
  }

  .qa-list {
    max-width: 100%;
  }
  .qa {
    border-top: 1px solid var(--line);
    padding: 26px 0;
    display: block;
  }
  .qa:last-child {
    border-bottom: 1px solid var(--line);
  }
  .qa-q {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--ink);
    margin-bottom: 14px;
  }
  .qa-a {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 680px;
  }
  .qa-a strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* ========== FINAL CTA ========== */
  .final {
    background: var(--ink);
    color: var(--cream);
    padding: 120px 0;
    text-align: center;
  }
  .final .eyebrow {
    color: var(--cream);
    margin-bottom: 28px;
    justify-content: center;
  }
  .final h2 {
    color: var(--cream);
    font-size: clamp(48px, 6.4vw, 84px);
    margin-bottom: 28px;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }
  .final h2 .highlight {
    color: var(--brand);
  }
  .final p {
    font-size: 17px;
    line-height: 1.5;
    color: rgba(234, 230, 220, 0.7);
    max-width: 500px;
    margin: 0 auto 36px;
  }
  .final-price {
    margin-top: 36px;
    font-size: 13px;
    color: rgba(234, 230, 220, 0.6);
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .final-price strong {
    color: var(--cream);
    font-weight: 700;
  }

  /* ========== SPLIT CTA PANEL (image + cta side by side) ========== */
  .split-cta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    background: var(--cream-soft);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    min-height: 480px;
  }
  .split-cta-image {
    position: relative;
    overflow: hidden;
    background: var(--cream-soft);
    min-height: 480px;
  }
  .split-cta-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .split-cta-content {
    padding: 80px 72px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
    max-width: 620px;
  }
  .split-cta-content .eyebrow {
    margin-bottom: 4px;
  }
  .split-cta-content h2 {
    font-size: clamp(32px, 3.6vw, 48px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--ink);
  }
  .split-cta-content h2 .highlight {
    color: var(--brand);
  }
  .split-cta-content p {
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 460px;
  }
  .split-cta-ctas {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  /* ========== INLINE CTA BAR ========== */
  .cta-bar {
    background: var(--cream);
    padding: 48px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .cta-bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .cta-bar-text {
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--ink);
    max-width: 560px;
  }
  .cta-bar-text .highlight {
    color: var(--brand);
  }
  .cta-bar-inline {
    background: var(--paper);
    padding: 48px 0;
  }

  /* ========== BUY PANEL ========== */
  .buy-panel {
    background: var(--cream);
    padding: 120px 0;
    position: relative;
  }
  .buy-inner {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 72px;
    align-items: center;
  }
  .buy-image {
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: 2px;
    background: #f5f4ee;
    position: relative;
  }
  .buy-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .buy-image-tag {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--ink);
    color: var(--cream);
    padding: 8px 14px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border-radius: 2px;
  }
  .buy-head {
    margin-bottom: 32px;
  }
  .buy-head .eyebrow {
    margin-bottom: 20px;
  }
  .buy-head h2 {
    font-size: clamp(36px, 4.6vw, 54px);
    margin-bottom: 16px;
  }
  .buy-head h2 .highlight {
    color: var(--brand);
  }
  .buy-head p {
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 500px;
  }

  .tiers {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 28px;
  }
  .tier {
    background: white;
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 22px 24px;
    cursor: pointer;
    transition: all 0.2s;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 16px 20px;
    align-items: center;
    position: relative;
  }
  .tier:hover {
    border-color: var(--ink);
  }
  .tier.selected {
    border-color: var(--brand);
    background: linear-gradient(to right, rgba(94, 145, 213, 0.06), rgba(94, 145, 213, 0.02));
    box-shadow: 0 0 0 1px var(--brand) inset;
  }
  .tier-radio {
    width: 20px;
    height: 20px;
    border: 2px solid var(--line);
    border-radius: 50%;
    display: inline-block;
    position: relative;
    flex-shrink: 0;
    transition: all 0.2s;
  }
  .tier.selected .tier-radio {
    border-color: var(--brand);
  }
  .tier.selected .tier-radio::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    background: var(--brand);
    border-radius: 50%;
  }
  .tier-detail {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .tier-title {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .tier-badge {
    font-size: 10px;
    font-weight: 700;
    color: white;
    background: var(--ink);
    padding: 4px 9px;
    border-radius: 2px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .tier-badge-blue {
    font-size: 10px;
    font-weight: 700;
    color: white;
    background: var(--brand);
    padding: 4px 9px;
    border-radius: 2px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .tier-sub {
    font-size: 13.5px;
    color: var(--ink-soft);
    font-weight: 500;
    line-height: 1.4;
  }
  .tier-sub-small {
    font-size: 12.5px;
    color: var(--muted);
    font-weight: 500;
    line-height: 1.4;
  }
  .tier-price {
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-end;
  }
  .tier-price-big {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1;
  }
  .tier-price-big .unit {
    font-size: 14px;
    color: var(--ink);
    font-weight: 700;
    letter-spacing: 0;
  }
  .tier-price-total {
    font-size: 12.5px;
    color: var(--ink);
    font-weight: 600;
  }
  .tier-price-old {
    color: var(--muted);
    text-decoration: line-through;
    font-weight: 500;
    margin-right: 4px;
  }
  .tier-savings {
    font-size: 12.5px;
    font-weight: 600;
    color: var(--brand);
    letter-spacing: 0;
    text-transform: none;
  }

  .buy-cta {
    display: block;
    width: 100%;
    background: var(--brand);
    color: white;
    padding: 18px 30px;
    border-radius: 2px;
    text-align: center;
    text-decoration: none;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: all 0.2s;
    border: none;
    cursor: pointer;
    margin-bottom: 16px;
  }
  .buy-cta:hover {
    background: var(--brand-hover);
  }

  .buy-trust {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--muted);
    font-weight: 500;
  }
  .buy-trust span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .buy-trust span::before {
    content: '✓';
    color: var(--brand);
    font-weight: 700;
  }

  /* ========== STICKY MOBILE CTA ========== */
  .sticky-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--ink);
    color: var(--cream);
    padding: 14px 20px;
    z-index: 100;
    border-top: 1px solid rgba(234, 230, 220, 0.15);
    box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.15);
  }
  .sticky-cta-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    max-width: 600px;
    margin: 0 auto;
  }
  .sticky-cta-text {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.2;
  }
  .sticky-cta-text .price {
    color: var(--brand);
    font-weight: 700;
  }
  .sticky-cta-text small {
    display: block;
    font-size: 11px;
    font-weight: 500;
    opacity: 0.7;
    margin-top: 2px;
    letter-spacing: 0.01em;
  }
  .sticky-cta-btn {
    background: var(--brand);
    color: white;
    padding: 12px 22px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .sticky-cta-btn:hover {
    background: var(--brand-hover);
  }

  /* ========== FOOTER ========== */
  .footer {
    padding: 48px 0;
    font-size: 11px;
    color: var(--muted);
    text-align: center;
    line-height: 1.6;
    background: var(--cream);
  }
  .footer p {
    max-width: 720px;
    margin: 0 auto 8px;
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 900px) {
    .hero {
      padding: 48px 0 64px;
    }
    .hero-stack {
      gap: 32px;
    }
    .hero-image {
      max-width: 100%;
    }
    .truth-band {
      grid-template-columns: 1fr;
      gap: 16px;
      text-align: left;
    }
    .truth h2 {
      font-size: 22px;
    }
    .mech-head,
    .reasons-head {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .pathways,
    .love-grid {
      grid-template-columns: 1fr;
    }
    .stat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .faq-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .faq-sidebar {
      position: static;
    }
    .faq-head {
      max-width: 100%;
    }
    .reason {
      grid-template-columns: 72px 1fr;
      gap: 16px 24px;
      padding: 28px 16px;
    }
    .reason-body {
      grid-column: 2;
    }
    .reason-num {
      font-size: 52px;
    }
    .reason:hover {
      padding-left: 16px;
      padding-right: 16px;
    }
    .buy-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .buy-image {
      max-width: 400px;
      margin: 0 auto;
      aspect-ratio: 1/1;
    }
    .cta-bar-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .sticky-cta {
      display: block;
    }
    body {
      padding-bottom: 72px;
    }
    .truth,
    .reasons,
    .clinical,
    .mechanism,
    .love,
    .faq,
    .final,
    .buy-panel {
      padding: 72px 0;
    }
    .container,
    .container-narrow {
      padding: 0 24px;
    }
    .trust-strip-inner {
      gap: 12px 18px;
    }
    .image-divider {
      height: 34vh;
      min-height: 260px;
    }
    .image-divider-text {
      padding: 0 24px;
    }
    .split-cta {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .split-cta-image {
      min-height: 360px;
      aspect-ratio: 4/5;
    }
    .split-cta-content {
      padding: 56px 28px;
    }
  }

  @media (max-width: 520px) {
    .nav {
      padding: 16px 20px;
    }
    .stat-grid {
      grid-template-columns: 1fr;
    }
    .tier {
      grid-template-columns: auto 1fr;
      gap: 10px 14px;
      padding: 18px 18px;
    }
    .tier-price {
      grid-column: 2;
      text-align: left;
      align-items: flex-start;
      flex-direction: row;
      gap: 8px;
      align-items: baseline;
    }
    .tier-price-old {
      order: 2;
    }
    .tier-savings {
      display: none;
    }
    .quiz-banner {
      padding: 28px 0;
    }
    .quiz-banner-inner {
      padding: 0 24px;
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .quiz-banner-link {
      width: 100%;
      justify-content: center;
    }
  }

  /* Fade-ins */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .fade-in {
    animation: fadeUp 0.7s ease both;
  }
  .d-1 {
    animation-delay: 0.08s;
  }
  .d-2 {
    animation-delay: 0.16s;
  }

  /* ========== ADD TO CART TOAST ========== */
  .wlp1-toast {
    position: fixed;
    top: 24px;
    right: 24px;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--ink);
    color: var(--cream);
    padding: 16px 20px 16px 18px;
    border-radius: 4px;
    box-shadow: 0 12px 32px -8px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(94, 145, 213, 0.25);
    min-width: 320px;
    max-width: 400px;
    transform: translateY(-20px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.32s cubic-bezier(0.2, 0.9, 0.3, 1.2), opacity 0.25s ease;
  }
  .wlp1-toast-visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  .wlp1-toast-icon {
    width: 28px;
    height: 28px;
    background: var(--brand);
    border-radius: 50%;
    display: grid;
    place-items: center;
    color: white;
    font-size: 14px;
    font-weight: 800;
    flex-shrink: 0;
  }
  .wlp1-toast-content {
    flex: 1;
    min-width: 0;
  }
  .wlp1-toast-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--cream);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-bottom: 2px;
  }
  .wlp1-toast-sub {
    font-size: 12.5px;
    color: rgba(234, 230, 220, 0.7);
    font-weight: 500;
    line-height: 1.35;
  }
  .wlp1-toast-link {
    font-size: 13px;
    font-weight: 700;
    color: var(--brand);
    text-decoration: none;
    letter-spacing: 0.02em;
    white-space: nowrap;
    padding: 6px 4px;
    transition: color 0.2s;
  }
  .wlp1-toast-link:hover {
    color: white;
  }

  /* Buy CTA button states */
  #wlp1-add-to-cart {
    transition: background 0.2s, opacity 0.2s;
  }
  #wlp1-add-to-cart[data-state='loading'] {
    opacity: 0.75;
    cursor: progress;
  }
  #wlp1-add-to-cart[data-state='success'] {
    background: var(--brand-deep);
  }
  #wlp1-add-to-cart[data-state='error'] {
    background: var(--accent, #c97b5e);
  }

  @media (max-width: 520px) {
    .wlp1-toast {
      top: auto;
      bottom: 80px;
      left: 12px;
      right: 12px;
      min-width: 0;
      max-width: none;
    }
  }

  /* ========== V2 HERO ADDITIONS ========== */
  .hero-review-row{
    display:flex;align-items:center;gap:10px;margin:0 0 10px 0;
    color:#1a1a1a;font-size:14px;font-weight:600;letter-spacing:.01em;
  }
  .hero-review-row .stars{display:inline-flex;align-items:center;color:#c8a96a;height:16px}
  .hero-review-row .stars svg{height:16px;width:auto}
  .hero-review-row .count{color:#1a1a1a;opacity:.85;font-weight:500}
  .hero-review-row .dot{width:3px;height:3px;border-radius:50%;background:#1a1a1a;opacity:.4;display:inline-block;margin:0 4px}
  .hero-image-frame{position:relative;max-width:560px;width:100%;margin:0 auto;justify-self:center}
  .hero-image-frame .hero-image{max-width:100%}
  .hero-bottle-inset{
    position:absolute;bottom:5%;left:5%;width:34%;aspect-ratio:1/1;
    background:#eef2f5;border-radius:6px;
    box-shadow:0 14px 36px rgba(0,0,0,.25);
    transform:rotate(-6deg);overflow:hidden;z-index:2
  }
  .hero-bottle-inset img{width:100%;height:100%;object-fit:contain;padding:10%}
  .hero-trust-row{display:none}
  @media (max-width:640px){
    .hero-bottle-inset{width:32%;bottom:5%;left:5%}

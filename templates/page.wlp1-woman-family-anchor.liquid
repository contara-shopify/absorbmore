<div id="wlp1-toast" class="wlp1-toast" role="status" aria-live="polite">
  <div class="wlp1-toast-icon">✓</div>
  <div class="wlp1-toast-content">
    <div class="wlp1-toast-title">Added to cart</div>
    <div class="wlp1-toast-sub" id="wlp1-toast-sub">WLP-1™ · 3-Month subscription</div>
  </div>
  <a href="/cart" class="wlp1-toast-link">View cart →</a>
</div>

<script>
  (function () {
    'use strict';

    // Tier selection
    window.selectTier = function (el) {
      document.querySelectorAll('.tier').forEach(function (t) {
        t.classList.remove('selected');
      });
      el.classList.add('selected');
    };

    var btn = document.getElementById('wlp1-add-to-cart');
    var toast = document.getElementById('wlp1-toast');
    var toastSub = document.getElementById('wlp1-toast-sub');
    var hideTimer = null;

    if (!btn) return;

    function showToast(label) {
      if (toastSub) toastSub.textContent = 'WLP-1™ · ' + label;
      if (!toast) return;
      toast.classList.add('wlp1-toast-visible');
      if (hideTimer) clearTimeout(hideTimer);
      hideTimer = setTimeout(function () {
        toast.classList.remove('wlp1-toast-visible');
      }, 4500);
    }

    function setBtnState(state, label) {
      btn.dataset.state = state;
      btn.textContent = label;
    }

    btn.addEventListener('click', function (e) {
      e.preventDefault();
      var selectedTier = document.querySelector('.tier.selected');
      if (!selectedTier) {
        selectedTier = document.querySelector('.tier');
      }
      if (!selectedTier) return;

      var variantId = selectedTier.getAttribute('data-variant-id');
      var sellingPlanId = selectedTier.getAttribute('data-selling-plan-id');
      var tierTitle = (selectedTier.querySelector('.tier-title') || {}).textContent || '';
      var planLabel =
        tierTitle
          .replace(/Save\s*\d+%/i, '')
          .replace(/Most Popular|Best Value/gi, '')
          .trim() + ' subscription';
      if (!sellingPlanId) {
        planLabel = 'One-time purchase';
      }

      var payload = {
        items: [
          {
            id: parseInt(variantId, 10),
            quantity: 1,
          },
        ],
      };
      if (sellingPlanId) {
        payload.items[0].selling_plan = parseInt(sellingPlanId, 10);
      }

      setBtnState('loading', 'Adding...');
      btn.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
        },
        body: JSON.stringify(payload),
      })
        .then(function (res) {
          if (!res.ok) throw new Error('Cart error: ' + res.status);
          return res.json();
        })
        .then(function () {
          setBtnState('success', 'Added ✓');
          // Redirect to cart after brief confirmation flash
          setTimeout(function () {
            window.location.href = '/cart';
          }, 350);
        })
        .catch(function (err) {
          console.error('WLP-1 add to cart failed:', err);
          setBtnState('error', 'Try again');
          btn.disabled = false;
          setTimeout(function () {
            setBtnState('default', 'Add to Cart →');
          }, 2500);
        });
    });
  })();
</script>

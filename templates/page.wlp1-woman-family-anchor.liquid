<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #EAE6DC;
    --cream-soft: #F8F5F2;
    --paper: #F2EEE3;
    --blue-tint: #E8EEF7;
    --blue-tint-soft: #F0F4FA;
    --ink: #1A1A18;
    --ink-soft: #3A3834;
    --muted: #6B6862;
    --line: #CDC7BA;
    --line-blue: #C4D3EA;
    --brand: #5E91D5;
    --brand-hover: #4A7DBE;
    --brand-deep: #3B6AA8;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--cream);
    color: var(--ink);
    line-height: 1.5;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  img { display: block; max-width: 100%; height: auto; }

  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .container-narrow {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 40px;
  }

  h2 {
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 0.98;
    color: var(--ink);
  }
  h2 .highlight { color: var(--brand); }

  .eyebrow {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-weight: 600;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .eyebrow .dot {
    width: 6px;
    height: 6px;
    background: var(--brand);
    border-radius: 50%;
  }

  .btn-primary {
    background: var(--brand);
    color: white;
    padding: 16px 30px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 14.5px;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: none;
    cursor: pointer;
  }
  .btn-primary:hover { background: var(--brand-hover); }
  .btn-primary .arrow { font-size: 16px; transition: transform 0.2s; }
  .btn-primary:hover .arrow { transform: translateX(3px); }

  .btn-secondary {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 4px;
    font-size: 14.5px;
    font-weight: 500;
  }

  /* ========== QUIZ BANNER (in-body) ========== */
  .quiz-banner {
    background: var(--ink);
    color: var(--cream);
    padding: 24px 0;
    position: relative;
    overflow: hidden;
  }
  .quiz-banner::before {
    content: '';
    position: absolute;
    top: -80px;
    right: -40px;
    width: 260px;
    height: 260px;
    background: radial-gradient(circle, rgba(94,145,213,0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  .quiz-banner-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
  }
  .quiz-banner-left {
    display: flex;
    align-items: center;
    gap: 20px;
    flex: 1;
    min-width: 0;
  }
  .quiz-banner-icon {
    width: 44px;
    height: 44px;
    background: var(--brand);
    border-radius: 50%;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    font-size: 18px;
    font-weight: 800;
    color: white;
  }
  .quiz-banner-text {
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: rgba(234, 230, 220, 0.85);
  }
  .quiz-banner-text strong {
    color: var(--cream);
    font-weight: 700;
    display: block;
    font-size: 18px;
    margin-bottom: 2px;
    letter-spacing: -0.015em;
  }
  .quiz-banner-link {
    background: var(--brand);
    color: white;
    padding: 14px 24px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .quiz-banner-link:hover {
    background: var(--brand-hover);
  }
  .quiz-banner-link .arrow {
    display: inline-block;
    transition: transform 0.2s;
  }
  .quiz-banner-link:hover .arrow {
    transform: translateX(3px);
  }

  /* ========== NAV ========== */
  .nav {
    padding: 20px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(234, 230, 220, 0.94);
    backdrop-filter: blur(8px);
  }
  .nav-logo {
    font-weight: 800;
    font-size: 15px;
    letter-spacing: -0.02em;
  }
  .nav-logo .mark { color: var(--brand); }
  .nav-cta {
    font-size: 13px;
    padding: 10px 20px;
    border: 1px solid var(--ink);
    border-radius: 2px;
    text-decoration: none;
    color: var(--ink);
    font-weight: 600;
    transition: all 0.2s;
  }
  .nav-cta:hover { background: var(--ink); color: var(--cream); }

  /* ========== HERO ========== */
  .hero {
    padding: 72px 0 96px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(94,145,213,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 72px;
    align-items: center;
  }
  .hero-eyebrow { margin-bottom: 32px; }
  .hero h1 {
    font-size: clamp(36px, 4.8vw, 62px);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.02;
    margin-bottom: 28px;
  }
  .hero h1 .line { display: block; }
  .hero h1 .highlight { color: var(--brand); }
  .hero-sub {
    font-size: 17px;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 480px;
    margin-bottom: 36px;
  }
  .hero-sub strong { color: var(--ink); font-weight: 600; }
  .hero-ctas {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-micro {
    margin-top: 32px;
    font-size: 12px;
    color: var(--muted);
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .hero-micro span { display: inline-flex; align-items: center; gap: 7px; }
  .hero-micro span::before {
    content: '';
    width: 14px;
    height: 1px;
    background: var(--brand);
  }
  /* Real image hero */
  .hero-image {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 2px;
    max-width: 480px;
    width: 100%;
    justify-self: end;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }
  .hero-image-tag {
    position: absolute;
    bottom: 20px;
    left: 20px;
    background: var(--cream);
    padding: 10px 16px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    border-radius: 2px;
  }
  .hero-image-tag .highlight { color: var(--brand); }

  /* ========== TRUST STRIP ========== */
  .trust-strip {
    padding: 22px 0;
    background: var(--ink);
    color: var(--cream);
  }
  .trust-strip-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .trust-item {
    font-size: 12px;
    font-weight: 600;
    color: var(--cream);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .trust-item::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--brand);
    border-radius: 50%;
  }

  /* ========== TRUTH TELL ========== */
  .truth {
    padding: 120px 0;
  }
  .truth-inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 72px;
    align-items: center;
  }
  .truth-content {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .truth-eyebrow { margin-bottom: 0; }
  .truth h2 {
    font-size: clamp(38px, 4.6vw, 56px);
    margin-bottom: 0;
  }
  .truth h2 .line { display: block; }
  .truth-sub {
    font-size: 17px;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 540px;
  }
  .truth-body {
    padding-top: 8px;
    border-top: 1px solid var(--line);
  }
  .truth-body p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 16px;
    max-width: 540px;
  }
  .truth-body p strong { color: var(--ink); font-weight: 600; }
  .truth-image {
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 2px;
  }
  .truth-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ========== 5 REASONS (warm paper with grid) ========== */
  .reasons {
    padding: 120px 0;
    background:
      linear-gradient(to bottom, var(--paper), var(--paper)),
      repeating-linear-gradient(0deg, transparent 0 39px, rgba(26,26,24,0.04) 39px 40px),
      repeating-linear-gradient(90deg, transparent 0 39px, rgba(26,26,24,0.04) 39px 40px);
    background-blend-mode: multiply;
    position: relative;
  }
  .reasons::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent 0 39px, rgba(26,26,24,0.035) 39px 40px),
      repeating-linear-gradient(90deg, transparent 0 39px, rgba(26,26,24,0.035) 39px 40px);
    pointer-events: none;
  }
  .reasons > .container { position: relative; z-index: 2; }
  .reasons-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-bottom: 64px;
    align-items: end;
  }
  .reasons-head .eyebrow { margin-bottom: 24px; }
  .reasons-head h2 {
    font-size: clamp(42px, 5.6vw, 72px);
  }
  .reasons-head h2 .highlight { color: var(--brand); }
  .reasons-head p {
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .reasons-head p strong { color: var(--ink); font-weight: 600; }

  .reason-list {
    border-top: 2px solid var(--ink);
    background: var(--paper);
  }
  .reason {
    display: grid;
    grid-template-columns: 120px 1fr 1.6fr;
    gap: 40px;
    padding: 36px 20px;
    border-bottom: 1px solid var(--line);
    align-items: start;
    transition: all 0.25s;
  }
  .reason:hover {
    background: var(--cream);
    padding-left: 32px;
    padding-right: 32px;
  }
  .reason-num {
    font-size: 72px;
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 0.85;
    color: var(--brand);
    font-feature-settings: "tnum";
  }
  .reason-h3 {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--ink);
  }
  .reason-h3 .highlight { color: var(--brand); }
  .reason-body {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--ink-soft);
  }
  .reason-body strong { color: var(--ink); font-weight: 600; }

  /* ========== CLINICAL STUDIES ========== */
  .clinical {
    background: var(--ink);
    color: var(--cream);
    padding: 120px 0;
  }
  .clinical-head {
    margin-bottom: 64px;
    max-width: 800px;
  }
  .clinical-head .eyebrow { color: var(--cream); margin-bottom: 28px; }
  .clinical-head h2 {
    color: var(--cream);
    font-size: clamp(42px, 5.6vw, 72px);
    margin-bottom: 20px;
  }
  .clinical-head h2 .highlight { color: var(--brand); }
  .clinical-head p {
    font-size: 17px;
    color: rgba(234, 230, 220, 0.7);
    line-height: 1.55;
    max-width: 600px;
  }
  .clinical-head p strong { color: var(--cream); font-weight: 600; }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(234, 230, 220, 0.12);
    border: 1px solid rgba(234, 230, 220, 0.12);
    margin-bottom: 40px;
  }
  .stat {
    background: var(--ink);
    padding: 40px 28px 36px;
  }
  .stat-num {
    font-size: clamp(52px, 5.5vw, 72px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--brand);
    margin-bottom: 12px;
  }
  .stat-num .unit {
    font-size: 0.42em;
    color: rgba(234, 230, 220, 0.5);
    margin-left: 2px;
  }
  .stat-label {
    font-size: 15px;
    font-weight: 700;
    color: var(--cream);
    margin-bottom: 8px;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .stat-fine {
    font-size: 12.5px;
    color: rgba(234, 230, 220, 0.55);
    line-height: 1.5;
  }

  .clinical-foot {
    font-size: 11px;
    color: rgba(234, 230, 220, 0.5);
    line-height: 1.6;
    max-width: 780px;
  }
  .clinical-foot strong { color: rgba(234, 230, 220, 0.75); font-weight: 600; }

  /* ========== MECHANISM (DARK) ========== */
  .mechanism {
    padding: 120px 0;
    background: var(--ink);
    color: var(--cream);
    position: relative;
    overflow: hidden;
  }
  .mechanism::before {
    content: '';
    position: absolute;
    top: -100px;
    left: -150px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(94,145,213,0.12) 0%, transparent 60%);
    pointer-events: none;
  }
  .mech-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-bottom: 56px;
    align-items: end;
    position: relative;
  }
  .mech-head .eyebrow {
    margin-bottom: 24px;
    color: var(--cream);
  }
  .mech-head h2 {
    font-size: clamp(38px, 5vw, 60px);
    color: var(--cream);
  }
  .mech-head h2 .highlight { color: var(--brand); }
  .mech-head p {
    font-size: 16px;
    line-height: 1.55;
    color: rgba(234, 230, 220, 0.7);
  }
  .mech-head p strong { color: var(--cream); font-weight: 600; }

  .pathways {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    position: relative;
  }
  .pathway {
    background: rgba(234, 230, 220, 0.04);
    border: 1px solid rgba(234, 230, 220, 0.15);
    padding: 32px 28px;
    transition: all 0.25s;
  }
  .pathway:hover {
    border-color: var(--brand);
    transform: translateY(-3px);
    background: rgba(94, 145, 213, 0.08);
  }
  .pathway-num {
    font-size: 11px;
    font-weight: 600;
    color: var(--brand);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .pathway-title {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-bottom: 14px;
    color: var(--cream);
  }
  .pathway-title .highlight { color: var(--brand); }
  .pathway-desc {
    font-size: 14.5px;
    line-height: 1.55;
    color: rgba(234, 230, 220, 0.7);
  }
  .pathway-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pathway-bullets li {
    font-size: 14.5px;
    line-height: 1.45;
    color: rgba(234, 230, 220, 0.7);
    padding-left: 22px;
    position: relative;
  }
  .pathway-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 10px;
    height: 2px;
    background: var(--brand);
  }
  .pathway-bullets li strong { color: var(--cream); font-weight: 600; }

  /* ========== CLINICAL HIGHLIGHTS (paper) ========== */
  .love {
    background: var(--paper);
    padding: 120px 0;
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .love-head {
    max-width: 800px;
    margin-bottom: 56px;
  }
  .love-head .eyebrow { margin-bottom: 24px; }
  .love-head h2 {
    font-size: clamp(42px, 5.6vw, 68px);
    margin-bottom: 20px;
  }
  .love-head h2 .highlight { color: var(--brand); }
  .love-head p {
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 560px;
  }

  .love-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .love-card {
    background: white;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 36px 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
    transition: transform 0.25s, box-shadow 0.25s;
    min-height: 320px;
  }
  .love-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 40px -20px rgba(26, 26, 24, 0.15);
  }
  .love-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 32px;
    width: 36px;
    height: 3px;
    background: var(--brand);
  }
  .love-tag {
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand);
  }
  .love-quote {
    font-size: 22px;
    font-weight: 500;
    font-style: italic;
    letter-spacing: -0.015em;
    line-height: 1.3;
    color: var(--ink);
    flex: 1;
  }
  .love-quote strong {
    font-weight: 800;
    font-style: italic;
    color: var(--ink);
  }
  .love-proof {
    border-top: 1px solid var(--line);
    padding-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .love-proof-label {
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--ink);
  }
  .love-proof-body {
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-soft);
    font-weight: 500;
  }
  .love-proof-body strong {
    color: var(--ink);
    font-weight: 700;
  }
  .love-meta {
    font-size: 11.5px;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0;
    text-transform: none;
    padding-top: 0;
    border-top: none;
    line-height: 1.5;
    margin-top: 4px;
  }

  /* ========== IMAGE DIVIDER ========== */
  .image-divider {
    position: relative;
    height: 44vh;
    min-height: 360px;
    overflow: hidden;
  }
  .image-divider img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .image-divider-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(26,26,24,0.35) 0%, rgba(26,26,24,0) 60%);
    display: flex;
    align-items: center;
  }
  .image-divider-text {
    color: white;
    padding: 0 40px;
    max-width: 640px;
    font-size: clamp(28px, 3.4vw, 46px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .image-divider-text .highlight { color: var(--brand); }

  /* ========== FAQ (cream-soft with sidebar) ========== */
  .faq {
    padding: 120px 0;
    background: var(--cream-soft);
    border-top: 1px solid var(--line);
  }
  .faq-inner {
    display: grid;
    grid-template-columns: 0.85fr 1.5fr;
    gap: 80px;
    align-items: start;
  }
  .faq-sidebar {
    position: sticky;
    top: 100px;
  }
  .faq-head {
    max-width: 360px;
    margin-bottom: 40px;
  }
  .faq-head .eyebrow { margin-bottom: 24px; }
  .faq-head h2 { font-size: clamp(40px, 4.6vw, 56px); margin-bottom: 20px; }
  .faq-head h2 .highlight { color: var(--brand); }
  .faq-head p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .faq-badge {
    display: inline-block;
    padding: 14px 20px;
    background: var(--ink);
    color: var(--cream);
    font-size: 12px;
    letter-spacing: 0.02em;
    font-weight: 500;

{% layout 'theme' %}

{%- comment -%}
  WLP-1 Evergreen Landing Page V2
  Template: page.wlp1-evergreen-v2.liquid
  Standalone Liquid template (not a section + JSON)

  To use:
  1. Upload this file to Templates/ in the theme editor
  2. Upload all 12 images to Assets/ with the following filenames:
     - wlp1-hero-jar.jpg
     - wlp1-benefit-1-appetite.jpg
     - wlp1-benefit-2-glp1.jpg
     - wlp1-benefit-3-thermogenesis.jpg
     - wlp1-benefit-4-composition.jpg
     - wlp1-included-unboxing.jpg
     - wlp1-strip-1-flatlay.jpg
     - wlp1-strip-2-bathroom.jpg
     - wlp1-strip-3-dining.jpg
     - wlp1-strip-4-capsule.jpg
     - wlp1-strip-5-pocket.jpg
     - wlp1-strip-6-composition.jpg
  3. Create a page in Admin, choose template "page.wlp1-evergreen-v2"
{%- endcomment -%}

<style>
/* Hide theme header/footer + reset body */
body {
  margin: 0;
  padding: 0;
}
header,
footer {
  display: none;
}

.wlp1ev {
  --blue: #5e91d5;
  --blue-hover: #4a7dbe;
  --cream: #F8F5F2;
  --cream-alt: #EAE6DC;
  --ink: #1A1A18;
  --ink-soft: #4a4a46;
  --line: #d9d4c8;
  --white: #ffffff;

  color: var(--ink);
  background: var(--cream);
  font-family: inherit;
  line-height: 1.5;
  font-size: 16px;
  -webkit-font-smoothing: antialiased;
}

.wlp1ev *, .wlp1ev *::before, .wlp1ev *::after {
  box-sizing: border-box;
}

.wlp1ev img { max-width: 100%; display: block; }

.wlp1ev .container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.wlp1ev .container-narrow {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ===== Announcement bar ===== */
.wlp1ev .announce {
  background: var(--ink);
  color: var(--cream);
  padding: 11px 0;
  font-size: 13px;
  letter-spacing: 0.02em;
  overflow: hidden;
  white-space: nowrap;
}
.wlp1ev .announce-track {
  display: inline-flex;
  align-items: center;
  gap: 36px;
  padding-left: 36px;
  animation: wlp1ev-announce-scroll 48s linear infinite;
  will-change: transform;
}
.wlp1ev .announce-item {
  display: inline-block;
  font-weight: 500;
}
.wlp1ev .announce-dot {
  color: var(--blue);
  font-size: 9px;
  opacity: 0.8;
}
@keyframes wlp1ev-announce-scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
.wlp1ev .announce:hover .announce-track {
  animation-play-state: paused;
}

/* ===== Logo bar ===== */
.wlp1ev .logobar {
  background: var(--cream);
  border-bottom: 1px solid var(--line);
  padding: 20px 0;
}
.wlp1ev .logobar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.wlp1ev .logobar-logo {
  display: inline-flex;
  align-items: center;
}
.wlp1ev .logobar-logo img {
  height: 28px;
  width: auto;
  display: block;
}
.wlp1ev .logobar-cta {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  padding: 10px 20px;
  border: 1px solid var(--ink);
  transition: background 0.2s, color 0.2s;
  white-space: nowrap;
  font-family: inherit;
}
.wlp1ev .logobar-cta:hover {
  background: var(--ink);
  color: var(--cream);
}

@media (max-width: 520px) {
  .wlp1ev .logobar { padding: 14px 0; }
  .wlp1ev .logobar-logo img { height: 22px; }
  .wlp1ev .logobar-cta {
    font-size: 11px;
    padding: 8px 14px;
    letter-spacing: 0.12em;
  }
}

/* ===== 1. HERO ===== */
.wlp1ev .hero {
  padding: 60px 0 40px;
  background: var(--cream);
}
.wlp1ev .hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}
.wlp1ev .hero-image {
  aspect-ratio: 1 / 1;
  background: var(--cream-alt);
  border-radius: 4px;
  position: relative;
  overflow: hidden;
}
.wlp1ev .hero-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.wlp1ev .eyebrow {
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--blue);
  font-weight: 600;
  margin-bottom: 20px;
}
.wlp1ev h1 {
  font-size: clamp(40px, 5vw, 64px);
  line-height: 1.05;
  font-weight: 500;
  letter-spacing: -0.02em;
  margin: 0 0 20px;
  color: var(--ink);
}
.wlp1ev h1 em {
  font-style: italic;
  color: var(--blue);
}
.wlp1ev .hero-sub {
  font-size: 20px;
  line-height: 1.5;
  color: var(--ink-soft);
  margin: 0 0 24px;
  max-width: 520px;
}
.wlp1ev .hero-bullets {
  list-style: none;
  padding: 0;
  margin: 0 0 30px;
  max-width: 520px;
}
.wlp1ev .hero-bullets li {
  position: relative;
  padding: 8px 0 8px 28px;
  font-size: 15px;
  color: var(--ink);
  line-height: 1.45;
  border-bottom: 1px solid var(--line);
}
.wlp1ev .hero-bullets li:first-child {
  border-top: 1px solid var(--line);
}
.wlp1ev .hero-bullets li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 15px;
  width: 14px;
  height: 14px;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 14 14' fill='none'><path d='M2 7.5L5.5 11L12 3' stroke='%235e91d5' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/></svg>");
  background-repeat: no-repeat;
}
.wlp1ev .hero-cta {
  display: inline-block;
  background: var(--blue);
  color: var(--white);
  border: none;
  padding: 18px 48px;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s;
  margin-bottom: 4px;
  text-decoration: none;
  font-family: inherit;
}
.wlp1ev .hero-cta:hover {
  background: var(--blue-hover);
  color: var(--white);
}
.wlp1ev .hero-stars {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 20px 0 16px;
  font-size: 14px;
  color: var(--ink-soft);
}
.wlp1ev .stars { color: var(--blue); letter-spacing: 2px; font-size: 18px; }
.wlp1ev .hero-micro {
  font-size: 13px;
  color: var(--ink-soft);
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
}
.wlp1ev .hero-micro span {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.wlp1ev .hero-micro span::before {
  content: '✓';
  color: var(--blue);
  font-weight: 700;
}

/* ===== Section base ===== */
.wlp1ev .section { padding: 100px 0; }
.wlp1ev .section-label {
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--blue);
  font-weight: 600;
  margin-bottom: 14px;
  text-align: center;
}
.wlp1ev .section-title {
  font-size: clamp(32px, 4vw, 48px);
  line-height: 1.1;
  font-weight: 500;
  letter-spacing: -0.02em;
  text-align: center;
  margin: 0 0 16px;
  color: var(--ink);
}
.wlp1ev .section-intro {
  font-size: 19px;
  line-height: 1.6;
  color: var(--ink-soft);
  text-align: center;
  max-width: 620px;
  margin: 0 auto 60px;
}

/* ===== 2. TRANSFORMATION ===== */
.wlp1ev .transformation { background: var(--white); }
.wlp1ev .transform-steps {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 40px;
  position: relative;
  margin-top: 30px;
}
.wlp1ev .transform-steps::before {
  content: '';
  position: absolute;
  top: 40px;
  left: 16.66%;
  right: 16.66%;
  height: 1px;
  background: var(--line);
  z-index: 0;
}
.wlp1ev .step {
  text-align: center;
  position: relative;
  z-index: 1;
}
.wlp1ev .step-num {
  width: 80px;
  height: 80px;
  margin: 0 auto 24px;
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-style: italic;
  font-size: 28px;
  color: var(--blue);
}
.wlp1ev .step h3 {
  font-size: 24px;
  font-weight: 500;
  margin: 0 0 10px;
  letter-spacing: -0.01em;
  color: var(--ink);
}
.wlp1ev .step p {
  color: var(--ink-soft);
  font-size: 15px;
  max-width: 260px;
  margin: 0 auto;
}

/* ===== 3. BENEFITS ===== */
.wlp1ev .benefits { background: var(--cream); }
.wlp1ev .benefit-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  margin-bottom: 100px;
}
.wlp1ev .benefit-row:last-child { margin-bottom: 0; }
.wlp1ev .benefit-row.reverse .benefit-media { order: 2; }
.wlp1ev .benefit-media {
  aspect-ratio: 4 / 5;
  background: var(--cream-alt);
  border-radius: 4px;
  position: relative;
  overflow: hidden;
}
.wlp1ev .benefit-media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.wlp1ev .benefit-eyebrow {
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--blue);
  font-weight: 600;
  margin-bottom: 16px;
}
.wlp1ev .benefit-copy h3 {
  font-size: clamp(28px, 3vw, 40px);
  line-height: 1.15;
  font-weight: 500;
  letter-spacing: -0.02em;
  margin: 0 0 20px;
  color: var(--ink);
}
.wlp1ev .benefit-copy p {
  font-size: 17px;
  color: var(--ink-soft);
  line-height: 1.6;
  margin: 0 0 20px;
}
.wlp1ev .stat-pair {
  display: flex;
  gap: 16px;
  margin-top: 8px;
}
.wlp1ev .stat-block {
  flex: 1;
  background: var(--white);
  border: 1px solid var(--line);
  padding: 20px 18px;
  text-align: left;
  max-width: 220px;
}
.wlp1ev .stat-num {
  font-size: 32px;
  font-weight: 500;
  color: var(--blue);
  line-height: 1;
  letter-spacing: -0.02em;
  margin-bottom: 8px;
}
.wlp1ev .stat-hormone {
  font-size: 13px;
  font-weight: 600;
  color: var(--ink);
  letter-spacing: 0.01em;
  margin-bottom: 2px;
}
.wlp1ev .stat-plain {
  font-size: 12px;
  color: var(--ink-soft);
  letter-spacing: 0.02em;
}

/* ===== 4. FEATURES ===== */
.wlp1ev .features { background: var(--white); }
.wlp1ev .features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px 50px;
  margin-top: 20px;
}
.wlp1ev .feature {
  display: flex;
  gap: 18px;
  align-items: flex-start;
}
.wlp1ev .feature-icon {
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  border: 1px solid var(--blue);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--blue);
  font-style: italic;
  font-size: 18px;
}
.wlp1ev .feature-text h4 {
  font-size: 15px;
  font-weight: 600;
  margin: 0 0 6px;
  letter-spacing: -0.005em;
  color: var(--ink);
}
.wlp1ev .feature-text p {
  font-size: 14px;
  color: var(--ink-soft);
  line-height: 1.5;
  margin: 0;
}

/* ===== 5. MID CTA ===== */
.wlp1ev .midcta {
  background: var(--ink);
  color: var(--cream);
  padding: 80px 0;
  text-align: center;
}
.wlp1ev .midcta-stars {
  font-size: 22px;
  letter-spacing: 4px;
  color: var(--blue);
  margin-bottom: 14px;
}
.wlp1ev .midcta-rating {
  font-size: 14px;
  letter-spacing: 0.05em;
  color: var(--cream-alt);
  margin-bottom: 28px;
}
.wlp1ev .midcta h2 {
  font-size: clamp(32px, 4vw, 44px);
  font-weight: 500;
  letter-spacing: -0.02em;
  margin: 0 0 32px;
  line-height: 1.15;
  color: var(--cream);
}
.wlp1ev .midcta h2 em { font-style: italic; color: var(--blue); }
.wlp1ev .midcta-cta {
  background: var(--blue);
  color: var(--white);
  border: none;
  padding: 18px 54px;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s;
  margin-bottom: 24px;
  display: inline-block;
  text-decoration: none;
  font-family: inherit;
}
.wlp1ev .midcta-cta:hover {
  background: var(--blue-hover);
  color: var(--white);
}
.wlp1ev .midcta-trust {
  display: flex;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
  font-size: 12px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--cream-alt);
}

/* ===== 6. WHAT'S INCLUDED ===== */
.wlp1ev .included { background: var(--cream); }
.wlp1ev .included-grid {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 60px;
  align-items: center;
}
.wlp1ev .included-media {
  aspect-ratio: 1 / 1;
  background: var(--cream-alt);
  border-radius: 4px;
  overflow: hidden;
}
.wlp1ev .included-media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.wlp1ev .included-copy h2 {
  font-size: clamp(32px, 4vw, 44px);
  font-weight: 500;
  letter-spacing: -0.02em;
  margin: 0 0 28px;
  line-height: 1.1;
  color: var(--ink);
}
.wlp1ev .included-list {
  list-style: none;
  padding: 0;
  margin: 0;
  border-top: 1px solid var(--line);
}
.wlp1ev .included-list li {
  padding: 18px 0;
  border-bottom: 1px solid var(--line);
  display: flex;
  align-items: flex-start;
  gap: 16px;
}
.wlp1ev .included-list strong {
  display: block;
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 4px;
  color: var(--ink);
}
.wlp1ev .included-list .inc-body {
  font-size: 14px;
  color: var(--ink-soft);
  line-height: 1.5;
}
.wlp1ev .inc-num {
  flex-shrink: 0;
  font-style: italic;
  color: var(--blue);
  font-size: 18px;
  min-width: 28px;
}

/* ===== 7. CLINICAL STUDIES ===== */
.wlp1ev .social { background: var(--white); }
.wlp1ev .reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-top: 20px;
}
.wlp1ev .review {
  background: var(--cream);
  padding: 30px 26px;
  border-radius: 4px;
  display: flex;
  flex-direction: column;
}
.wlp1ev .study-badge {
  display: inline-block;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--blue);
  font-weight: 600;
  margin-bottom: 16px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--line);
  align-self: flex-start;
}
.wlp1ev .review-title {
  font-size: 22px;
  font-weight: 500;
  margin: 0 0 14px;
  letter-spacing: -0.01em;
  line-height: 1.2;
  color: var(--ink);
}
.wlp1ev .review-body {
  font-size: 14px;
  color: var(--ink-soft);
  line-height: 1.6;
  margin: 0 0 18px;
  flex: 1;
}
.wlp1ev .study-stat {
  background: var(--white);
  border: 1px solid var(--line);
  padding: 12px 14px;
  font-size: 13px;
  color: var(--ink);
  margin-bottom: 18px;
  font-weight: 500;
}
.wlp1ev .study-stat strong {
  color: var(--blue);
  font-size: 18px;
  font-weight: 600;
}
.wlp1ev .review-author {
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink);
  font-weight: 600;
  padding-top: 16px;
  border-top: 1px solid var(--line);
}
.wlp1ev .review-author span {
  display: block;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
  color: var(--ink-soft);
  font-size: 12px;
  margin-top: 4px;
}

/* ===== 8. THREE PATHWAYS ===== */
.wlp1ev .ugc { background: var(--ink); color: var(--cream); padding: 90px 0; }
.wlp1ev .ugc .section-label { color: var(--blue); }
.wlp1ev .ugc .section-title { color: var(--cream); }
.wlp1ev .ugc .section-intro { color: var(--cream-alt); }
.wlp1ev .pathway-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-top: 40px;
}
.wlp1ev .pathway-card {
  background: #22221f;
  border: 1px solid #2a2a26;
  padding: 40px 32px;
  display: flex;
  flex-direction: column;
  transition: transform 0.3s, border-color 0.3s;
  border-radius: 4px;
}
.wlp1ev .pathway-card:hover {
  transform: translateY(-4px);
  border-color: var(--blue);
}
.wlp1ev .pathway-num {
  font-style: italic;
  font-size: 28px;
  color: var(--blue);
  margin-bottom: 28px;
}
.wlp1ev .pathway-title {
  font-size: 26px;
  font-weight: 500;
  color: var(--cream);
  margin: 0 0 14px;
  letter-spacing: -0.01em;
}
.wlp1ev .pathway-body {
  font-size: 15px;
  color: var(--cream-alt);
  line-height: 1.6;
  margin: 0 0 24px;
  flex: 1;
}
.wlp1ev .pathway-stat {
  font-size: 22px;
  color: var(--blue);
  font-weight: 500;
  margin-bottom: 10px;
  letter-spacing: -0.01em;
}
.wlp1ev .pathway-ingredient {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--cream-alt);
  padding-top: 18px;
  border-top: 1px solid #2a2a26;
}

/* ===== 9. COMPARISON ===== */
.wlp1ev .compare { background: var(--cream); }
.wlp1ev .compare-table {
  margin-top: 20px;
  width: 100%;
  border-collapse: collapse;
  background: var(--white);
  border: 1px solid var(--line);
}
.wlp1ev .compare-table th,
.wlp1ev .compare-table td {
  padding: 20px 18px;
  text-align: center;
  border-bottom: 1px solid var(--line);
  font-size: 14px;
}
.wlp1ev .compare-table th {
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-soft);
  font-weight: 600;
  background: var(--cream);
}
.wlp1ev .compare-table th.us {
  background: var(--blue);
  color: var(--white);
}
.wlp1ev .compare-table td:first-child {
  text-align: left;
  font-weight: 500;
  color: var(--ink);
}
.wlp1ev .compare-table td.us {
  background: rgba(94, 145, 213, 0.06);
}
.wlp1ev .check { color: var(--blue); font-size: 18px; font-weight: 700; }
.wlp1ev .xmark { color: var(--line); font-size: 18px; }
.wlp1ev .compare-row-header {
  font-style: italic;
  font-size: 15px;
}

/* ===== 10. FAQ ===== */
.wlp1ev .faq { background: var(--white); }
.wlp1ev .faq-list {
  max-width: 800px;
  margin: 40px auto 0;
}
.wlp1ev .faq-item {
  border-bottom: 1px solid var(--line);
}
.wlp1ev .faq-item:first-child {
  border-top: 1px solid var(--line);
}
.wlp1ev .faq-q {
  width: 100%;
  background: none;
  border: none;
  padding: 24px 0;
  text-align: left;
  font-size: 20px;
  font-weight: 500;
  letter-spacing: -0.01em;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: var(--ink);
}
.wlp1ev .faq-q::after {
  content: '+';
  font-weight: 300;
  font-size: 28px;
  color: var(--blue);
  transition: transform 0.2s;
  font-family: inherit;
}
.wlp1ev .faq-item.open .faq-q::after {
  content: '−';
}
.wlp1ev .faq-a {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
  font-size: 15px;
  color: var(--ink-soft);
  line-height: 1.6;
}

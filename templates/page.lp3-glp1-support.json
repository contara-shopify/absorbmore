                "collapsible_F6wpHT": {
                  "type": "collapsible",
                  "name": "Collapsible",
                  "settings": {
                    "label": "Are your products safe and third-party tested?",
                    "metafield_namespace_key": "",
                    "metafield_image_key": "image",
                    "metafield_label_key": "title",
                    "accordion_class": "accordion",
                    "content": "<p>Yes, all of our products are produced in GMP and NSF certified facilities and undergo third-party testing to verify quality and consistency. While dietary supplements are not evaluated by the FDA for disease diagnosis or treatment, we stand behind their safety and transparency, with rigorous testing on every batch.</p>",
                    "show": false,
                    "metafield_content_key": "content",
                    "metafield_default_state": "closed",

    "ctr_faq_R3fB3z": {
      "type": "ctr-faq",
      "blocks": {
        "faq_mXPXeL": {
          "type": "faq",
          "settings": {
            "question": "Is this safe to take alongside my GLP-1 medication (Ozempic, Wegovy, Mounjaro)?",
            "answer": "<p>These are dietary supplements — vitamins, minerals, and electrolytes — not pharmaceutical compounds that interact with GLP-1 receptor agonists. That said, we always recommend consulting your prescribing physician before adding any supplement to your regimen. Over 900 clinicians recommend our products.</p>"
          }
        },
        "faq_Day8pN": {
          "type": "faq",
          "settings": {
            "question": "When should I expect to feel a difference?",
            "answer": "<p>Most customers report noticeable changes in energy and cravings within the first 1–2 weeks. For full benefits including weight management support, we recommend consistent use for at least 30 days.</p>"
          }
        },
        "faq_RExicR": {
          "type": "faq",
          "settings": {
            "question": "Which nutrients matter most for GLP-1 users?",
            "answer": "<p>GLP-1 medications can deplete key nutrients including B vitamins, magnesium, zinc, and electrolytes. Our formula is specifically designed to replenish these nutrients while supporting the metabolic pathways activated by GLP-1 therapy.</p>"
          }
        },
        "faq_bb9Ra3": {
          "type": "faq",
          "settings": {
            "question": "Why not just take a standard multivitamin?",
            "answer": "<p>Standard multivitamins use cheap, poorly absorbed forms of nutrients. Our patented absorption technology ensures up to 5x better bioavailability, meaning your body actually uses what you take — not just passes it through.</p>"
          }
        },
        "faq_kMGkeJ": {
          "type": "faq",
          "settings": {
            "question": "What is the return policy?",
            "answer": "<p>We offer a 60-day money-back guarantee. If you're not completely satisfied, contact our support team for a full refund — no questions asked.</p>"
          }
        }
      },

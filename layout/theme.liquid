  {%- if customer.has_account -%}
    {%- case request.path -%}
    {%- when "/account/register" -%}
      <script>
        window.location.href = `{{ request.origin }}{{ routes.account_url }}`;
      </script>
    {%- when "/account/register" -%}
      <script>
        window.location.href = `{{ request.origin }}{{ routes.account_url }}`;
      </script>
    {%- when "/account/login" -%}
      <script>
        window.location.href = `{{ request.origin }}{{ routes.account_url }}`;
      </script>

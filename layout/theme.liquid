  {% if request.design_mode != true or request.visual_preview_mode == true %}
    {% capture head_sections %}{% sections '0_head' %}{% endcapture %}
    {% assign cleaned_head_sections = head_sections | replace: '<!-- BEGIN sections: 0_head -->', '' | replace: '<!-- END sections: 0_head -->', '' | replace_first: '>', '|~|SPLIT|~|' | split: '|~|SPLIT|~|' | last | replace: '</div>', '' %}
    {{ cleaned_head_sections }}
  {% endif %}

   {% render 'collection-schema' %}

</head>

<body id="shopify-override"
      data-template="{{ template | handleize }}"
      data-page-handle="{{ page.handle }}"
      x-data="{ windowWidth: window.innerWidth, windowHeight: window.innerHeight }"
      :class="$modal.id && 'modal-open'"
      :data-active-modal="$modal.id"
      @resize.window="$data.windowWidth = window.innerWidth, windowHeight = window.innerHeight"
      class="relative flex min-h-screen flex-col overscroll-none{% if request.visual_preview_mode %} bg-white text-black{% endif %}"
      @hashchange.window="$router.hash = window.location.hash;"
      data-barba="wrapper">

  <style type="text/css">
    /* Preview bar */
    #preview-bar-iframe,
    #PBarNextFrameWrapper,
    #PBarNextFrame {
      display: block !important;
    }
  </style>

  {% if request.design_mode == true and request.visual_preview_mode != true %}
    {% sections '0_head' %}
  {% endif %}

  {% if request.design_mode != true or settings.development__block_design_system != true %}
    <div data-globals-section>
      {% capture content %}{% sections '0_global' %}{% endcapture %}
      {% render '_layout.merge_styles', input: content %}
    </div>
  {% endif %}

  {% if request.design_mode and settings.development__block_card_sections != true and request.visual_preview_mode != true %}
    <div data-cards-section data-cards-styles-section>{% sections '0_card' %}</div>
  {% elsif request.design_mode != true %}
    <div data-cards-styles-section class="!hidden">
      {% comment %} This need some real world performance testing. Using '0_card' could be faster if there are too many cards for backup themes and no cleanup.{% endcomment %}
      {%- render 'card_product_card._styles' -%}
      {%- render 'card_collection_card._styles' -%}
      {%- render 'card_article_card._styles' -%}
      {%- render 'card_blog_card._styles' -%}
      {%- render 'card_page_card._styles' -%}
      {%- render 'card_line_item_card._styles' -%}
      {%- render 'card_comment_card._styles' -%}
      {% comment %}Alternative approach:{% endcomment %}
      {% comment %}{% sections '0_card' %}{% endcomment %}
    </div>
  {% elsif request.design_mode and settings.development__block_card_sections %}
    <div data-cards-styles-section class="!hidden">
      {%- render 'card_product_card._styles' -%}
      {%- render 'card_collection_card._styles' -%}
      {%- render 'card_article_card._styles' -%}
      {%- render 'card_blog_card._styles' -%}
      {%- render 'card_page_card._styles' -%}
      {%- render 'card_line_item_card._styles' -%}
      {%- render 'card_comment_card._styles' -%}
    </div>
  {% endif %}

  {% if request.design_mode == false %}
    {% section 'global_page_transitions' %}
  {% endif %}

  <a href="#main-content"
     class="bg-white text-sm font-medium p-1 text-gray-700 left-1/2 absolute top-0 z-[101] -translate-y-full transition-all duration-300 -translate-x-1/2 focus-visible:translate-y-0">Skip to main content</a>

  {% if request.design_mode != true or settings.development__block_modal_sections == true or request.visual_preview_mode == true %}
    <div data-dynamic-modals></div>
  {% endif %}

  {% render "_layout.load_dynamic_modals" %}

  {% if request.design_mode == true %}
    {% render "_layout.load_visual_preview_styles" %}
  {% endif %}

  {% if request.design_mode == true and settings.development__block_modal_sections == false and request.visual_preview_mode != true %}
    {% capture modals_theme_editor_content %}
      {% capture modals %}
        {% sections '0_modal' %}
      {% endcapture %}
      {% capture megamenu_group_content %}
        <div x-data="{ show_megamenu_group: ($modal.id.includes('megamenu--') && $el.querySelector(`[data-megamenu='${$modal.id}']`)) }"
             x-effect="show_megamenu_group = ($modal.id.includes('megamenu--') && $el.querySelector(`[data-megamenu='${$modal.id}']`)) || $el.querySelector(`[data-style-id*='${$editor.select_section_id}']`)"
             x-cloak>
          <div class="bg-modal-backdrop fixed inset-x-0 bottom-0 top-[--header-height-offset] z-20 transition duration-75 ease-in-out"
               x-show="show_megamenu_group"
               x-transition:enter-start="opacity-0"
               x-transition:enter-end="opacity-100"
               x-transition:leave-start="opacity-100"
               x-transition:leave-end="opacity-0"
               @click="$modal.setId('')"></div>
          {% capture selector %}[data-style-id="section_group__megamenu"]{% endcapture %}
          {% if settings.megamenu__text_color != blank or settings.megamenu__text_color.alpha != 0 or settings.megamenu__background_color != blank %}
            {% capture megamenu__css %}
              & {
              {% if settings.megamenu__text_color != blank and settings.megamenu__text_color.alpha != 0 %}color: {{ settings.megamenu__text_color }};{% endif %}
              {% if settings.megamenu__background_color != blank %}background-color: {{ settings.megamenu__background_color }};{% endif %}
              }
            {% endcapture %}
          {% endif %}

          <style>
            {{ megamenu__css | append: settings.megamenu__custom_css | replace: '&', selector | strip_newlines }}
          </style>
          <section data-style-id="section_group__megamenu"
                   class="pointer-events-auto fixed inset-x-0 top-[--header-height-offset] z-30 transition-all duration-300 ease-in-out"
                   x-transition:enter-start="-translate-y-full"
                   x-transition:enter-end="translate-y-0"
              {% comment %}x-transition:leave="delay-100"{% endcomment %}
                   x-transition:leave-start="translate-y-0"
                   x-transition:leave-end="-translate-y-full"
                   x-show="show_megamenu_group"
                   x-trap.noautofocus="show_megamenu_group">
            <div class="relative">
              {% sections '0_megamenu' %}
            </div>
          </section>
        </div>
      {% endcapture %}
      {% capture content %}
        {{ modals }}
        {{ megamenu_group_content }}
      {% endcapture %}
      {% liquid
        assign content = content | replace: '<style></style>', '' | append: " "
        assign content_array = content | split: "</style>"
        assign styles_content = ''
        assign content = ''
        for split in content_array
          if forloop.last
            assign content = content | append: split
            break
          endif
          assign splits = split | split: "<style"
          assign content_split = splits | first
          assign style_split = splits | last | replace_first: '>', ' |%SPLIT|>|%|' | split: '|%SPLIT|>|%|' | last
          assign content = content | append: content_split
          assign styles_content = styles_content | append: style_split
        endfor
      %}
      <div data-dynamic-modals>
        <style>{{ styles_content | strip_newlines }}</style>
        {{ content }}
      </div>
    {% endcapture %}
    {% render '_layout.render_tabs', content: modals_theme_editor_content %}
  {% endif %}

  {% if request.visual_preview_mode == true %}
    {% capture modals_preview_content %}
      {% sections '0_modal' %}
      <div class="relative">
        {% sections '0_megamenu' %}
      </div>
    {% endcapture %}
    {% render '_layout.render_tabs', content: modals_preview_content %}
  {% endif %}

  {% capture core_content %}
  {% if request.design_mode != true %}
    <header data-header-section
            class="header-sections-container transition-all duration-200 ease-in-out"
            x-init="_sections.initLayoutEffects(document.body, $el)">
      {% capture content %}{% sections '0_header' %}{% endcapture %}
      {% render '_layout.merge_styles', input: content %}
    </header>
  {% endif %}

  {% if request.design_mode and settings.development__block_header_sections != true %}
    <header data-header-section
            class="header-sections-container transition-all duration-200 ease-in-out"
            x-init="_sections.initLayoutEffects(document.body, $el)">
      {% sections '0_header' %}
    </header>
  {% endif %}

    <main data-content-root
          id="main-content"
          data-barba="container"
          data-barba-namespace="tmp"
          data-template="{{ template | escape }}"
          data-pathname="{{ request.path | escape }}"
          :class="/^\/policies\//gi.test($router.pathname) ? 'richtext-md richtext-margins-lg' : ''"
          class="relative mt-[--navigation-bar-transparent-height] flex flex-1 shrink-0 flex-col main-sections-container overflow-x-clip">
      {% if request.design_mode != true or settings.development__block_template_sections != true %}
        {% capture content %}{{ content_for_layout }}{% endcapture %}
        {% render '_layout.merge_styles', input: content %}
      {% endif %}
      {% if request.design_mode == false %}
        {% section "data_product_json" %}
        {% section "data_collection_json" %}
        {% section "data_article_json" %}
        {% section "data_page_json" %}
      {% endif %}
      <div x-init="() => {
          window.collection = { id: {{ collection.id | json }} };
          window.article = { id: {{ article.id | json }} };
          window.blog = { id: {{ blog.id | json }} };
          window.page = { id: {{ page.id | json }} };
          window.product = { id: {{ product.id | json }} };
        }"></div>
    </main>
  {% if request.design_mode != true or settings.development__block_footer_sections != true %}
    <footer data-footer-section>
      {% capture content %}{% sections '0_footer' %}{% endcapture %}
      {% render '_layout.merge_styles', input: content %}
    </footer>
  {% endif %}
    {% render '_layout.toast' %}
    <div data-tooltip-container
         class="pointer-events-none fixed inset-0 z-max"
         x-init="$watch('$router.pathname', () => { $el.innerHTML = ''; })"></div>

    <script type="application/javascript">
      document.documentElement.style.setProperty(
        "--scrollbar-width",
        `${window.innerWidth - document.documentElement.clientWidth}px`,
      );
    </script>
    {% if request.design_mode == true %}
      {% section "data_product_json" %}
      {% section "data_collection_json" %}
      {% section "data_article_json" %}
      {% section "data_page_json" %}
    {% endif %}
  {% endcapture %}

  {% render '_layout.render_tabs', content: core_content %}

  {% if request.design_mode == true %}
    {% section 'global_page_transitions' %}
    <script>
      (() => {
        const script = document.querySelector('script#OnlineStoreEditorData');
        if (!script) throw new Error('OnlineStoreEditorData script not found');

        const data = JSON.parse(script.textContent || script.innerHTML || '{}');

        window?.parent?.postMessage(
          {
            source: "shopify-theme",
            type: "SHOPIFY:ACCELERATE:THEME_EDITOR_UPDATE",
            data,
          },
          "*",
        );

        window?.top?.postMessage(
          {
            source: "shopify-theme",
            type: "SHOPIFY:ACCELERATE:THEME_EDITOR_UPDATE",
            data,
          },
          "*",
        );
        (async () => {
          window.wait_for_cache_bust = true;
          window.theme_settings;
          await caches.delete("platter-modals--{{ settings.development__cache_version }}");
          localStorage.clear();
          sessionStorage.clear();

          await idbKeyval.clear();

          console.log(`await caches.delete("platter-modals--{{ settings.development__cache_version }}");`);
          console.log(`localStorage.clear();`);
          console.log(`sessionStorage.clear();`);
          console.log(`await idbKeyval.clear();`);
          console.log("Platter Theme Cache Cleared");
          window.wait_for_cache_bust = false;
          document.dispatchEvent(new CustomEvent('platter-cache-busted'));
        })();
      })();
    </script>
  {% endif %}

  <script>
    (async () => {
      const oldCacheVersion = utils.getCookie('platter-cache-version');
      if (oldCacheVersion && oldCacheVersion !== `{{ settings.development__cache_version | default: 1 }}`) {
        window.wait_for_cache_bust = true;
        await caches.delete("platter-modals--{{ settings.development__cache_version }}");
        localStorage.clear();
        sessionStorage.clear();
        await idbKeyval.clear();
        window.wait_for_cache_bust = false;
        document.dispatchEvent(new CustomEvent('platter-cache-busted'));
      }
      utils.setCookie('platter-cache-version', `{{ settings.development__cache_version | default: 1 }}`, 60);
    })();
  </script>
  {% capture no_render %}
    <div class="!hidden
            max-sm:!hidden sm:!hidden max-md:!hidden md:!hidden max-lg:!hidden lg:!hidden max-xl:!hidden xl:!hidden
            max-md:-mx-container-xs max-md:-mx-container-sm max-md:-mx-container-md max-md:-mx-container-lg max-md:-mx-container-gutter md:-mx-container-xs md:-mx-container-sm md:-mx-container-md md:-mx-container-lg md:-mx-container-gutter -mx-container-xs -mx-container-sm -mx-container-md -mx-container-lg -mx-container-gutter
            max-md:px-container-xs max-md:px-container-sm max-md:px-container-md max-md:px-container-lg max-md:px-container-gutter md:px-container-xs md:px-container-sm md:px-container-md md:px-container-lg md:px-container-gutter px-container-xs px-container-sm px-container-md px-container-lg px-container-gutter
            max-md:scroll-px-container-xs max-md:scroll-px-container-sm max-md:scroll-px-container-md max-md:scroll-px-container-lg max-md:scroll-px-container-gutter md:scroll-px-container-xs md:scroll-px-container-sm md:scroll-px-container-md md:scroll-px-container-lg  md:scroll-px-container-gutter scroll-px-container-xs scroll-px-container-sm scroll-px-container-md scroll-px-container-lg scroll-px-container-gutter
            [&_:where(p,h1,h2,h3,h4,h5,h6)]:items-center max-md:text-center !font-semibold [&_a]:link-effect !font-bold !w-full
            pl-container-xs pl-container-sm pl-container-md pl-container-lg pl-container-gutter
            pr-container-xs pr-container-sm pr-container-md pr-container-lg pr-container-gutter
    "></div>
  {% endcapture %}
  <form method="post"
        id="global_link_form"
        class="!hidden"
        @submit.prevent.stop="() => {}">
  </form>
</body>
</html>
